            <% if (currentPage > 1) { %>
              <a href="<%= buildPageUrl(currentPage - 1, pageLimit) %>" class="admin-page-btn admin-page-nav">
                Previous
              </a>
            <% } else { %>
              <span class="admin-page-btn admin-page-nav disabled">Previous</span>
            <% } %>

            <% visiblePages.forEach(p => { %>
              <% if (p === 'dots-left' || p === 'dots-right') { %>
                <span class="admin-page-dots">...</span>
              <% } else if (p === currentPage) { %>
                <span class="admin-page-btn active"><%= p %></span>
              <% } else { %>
                <a href="<%= buildPageUrl(p, pageLimit) %>" class="admin-page-btn"><%= p %></a>
              <% } %>
            <% }) %>

            <% if (currentPage < totalPages) { %>
              <a href="<%= buildPageUrl(currentPage + 1, pageLimit) %>" class="admin-page-btn admin-page-nav">
                Next
              </a>
            <% } else { %>
              <span class="admin-page-btn admin-page-nav disabled">Next</span>
            <% } %>
