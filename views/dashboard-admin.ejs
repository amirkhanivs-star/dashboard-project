<script>
  (function () {
    const table = document.getElementById('adminAdmissionsTable');
    if (!table) return;

    const filters = {};
    document.querySelectorAll('[data-filter-col]').forEach(el => {
      const key = el.getAttribute('data-filter-col');
      if (!key) return;
      filters[key] = el;
    });

    function cellValueByCol(row, colKey) {
      const cell = row.querySelector(`td[data-col="${colKey}"]`);
      if (!cell) return '';
      const el = cell.querySelector('input, select');
      if (el) return (el.value || '').toLowerCase().trim();
      return (cell.textContent || '').toLowerCase().trim();
    }

    function applyFilters() {
      const rows = table.querySelectorAll('tbody tr.admin-row');
      rows.forEach(row => {
        let ok = true;

        Object.keys(filters).forEach(colKey => {
          if (!ok) return;

          const f = filters[colKey];
          const filterVal = (f.value || '').toLowerCase().trim();
          if (!filterVal) return;

          const cellVal = cellValueByCol(row, colKey);
          if (!cellVal.includes(filterVal)) ok = false;
        });

        row.style.display = ok ? '' : 'none';
      });
    }

    Object.values(filters).forEach(input => {
      if (!input) return;
      input.addEventListener('input', applyFilters);
      if (input.tagName === 'SELECT') input.addEventListener('change', applyFilters);
    });
  })();

  (function () {
    const overlay = document.getElementById('upload-flash-overlay');
    const iconWrap = document.getElementById('upload-flash-icon-wrap');
    const titleEl  = document.getElementById('upload-flash-title');
    const msgEl    = document.getElementById('upload-flash-message');
    const closeBtn = document.getElementById('upload-flash-close-btn');

    if (!overlay || !iconWrap || !titleEl || !msgEl || !closeBtn) return;

    function setIcon(type) {
      if (type === 'success') {
        iconWrap.innerHTML = `
          <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center"
               style="width:56px;height:56px;background:linear-gradient(135deg,#22c55e,#16a34a);">
            <i class="bi bi-check-lg text-white fs-3"></i>
          </div>`;
      } else if (type === 'danger' || type === 'error') {
        iconWrap.innerHTML = `
          <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center"
               style="width:56px;height:56px;background:linear-gradient(135deg,#ef4444,#b91c1c);">
            <i class="bi bi-exclamation-lg text-white fs-3"></i>
          </div>`;
      } else {
        iconWrap.innerHTML = `
          <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center bg-primary"
               style="width:56px;height:56px;">
            <i class="bi bi-info-lg text-white fs-4"></i>
          </div>`;
      }
    }

    window.showUploadFlash = function(type, title, message) {
      setIcon(type || 'info');
      titleEl.textContent = title || 'Notification';
      msgEl.textContent = message || '';
      overlay.classList.remove('d-none');
    };

    function close() {
      overlay.classList.add('fade-out');
      setTimeout(() => {
        overlay.classList.add('d-none');
        overlay.classList.remove('fade-out');
      }, 260);
    }

    closeBtn.addEventListener('click', close);
  })();


  
  (function () {
    const flash = <%- JSON.stringify(typeof flash !== 'undefined' ? flash : null) %>;
    if (!flash || !flash.message) return;

    if (typeof window.showUploadFlash === 'function') {
      window.showUploadFlash(
        flash.type || 'info',
        flash.title || 'Notification',
        flash.message || ''
      );
    }
  })();

/* ✅ Apply colors to Current Status + Fee Status selects (Admin) */
  (function () {
    function applyStatusClass(sel) {
      if (!sel) return;
      sel.classList.remove('status-running','status-leave','status-stop','status-left','status-freez');

      const v = (sel.value || '').toLowerCase().trim();
      if (v === 'running') sel.classList.add('status-running');
      else if (v === 'leave') sel.classList.add('status-leave');
      else if (v === 'stop') sel.classList.add('status-stop');
      else if (v === 'left') sel.classList.add('status-left');
      else if (v === 'freez') sel.classList.add('status-freez');
    }

    function applyFeeClass(sel) {
      if (!sel) return;
      sel.classList.remove('fee-dues','fee-nodues');

      const v = (sel.value || '').toLowerCase().trim();
      if (v === 'present + dues') sel.classList.add('fee-dues');
      else if (v === 'present + no dues') sel.classList.add('fee-nodues');
    }

    function init() {
      document.querySelectorAll('.js-status-select').forEach(s => {
        applyStatusClass(s);
        s.addEventListener('change', function(){ applyStatusClass(s); });
      });

      document.querySelectorAll('.js-fee-select').forEach(s => {
        applyFeeClass(s);
        s.addEventListener('change', function(){ applyFeeClass(s); });
      });

      const fs = document.getElementById('filter-status');
      if (fs) { applyStatusClass(fs); fs.addEventListener('change', () => applyStatusClass(fs)); }

      const ffee = document.getElementById('filter-fee-status');
      if (ffee) { applyFeeClass(ffee); ffee.addEventListener('change', () => applyFeeClass(ffee)); }
    }

   if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', init);
} else {
  init();
}
  })();

  (function () {
  window.STATUS_OPTION_CACHE = {
    current: [],
    fee: [],
    billing: []
  };

  function setSelectVisual(sel, color) {
    if (!sel) return;
    const c = color || '#64748b';
    sel.style.setProperty('--dot', c);
    sel.style.setProperty('--bd', c + '33');
    sel.style.setProperty('--tx', '#0f172a');
    sel.style.setProperty('--bg', c + '18');
  }

  function getCachedOptions(type) {
    return Array.isArray(window.STATUS_OPTION_CACHE?.[type])
      ? window.STATUS_OPTION_CACHE[type]
      : [];
  }

  function findColor(items, value) {
    const v = String(value || '').trim().toLowerCase();
    const found = (items || []).find(x => String(x.value || '').trim().toLowerCase() === v);
    return found ? found.color : '#64748b';
  }

  function applyDynamicColors() {
    const currentItems = getCachedOptions('current');
    const feeItems = getCachedOptions('fee');

    document.querySelectorAll('.js-status-select, #filter-status').forEach(sel => {
      if ((sel.value || '') === '__add_new_status__') return;
      setSelectVisual(sel, findColor(currentItems, sel.value));
    });

    document.querySelectorAll('.js-fee-select, #filter-fee-status').forEach(sel => {
      if ((sel.value || '') === '__add_new_fee_status__') return;
      setSelectVisual(sel, findColor(feeItems, sel.value));
    });
  }

  window.applyDynamicDropdownColors = applyDynamicColors;

  function applyDynamicBillingColors() {
    const billingItems = getCachedOptions('billing');

    document.querySelectorAll('.bill-status').forEach(sel => {
      const val = String(sel.value || '').trim();
      if (!val || val === '__add_new_billing_status__') {
        setSelectVisual(sel, '#64748b');
        return;
      }
      setSelectVisual(sel, findColor(billingItems, val));
    });
  }

  window.applyDynamicBillingColors = applyDynamicBillingColors;

  function init() {
    document.addEventListener('change', function (e) {
      if (e.target.matches('.js-status-select, #filter-status, .js-fee-select, #filter-fee-status')) {
        applyDynamicColors();
      }

      if (e.target.matches('.bill-status')) {
        applyDynamicBillingColors();
      }
    });

    applyDynamicColors();
    applyDynamicBillingColors();
  }

  document.addEventListener('click', function (e) {
    const btn = e.target.closest('#openBillingStatusManagerBtn');
    if (!btn) return;

    const billingModalEl = document.getElementById('billingStatusOptionModal');
    if (!billingModalEl) return;

    billingModalEl.classList.remove('d-none');
    billingModalEl.setAttribute('aria-hidden', 'false');
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();


(function () {
  let activeType = 'current';
  let pendingSelect = null;

  const modalEl = document.getElementById('statusOptionModal');
  if (!modalEl) return;

  const titleEl = document.getElementById('statusOptionModalTitle');
  const inputEl = document.getElementById('statusOptionInput');
  const colorEl = document.getElementById('statusOptionColor');
  const saveBtn = document.getElementById('statusOptionSaveBtn');
  const listEl = document.getElementById('statusOptionList');
  const listTitleEl = document.getElementById('statusOptionListTitle');

  function optionLabel(type) {
    return type === 'current' ? 'Current Status' : 'Fee Status';
  }

  function apiBase(type) {
    return type === 'current'
      ? '/api/options/status'
      : '/api/options/fee-status';
  }

 function normalizeRows(type, rows) {
  return (rows || []).map(row => ({
    id: row.id,
    value: row.value || row.label || row.opt_key || '',
    color: row.color || '#64748b',
    is_custom: Number(row.is_custom || 0)
  }));
}

  async function fetchOptions(type) {
    const res = await fetch(apiBase(type), {
      headers: { 'Accept': 'application/json' }
    });

    const data = await res.json();
    if (!res.ok || !data.success) {
      throw new Error(data.message || 'Failed to load options');
    }

    const items = normalizeRows(type, data.data || []);
    window.STATUS_OPTION_CACHE[type] = items;
    return items;
  }

  async function updateColor(type, id, color) {
    const res = await fetch(`${apiBase(type)}/${id}`, {
      method: 'PATCH',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify({ color })
    });

    const data = await res.json();
    if (!res.ok || !data.success) {
      throw new Error(data.message || 'Failed to update color');
    }

    return data;
  }

  async function createOption(type, value, color) {
    const res = await fetch(apiBase(type), {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify({ label: value, color })
    });

    const data = await res.json();
    if (!res.ok || !data.success) {
      throw new Error(data.message || 'Failed to save option');
    }

    return data.data;
  }

  async function deleteOption(type, id) {
    const res = await fetch(`${apiBase(type)}/${id}`, {
      method: 'DELETE',
      headers: { 'Accept': 'application/json' }
    });

    const data = await res.json();
    if (!res.ok || !data.success) {
      throw new Error(data.message || 'Failed to delete option');
    }

    return true;
  }

  function rebuildSelect(selectEl, items, selectedValue, includeAll, addValue) {
    if (!selectEl) return;

    let html = includeAll ? '<option value="">All</option>' : '';

    html += items.map(item => {
      const selected = String(selectedValue || '') === String(item.value) ? 'selected' : '';
      return `<option value="${item.value}" ${selected}>${item.value}</option>`;
    }).join('');

    if (addValue) {
      html += `<option value="${addValue}">+ Add Option</option>`;
    }

    selectEl.innerHTML = html;
  }

  function renderList() {
    const items = Array.isArray(window.STATUS_OPTION_CACHE?.[activeType])
      ? window.STATUS_OPTION_CACHE[activeType]
      : [];

    titleEl.textContent = `Manage ${optionLabel(activeType)} Options`;
    listTitleEl.textContent = `${optionLabel(activeType)} Options`;

    if (!items.length) {
      listEl.innerHTML = '<div class="status-option-empty">No options available.</div>';
      return;
    }

    listEl.innerHTML = items.map((item, index) => `
      <div class="status-option-item">
        <div class="status-option-left">
          <span class="status-option-dot" style="background:${item.color || '#64748b'}"></span>
          <div class="status-option-name">${item.value}</div>
        </div>
        <div class="status-option-actions">
          <input
            type="color"
            class="form-control form-control-color status-option-color-input"
            value="${item.color || '#64748b'}"
            data-index="${index}"
            data-id="${item.id}"
            style="width:48px;min-width:48px;"
          >
          ${item.is_custom ? `
  <button
    type="button"
    class="btn btn-sm btn-outline-danger rounded-pill status-option-delete-btn"
    data-index="${index}"
    data-id="${item.id}"
  >
    Delete
  </button>
` : ''}
        </div>
      </div>
    `).join('');
  }

  function refreshDropdowns() {
    const currentItems = window.STATUS_OPTION_CACHE.current || [];
    const feeItems = window.STATUS_OPTION_CACHE.fee || [];

    const filterStatus = document.getElementById('filter-status');
    const filterFeeStatus = document.getElementById('filter-fee-status');

    rebuildSelect(filterStatus, currentItems, filterStatus?.value, true, '');
    rebuildSelect(filterFeeStatus, feeItems, filterFeeStatus?.value, true, '');

    document.querySelectorAll('.js-status-select').forEach(sel => {
      const selected = sel.getAttribute('data-prev-value') || sel.value || 'New Admission';
      rebuildSelect(sel, currentItems, selected, false, '__add_new_status__');
      sel.value = selected;
    });

    document.querySelectorAll('.js-fee-select').forEach(sel => {
      const selected = sel.getAttribute('data-prev-value') || sel.value || 'New Admission';
