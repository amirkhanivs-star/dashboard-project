<%- include('partials/bootstrap-header', { user, pageTitle: 'Department Admin Dashboard' }) %>

<%
  const deptTitle = user && user.dept
    ? user.dept.charAt(0).toUpperCase() + user.dept.slice(1)
    : 'Department';

      const paginationData = pagination || {};
  const currentPage = Number(paginationData.page || 1);
  const totalPages = Number(paginationData.totalPages || 1);
  const pageLimit = Number(paginationData.limit || 200);
  const totalRecords = Number(paginationData.totalRecords || 0);
  const startRecord = Number(paginationData.startRecord || 0);
  const endRecord = Number(paginationData.endRecord || 0);

  function buildPageUrl(pageNumber, limitNumber) {
    const params = new URLSearchParams();
    params.set('page', String(pageNumber));
    params.set('limit', String(limitNumber));
    return `/dashboard?${params.toString()}`;
  }

  function getVisiblePages(current, total) {
    const pages = [];
    const start = Math.max(1, current - 2);
    const end = Math.min(total, current + 2);

    if (start > 1) {
      pages.push(1);
      if (start > 2) pages.push('dots-left');
    }

    for (let i = start; i <= end; i++) {
      pages.push(i);
    }

    if (end < total) {
      if (end < total - 1) pages.push('dots-right');
      pages.push(total);
    }

    return pages;
  }

  const visiblePages = getVisiblePages(currentPage, totalPages);

    const totalAdmissions = Number(totalRecords || (admissions || []).length);

  const paidCount = (admissions || []).filter(a => a.accounts && a.accounts.paymentStatus === 'Paid').length;
  const partiallyPaid = (admissions || []).filter(a => a.accounts && a.accounts.paymentStatus === 'Partial').length;
  const unpaidCount = (admissions || []).filter(a => !a.accounts || !a.accounts.paymentStatus || a.accounts.paymentStatus === 'Unpaid').length;

  const completedPipeline = (admissions || []).filter(a => {
    return a.accounts &&
      a.accounts.paymentStatus &&
      a.accounts.registrationNumber &&
      a.admission &&
      a.admission.fees &&
      a.admission.month;
  }).length;

  const paidPercent = totalAdmissions ? Math.round((paidCount / totalAdmissions) * 100) : 0;

  // =========================
  // ✅ PERMISSIONS HELPERS (Admin)
  // =========================
  let _perms =
    (user && (user.permissions || user.perms || user.permission || user.permissionMap)) || null;

  // if perms stored as JSON string
  try {
    if (typeof _perms === 'string') _perms = JSON.parse(_perms);
  } catch (e) {}

  const _isSuper =
    !!(user && (
      user.role === 'superadmin' ||
      user.role === 'super_admin' ||
      user.agentType === 'superadmin' ||
      user.agentType === 'super_admin' ||
      user.isSuperAdmin === true ||
      user.is_super_admin === true
    ));

  function _getNested(obj, path) {
    try {
      const parts = String(path || '').split('.');
      let cur = obj;
      for (const p of parts) {
        if (!cur || typeof cur !== 'object' || !(p in cur)) return undefined;
        cur = cur[p];
      }
      return cur;
    } catch (e) {
      return undefined;
    }
  }

  function _hasKey(key) {
    if (_isSuper) return true;
    if (!_perms) return false;

    // wildcard
    if (_perms === true) return true;

    // Array format
    if (Array.isArray(_perms)) {
      return _perms.includes(key) || _perms.includes('*') || _perms.includes('all');
    }

    // Object format (flat or nested)
    if (typeof _perms === 'object') {
      if (key in _perms) return !!_perms[key];

      const nested = _getNested(_perms, key);
      if (typeof nested !== 'undefined') return !!nested;

      const alt = key.replace(/\./g, '_');
      if (alt in _perms) return !!_perms[alt];

      return false;
    }

    return false;
  }

  function canAny(keys) {
    return (keys || []).some(k => _hasKey(k));
  }

  // ✅ NEW: map EJS checkbox keys (saved by super admin UI) to dashboard checks
 const COL_MAP = {
  status: 'colStatus',
  feeStatus: 'colFeeStatus',
  dept: 'colDept',
  student: 'colStudentName',
  father: 'colFatherName',
  fatherEmail: 'colFatherEmail',
  grade: 'colGrade',
  tuitionGrade: 'colTuitionGrade',
  phone: 'colPhone',
  processedBy: 'colProcessedBy',
  paymentStatus: 'colPaymentStatus',
  paidUpto: 'colPaidUpto',
  verificationNumber: 'colVerificationNumber',
  registrationNumber: 'colRegistrationNumber',
  familyNumber: 'colFamilyNumber',
  registrationFee: 'colRegistrationFee',
  fees: 'colFees',
  currency: 'colCurrency',
  month: 'colMonth',
  totalFees: 'colTotalFees',
  pendingDues: 'colPendingDues',
  receivedPayment: 'colReceivedPayment',
  invoiceStatus: 'colInvoiceStatus',
  invoiceStatusTimestamp: 'colInvoiceStatusTimestamp',
  paidInvoiceStatus: 'colPaidInvoiceStatus',
  paidInvoiceStatusTimestamp: 'colPaidInvoiceStatusTimestamp',
  actionButtons: 'colActionButtons'
};

  const BTN_MAP = {
    details: 'btnDetails',
    pdf: 'btnPdf',
    update: 'btnUpdateRow',
    whatsapp: 'btnWhatsApp',
    billing: 'btnBilling',
    upload: 'btnUpload',
    files: 'btnFiles',
    edit: 'btnEditRow'
  };

  // Column + button permission helpers
  function canCol(name) {
    if (_isSuper) return true;
    const k = String(name || '').trim();

    const mapped = COL_MAP[k];

    return canAny([
      // ✅ direct keys saved in DB by super user UI
      mapped,

      // legacy keys used in old DB (your super-users.ejs supports these)
      k === 'phone' ? 'showPhone' : null,
      k === 'paymentStatus' ? 'showPaymentStatus' : null,
      k === 'paidUpto' ? 'showPaidUpto' : null,
      k === 'verificationNumber' ? 'showVerificationNumber' : null,
      k === 'registrationNumber' ? 'showRegistrationNumber' : null,

      // old styles (if you ever used)
      `col.${k}`,
      `show_${k}`,
      `show${k.charAt(0).toUpperCase() + k.slice(1)}`,

      // future schema (admin.col.*, super.col.*)
      `admin.col.${k}`,
      `admin.column.${k}`,
      `super.col.${k}`,
      `super.column.${k}`,

      // keep raw key as fallback
      k
    ].filter(Boolean));
  }

  function canBtn(name) {
    if (_isSuper) return true;
    const k = String(name || '').trim();

    const mapped = BTN_MAP[k];

    return canAny([
      // ✅ direct keys saved in DB
      mapped,

      // legacy / future schema
      `admin.btn.${k}`,
      `admin.button.${k}`,
      `super.btn.${k}`,
      `super.button.${k}`,

      `btn_${k}`,
      `btn${k.charAt(0).toUpperCase() + k.slice(1)}`,

      k
    ].filter(Boolean));
  }

  // Editing:
  function _cap(s){ return String(s||'').charAt(0).toUpperCase() + String(s||'').slice(1); }

  const _allowEditAll = canAny([
    'super.edit.all','admin.edit.all','edit.all',
    'super.editAll','admin.editAll','editAll'
  ]);

  function canEditField(field) {
    if (_isSuper) return true;

    // ✅ update button (btnUpdateRow) required
    if (!canBtn('update')) return false;

    if (_allowEditAll) return true;

    const k = String(field || '').trim();

    const specificTrue = canAny([
      `super.edit.${k}`, `admin.edit.${k}`, `edit.${k}`,
      `super.edit_${k}`, `admin.edit_${k}`, `edit_${k}`,
      `edit${_cap(k)}`, `canEdit${_cap(k)}`, `can_edit_${k}`,
    ]);

    const anyEditKeyPresent = canAny([
      'super.edit', 'admin.edit', 'edit',
      'super.edit.student','admin.edit.student','edit.student',
      'super.edit.father','admin.edit.father','edit.father',
      'super.edit.grade','admin.edit.grade','edit.grade',
      'super.edit.phone','admin.edit.phone','edit.phone',
    ]);

    if (anyEditKeyPresent) return specificTrue;

    // ✅ default allow when update allowed
    return true;
  }

  const P = {
   col: {
  status: canCol('status'),
  feeStatus: canCol('feeStatus'),
  dept: canCol('dept'),
  student: canCol('student'),
  father: canCol('father'),
  fatherEmail: canCol('fatherEmail'),
  grade: canCol('grade'),
  tuitionGrade: canCol('tuitionGrade'),
  phone: canCol('phone'),
  processedBy: canCol('processedBy'),
  paymentStatus: canCol('paymentStatus'),
  paidUpto: canCol('paidUpto'),
  verif: canCol('verificationNumber'),
  reg: canCol('registrationNumber'),
  family: canCol('familyNumber'),
  registrationFee: canCol('registrationFee'),
  fees: canCol('fees'),
  currency: canCol('currency'),
  month: canCol('month'),
  totalFees: canCol('totalFees'),
  pendingDues: canCol('pendingDues'),
  receivedPayment: canCol('receivedPayment'),
  invoiceStatus: canCol('invoiceStatus'),
  invoiceStatusTimestamp: canCol('invoiceStatusTimestamp'),
  paidInvoiceStatus: canCol('paidInvoiceStatus'),
  paidInvoiceStatusTimestamp: canCol('paidInvoiceStatusTimestamp'),
  actionButtons: canCol('actionButtons')
},

      // ✅ action column itself controlled
    btn: {
      details: canBtn('details'),
      pdf: canBtn('pdf'),
      update: canBtn('update'),
      whatsapp: canBtn('whatsapp'),
      billing: canBtn('billing'),
      upload: canBtn('upload'),
      files: canBtn('files'),
    },
   edit: {
  dept: false,
  status: canEditField('status'),
  feeStatus: canEditField('feeStatus'),
  student: canEditField('student'),
  father: canEditField('father'),
  fatherEmail: canEditField('fatherEmail'),
  grade: canEditField('grade'),
  tuitionGrade: canEditField('tuitionGrade'),
  phone: canEditField('phone'),
  paymentStatus: canEditField('paymentStatus'),
  paidUpto: canEditField('paidUpto'),
  verif: canEditField('verificationNumber'),
  reg: canEditField('registrationNumber'),
  family: canEditField('familyNumber'),
  registrationFee: canEditField('registrationFee'),
  fees: canEditField('fees'),
  currency: canEditField('currency'),
  month: canEditField('month'),
    }
  };

  // ✅ Action column shows only if column permission is ON and at least one button allowed
 const showActions =
  P.col.actionButtons &&
  (P.btn.details || P.btn.pdf || P.btn.update || P.btn.whatsapp || P.btn.billing || P.btn.upload || P.btn.files);
const baseCols = Object.keys(P.col).filter(k => k !== 'actionButtons' && P.col[k]).length;
const visibleColCount = baseCols + (showActions ? 1 : 0);
const DEFAULT_CURRENT_STATUS_OPTIONS =
  (typeof statusOptionsCurrent !== 'undefined' && Array.isArray(statusOptionsCurrent) && statusOptionsCurrent.length)
    ? statusOptionsCurrent.map(opt => ({
        id: opt.id,
        value: opt.value || opt.label || opt.opt_key || '',
        label: opt.label || opt.value || opt.opt_key || '',
        color: opt.color || '#64748b',
        is_custom: Number(opt.is_custom || 0)
      })).filter(opt => opt.value)
    : [
        { value: 'New Admission', label: 'New Admission', color: '#64748b' },
        { value: 'Running', label: 'Running', color: '#22c55e' },
        { value: 'Leave', label: 'Leave', color: '#f59e0b' },
        { value: 'Stop', label: 'Stop', color: '#ef4444' },
        { value: 'Left', label: 'Left', color: '#2563eb' },
        { value: 'Freez', label: 'Freez', color: '#94a3b8' }
      ];

const DEFAULT_FEE_STATUS_OPTIONS =
  (typeof statusOptionsFee !== 'undefined' && Array.isArray(statusOptionsFee) && statusOptionsFee.length)
    ? statusOptionsFee.map(opt => ({
        id: opt.id,
        value: opt.value || opt.label || opt.opt_key || '',
        label: opt.label || opt.value || opt.opt_key || '',
        color: opt.color || '#64748b',
        is_custom: Number(opt.is_custom || 0)
      })).filter(opt => opt.value)
    : [
        { value: 'New Admission', label: 'New Admission', color: '#64748b' },
        { value: 'Present + Dues', label: 'Present + Dues', color: '#ef4444' },
        { value: 'Present + No Dues', label: 'Present + No Dues', color: '#22c55e' }
      ];

      const DEFAULT_CURRENCY_OPTIONS =
  (typeof currencyOptions !== 'undefined' && Array.isArray(currencyOptions) && currencyOptions.length)
    ? currencyOptions.map(opt => ({
        id: opt.id,
        value: opt.value || opt.label || opt.opt_key || '',
        label: opt.label || opt.value || opt.opt_key || '',
        is_custom: Number(opt.is_custom || 0)
      })).filter(opt => opt.value)
    : [
        { value: 'AED', label: 'AED', is_custom: 0 },
        { value: 'SAR', label: 'SAR', is_custom: 0 },
        { value: 'PKR', label: 'PKR', is_custom: 0 },
        { value: 'USD', label: 'USD', is_custom: 0 },
        { value: 'GBP', label: 'GBP', is_custom: 0 }
      ];

      const DEFAULT_BANK_OPTIONS =
  (typeof bankOptions !== 'undefined' && Array.isArray(bankOptions) && bankOptions.length)
    ? bankOptions.map(opt => ({
        id: opt.id,
        value: opt.value || opt.label || opt.opt_key || '',
        label: opt.label || opt.value || opt.opt_key || '',
        is_custom: Number(opt.is_custom || 0)
      })).filter(opt => opt.value)
    : [
        { value: 'Meezan Bank', label: 'Meezan Bank', is_custom: 0 },
        { value: 'Bank Al Habib', label: 'Bank Al Habib', is_custom: 0 },
        { value: 'HBL', label: 'HBL', is_custom: 0 },
        { value: 'UBL', label: 'UBL', is_custom: 0 },
        { value: 'JazzCash', label: 'JazzCash', is_custom: 0 },
        { value: 'EasyPaisa', label: 'EasyPaisa', is_custom: 0 }
      ];
      const DEFAULT_CLASS_OPTIONS =
  (typeof classOptions !== 'undefined' && Array.isArray(classOptions) && classOptions.length)
    ? classOptions
    : [
        'FS 1',
        'FS 2',
        'FS 3',
        'Grade 1',
        'Grade 2',
        'Grade 3',
        'Grade 4',
        'Grade 5',
        'Grade 6',
        'Grade 7',
        'Grade 8 (FBISE)',
        "Grade 8 (IGCSE / O'Level)",
        'Grade 9 (FBISE)',
        "Grade 9 (IGCSE / O'Level)",
        'Grade 10 (FBISE)',
        "Grade 10 (IGCSE / O'Level)",
        'Grade 11 (FBISE)',
        "Grade 11 (IGCSE, O / A'Level)",
        'Grade 12 (FBISE)'
      ];
%>

<div class="admin-shell">

  <!-- TOP HERO -->
  <div class="admin-header-card mb-3">
    <div>
      <div class="d-flex align-items-center gap-2 mb-1">
        <span class="badge rounded-pill admin-chip">
          <i class="bi bi-shield-lock me-1"></i> Department Admin
        </span>
        <span class="badge rounded-pill admin-chip">
          <i class="bi bi-building me-1"></i> <span class="text-capitalize"><%= user.dept %></span> Dept
        </span>
        <span class="badge rounded-pill admin-chip">
          <i class="bi bi-activity me-1"></i> Live pipeline view
        </span>
      </div>

      <h2 class="h4 fw-bold mb-1 text-admin-heading">
        <%= deptTitle %> Admin Dashboard
      </h2>

      <div class="small text-muted">
        Dept scope:
        <span class="badge rounded-pill admin-dept-pill ms-1 text-capitalize">
          <span class="dept-dot me-1"></span>
          <%= user.dept %>
        </span>
      </div>
    </div>

    <div class="text-end small text-muted d-none d-md-block">
      <div>Manage Accounts + Admission from one screen.</div>
      <div>Real-time updates for your department only.</div>
    </div>
  </div>

  <!-- STATS -->
  <div class="row g-3 mb-3 admin-stat-row">
    <div class="col-md-3">
      <div class="card admin-stat-card stat-primary">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <div class="stat-label">Dept Admissions</div>
              <div class="stat-value"><%= totalAdmissions %></div>
            </div>
            <div class="stat-icon-wrap">
              <i class="bi bi-people stat-icon"></i>
            </div>
          </div>
        </div>
        <div class="card-footer stat-footer">
          All forms for this department
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card admin-stat-card stat-success">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <div class="stat-label">Marked as Paid</div>
              <div class="stat-value"><%= paidCount %></div>
            </div>
            <div class="stat-icon-wrap">
              <i class="bi bi-check2-circle stat-icon"></i>
            </div>
          </div>
        </div>
        <div class="card-footer stat-footer">
          Based on Accounts update
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card admin-stat-card stat-warning">
        <div class="card-body">
          <div class="stat-label mb-1">Payment Overview</div>
          <div class="stat-value-sm">
            <span class="text-success fw-semibold"><%= paidCount %></span> Paid ·
            <span class="text-warning fw-semibold"><%= partiallyPaid %></span> Partial ·
            <span class="text-danger fw-semibold"><%= unpaidCount %></span> Unpaid
          </div>
          <div class="progress mt-2" style="height:5px;">
            <div
              class="progress-bar bg-success"
              role="progressbar"
              style="width:<%= paidPercent %>%"
              aria-valuenow="<%= paidPercent %>"
              aria-valuemin="0"
              aria-valuemax="100"></div>
          </div>
        </div>
        <div class="card-footer stat-footer">
          Based on current table status
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card admin-stat-card stat-info">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <div class="stat-label">Pipeline Completed</div>
              <div class="stat-value"><%= completedPipeline %></div>
            </div>
            <div class="stat-icon-wrap">
              <i class="bi bi-diagram-3 stat-icon"></i>
            </div>
          </div>
        </div>
        <div class="card-footer stat-footer">
          Accounts + Admission steps done
        </div>
      </div>
    </div>
  </div>

  <div class="alert alert-info small mb-3 admin-info-alert">
    <strong>Admissions for <%= deptTitle %>:</strong>
    overview of students and pipeline. You can update allowed fields directly from this table.
  </div>

  <!-- TABLE -->
  <div class="card shadow-sm admin-table-card">
    <div class="card-header d-flex justify-content-between align-items-center">
      <div>
        <strong>Admissions for <%= deptTitle %></strong>
        <small class="text-muted ms-2">Student details &amp; pipeline status</small>
      </div>
      <span class="badge text-bg-light text-muted small">
        Dept: <span class="text-capitalize"><%= user.dept %></span>
      </span>
    </div>

        <div class="px-3 pt-3 pb-2 border-top bulk-challan-toolbar-wrap">
      <div class="d-flex justify-content-end">
        <button
          type="button"
          class="btn rounded-pill px-4 bulk-challan-open-btn"
          id="openBulkChallanBtn">
          <i class="bi bi-whatsapp me-2"></i>Send Bulk Challan
        </button>
      </div>
    </div>

    <div class="card-body p-0">
      <div class="table-responsive pipeline-scroll">
        <table id="adminAdmissionsTable" class="table table-sm mb-0 align-middle pipeline-table">
          <thead class="table-dark">
            <tr>
              <% if (P.col.status) { %><th data-col="status">Current Status</th><% } %>
              <% if (P.col.feeStatus) { %><th data-col="feeStatus">Fee Status</th><% } %>
              <% if (P.col.dept) { %><th data-col="dept">Dept</th><% } %>
              <% if (P.col.student) { %><th data-col="student">Student</th><% } %>
              <% if (P.col.father) { %><th data-col="father">Father</th><% } %>
              <% if (P.col.fatherEmail) { %><th data-col="fatherEmail">Email Address</th><% } %>
              <% if (P.col.grade) { %><th data-col="grade">Grade</th><% } %>
              <% if (P.col.tuitionGrade) { %><th data-col="tuitionGrade">Grade Section</th><% } %>
              <% if (P.col.phone) { %><th data-col="phone">Phone Number</th><% } %>
              <% if (P.col.processedBy) { %><th data-col="processedBy">Processed By</th><% } %>
              <% if (P.col.paymentStatus) { %><th data-col="paymentStatus">Payment Status</th><% } %>
              <% if (P.col.paidUpto) { %><th data-col="paidUpto">Paid Upto</th><% } %>
              <% if (P.col.verif) { %><th data-col="verificationNumber">Verif #</th><% } %>
              <% if (P.col.reg) { %><th data-col="registrationNumber">Reg #</th><% } %>
              <% if (P.col.family) { %><th data-col="familyNumber">Family Num #</th><% } %>
              <% if (P.col.registrationFee) { %><th data-col="registrationFee">Registration Fee</th><% } %>
              <% if (P.col.fees) { %><th data-col="fees">Monthly Fees</th><% } %>
              <% if (P.col.currency) { %><th data-col="currency">Currency</th><% } %>
              <% if (P.col.month) { %><th data-col="month">Month/Year</th><% } %>
              <% if (P.col.totalFees) { %><th data-col="totalFees">Total Fees</th><% } %>
              <% if (P.col.pendingDues) { %><th data-col="pendingDues">Pending Dues</th><% } %>
              <% if (P.col.receivedPayment) { %><th data-col="receivedPayment">Received Payment</th><% } %>
              <% if (P.col.invoiceStatus) { %><th data-col="invoiceStatus">Invoice Status</th><% } %>
<% if (P.col.invoiceStatusTimestamp) { %><th data-col="invoiceStatusTimestamp">Invoice Status Timestamp</th><% } %>
<% if (P.col.paidInvoiceStatus) { %><th data-col="paidInvoiceStatus">Paid Invoice Status</th><% } %>
<% if (P.col.paidInvoiceStatusTimestamp) { %><th data-col="paidInvoiceStatusTimestamp">Paid Invoice Status Timestamp</th><% } %>
              

              <% if (showActions) { %>
                <th class="text-center col-actions" data-col="actions">Action Buttons</th>
              <% } %>
            </tr>

            <!-- Filter row -->
            <tr class="bg-secondary-subtle admin-filter-row">
             <% if (P.col.status) { %>
  <th data-col="status">
    <select id="filter-status" class="form-select form-select-sm status-select" data-filter-col="status">
      <option value="">All</option>
      <% DEFAULT_CURRENT_STATUS_OPTIONS.forEach(opt => { %>
        <option value="<%= opt.value %>"><%= opt.value %></option>
      <% }) %>
    </select>
  </th>
<% } %>

<% if (P.col.feeStatus) { %>
  <th data-col="feeStatus">
    <select id="filter-fee-status" class="form-select form-select-sm fee-select" data-filter-col="feeStatus">
      <option value="">All</option>
      <% DEFAULT_FEE_STATUS_OPTIONS.forEach(opt => { %>
        <option value="<%= opt.value %>"><%= opt.value %></option>
      <% }) %>
    </select>
  </th>
<% } %>
              <% if (P.col.dept) { %><th data-col="dept"></th><% } %>

              <% if (P.col.student) { %>
                <th data-col="student">
                  <input type="text" class="form-control form-control-sm" placeholder="Student" data-filter-col="student">
                </th>
              <% } %>

              <% if (P.col.father) { %>
                <th data-col="father">
                  <input type="text" class="form-control form-control-sm" placeholder="Father" data-filter-col="father">
                </th>
              <% } %>

              <% if (P.col.fatherEmail) { %>
              <th data-col="fatherEmail">
              <input type="text" class="form-control form-control-sm" placeholder="Email Address" data-filter-col="fatherEmail">
              </th>
              <% } %>

              <% if (P.col.grade) { %>
                <th data-col="grade">
                  <input type="text" class="form-control form-control-sm" placeholder="Grade" data-filter-col="grade">
                </th>
              <% } %>

              <% if (P.col.tuitionGrade) { %>
