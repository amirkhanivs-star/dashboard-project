<script>
  (function () {
    if (typeof io === "undefined") return;
    const socket = io();
    let pending = false;

    socket.on("admission:changed", function () {
      const billingModal = document.getElementById("billingModal");
      const billingOpen =
        billingModal &&
        billingModal.classList.contains("show");

      const flashOpen =
        document.getElementById("upload-flash-overlay") &&
        !document.getElementById("upload-flash-overlay").classList.contains("d-none");

      const recentSubmit =
        sessionStorage.getItem("admin_dashboard_recent_submit") === "1";

      if (billingOpen || flashOpen || recentSubmit) {
        return;
      }

      if (pending) return;
      pending = true;

      setTimeout(function () {
        if (typeof saveViewportState === "function") {
          saveViewportState();
        }
        window.location.reload();
      }, 4200);
    });

    socket.on("user:updated", function (payload) {
      const currentUserId = Number(window.CURRENT_USER?.id || 0);
      const targetUserId = Number(payload?.userId || 0);

      if (!currentUserId || !targetUserId) return;
      if (currentUserId !== targetUserId) return;

      const flashOpen =
        document.getElementById("upload-flash-overlay") &&
        !document.getElementById("upload-flash-overlay").classList.contains("d-none");

      const billingModal = document.getElementById("billingModal");
      const billingOpen =
        billingModal &&
        billingModal.classList.contains("show");

      if (flashOpen || billingOpen) return;
      if (pending) return;

      pending = true;

      setTimeout(function () {
        if (typeof saveViewportState === "function") {
          saveViewportState();
        }
        window.location.reload();
      }, 300);
    });
  })();
</script>

<script>
  (function () {
    const STORAGE_KEY = "admin_dashboard_viewport";
    const RECENT_KEY = "admin_dashboard_recent_submit";

    function getPipelineScroll() {
      return document.querySelector(".pipeline-scroll");
    }

    function getMainScrollTop() {
      return (
        window.pageYOffset ||
        document.documentElement.scrollTop ||
        document.body.scrollTop ||
        0
      );
    }

    function setMainScrollTop(value) {
      window.scrollTo(0, Number(value || 0));
      document.documentElement.scrollTop = Number(value || 0);
      document.body.scrollTop = Number(value || 0);
    }

    window.saveViewportState = function () {
      const wrap = getPipelineScroll();

      const state = {
        pageY: getMainScrollTop(),
        tableLeft: wrap ? wrap.scrollLeft : 0,
        tableTop: wrap ? wrap.scrollTop : 0
      };

      sessionStorage.setItem(STORAGE_KEY, JSON.stringify(state));
    };

    function restoreViewportState() {
      const raw = sessionStorage.getItem(STORAGE_KEY);
      if (!raw) return;

      try {
        const state = JSON.parse(raw);
        const wrap = getPipelineScroll();

        const applyRestore = function () {
          setMainScrollTop(state.pageY || 0);

          if (wrap) {
            wrap.scrollLeft = Number(state.tableLeft || 0);
            wrap.scrollTop = Number(state.tableTop || 0);
          }
        };

        applyRestore();

        requestAnimationFrame(() => {
          applyRestore();

          requestAnimationFrame(() => {
            applyRestore();

            setTimeout(() => {
              applyRestore();
            }, 120);
          });
        });
      } catch (err) {
        console.error("Viewport restore failed:", err);
      }

      sessionStorage.removeItem(STORAGE_KEY);
    }

    function bindSaveEvents() {
      document.querySelectorAll('form[id^="rowForm_"]').forEach(form => {
        if (form.dataset.viewportBound === "1") return;
        form.dataset.viewportBound = "1";

        form.addEventListener("submit", function () {
          window.saveViewportState();
          sessionStorage.setItem(RECENT_KEY, "1");
        });
      });

      document.querySelectorAll(".action-update").forEach(btn => {
        if (btn.dataset.viewportBound === "1") return;
        btn.dataset.viewportBound = "1";

        btn.addEventListener("click", function () {
          window.saveViewportState();
          sessionStorage.setItem(RECENT_KEY, "1");
        });
      });
    }

    document.addEventListener("DOMContentLoaded", function () {
      bindSaveEvents();
    });

    window.addEventListener("load", function () {
      restoreViewportState();

      setTimeout(function () {
        sessionStorage.removeItem(RECENT_KEY);
      }, 8000);
    });
  })();
</script>

