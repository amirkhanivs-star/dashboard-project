const editBillingStatusSaveBtn = document.getElementById('editBillingStatusSaveBtn');

let editingBillingStatusId = null;
let editingBillingStatusOldValue = '';

listEl.addEventListener('click', function (e) {
  if (e.target.closest('.billing-status-delete-btn')) return;
  if (e.target.closest('.billing-status-color-input')) return;

  const wrap = e.target.closest('.status-option-item');
  if (!wrap) return;

  const nameEl = wrap.querySelector('.status-option-name');
