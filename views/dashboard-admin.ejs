<style>
  @keyframes flashScaleIn {
    from { transform: scale(0.9); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  @keyframes flashFadeOut {
    to { opacity: 0; visibility: hidden; }
  }

  @keyframes billingStatusPopIn {
    from {
      opacity: 0;
      transform: translateY(10px) scale(.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  #upload-flash-overlay.fade-out {
    animation: flashFadeOut 250ms ease-in forwards;
  }

  body.row-saving-active {
  overflow: hidden;
}

.row-saving-card {
  min-width: 280px;
  max-width: 360px;
  animation: flashScaleIn 180ms ease-out;
}

.row-saving-spinner {
  width: 44px;
  height: 44px;
  border-radius: 999px;
  border: 4px solid rgba(15, 23, 42, 0.12);
  border-top-color: #111827;
  animation: rowSavingSpin .75s linear infinite;
}

@keyframes rowSavingSpin {
  to { transform: rotate(360deg); }
}

  html,
  body {
    overflow-x: hidden;
