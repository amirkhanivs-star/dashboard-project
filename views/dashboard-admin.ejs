<script>
  (function () {
    document.addEventListener('DOMContentLoaded', function () {
      const openBtn = document.getElementById('openBulkChallanBtn');
      const modalEl = document.getElementById('bulkChallanModal');
      if (!openBtn || !modalEl || typeof bootstrap === 'undefined') return;

      const bulkModal = bootstrap.Modal.getOrCreateInstance(modalEl);

      const monthEl = document.getElementById('bulkChallanMonth');
      const monthGrid = document.getElementById('bulkChallanMonthGrid');

      const feeTypeEl = document.getElementById('bulkChallanFeeType');

      const classEl = document.getElementById('bulkChallanClass');
      const classGrid = document.getElementById('bulkChallanClassGrid');

      const sectionEl = document.getElementById('bulkChallanSection');
      const yearEl = document.getElementById('bulkChallanYear');

      const createBtn = document.getElementById('bulkChallanCreateBtn');
      const sendBtn = document.getElementById('bulkChallanSendBtn');

      const summaryBox = document.getElementById('bulkChallanSummaryBox');
      const summaryText = document.getElementById('bulkChallanSummaryText');

      function showPopup(type, title, message) {
        if (typeof window.showUploadFlash === 'function') {
          window.showUploadFlash(type, title, message);
        } else {
          alert(message || title || 'Notification');
        }
      }

      function getPayload() {
        return {
          month: String(monthEl?.value || '').trim(),
          feeType: String(feeTypeEl?.value || '').trim(),
          className: String(classEl?.value || '').trim(),
          section: String(sectionEl?.value || 'All Sections').trim(),
          year: String(yearEl?.value || '').trim()
        };
      }

      function validatePayload(payload) {
        return !!(
          payload.month &&
          payload.feeType &&
          payload.className &&
          payload.section &&
          payload.year
        );
      }

      function setLoading(btn, state, loadingText, normalHtml) {
        if (!btn) return;
        btn.disabled = !!state;
        btn.innerHTML = state ? loadingText : normalHtml;
      }

      async function postJson(url, payload) {
        const res = await fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify(payload)
        });

        const data = await res.json().catch(() => ({}));
        return { ok: res.ok, data };
      }

      if (monthGrid && monthEl) {
        monthGrid.addEventListener('click', function (e) {
          const chip = e.target.closest('.bulk-month-chip');
          if (!chip) return;

          monthGrid.querySelectorAll('.bulk-month-chip').forEach(btn => btn.classList.remove('active'));
          chip.classList.add('active');
          monthEl.value = chip.getAttribute('data-month') || '';
        });
      }

      if (classGrid && classEl) {
        classGrid.addEventListener('click', function (e) {
          const chip = e.target.closest('.bulk-class-chip');
          if (!chip) return;

          classGrid.querySelectorAll('.bulk-class-chip').forEach(btn => btn.classList.remove('active'));
          chip.classList.add('active');
          classEl.value = chip.getAttribute('data-class') || '';
        });
      }

      openBtn.addEventListener('click', function () {
        summaryBox.classList.add('d-none');
        summaryText.textContent = '-';

        monthEl.value = '';
        classEl.value = '';

        if (monthGrid) {
          monthGrid.querySelectorAll('.bulk-month-chip').forEach(btn => btn.classList.remove('active'));
        }

        if (classGrid) {
          classGrid.querySelectorAll('.bulk-class-chip').forEach(btn => btn.classList.remove('active'));
        }

        bulkModal.show();
      });

      createBtn.addEventListener('click', async function () {
        const payload = getPayload();

        if (!validatePayload(payload)) {
          showPopup('error', 'Invalid Selection', 'Please select month, fee type, class, section and year.');
          return;
        }

        const normalHtml = 'Create Invoice';
        try {
          setLoading(createBtn, true, '<span class="spinner-border spinner-border-sm me-2"></span>Creating...', normalHtml);

          const result = await postJson('/api/bulk-challan/create', payload);

          if (!result.ok || !result.data?.success) {
            showPopup('error', 'Update Failed', result.data?.message || 'Invoice status update failed.');
            return;
          }

          const summary = result.data.summary || {};
          summaryText.textContent =
            `Matched: ${summary.totalMatched || 0} | Ready to Send: ${summary.readyToSend || 0} | Already Updated: ${summary.alreadyUpdated || 0}`;
          summaryBox.classList.remove('d-none');

          showPopup('success', 'Success', result.data?.message || 'Invoice status updated successfully.');

          if (typeof window.saveViewportState === 'function') {
            window.saveViewportState();
          }

          setTimeout(() => window.location.reload(), 900);
        } catch (err) {
          console.error(err);
          showPopup('error', 'Update Failed', 'Invoice status update failed.');
        } finally {
          setLoading(createBtn, false, '', normalHtml);
        }
      });

      sendBtn.addEventListener('click', async function () {
        const payload = getPayload();

        if (!validatePayload(payload)) {
          showPopup('error', 'Invalid Selection', 'Please select month, fee type, class, section and year.');
          return;
        }

        const normalHtml = '<i class="bi bi-whatsapp me-1"></i> Send Invoice to WhatsApp';
        try {
          setLoading(sendBtn, true, '<span class="spinner-border spinner-border-sm me-2"></span>Sending...', normalHtml);

          const result = await postJson('/api/bulk-challan/send-whatsapp', payload);

          if (!result.ok || !result.data?.success) {
            showPopup('error', 'Send Failed', result.data?.message || 'Failed to send invoices to WhatsApp.');
            return;
          }

          showPopup(
            'success',
            'Sent Successfully',
            result.data?.message || 'Invoices sent to WhatsApp successfully.'
          );
        } catch (err) {
          console.error(err);
          showPopup('error', 'Send Failed', 'Failed to send invoices to WhatsApp.');
        } finally {
          setLoading(sendBtn, false, '', normalHtml);
        }
      });
    });
  })();
</script>
