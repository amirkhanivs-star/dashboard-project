<%- include('partials/bootstrap-header', { user, pageTitle: 'Edit User' }) %>

<%
  let p = editUser.permissions || {};
  try { if (typeof p === 'string') p = JSON.parse(p); } catch(e) { p = {}; }
  const roleText = String(editUser.role || '').replace(/_/g, ' ');
  const deptDisplay =
  String(editUser.dept || '').trim().toLowerCase() === 'accounts'
    ? 'School Accounts'
    : (editUser.dept || '—');

const roleCircleClass =
  editUser.role === 'super_admin' ? 'bg-danger text-white' :
  editUser.role === 'admin' ? 'bg-success text-white' :
  editUser.role === 'agent' ? 'agent-role-circle' :
  'subagent-role-circle';

const roleBadgeClass =
  editUser.role === 'super_admin' ? 'bg-danger-subtle text-danger' :
  editUser.role === 'admin' ? 'bg-success-subtle text-success' :
  editUser.role === 'agent' ? 'agent-role-badge' :
  'subagent-role-badge';

const editUserAdmissionLink =
  editUser.admissionLink || editUser.admission_link || '';

const safePipelineTransferInfo =
  (typeof pipelineTransferInfo !== "undefined" && pipelineTransferInfo)
    ? pipelineTransferInfo
    : {
        eligible: false,
        count: 0,
        currentPipelineType: "",
        currentPipelineLabel: "",
        sourceUserId: editUser.id,
        sourceUserName: editUser.name || "",
        targets: [],
      };

const pipelineTransferInfoJson =
  JSON.stringify({
    eligible: !!safePipelineTransferInfo.eligible,
    count: Number(safePipelineTransferInfo.count || 0),
    currentPipelineType: safePipelineTransferInfo.currentPipelineType || "",
    currentPipelineLabel: safePipelineTransferInfo.currentPipelineLabel || "",
    sourceUserName: safePipelineTransferInfo.sourceUserName || editUser.name || "",
    targets: safePipelineTransferInfo.targets || [],
  }).replace(/</g, "\\u003c");
%>

<style>
  .agent-role-circle{
  background: linear-gradient(135deg, #8b5cf6, #5b21b6) !important;
  color: #fff !important;
  box-shadow: 0 8px 18px rgba(124, 58, 237, 0.22);
}

.agent-role-badge{
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: .22rem;
  border-radius: 999px;
  padding: .35em .9em;
  font-size: .75rem;
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
  background: rgba(124, 58, 237, 0.14) !important;
  color: #5b21b6 !important;
  border: 1px solid rgba(124, 58, 237, 0.30) !important;
  box-shadow: 0 4px 12px rgba(124, 58, 237, 0.10);
}

.agent-role-badge i{
  font-size: .72rem;
  line-height: 1;
  color: #5b21b6 !important;
}
  .subagent-role-circle{
    background: linear-gradient(135deg, #60a5fa 0%, #2563eb 100%) !important;
    color: #fff !important;
    box-shadow: 0 8px 18px rgba(37, 99, 235, 0.22);
  }

  .subagent-role-badge{
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: .22rem;
    border-radius: 999px;
    padding: .35em .9em;
    font-size: .75rem;
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
    background: rgba(59, 130, 246, 0.10) !important;
    color: #2563eb !important;
    border: 1px solid rgba(59, 130, 246, 0.26) !important;
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.08);
  }

  .subagent-role-badge i{
    font-size: .72rem;
    line-height: 1;
    color: #2563eb !important;
  }
  .edit-user-link-preview{
    margin-top: 8px;
    width: 100%;
  }

  .edit-user-link-mini{
    display: flex;
    align-items: flex-start;
    gap: 7px;
    width: 100%;
    padding: 6px 8px;
    border-radius: 10px;
    font-size: .70rem;
    font-weight: 800;
    line-height: 1.25;
    border: 1px solid transparent;
  }

  .edit-user-link-mini i{
    font-size: .74rem;
    line-height: 1.2;
    margin-top: 1px;
    flex: 0 0 auto;
  }

  .edit-user-link-text{
    flex: 1 1 auto;
    min-width: 0;
    white-space: normal;
    overflow: visible;
    text-overflow: unset;
    overflow-wrap: anywhere;
    word-break: break-word;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: .66rem;
    font-weight: 800;
  }

  .edit-user-link-copy{
    width: 23px;
    height: 23px;
    border: 0;
    border-radius: 8px;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 23px;
    transition: all .16s ease;
  }

  .edit-user-link-copy i{
    font-size: .72rem;
    line-height: 1;
  }

  .edit-user-link-copy:hover{
    transform: translateY(-1px);
    filter: brightness(.98);
  }

  .edit-user-link-copy:disabled{
    opacity: .75;
    cursor: not-allowed;
    transform: none;
  }

  .edit-user-link-mini.link-role-super{
    background: rgba(220, 53, 69, 0.08);
    border-color: rgba(220, 53, 69, 0.24);
    color: #b42318;
  }

  .edit-user-link-mini.link-role-super .edit-user-link-copy{
    background: rgba(220, 53, 69, 0.14);
    color: #b42318;
  }

  .edit-user-link-mini.link-role-admin{
    background: rgba(25, 135, 84, 0.08);
    border-color: rgba(25, 135, 84, 0.24);
    color: #157347;
  }

  .edit-user-link-mini.link-role-admin .edit-user-link-copy{
    background: rgba(25, 135, 84, 0.14);
    color: #157347;
  }

  .edit-user-link-mini.link-role-agent{
    background: rgba(124, 58, 237, 0.09);
    border-color: rgba(124, 58, 237, 0.26);
    color: #5b21b6;
  }

  .edit-user-link-mini.link-role-agent .edit-user-link-copy{
    background: rgba(124, 58, 237, 0.15);
    color: #5b21b6;
  }

  .edit-user-link-mini.link-role-sub-agent{
    background: rgba(37, 99, 235, 0.08);
    border-color: rgba(37, 99, 235, 0.24);
    color: #1d4ed8;
  }

  .edit-user-link-mini.link-role-sub-agent .edit-user-link-copy{
    background: rgba(37, 99, 235, 0.14);
    color: #1d4ed8;
  }


  .pipeline-transfer-warning{
    margin-top: 12px;
    border: 1px solid rgba(220, 53, 69, 0.22);
    background: linear-gradient(135deg, rgba(220, 53, 69, 0.06), rgba(255, 255, 255, 0.95));
    border-radius: 16px;
    padding: 12px 14px;
    display: none;
  }

  .pipeline-transfer-warning.is-visible{
    display: block;
  }

  .pipeline-transfer-warning .transfer-count-badge{
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 28px;
    height: 28px;
    padding: 0 9px;
    border-radius: 999px;
    background: rgba(220, 53, 69, 0.12);
    color: #b42318;
    font-weight: 900;
    border: 1px solid rgba(220, 53, 69, 0.24);
  }

  .pipeline-transfer-modal-card{
    border-radius: 22px;
    border: 0;
    overflow: hidden;
  }

  .pipeline-transfer-modal-head{
    background: linear-gradient(135deg, #dc3545, #9f1239);
    color: #fff;
  }

  .pipeline-transfer-target-card{
    border: 1px solid rgba(220, 53, 69, 0.16);
    border-radius: 16px;
    background: rgba(220, 53, 69, 0.04);
    padding: 12px;
  }

  .pipeline-transfer-note{
    border-radius: 14px;
    background: #fff7ed;
    border: 1px solid #fed7aa;
    color: #9a3412;
    padding: 10px 12px;
    font-size: .78rem;
    line-height: 1.45;
  }
    /* ================== CAN VIEW / CAN EDIT MATRIX ================== */
  .permission-quickbar {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    padding: 10px 12px;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    background: #f8fafc;
  }

  .permission-quickbar-label {
    margin-right: 2px;
    color: #475569;
    font-size: .70rem;
    font-weight: 800;
  }

  .permission-quickbar .btn {
    padding: 4px 10px;
    font-size: .68rem;
    font-weight: 700;
  }

  .permission-default-note {
    margin-left: auto;
    color: #64748b;
    font-size: .66rem;
    font-weight: 700;
  }

  .permission-groups-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .permission-group-card {
    min-width: 0;
    overflow: hidden;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    background: #ffffff;
  }

  .permission-group-title {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 9px 10px;
    border-bottom: 1px solid #e5e7eb;
    background: #f8fafc;
    color: #1f2937;
    font-size: .74rem;
    font-weight: 800;
  }

  .permission-group-title i {
    color: #dc3545;
    font-size: .78rem;
  }

  .permission-matrix-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 43px 43px;
    align-items: stretch;
    min-height: 34px;
    border-top: 1px solid #f1f5f9;
  }

  .permission-matrix-row:first-of-type {
    border-top: 0;
  }

  .permission-matrix-head {
    min-height: 29px;
    background: #f8fafc;
    color: #64748b;
    font-size: .59rem;
    font-weight: 800;
    letter-spacing: .035em;
    text-transform: uppercase;
  }

  .permission-matrix-head > span:first-child {
    display: flex;
    align-items: center;
    padding: 5px 9px;
  }

  .permission-field-label {
    display: flex;
    align-items: center;
    min-width: 0;
    margin: 0;
    padding: 6px 9px;
    color: #334155;
    font-size: .69rem;
    font-weight: 700;
    line-height: 1.15;
    cursor: pointer;
    overflow-wrap: anywhere;
  }

  .permission-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    border-left: 1px solid #eef2f7;
  }

  .permission-cell .form-check-input {
    float: none;
    width: 1rem;
    height: 1rem;
    margin: 0;
    cursor: pointer;
  }

  .permission-cell .form-check-input:disabled {
    opacity: .42;
    cursor: not-allowed;
  }

  .permission-lock {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 7px;
    background: #f1f5f9;
    color: #94a3b8;
    font-size: .65rem;
  }

  .permission-legend {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 7px;
    margin-bottom: 9px;
    color: #64748b;
    font-size: .67rem;
  }

  .permission-legend-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 8px;
    border: 1px solid #e5e7eb;
    border-radius: 999px;
    background: #ffffff;
    font-weight: 700;
  }

  .permission-legend-item i {
    font-size: .68rem;
  }

  @media (max-width: 1199.98px) {
    .permission-groups-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 767.98px) {
    .permission-groups-grid {
      grid-template-columns: 1fr;
    }

    .permission-default-note {
      width: 100%;
      margin-top: 3px;
      margin-left: 0;
    }
  }
</style>

<div class="container-fluid py-4">
 <a href="/dashboard/super/users" class="small text-danger text-decoration-none mb-3 d-inline-flex align-items-center fw-semibold">
  <i class="bi bi-arrow-left me-1"></i> Back to Users
</a>

  <div class="card border-0 shadow-sm rounded-4 mb-3">
    <div class="card-body d-flex flex-wrap align-items-center justify-content-between gap-2 small">
      <div class="d-flex align-items-center gap-2">
        <span class="d-inline-flex align-items-center justify-content-center rounded-circle <%= roleCircleClass %>"
              style="width:30px;height:30px;">
          <%= (editUser.name || 'U').charAt(0).toUpperCase() %>
        </span>
        <div>
          <div class="fw-semibold"><%= editUser.name %></div>
          <div class="text-muted"><%= editUser.email %></div>
        </div>
      </div>

      <div class="d-flex flex-wrap gap-2">
        <span class="badge rounded-pill bg-light text-muted border">
          ID: <strong class="ms-1">#<%= editUser.id %></strong>
        </span>
         <span class="badge rounded-pill <%= roleBadgeClass %> text-capitalize">
          <i class="bi bi-person-badge me-1"></i><%= roleText %>
         </span>
        <span class="badge rounded-pill bg-light text-muted text-capitalize">
          Dept: <span class="ms-1"><%= deptDisplay %></span>
        </span>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm rounded-4 mb-3">
    <div class="card-body py-3 d-flex flex-wrap align-items-center justify-content-between gap-2">
      <div class="d-flex align-items-center gap-2 small text-muted">
        <i class="bi bi-shield-lock text-danger"></i>
        Can View controls visibility. Can Edit controls whether the user can update each column.
      </div>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-lg-3">
      <div class="card shadow-sm h-100 small border-0 rounded-4">
        <div class="card-body">
          <h6 class="mb-2 d-flex align-items-center">
            <i class="bi bi-sliders2-vertical me-2 text-danger"></i>
            Editing: <%= editUser.name %>
          </h6>
          <p class="text-muted mb-2">
            ID: <strong><%= editUser.id %></strong><br>
            Current role:
            <span class="text-capitalize"><%= String(editUser.role || '').replace(/_/g,' ') %></span><br>
            Dept:
            <span><%= deptDisplay %></span>
          </p>
          <p class="text-muted mb-0">
The Super Admin can edit the role, department, assigned admin, pipeline type, columns, and buttons from here.
          </p>
        </div>
      </div>
    </div>

    <div class="col-lg-9">
      <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header border-0 bg-white bg-opacity-75">
          <h5 class="mb-0 d-flex align-items-center">
            <i class="bi bi-pencil-square me-2 text-danger"></i>
            Edit Admin / Agent / Sub Agent
          </h5>
          <small class="text-muted">
            Saved Can View, Can Edit, button, and special permissions are loaded below.
          </small>
        </div>

        <div class="card-body">
          <% if (error) { %>
          <div class="alert alert-danger py-2 small"><%= error %></div>
          <% } %>

          <form
            method="POST"
            action="/dashboard/super/users/<%= editUser.id %>/edit"
            id="editUserForm">
            <input
              type="hidden"
              name="pipelineTransferTargetUserId"
              id="pipelineTransferTargetUserId"
              value="">
            <div class="row g-3">
              <div class="col-12">
                <h6 class="mb-1">1. Basic information</h6>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Name</label>
                <input
                  type="text"
                  name="name"
                  id="editUserNameInput"
                  class="form-control"
                  value="<%= editUser.name %>"
                  required>

                <% const editLinkRoleClass =
                  editUser.role === 'super_admin' ? 'link-role-super' :
                  editUser.role === 'admin' ? 'link-role-admin' :
                  editUser.role === 'agent' ? 'link-role-agent' :
                  'link-role-sub-agent';
                %>

                <div class="edit-user-link-preview">
                  <div class="edit-user-link-mini <%= editLinkRoleClass %>" title="<%= editUserAdmissionLink %>">
                    <i class="bi bi-link-45deg"></i>

                    <span
                      id="editUserAdmissionLinkPreview"
                      class="edit-user-link-text">
                      <%= editUserAdmissionLink || 'Type name to generate link' %>
                    </span>

                    <button
                      type="button"
                      class="edit-user-link-copy"
                      id="copyEditUserAdmissionLinkBtn"
                      title="Copy admission form link"
                      aria-label="Copy admission form link">
                      <i class="bi bi-clipboard"></i>
                    </button>
                  </div>
                </div>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Email</label>
                <input type="email" name="email" class="form-control" value="<%= editUser.email %>" required>
              </div>

              <div class="col-md-4">
                <label class="form-label small">New Password (optional)</label>
                <input type="text" name="password" class="form-control" placeholder="Leave blank to keep same">
              </div>

              <div class="col-12 mt-3">
                <h6 class="mb-1">2. Role &amp; Department</h6>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Role</label>
                <select name="role" id="roleSelect" class="form-select" required>
                  <option value="admin" <%= editUser.role === 'admin' ? 'selected' : '' %>>Admin</option>
                  <option value="agent" <%= editUser.role === 'agent' ? 'selected' : '' %>>Agent</option>
                  <option value="sub_agent" <%= editUser.role === 'sub_agent' ? 'selected' : '' %>>Sub Agent</option>
                </select>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Department</label>
                <select name="dept" id="deptSelect" class="form-select" required>
                  <option value="quran" <%= editUser.dept === 'quran' ? 'selected' : 'disabled' %>>Quran - Coming Soon</option>
                  <option value="tuition" <%= editUser.dept === 'tuition' ? 'selected' : 'disabled' %>>Tuition - Coming Soon</option>
                  <option value="school" <%= editUser.dept === 'school' ? 'selected' : '' %>>School</option>
                  <option value="accounts" <%= editUser.dept === 'accounts' ? 'selected' : '' %>>School Accounts</option>
                </select>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Pipeline / Agent Type</label>
                <select name="agentType" id="agentTypeSelect" class="form-select" data-current-agent-type="<%= editUser.agentType || '' %>">
                <option value="">Select type</option>
               </select>
                <small class="text-muted d-block">
                  This is only meaningful for Agent and Sub Agent. It will be ignored for Admin.
                </small>
              </div>

              <% if (safePipelineTransferInfo.eligible) { %>
              <div class="col-12">
                <div
                  class="pipeline-transfer-warning"
                  id="pipelineTransferWarning">
                  <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
                    <div>
                      <div class="small fw-bold text-danger text-uppercase mb-1">
                        <i class="bi bi-arrow-left-right me-1"></i>
                        Pipeline Transfer Required
                      </div>
                      <div class="fw-semibold">
                        <span class="transfer-count-badge me-1">
                          <%= safePipelineTransferInfo.count || 0 %>
                        </span>
                        assigned admission(s) are currently in
                        <%= safePipelineTransferInfo.currentPipelineLabel || 'this pipeline' %>.
                      </div>
                      <div class="small text-muted mt-1">
                        If you change this user's School Accounts pipeline type, these admissions must be transferred to another
                        <%= safePipelineTransferInfo.currentPipelineLabel || 'same pipeline' %> Agent/Sub-Agent.
                      </div>
                    </div>
                    <div class="small text-muted">
                      Source user:
                      <strong><%= safePipelineTransferInfo.sourceUserName || editUser.name || 'Current user' %></strong>
                    </div>
                  </div>
                </div>
              </div>
              <% } %>
              <!-- ASSIGNMENT -->
              <div class="col-12 mt-3" id="assignmentSection">
                <div class="rounded-4 border bg-light p-3">
                  <div class="d-flex align-items-start justify-content-between flex-wrap gap-2">
                    <div>
                      <h6 class="mb-1">
                        <i class="bi bi-diagram-3 me-1 text-danger"></i>
                        Assignment & Data Access
                      </h6>
                      <p class="text-muted small mb-2">
                        Reassign this Agent/Sub Agent to another Admin. Admin users do not need assignment.
                      </p>
                    </div>
                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle">
                      Required for Agent/Sub Agent
                    </span>
                  </div>

                  <div class="row g-3">
                    <div class="col-md-6">
                      <label class="form-label small">Assigned Admin</label>
                      <select name="assignedAdminId" id="assignedAdminSelect" class="form-select">
                        <option value="">Select assigned admin</option>
                        <% 
                          const adminsForAssignment = (typeof assignableAdmins !== "undefined" && Array.isArray(assignableAdmins))
                            ? assignableAdmins
                            : [];

                          const currentAssignedAdminId = String(editUser.assigned_admin_id || editUser.managerId || "");
                        %>

                        <% adminsForAssignment.forEach(function(admin) { %>
                          <option 
                            value="<%= admin.id %>" 
                            data-dept="<%= admin.dept || '' %>"
                            <%= String(admin.id) === currentAssignedAdminId ? 'selected' : '' %>
                          >
                            <%= admin.name %>
                            <% if (admin.dept) { %>
                              - <%= String(admin.dept).toUpperCase() %>
                            <% } %>
                            <% if (admin.email) { %>
                              (<%= admin.email %>)
                            <% } %>
                          </option>
                        <% }) %>
                      </select>
                      <small class="text-muted d-block" id="assignedAdminHelp">
                        Only admins from the selected department will be shown.
                      </small>
                    </div>

                    <div class="col-md-6">
                      <label class="form-label small">Access Scope</label>
                      <input type="text" id="accessScopePreview" class="form-control bg-white" value="Auto by role" readonly>
                      <small class="text-muted d-block">
                        Backend will automatically update access scope after saving.
                      </small>
                    </div>
                  </div>
                </div>
              </div>
              <!-- QUICK PERMISSION CONTROLS -->
              <div class="col-12 mt-3">
                <div class="permission-quickbar">
                  <span class="permission-quickbar-label">
                    <i class="bi bi-eye me-1"></i>
                    Columns:
                  </span>

                  <button
                    type="button"
                    class="btn btn-outline-secondary btn-sm rounded-pill"
                    id="btnViewAll">
                    View all
                  </button>

                  <button
                    type="button"
                    class="btn btn-outline-secondary btn-sm rounded-pill"
                    id="btnViewNone">
                    View none
                  </button>

                  <button
                    type="button"
                    class="btn btn-outline-secondary btn-sm rounded-pill"
                    id="btnEditAll">
                    Edit all
                  </button>

                  <button
                    type="button"
                    class="btn btn-outline-secondary btn-sm rounded-pill"
                    id="btnEditNone">
                    Edit none
                  </button>

                  <span class="permission-quickbar-label ms-md-2">
                    <i class="bi bi-hand-index-thumb me-1"></i>
                    Buttons:
                  </span>

                  <button
                    type="button"
                    class="btn btn-outline-secondary btn-sm rounded-pill"
                    id="btnButtonsAll">
                    All on
                  </button>

                  <button
                    type="button"
                    class="btn btn-outline-secondary btn-sm rounded-pill"
                    id="btnButtonsNone">
                    All off
                  </button>

