                              <label class="form-check-label" for="colFamilyNumber">Family Num #</label>
                            </div>
                          </div>

                          <div class="col-md-4">
                            <div class="form-check small">
                              <input class="form-check-input col-toggle" type="checkbox" id="colRegistrationFee" name="colRegistrationFee" checked>
                              <label class="form-check-label" for="colRegistrationFee">Registration Fee</label>
                              </div>
                         </div>

                          <div class="col-md-4">
                            <div class="form-check small">
                              <input class="form-check-input col-toggle" type="checkbox" id="colFees" name="colFees" checked>
                              <label class="form-check-label" for="colFees">Fees</label>
                            </div>
                          </div>

                          <!-- ✅ ADDED: Currency column permission -->
                          <div class="col-md-4">
                            <div class="form-check small">
                              <input class="form-check-input col-toggle" type="checkbox" id="colCurrency" name="colCurrency" checked>
                              <label class="form-check-label" for="colCurrency">Currency</label>
