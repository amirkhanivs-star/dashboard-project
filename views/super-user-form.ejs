<%- include('partials/bootstrap-header', { user, pageTitle: 'Create Admin / Agent / Sub Agent' }) %>
<style>
  .create-user-link-preview{
    margin-top: 8px;
    width: 100%;
  }

  .create-user-link-mini{
    display: flex;
    align-items: flex-start;
    gap: 7px;
    width: 100%;
    padding: 6px 8px;
    border-radius: 10px;
    font-size: .70rem;
    font-weight: 800;
    line-height: 1.25;
    background: #f8fafc;
    border: 1px solid #e5e7eb;
    color: #475569;
  }

  .create-user-link-mini i{
    font-size: .74rem;
    line-height: 1.2;
    margin-top: 1px;
    flex: 0 0 auto;
    color: #64748b;
  }

  .create-user-link-text{
    flex: 1 1 auto;
    min-width: 0;
    white-space: normal;
    overflow: visible;
    text-overflow: unset;
    overflow-wrap: anywhere;
    word-break: break-word;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: .66rem;
    font-weight: 800;
  }

  .create-user-link-copy{
    width: 23px;
    height: 23px;
    border: 0;
    border-radius: 8px;
    padding: 0;
    background: #e5e7eb;
    color: #475569;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 23px;
    transition: all .16s ease;
  }

  .create-user-link-copy i{
    font-size: .72rem;
    line-height: 1;
    color: #475569;
  }

  .create-user-link-copy:hover{
    background: #d1d5db;
    transform: translateY(-1px);
  }

  .create-user-link-copy:disabled{
    opacity: .75;
    cursor: not-allowed;
    transform: none;
  }
    /* ================== CAN VIEW / CAN EDIT MATRIX ================== */
  .permission-quickbar {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    padding: 10px 12px;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    background: #f8fafc;
  }

  .permission-quickbar-label {
    font-size: .70rem;
    font-weight: 800;
    color: #475569;
    margin-right: 2px;
  }

  .permission-quickbar .btn {
    font-size: .68rem;
    font-weight: 700;
    padding: 4px 10px;
  }

  .permission-default-note {
    margin-left: auto;
    font-size: .66rem;
    font-weight: 700;
    color: #64748b;
  }

  .permission-groups-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .permission-group-card {
    min-width: 0;
    overflow: hidden;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    background: #ffffff;
  }

  .permission-group-title {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 9px 10px;
    border-bottom: 1px solid #e5e7eb;
    background: #f8fafc;
    color: #1f2937;
    font-size: .74rem;
    font-weight: 800;
  }

  .permission-group-title i {
    color: #dc3545;
    font-size: .78rem;
  }

  .permission-matrix-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 43px 43px;
    align-items: stretch;
    min-height: 34px;
    border-top: 1px solid #f1f5f9;
  }

  .permission-matrix-row:first-of-type {
    border-top: 0;
  }

  .permission-matrix-head {
    min-height: 29px;
    background: #f8fafc;
    color: #64748b;
    font-size: .59rem;
    font-weight: 800;
    letter-spacing: .035em;
    text-transform: uppercase;
  }

  .permission-field-label {
    display: flex;
    align-items: center;
    min-width: 0;
    margin: 0;
    padding: 6px 9px;
    color: #334155;
    font-size: .69rem;
    font-weight: 700;
    line-height: 1.15;
    cursor: pointer;
    overflow-wrap: anywhere;
  }

  .permission-matrix-head > span:first-child {
    display: flex;
    align-items: center;
    padding: 5px 9px;
  }

  .permission-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    border-left: 1px solid #eef2f7;
  }

  .permission-cell .form-check-input {
    float: none;
    width: 1rem;
    height: 1rem;
    margin: 0;
    cursor: pointer;
  }

  .permission-cell .form-check-input:disabled {
    cursor: not-allowed;
    opacity: .42;
  }

  .permission-lock {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 7px;
    background: #f1f5f9;
    color: #94a3b8;
    font-size: .65rem;
  }

  .permission-legend {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 7px;
    margin-bottom: 9px;
    font-size: .67rem;
    color: #64748b;
  }

  .permission-legend-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 8px;
    border: 1px solid #e5e7eb;
    border-radius: 999px;
    background: #ffffff;
    font-weight: 700;
  }

  .permission-legend-item i {
    font-size: .68rem;
  }

  @media (max-width: 1199.98px) {
    .permission-groups-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 767.98px) {
    .permission-groups-grid {
      grid-template-columns: 1fr;
    }

    .permission-default-note {
      width: 100%;
      margin-left: 0;
      margin-top: 3px;
    }
  }
</style>
<div class="container-fluid py-4">
  <a href="/dashboard/super/users" class="small text-danger text-decoration-none mb-3 d-inline-flex align-items-center fw-semibold">
    <i class="bi bi-arrow-left me-1"></i> Back to Users
  </a>

  <!-- Step indicator bar -->
  <div class="card border-0 shadow-sm rounded-4 mb-3">
    <div class="card-body py-3 d-flex flex-wrap align-items-center gap-3">
      <span class="badge rounded-pill bg-light text-muted border d-flex align-items-center">
        <i class="bi bi-compass me-2 text-danger"></i>
        User Creation Wizard
      </span>

      <div class="d-flex flex-wrap gap-3 small">
        <div class="d-flex align-items-center gap-2">
         <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-danger text-white"
          style="width:22px;height:22px;font-size:.75rem;">1</span>
          <span>Basic info</span>
        </div>
        <div class="d-flex align-items-center gap-2">
          <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-success-subtle text-success"
                style="width:22px;height:22px;font-size:.75rem;">2</span>
          <span>Role &amp; department</span>
        </div>
        <div class="d-flex align-items-center gap-2">
<span class="d-inline-flex align-items-center justify-content-center rounded-circle"
      style="width:22px;height:22px;font-size:.75rem; background:rgba(124,58,237,.14); color:#5b21b6; border:1px solid rgba(124,58,237,.30);">3</span>          <span>View &amp; Edit</span>
        </div>
        <div class="d-flex align-items-center gap-2">
         <span class="d-inline-flex align-items-center justify-content-center rounded-circle"
         style="width:22px;height:22px;font-size:.75rem; background:rgba(59,130,246,.10); color:#2563eb; border:1px solid rgba(59,130,246,.26); box-shadow:0 4px 12px rgba(59,130,246,.08);">4</span>
          <span>Buttons &amp; Permissions</span>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <!-- Left wizard steps -->
    <div class="col-lg-3">
      <div class="card shadow-sm h-100 border-0 rounded-4">
        <div class="card-body small">
          <h6 class="mb-3 d-flex align-items-center">
            <i class="bi bi-compass me-2 text-danger"></i>
            User Creation Wizard
          </h6>
          <p class="text-muted mb-3">
            The Super Admin can create an Admin, Agent, or Sub Agent for any department from here.
          </p>

          <ol class="ps-3 mb-0">
            <li class="mb-1">Set the basic information.</li>
            <li class="mb-1">Choose the role, department, assigned admin & pipeline type for Agents/Sub Agents.</li>
            <li class="mb-1">Choose which columns the user can view or edit.</li>
            <li class="mb-1">Configure buttons and special permissions.</li>
          </ol>

          <hr>
          <p class="text-muted mb-0">
            Can View controls visibility. Can Edit controls whether the user can update that column.
          </p>
        </div>
      </div>
    </div>

    <!-- Right main form -->
    <div class="col-lg-9">
      <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header border-0 bg-white bg-opacity-75">
          <h5 class="mb-0 d-flex align-items-center">
            <i class="bi bi-person-plus me-2 text-danger"></i>
            Create Admin / Agent / Sub Agent
          </h5>
          <small class="text-muted">
            <strong>Tip:</strong> Keep a strong password. The user cannot change it later.
          </small>
        </div>

        <div class="card-body">
          <% if (error) { %>
          <div class="alert alert-danger py-2 small"><%= error %></div>
          <% } %>

          <form method="POST" action="/dashboard/super/users">
            <div class="row g-3">
              <!-- BASIC INFO -->
              <div class="col-12">
                <h6 class="mb-1">1. Basic information</h6>
                <p class="text-muted small mb-2">
                  Set the name, email, and  password.
                </p>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Name</label>
                <input
                  type="text"
                  name="name"
                  id="createUserNameInput"
                  class="form-control"
                  placeholder=""
                  required
                >

                <div class="create-user-link-preview">
                  <div class="create-user-link-mini" title="">
                    <i class="bi bi-link-45deg"></i>

                    <span
                      id="createUserAdmissionLinkPreview"
                      class="create-user-link-text">
                      Type name to generate link
                    </span>

                    <button
                      type="button"
                      class="create-user-link-copy"
                      id="copyCreateUserAdmissionLinkBtn"
                      title="Copy admission form link"
                      aria-label="Copy admission form link">
                      <i class="bi bi-clipboard"></i>
                    </button>
                  </div>
                </div>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Email</label>
                <input
                  type="email"
                  name="email"
                  class="form-control"
                  placeholder="name@ivs.com"
                  required
                >
              </div>

              <div class="col-md-4">
                <label class="form-label small">Password</label>
                <input
                  type="text"
                  name="password"
                  class="form-control"
                  placeholder=""
                  required
                >
              </div>

              <!-- ROLE & DEPARTMENT -->
              <div class="col-12 mt-3">
                <h6 class="mb-1">2. Role &amp; Department</h6>
                <p class="text-muted small mb-2">
                  Admin is assigned a primary department. Agent and Sub Agent work according to the selected pipeline.
                </p>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Role</label>
                <select name="role" id="roleSelect" class="form-select" required>
                  <option value="">Select role</option>
                  <option value="admin">Admin</option>
                  <option value="agent">Agent</option>
                  <option value="sub_agent">Sub Agent</option>
                </select>
                <small class="text-muted d-block">
                  Admin = department head. Agent/Sub Agent = pipeline users.
                </small>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Department</label>
                <select name="dept" id="deptSelect" class="form-select" required>
                  <option value="">Select department</option>
                  <option value="quran" disabled>Quran - Coming Soon</option>
                  <option value="tuition" disabled>Tuition - Coming Soon</option>
                  <option value="school">School</option>
                  <option value="accounts">School Accounts</option> 
                </select>
                <small class="text-muted d-block">
                  Assign each user to one primary department.
                </small>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Pipeline / Agent Type</label>
               <select name="agentType" id="agentTypeSelect" class="form-select">
               <option value="">Select type</option>
               </select>
                <small class="text-muted d-block">
                  Only for Agent and Sub Agent. It will be ignored for Admin.
                </small>
              </div>
              <!-- ASSIGNMENT -->
              <div class="col-12 mt-3" id="assignmentSection">
                <div class="rounded-4 border bg-light p-3">
                  <div class="d-flex align-items-start justify-content-between flex-wrap gap-2">
                    <div>
                      <h6 class="mb-1">
                        <i class="bi bi-diagram-3 me-1 text-danger"></i>
                        Assignment & Data Access
                      </h6>
                      <p class="text-muted small mb-2">
                        Select which Admin will manage this Agent/Sub Agent. Admin users do not need assignment.
                      </p>
                    </div>
                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle">
                      Required for Agent/Sub Agent
                    </span>
                  </div>

                  <div class="row g-3">
                    <div class="col-md-6">
                      <label class="form-label small">Assigned Admin</label>
                      <select name="assignedAdminId" id="assignedAdminSelect" class="form-select">
                        <option value="">Select assigned admin</option>
                        <% 
                          const adminsForAssignment = (typeof assignableAdmins !== "undefined" && Array.isArray(assignableAdmins))
                            ? assignableAdmins
                            : [];
                        %>
                        <% adminsForAssignment.forEach(function(admin) { %>
                          <option 
                            value="<%= admin.id %>" 
                            data-dept="<%= admin.dept || '' %>"
                          >
                            <%= admin.name %> 
                            <% if (admin.dept) { %>
                              - <%= String(admin.dept).toUpperCase() %>
                            <% } %>
                            <% if (admin.email) { %>
                              (<%= admin.email %>)
                            <% } %>
                          </option>
                        <% }) %>
                      </select>
                      <small class="text-muted d-block" id="assignedAdminHelp">
                        Only admins from the selected department will be shown.
                      </small>
                    </div>

                    <div class="col-md-6">
                      <label class="form-label small">Access Scope</label>
                      <input type="text" id="accessScopePreview" class="form-control bg-white" value="Auto by role" readonly>
                      <small class="text-muted d-block">
                        Super Admin controls assignment. Backend will automatically set access scope.
                      </small>
                    </div>
                  </div>
                </div>
              </div>
              <!-- QUICK PERMISSION CONTROLS -->
              <div class="col-12 mt-3">
                <div class="permission-quickbar">
                  <span class="permission-quickbar-label">
                    <i class="bi bi-eye me-1"></i>
                    Columns:
                  </span>

                  <button
                    type="button"
                    class="btn btn-outline-secondary btn-sm rounded-pill"
                    id="btnViewAll">
                    View all
                  </button>

                  <button
                    type="button"
                    class="btn btn-outline-secondary btn-sm rounded-pill"
                    id="btnViewNone">
                    View none
                  </button>

                  <button
                    type="button"
                    class="btn btn-outline-secondary btn-sm rounded-pill"
                    id="btnEditAll">
                    Edit all
                  </button>

                  <button
                    type="button"
                    class="btn btn-outline-secondary btn-sm rounded-pill"
                    id="btnEditNone">
                    Edit none
                  </button>

                  <span class="permission-quickbar-label ms-md-2">
                    <i class="bi bi-hand-index-thumb me-1"></i>
                    Buttons:
                  </span>

                  <button
                    type="button"
                    class="btn btn-outline-secondary btn-sm rounded-pill"
                    id="btnButtonsAll">
                    All on
                  </button>

                  <button
                    type="button"
                    class="btn btn-outline-secondary btn-sm rounded-pill"
                    id="btnButtonsNone">
                    All off
                  </button>

                  <span class="permission-default-note">
                    Default: all columns visible, editing disabled
                  </span>
                </div>
              </div>

              <!-- COLUMNS + BUTTONS ACCORDION -->
              <div class="col-12 mt-3">
                <h6 class="mb-1">3. Columns & Buttons Permissions</h6>
                <p class="text-muted small mb-2">
                                    Turn columns, buttons, and special permissions on or off one by one.
                </p>

                <div class="accordion" id="permAccordion">

                                  <!-- CAN VIEW / CAN EDIT COLUMNS -->
                  <div class="accordion-item border-0 shadow-sm rounded-4 mb-2">
                    <h2 class="accordion-header" id="headingAllCols">
                      <button
                        class="accordion-button rounded-4"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#collapseAllCols"
                        aria-expanded="true"
                        aria-controls="collapseAllCols">
                        <i class="bi bi-table me-2 text-danger"></i>
                        Admissions pipeline columns
                      </button>
                    </h2>

                    <div
                      id="collapseAllCols"
                      class="accordion-collapse collapse show"
                      aria-labelledby="headingAllCols"
                      data-bs-parent="#permAccordion">

                      <div class="accordion-body">
                        <div class="permission-legend">
                          <span class="permission-legend-item">
                            <i class="bi bi-eye text-success"></i>
                            Can View
                          </span>

                          <span class="permission-legend-item">
                            <i class="bi bi-pencil-square text-primary"></i>
                            Can Edit
                          </span>

                          <span class="permission-legend-item">
                            <i class="bi bi-lock-fill text-secondary"></i>
                            System controlled
                          </span>
                        </div>

                        <%
                          const columnPermissionGroups = [
                            {
                              title: "Admission Details",
                              icon: "bi-person-vcard",
                              items: [
                                { view: "colStatus", edit: "editStatus", label: "Current Status" },
                                { view: "colFeeStatus", edit: "editFeeStatus", label: "Fee Status" },
                                { view: "colDept", edit: "editDept", label: "Department" },
                                { view: "colStudentName", edit: "editStudentName", label: "Student" },
                                { view: "colFatherName", edit: "editFatherName", label: "Father" },
                                { view: "colFatherEmail", edit: "editFatherEmail", label: "Father Email" },
                                { view: "colGrade", edit: "editGrade", label: "Grade" },
                                { view: "colTuitionGrade", edit: "editTuitionGrade", label: "Grade Section" },
                                { view: "colPhone", edit: "editPhone", label: "Phone Number" },
                                { view: "colProcessedBy", edit: "", label: "Processed By" }
                              ]
                            },
                            {
                              title: "Accounts & Fees",
                              icon: "bi-cash-stack",
                              items: [
                                { view: "colPaymentStatus", edit: "editPaymentStatus", label: "Payment Status" },
                                { view: "colPaidUpto", edit: "", label: "Paid Upto" },
                                { view: "colVerificationNumber", edit: "editVerificationNumber", label: "Verification #" },
                                { view: "colRegistrationNumber", edit: "editRegistrationNumber", label: "Registration #" },
                                { view: "colFamilyNumber", edit: "editFamilyNumber", label: "Family #" },
                                { view: "colRegistrationFee", edit: "editRegistrationFee", label: "Registration Fee" },
                                { view: "colFees", edit: "editFees", label: "Fees" },
                                { view: "colCurrency", edit: "editCurrency", label: "Currency" },
                                { view: "colBank", edit: "editBank", label: "Bank" },
                                { view: "colMonth", edit: "editMonth", label: "Month" }
                              ]
                            },
                            {
                              title: "Totals & Invoice",
                              icon: "bi-receipt",
                              items: [
                                { view: "colTotalFees", edit: "", label: "Total Fees" },
                                { view: "colPendingDues", edit: "", label: "Pending Dues" },
                                { view: "colReceivedPayment", edit: "", label: "Received Payment" },
                                { view: "colComment", edit: "editComment", label: "Comment" },
                                { view: "colInvoiceStatus", edit: "", label: "Invoice Status" },
                                { view: "colInvoiceStatusTimestamp", edit: "", label: "Invoice Status Time" },
                                { view: "colPaidInvoiceStatus", edit: "", label: "Paid Invoice Status" },
                                { view: "colPaidInvoiceStatusTimestamp", edit: "", label: "Paid Invoice Time" },
                                { view: "colActionButtons", edit: "", label: "Action Buttons" }
                              ]
                            }
                          ];
                        %>

                        <div class="permission-groups-grid">
                          <% columnPermissionGroups.forEach(function(group) { %>
                            <div class="permission-group-card">
                              <div class="permission-group-title">
                                <i class="bi <%= group.icon %>"></i>
                                <span><%= group.title %></span>
                              </div>

                              <div class="permission-matrix-row permission-matrix-head">
                                <span>Column</span>
                                <span class="permission-cell">View</span>
                                <span class="permission-cell">Edit</span>
                              </div>

                              <% group.items.forEach(function(item) { %>
                                <div class="permission-matrix-row">
                                  <label
                                    class="permission-field-label"
                                    for="<%= item.view %>">
                                    <%= item.label %>
                                  </label>

                                  <div class="permission-cell">
                                    <!-- Hidden input makes View None submit correctly -->
                                    <input
                                      type="hidden"
                                      name="<%= item.view %>"
                                      value="">

                                    <input
                                      class="form-check-input col-toggle view-toggle"
                                      type="checkbox"
                                      id="<%= item.view %>"
                                      name="<%= item.view %>"
                                      data-edit-target="<%= item.edit || '' %>"
                                      title="Can View: <%= item.label %>"
                                      aria-label="Can View <%= item.label %>"
                                      checked>
                                  </div>

                                  <div class="permission-cell">
                                    <% if (item.edit) { %>
                                      <!-- Hidden input explicitly submits Edit OFF -->
                                      <input
                                        type="hidden"
                                        name="<%= item.edit %>"
                                        value="">

                                      <input
                                        class="form-check-input edit-toggle"
                                        type="checkbox"
                                        id="<%= item.edit %>"
                                        name="<%= item.edit %>"
                                        data-view-target="<%= item.view %>"
                                        title="Can Edit: <%= item.label %>"
                                        aria-label="Can Edit <%= item.label %>">
                                    <% } else { %>
                                      <span
                                        class="permission-lock"
                                        title="This value is calculated or system controlled">
                                        <i class="bi bi-lock-fill"></i>
                                      </span>
                                    <% } %>
                                  </div>
                                </div>
                              <% }) %>
                            </div>
                          <% }) %>
                        </div>
                      </div>
                    </div>
                  </div>

               <!-- BUTTONS -->
<div class="accordion-item border-0 shadow-sm rounded-4">
  <h2 class="accordion-header" id="headingButtons">
    <button class="accordion-button collapsed rounded-4" type="button" data-bs-toggle="collapse" data-bs-target="#collapseButtons" aria-expanded="false" aria-controls="collapseButtons">
      <i class="bi bi-hand-index-thumb me-2 text-danger"></i>
      Buttons
    </button>
  </h2>
  <div id="collapseButtons" class="accordion-collapse collapse" aria-labelledby="headingButtons" data-bs-parent="#permAccordion">
    <div class="accordion-body">
      <div class="row g-2">
        <div class="col-md-4">
          <div class="form-check small">
            <input class="form-check-input perm-toggle" type="checkbox" id="btnEditRow" name="btnEditRow" checked>
            <label class="form-check-label" for="btnEditRow">Show Edit button</label>
          </div>
        </div>

        <div class="col-md-4">
         <div class="form-check small">
           <input class="form-check-input perm-toggle" type="checkbox" id="btnDetails" name="btnDetails" checked>
           <label class="form-check-label" for="btnDetails">Show View Details button</label>
         </div>
        </div>

        <div class="col-md-4">
          <div class="form-check small">
            <input class="form-check-input perm-toggle" type="checkbox" id="btnUpdateRow" name="btnUpdateRow" checked>
            <label class="form-check-label" for="btnUpdateRow">Show Update/Save button</label>
          </div>
        </div>

        <div class="col-md-4">
          <div class="form-check small">
            <input class="form-check-input perm-toggle" type="checkbox" id="btnPdf" name="btnPdf" checked>
            <label class="form-check-label" for="btnPdf">Show PDF button</label>
          </div>
        </div>

        <div class="col-md-4">
          <div class="form-check small">
            <input class="form-check-input perm-toggle" type="checkbox" id="btnBilling" name="btnBilling" checked>
            <label class="form-check-label" for="btnBilling">Show Billing button</label>
          </div>
        </div>

        <div class="col-md-4">
          <div class="form-check small">
            <input class="form-check-input perm-toggle" type="checkbox" id="btnWhatsApp" name="btnWhatsApp" checked>
            <label class="form-check-label" for="btnWhatsApp">Show WhatsApp button</label>
          </div>
        </div>

        <div class="col-md-4">
          <div class="form-check small">
            <input class="form-check-input perm-toggle" type="checkbox" id="btnUpload" name="btnUpload" checked>
            <label class="form-check-label" for="btnUpload">Show Upload button</label>
          </div>
        </div>

        <div class="col-md-4">
          <div class="form-check small">
            <input class="form-check-input perm-toggle" type="checkbox" id="btnFiles" name="btnFiles" checked>
            <label class="form-check-label" for="btnFiles">Show Files button</label>
          </div>
        </div>

        <!-- ✅ NEW: match edit screen -->
        <div class="col-md-4">
          <div class="form-check small">
            <input class="form-check-input perm-toggle" type="checkbox" id="canDeleteFiles" name="canDeleteFiles" checked>
            <label class="form-check-label" for="canDeleteFiles">Can Delete Files</label>
          </div>
        </div>
                <div class="col-md-4">
          <div class="form-check small">
           <input class="form-check-input perm-toggle" type="checkbox" id="canDeleteAdmissions" name="canDeleteAdmissions" checked>
            <label class="form-check-label" for="canDeleteAdmissions">Can Delete Admissions</label>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
                </div>
              </div>
            </div>

            <hr>
            <div class="d-flex justify-content-between">
              <a href="/dashboard/super/users" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                Cancel
              </a>
               <button type="submit" class="btn btn-danger rounded-pill px-4">
                <i class="bi bi-save me-1"></i>
                Save User
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const roleSelect = document.getElementById("roleSelect");
    const deptSelect = document.getElementById("deptSelect");
    const agentTypeSelect = document.getElementById("agentTypeSelect");
        const createUserNameInput = document.getElementById("createUserNameInput");
    const createUserAdmissionLinkPreview = document.getElementById("createUserAdmissionLinkPreview");
    const copyCreateUserAdmissionLinkBtn = document.getElementById("copyCreateUserAdmissionLinkBtn");

    const admissionFormBaseUrl =
      <%- JSON.stringify(
        typeof admissionFormBaseUrl !== "undefined" &&
        admissionFormBaseUrl
          ? String(admissionFormBaseUrl)
          : "https://ivs-admission-form.onrender.com/"
      )
        .replace(/</g, "\\u003C")
        .replace(/>/g, "\\u003E")
        .replace(/&/g, "\\u0026")
        .replace(/\u2028/g, "\\u2028")
        .replace(/\u2029/g, "\\u2029") %>;

    const assignmentSection = document.getElementById("assignmentSection");
    const assignedAdminSelect = document.getElementById("assignedAdminSelect");
    const assignedAdminHelp = document.getElementById("assignedAdminHelp");
    const accessScopePreview = document.getElementById("accessScopePreview");

    const btnViewAll = document.getElementById("btnViewAll");
    const btnViewNone = document.getElementById("btnViewNone");
    const btnEditAll = document.getElementById("btnEditAll");
    const btnEditNone = document.getElementById("btnEditNone");
    const btnButtonsAll = document.getElementById("btnButtonsAll");
    const btnButtonsNone = document.getElementById("btnButtonsNone");
    function buildAdmissionLinkFromName(name) {
      const cleanName = String(name || "").trim();
      const baseUrl = String(admissionFormBaseUrl || "https://ivs-admission-form.onrender.com/")
        .trim()
        .replace(/\?+$/, "")
        .replace(/\/+$/, "/");

      if (!cleanName) return "";

      return baseUrl + "?sentBy=" + encodeURIComponent(cleanName);
    }

    function syncCreateUserAdmissionLinkPreview() {
      if (!createUserNameInput || !createUserAdmissionLinkPreview) return;

      const link = buildAdmissionLinkFromName(createUserNameInput.value);
      createUserAdmissionLinkPreview.textContent = link || "Type name to generate link";

      const linkWrap = createUserAdmissionLinkPreview.closest(".create-user-link-mini");
      if (linkWrap) {
        linkWrap.setAttribute("title", link || "");
      }

      if (copyCreateUserAdmissionLinkBtn) {
        copyCreateUserAdmissionLinkBtn.disabled = !link;
      }
    }

    async function copyCreateUserAdmissionLink(text) {
      const cleanText = String(text || "").trim();
      if (!cleanText) return false;

      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(cleanText);
          return true;
        }

        const textarea = document.createElement("textarea");
        textarea.value = cleanText;
        textarea.style.position = "fixed";
        textarea.style.left = "-9999px";
        textarea.style.top = "-9999px";
        document.body.appendChild(textarea);
        textarea.focus();
        textarea.select();

        const copied = document.execCommand("copy");
        document.body.removeChild(textarea);

        return copied;
      } catch (err) {
        console.error("Create user admission link copy failed:", err);
        return false;
      }
    }
    const schoolAgentTypeOptions = [
  { value: "accounts", label: "Accounts" },
  { value: "admission", label: "Admission" },
  { value: "management", label: "Management" },
];

const schoolAccountsAgentTypeOptions = [
  { value: "print_record_update", label: "Print + Record update" },
  { value: "verification_registration", label: "Verification & Registration" },
  { value: "paid_slip", label: "Paid slip" },
];

function normalizeUserDepartmentKey(value) {
  const cleanValue = String(value || "")
    .trim()
    .toLowerCase()
    .replace(/[_-]+/g, " ")
    .replace(/\s+/g, " ");

  if (
    [
      "accounts",
      "account",
      "school account",
      "school accounts",
      "accounts department",
      "school accounts department"
    ].includes(cleanValue)
  ) {
    return "accounts";
  }

  if (
    [
      "school",
      "school dept",
      "school department"
    ].includes(cleanValue)
  ) {
    return "school";
  }

  if (
    [
      "quran",
      "quran dept",
      "quran department"
    ].includes(cleanValue)
  ) {
    return "quran";
  }

  if (
    [
      "tuition",
      "tuition dept",
      "tuition department"
    ].includes(cleanValue)
  ) {
    return "tuition";
  }

  return cleanValue;
}

function isSchoolAccountsDept(dept) {
  return (
    normalizeUserDepartmentKey(dept) ===
    "accounts"
  );
}

function syncAgentTypeOptions() {
  if (!agentTypeSelect) return;

  const dept =
    deptSelect
      ? deptSelect.value
      : "";

  const currentValue =
    agentTypeSelect.value;

  const options =
    isSchoolAccountsDept(dept)
      ? schoolAccountsAgentTypeOptions
      : schoolAgentTypeOptions;

  agentTypeSelect.innerHTML =
    '<option value="">Select type</option>';

  options.forEach((item) => {
    const opt =
      document.createElement("option");

    opt.value = item.value;
    opt.textContent = item.label;

    agentTypeSelect.appendChild(opt);
  });

  const exists =
    options.some((item) =>
      item.value === currentValue
    );

  agentTypeSelect.value =
    exists
      ? currentValue
      : "";
}

function filterAssignedAdmins() {
  if (!assignedAdminSelect) return;

  const selectedDept =
    normalizeUserDepartmentKey(
      deptSelect
        ? deptSelect.value
        : ""
    );

  let visibleCount = 0;

  Array.from(
    assignedAdminSelect.options
  ).forEach((opt) => {
    if (!opt.value) {
      opt.hidden = false;
      opt.disabled = false;
      return;
    }

    const adminDept =
      normalizeUserDepartmentKey(
        opt.getAttribute("data-dept") || ""
      );

    const shouldShow =
      !selectedDept ||
      adminDept === selectedDept;

    opt.hidden = !shouldShow;
    opt.disabled = !shouldShow;

    if (shouldShow) {
      visibleCount += 1;
    }
  });

  const selectedOption =
    assignedAdminSelect.options[
      assignedAdminSelect.selectedIndex
    ];

  if (
    selectedOption &&
    selectedOption.disabled
  ) {
    assignedAdminSelect.value = "";
  }

  if (assignedAdminHelp) {
    assignedAdminHelp.textContent =
      visibleCount
        ? "Only admins from the selected department are shown."
        : "No admin found for this department. Please create an Admin first.";
  }
}

    function syncRoleUI() {
      const role = (roleSelect && roleSelect.value) ? roleSelect.value : "";
      const dept = (deptSelect && deptSelect.value) ? deptSelect.value : "";
      syncAgentTypeOptions();

      if (agentTypeSelect) {
        const isPipelineRole =
          role === "agent" ||
          role === "sub_agent";

        if (!isPipelineRole) {
          agentTypeSelect.value = "";
          agentTypeSelect.disabled = true;
          agentTypeSelect.required = false;
          agentTypeSelect.classList.add("bg-light");
        } else {
          agentTypeSelect.disabled = false;
          agentTypeSelect.required = true;
          agentTypeSelect.classList.remove("bg-light");
        }
      }

      if (assignmentSection && assignedAdminSelect) {
        if (role === "agent" || role === "sub_agent") {
          assignmentSection.style.display = "";
          assignedAdminSelect.disabled = false;
          assignedAdminSelect.required = true;
        } else {
          assignmentSection.style.display = "none";
          assignedAdminSelect.value = "";
          assignedAdminSelect.disabled = true;
          assignedAdminSelect.required = false;
        }
      }

      if (accessScopePreview) {
        if (role === "admin" && dept === "accounts") {
          accessScopePreview.value = "School admissions - School Accounts Admin";
        } else if (role === "admin") {
          accessScopePreview.value = "Team admissions - Department Admin";
        } else if (role === "agent" || role === "sub_agent") {
          accessScopePreview.value = "Own admissions - Assigned team user";
        } else {
          accessScopePreview.value = "Auto by role";
        }
      }

      filterAssignedAdmins();
    }

    function syncViewEditPair(viewCheckbox) {
      if (!viewCheckbox) return;

      const editTargetId = String(
        viewCheckbox.getAttribute("data-edit-target") || ""
      ).trim();

      if (!editTargetId) return;

      const editCheckbox = document.getElementById(editTargetId);
      if (!editCheckbox) return;

      if (!viewCheckbox.checked) {
        editCheckbox.checked = false;
        editCheckbox.disabled = true;
      } else {
        editCheckbox.disabled = false;
      }
    }

    function setAllViews(enabled) {
      document.querySelectorAll(".view-toggle").forEach((viewCheckbox) => {
        viewCheckbox.checked = !!enabled;
        syncViewEditPair(viewCheckbox);
      });
    }

    function setAllEdits(enabled) {
      document.querySelectorAll(".edit-toggle").forEach((editCheckbox) => {
        const viewTargetId = String(
          editCheckbox.getAttribute("data-view-target") || ""
        ).trim();

        const viewCheckbox = viewTargetId
          ? document.getElementById(viewTargetId)
          : null;

        if (enabled) {
          if (viewCheckbox) {
            viewCheckbox.checked = true;
          }

          editCheckbox.disabled = false;
          editCheckbox.checked = true;
        } else {
          editCheckbox.checked = false;

          if (viewCheckbox) {
            syncViewEditPair(viewCheckbox);
          }
        }
      });
    }

    function setAllButtons(enabled) {
      document.querySelectorAll(".perm-toggle").forEach((checkbox) => {
        if (checkbox.disabled) return;
        checkbox.checked = !!enabled;
      });
    }

    function bindViewEditPermissionRules() {
      document.querySelectorAll(".view-toggle").forEach((viewCheckbox) => {
        viewCheckbox.addEventListener("change", function () {
          syncViewEditPair(this);
        });

        syncViewEditPair(viewCheckbox);
      });

      document.querySelectorAll(".edit-toggle").forEach((editCheckbox) => {
        editCheckbox.addEventListener("change", function () {
          if (!this.checked) return;

          const viewTargetId = String(
            this.getAttribute("data-view-target") || ""
          ).trim();

          const viewCheckbox = viewTargetId
            ? document.getElementById(viewTargetId)
            : null;

          if (viewCheckbox) {
            viewCheckbox.checked = true;
            syncViewEditPair(viewCheckbox);
          }
        });
      });
    }
        if (createUserNameInput) {
      createUserNameInput.addEventListener("input", syncCreateUserAdmissionLinkPreview);
    }

    if (copyCreateUserAdmissionLinkBtn) {
      copyCreateUserAdmissionLinkBtn.addEventListener("click", async function () {
        const link = createUserAdmissionLinkPreview
          ? createUserAdmissionLinkPreview.textContent.trim()
          : "";
        if (!link || link === "Type name to generate link") return;

        const oldHtml = copyCreateUserAdmissionLinkBtn.innerHTML;
        copyCreateUserAdmissionLinkBtn.disabled = true;
        copyCreateUserAdmissionLinkBtn.innerHTML = '<i class="bi bi-hourglass-split"></i>';

        const copied = await copyCreateUserAdmissionLink(link);

        if (copied) {
          copyCreateUserAdmissionLinkBtn.innerHTML = '<i class="bi bi-check2-circle"></i>';
          copyCreateUserAdmissionLinkBtn.title = "Copied";
        } else {
          prompt("Copy this admission form link:", link);
          copyCreateUserAdmissionLinkBtn.innerHTML = oldHtml;
        }

        setTimeout(function () {
          copyCreateUserAdmissionLinkBtn.disabled = false;
          copyCreateUserAdmissionLinkBtn.innerHTML = oldHtml;
          copyCreateUserAdmissionLinkBtn.title = "Copy admission form link";
          syncCreateUserAdmissionLinkPreview();
        }, 1200);
      });
    }
    if (roleSelect) roleSelect.addEventListener("change", syncRoleUI);
    if (deptSelect) {
    deptSelect.addEventListener("change", function () {
    syncAgentTypeOptions();
    syncRoleUI();
  });
}

    if (btnViewAll) {
      btnViewAll.addEventListener("click", function () {
        setAllViews(true);
      });
    }

    if (btnViewNone) {
      btnViewNone.addEventListener("click", function () {
        setAllViews(false);
      });
    }

    if (btnEditAll) {
      btnEditAll.addEventListener("click", function () {
        setAllEdits(true);
      });
    }

    if (btnEditNone) {
      btnEditNone.addEventListener("click", function () {
        setAllEdits(false);
      });
    }

    if (btnButtonsAll) {
      btnButtonsAll.addEventListener("click", function () {
        setAllButtons(true);
      });
    }

    if (btnButtonsNone) {
      btnButtonsNone.addEventListener("click", function () {
        setAllButtons(false);
      });
    }

    bindViewEditPermissionRules();
    syncRoleUI();
    syncCreateUserAdmissionLinkPreview();
  })();
</script>

<%- include('partials/bootstrap-footer') %>
