<%- include('partials/bootstrap-header', { user, pageTitle: 'Create Admin / Agent / Sub Agent' }) %>

<div class="container-fluid py-4">
  <a href="/dashboard/super/users" class="small text-danger text-decoration-none mb-3 d-inline-flex align-items-center fw-semibold">
    <i class="bi bi-arrow-left me-1"></i> Back to Users
  </a>

  <!-- Step indicator bar -->
  <div class="card border-0 shadow-sm rounded-4 mb-3">
    <div class="card-body py-3 d-flex flex-wrap align-items-center gap-3">
      <span class="badge rounded-pill bg-light text-muted border d-flex align-items-center">
        <i class="bi bi-compass me-2 text-danger"></i>
        User Creation Wizard
      </span>

      <div class="d-flex flex-wrap gap-3 small">
        <div class="d-flex align-items-center gap-2">
         <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-danger text-white"
          style="width:22px;height:22px;font-size:.75rem;">1</span>
          <span>Basic info</span>
        </div>
        <div class="d-flex align-items-center gap-2">
          <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-success-subtle text-success"
                style="width:22px;height:22px;font-size:.75rem;">2</span>
          <span>Role &amp; department</span>
        </div>
        <div class="d-flex align-items-center gap-2">
          <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-warning-subtle text-warning"
           style="width:22px;height:22px;font-size:.75rem;">3</span>
          <span>Columns</span>
        </div>
        <div class="d-flex align-items-center gap-2">
         <span class="d-inline-flex align-items-center justify-content-center rounded-circle"
         style="width:22px;height:22px;font-size:.75rem; background:rgba(59,130,246,.10); color:#2563eb; border:1px solid rgba(59,130,246,.26); box-shadow:0 4px 12px rgba(59,130,246,.08);">4</span>
          <span>Buttons &amp; Permissions</span>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <!-- Left wizard steps -->
    <div class="col-lg-3">
      <div class="card shadow-sm h-100 border-0 rounded-4">
        <div class="card-body small">
          <h6 class="mb-3 d-flex align-items-center">
            <i class="bi bi-compass me-2 text-danger"></i>
            User Creation Wizard
          </h6>
          <p class="text-muted mb-3">
            The Super Admin can create an Admin, Agent, or Sub Agent for any department from here.
          </p>

          <ol class="ps-3 mb-0">
            <li class="mb-1">Set the basic information.</li>
            <li class="mb-1">Choose the role, department & Pipeline / Agent Type for Agents/SubAgents.</li>
            <li class="mb-1">Choose the allowed columns.</li>
            <li class="mb-1">Turn columns & buttons permissions on or off.</li>
          </ol>

          <hr>
          <p class="text-muted mb-0">
            Configure column and button access from here. The user will only see the allowed items.
          </p>
        </div>
      </div>
    </div>

    <!-- Right main form -->
    <div class="col-lg-9">
      <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header border-0 bg-white bg-opacity-75">
          <h5 class="mb-0 d-flex align-items-center">
            <i class="bi bi-person-plus me-2 text-danger"></i>
            Create Admin / Agent / Sub Agent
          </h5>
          <small class="text-muted">
            <strong>Tip:</strong> Keep a strong password. The user cannot change it later.
          </small>
        </div>

        <div class="card-body">
          <% if (error) { %>
          <div class="alert alert-danger py-2 small"><%= error %></div>
          <% } %>

          <form method="POST" action="/dashboard/super/users">
            <div class="row g-3">
              <!-- BASIC INFO -->
              <div class="col-12">
                <h6 class="mb-1">1. Basic information</h6>
                <p class="text-muted small mb-2">
                  Set the name, email, and  password.
                </p>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Name</label>
                <input
                  type="text"
                  name="name"
                  class="form-control"
                  placeholder=""
                  required
                >
              </div>

              <div class="col-md-4">
                <label class="form-label small">Email</label>
                <input
                  type="email"
                  name="email"
                  class="form-control"
                  placeholder="name@ivs.com"
                  required
                >
              </div>

              <div class="col-md-4">
                <label class="form-label small">Password</label>
                <input
                  type="text"
                  name="password"
                  class="form-control"
                  placeholder=""
                  required
                >
              </div>

              <!-- ROLE & DEPARTMENT -->
              <div class="col-12 mt-3">
                <h6 class="mb-1">2. Role &amp; Department</h6>
                <p class="text-muted small mb-2">
                  Admin is assigned a primary department. Agent and Sub Agent work according to the selected pipeline.
                </p>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Role</label>
                <select name="role" id="roleSelect" class="form-select" required>
                  <option value="">Select role</option>
                  <option value="admin">Admin</option>
                  <option value="agent">Agent</option>
                  <option value="sub_agent">Sub Agent</option>
                </select>
                <small class="text-muted d-block">
                  Admin = department head. Agent/Sub Agent = pipeline users.
                </small>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Department</label>
                <select name="dept" class="form-select" required>
                  <option value="">Select department</option>
                  <option value="quran">Quran</option>
                  <option value="tuition">Tuition</option>
                  <option value="school">School</option>
                </select>
                <small class="text-muted d-block">
                  Assign each user to one primary department.
                </small>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Pipeline / Agent Type</label>
               <select name="agentType" id="agentTypeSelect" class="form-select">
               <option value="">Select type</option>
               <option value="accounts">Accounts</option>
               <option value="admission">Admission</option>
               <option value="management">Management</option>
              </select>
                <small class="text-muted d-block">
                  Only for Agent and Sub Agent. It will be ignored for Admin.
                </small>
              </div>

              <!-- QUICK TOGGLES -->
              <div class="col-12 mt-3">
                <div class="d-flex flex-wrap gap-2 align-items-center">
                  <span class="small text-muted">Quick:</span>
                  <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill px-3" id="btnSelectAll">
                    Select all
                  </button>
                  <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill px-3" id="btnSelectNone">
                    Select none
                  </button>
                  <span class="small text-muted ms-2">
                    (Applies only to permission and column checkboxes)
                  </span>
                </div>
              </div>

              <!-- COLUMNS + BUTTONS ACCORDION -->
              <div class="col-12 mt-3">
                <h6 class="mb-1">3. Columns & Buttons Permissions</h6>
                <p class="text-muted small mb-2">
                                    Turn columns, buttons, and special permissions on or off one by one.
                </p>

