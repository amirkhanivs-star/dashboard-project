<script>
  (function () {
    const roleSelect = document.getElementById("roleSelect");
    const agentTypeSelect = document.getElementById("agentTypeSelect");

    const btnSelectAll = document.getElementById("btnSelectAll");
    const btnSelectNone = document.getElementById("btnSelectNone");

    function syncRoleUI() {
      const role = (roleSelect && roleSelect.value) ? roleSelect.value : "";

    if (agentTypeSelect) {
  if (role === "admin") {
    agentTypeSelect.value = "";
    agentTypeSelect.disabled = true;
    agentTypeSelect.classList.add("bg-light");
  } else {
    agentTypeSelect.disabled = false;
    agentTypeSelect.classList.remove("bg-light");
  }
}
    }

    function toggleAll(on) {
      document.querySelectorAll(".perm-toggle, .col-toggle").forEach((cb) => {
        if (cb.disabled) return;
        cb.checked = !!on;
      });
    }

    if (roleSelect) roleSelect.addEventListener("change", syncRoleUI);

    if (btnSelectAll) btnSelectAll.addEventListener("click", () => toggleAll(true));
    if (btnSelectNone) btnSelectNone.addEventListener("click", () => toggleAll(false));

    // init
    syncRoleUI();
  })();
</script>

<%- include('partials/bootstrap-footer') %>
