<div class="col-md-4">
  <div class="form-check small">
    <input class="form-check-input col-toggle" type="checkbox" id="colPaidInvoiceStatus" name="colPaidInvoiceStatus" checked>
    <label class="form-check-label" for="colPaidInvoiceStatus">Paid Invoice Status</label>
  </div>
</div>

<div class="col-md-4">
  <div class="form-check small">
    <input class="form-check-input col-toggle" type="checkbox" id="colPaidInvoiceStatusTimestamp" name="colPaidInvoiceStatusTimestamp" checked>
    <label class="form-check-label" for="colPaidInvoiceStatusTimestamp">Paid Invoice Status Timestamp</label>
  </div>
</div>

                          <div class="col-md-4">
                            <div class="form-check small">
