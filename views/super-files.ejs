<%- include('partials/bootstrap-header', { user, pageTitle: pageTitle || 'Uploaded Files' }) %>
<%- include('partials/flash') %>

<%
  // ===== Safe helpers (EJS) =====
  const _safeStr = (v) => (v === null || typeof v === 'undefined') ? '' : String(v);
  const _lower = (v) => _safeStr(v).toLowerCase();
  const _isImg = (mime) => _safeStr(mime).startsWith('image/');
  const _ext = (name) => {
    const s = _safeStr(name);
    const i = s.lastIndexOf('.');
    return i >= 0 ? s.slice(i + 1).toLowerCase() : '';
  };
  const _fmtDate = (v) => _safeStr(v);

  const _isAbsUrl = (s) => /^https?:\/\//i.test(_safeStr(s).trim());

  // ✅ Build file link (works for uploads + stored links)
  function _fileHref(f) {
    let u =
      (f && (f.file_url || f.url || f.link || f.public_url || f.href || f.download_url || f.file_link)) || '';

    if (!u && f && f.stored_name) u = f.stored_name;

    u = _safeStr(u).trim();
    if (!u) return '';

    if (_isAbsUrl(u)) return u;
    if (u.startsWith('/')) return u;
    if (u.startsWith('uploads/')) return '/' + u;
    return '/uploads/' + u;
  }

  // ✅ detect REAL "link item" only
  function _isLinkItem(f) {
    if (!f) return false;
    const mime = _safeStr(f.mime_type).trim().toLowerCase();
    return mime === 'text/url';
  }

  // ✅ safe encode JSON for data-attribute
  const _encJson = (obj) => encodeURIComponent(JSON.stringify(obj || {}));

  // ✅ safe parse date
  function _parseDate(s){
    const d = new Date(_safeStr(s));
    return isNaN(d.getTime()) ? null : d;
  }

  function _getYearMonth(createdAt){
    const d = _parseDate(createdAt);
    if (!d) return { year: 0, month: 0 };
    return { year: d.getFullYear(), month: d.getMonth() + 1 };
  }

  const MONTHS = [
    { n: 1,  key: "jan", label: "January" },
    { n: 2,  key: "feb", label: "February" },
    { n: 3,  key: "mar", label: "March" },
    { n: 4,  key: "apr", label: "April" },
    { n: 5,  key: "may", label: "May" },
    { n: 6,  key: "jun", label: "June" },
    { n: 7,  key: "jul", label: "July" },
    { n: 8,  key: "aug", label: "August" },
    { n: 9,  key: "sep", label: "September" },
    { n: 10, key: "oct", label: "October" },
    { n: 11, key: "nov", label: "November" },
    { n: 12, key: "dec", label: "December" }
  ];

  const IS_SINGLE_ADMISSION_VIEW = !!admissionId;
  const FAMILY_NUMBER = _safeStr(typeof familyNumber !== 'undefined' ? familyNumber : '').trim();
  const FAMILY_ADMISSION_IDS = Array.isArray(typeof familyAdmissionIds !== 'undefined' ? familyAdmissionIds : null)
    ? familyAdmissionIds
    : [];

  const IS_FAMILY_VIEW = !!(IS_SINGLE_ADMISSION_VIEW && FAMILY_NUMBER);
  const FAMILY_COUNT = FAMILY_ADMISSION_IDS.length || 0;

  // Role flags (for delete routing)
  const _isSuper =
    !!(user && (
      user.role === 'super_admin' ||
      user.role === 'superadmin' ||
      user.agentType === 'super_admin' ||
      user.agentType === 'superadmin' ||
      user.isSuperAdmin === true ||
      user.is_super_admin === true
    ));

  // Perms
  let _perms =
    (typeof perms !== "undefined" && perms)
      ? perms
      : ((user && (user.permissions || user.perms || user.permission || user.permissionMap)) || null);

  try { if (typeof _perms === 'string') _perms = JSON.parse(_perms); } catch(e) {}

  function _canDeleteFiles() {
    if (_isSuper) return true;
    if (!_perms) return false;
    if (Array.isArray(_perms)) return _perms.includes("canDeleteFiles");
    if (typeof _perms === "object") return !!_perms.canDeleteFiles;
    return false;
  }

  function _canUploadFiles() {
    if (_isSuper) return true;
    if (!_perms) return false;

    if (Array.isArray(_perms)) {
      return _perms.includes("btnUpload") ||
             _perms.includes("btnUploadFiles") ||
             _perms.includes("canUploadFiles") ||
             _perms.includes("uploadFiles") ||
             _perms.includes("canUpload");
    }

    if (typeof _perms === "object") {
      return !!(_perms.btnUpload ||
                _perms.btnUploadFiles ||
                _perms.canUploadFiles ||
                _perms.uploadFiles ||
                _perms.canUpload);
    }

    return false;
  }

  const ALLOW_DELETE = _canDeleteFiles();
  const ALLOW_UPLOAD_URL = _canUploadFiles();

  const filesList = files || [];

  // ✅ Build Year -> Month counts (for folder UI)
  const yearMap = {};
  (filesList || []).forEach(f => {
    const created = _safeStr(f.created_at);
    const ym = _getYearMonth(created);
    if (!ym.year || !ym.month) return;

    if (!yearMap[ym.year]) yearMap[ym.year] = { total: 0, months: {} };
    if (!yearMap[ym.year].months[ym.month]) yearMap[ym.year].months[ym.month] = 0;

    yearMap[ym.year].total += 1;
    yearMap[ym.year].months[ym.month] += 1;
  });

  const years = Object.keys(yearMap).map(n => parseInt(n, 10)).filter(Boolean).sort((a,b)=>b-a);

  // current year/month (for uploads default folder)
  const _now = new Date();
  const CURRENT_YEAR = _now.getFullYear();
  const CURRENT_MONTH = _now.getMonth() + 1;
%>

