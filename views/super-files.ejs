<script>
  (function () {
    const grid = document.getElementById("vfGrid");
    const listWrap = document.getElementById("vfListWrap");
    const countBadge = document.getElementById("vfCountBadge");
    const countBadge2 = document.getElementById("vfCountBadge2");
    const toolbar = document.getElementById("vfToolbar");
    const monthHeader = document.getElementById("vfMonthHeader");
    const monthHeaderText = document.getElementById("vfMonthHeaderText");
    const emptyMonth = document.getElementById("vfEmptyMonth");
    const stageHint = document.getElementById("vfStageHint");

    const yearsView = document.getElementById("vfYearsView");
    const monthsView = document.getElementById("vfMonthsView");

    const crumbRoot = document.getElementById("vfCrumbRoot");
    const crumbYear = document.getElementById("vfCrumbYear");
    const crumbMonth = document.getElementById("vfCrumbMonth");
    const sep1 = document.getElementById("vfCrumbSep1");
    const sep2 = document.getElementById("vfCrumbSep2");

    const elSearch = document.getElementById("vfSearch");
    const elAdmission = document.getElementById("vfAdmission");
    const elStudent = document.getElementById("vfStudent");
    const elType = document.getElementById("vfType");
    const elDatePreset = document.getElementById("vfDatePreset");
    const elFromWrap = document.getElementById("vfFromWrap");
    const elToWrap = document.getElementById("vfToWrap");
    const elFrom = document.getElementById("vfFrom");
    const elTo = document.getElementById("vfTo");
    const elSort = document.getElementById("vfSort");
    const elView = document.getElementById("vfView");
    const elClear = document.getElementById("vfClear");

    const gridItems = Array.from(document.querySelectorAll(".vf-col"));
    const listRows = Array.from(document.querySelectorAll("#vfListBody tr"));

    let selectedYear = null;
    let selectedMonth = null;

    const VIEW_KEY = "vfViewMode::super-files";
    function getSavedView() {
      try { return localStorage.getItem(VIEW_KEY) || ""; } catch(e) { return ""; }
    }
    function saveView(v) {
      try { localStorage.setItem(VIEW_KEY, v); } catch(e) {}
    }

    function applyViewMode(mode) {
      if (mode === "list") {
        if (grid) grid.classList.add("vf-hidden");
        if (listWrap) listWrap.classList.remove("vf-hidden");
      } else {
        if (listWrap) listWrap.classList.add("vf-hidden");
        if (grid) grid.classList.remove("vf-hidden");
      }

      function setCols(cls) {
        gridItems.forEach(item => {
          const toRemove = Array.from(item.classList).filter(c => c.startsWith("col-"));
          toRemove.forEach(c => item.classList.remove(c));
          cls.split(' ').forEach(c => item.classList.add(c));
        });
      }

      if (mode === "lg") setCols("col-12 col-sm-6 col-lg-4");
      else if (mode === "md") setCols("col-12 col-sm-6 col-md-4 col-lg-3");
      else if (mode === "sm") setCols("col-12 col-sm-6 col-md-3 col-lg-2");
    }

    function parseAnyDate(s) {
      if (!s) return null;
      const d = new Date(s);
      if (!isNaN(d.getTime())) return d;
      return null;
    }

    function inDateRange(dateObj, preset, fromStr, toStr) {
      if (!preset) return true;
      const now = new Date();
      if (!dateObj) return false;

      if (preset === "today") return dateObj.toDateString() === now.toDateString();
      if (preset === "month") return dateObj.getFullYear() === now.getFullYear() && dateObj.getMonth() === now.getMonth();
      if (preset === "year") return dateObj.getFullYear() === now.getFullYear();

      if (preset === "custom") {
        const from = fromStr ? new Date(fromStr + "T00:00:00") : null;
        const to = toStr ? new Date(toStr + "T23:59:59") : null;
        if (from && dateObj < from) return false;
        if (to && dateObj > to) return false;
        return true;
      }
      return true;
    }

    function matchesText(haystack, needle) {
      if (!needle) return true;
      return (haystack || "").includes(needle);
    }

    function matchType(itemType, filterType) {
      if (!filterType) return true;
      return itemType === filterType;
    }

    function matchFolder(y, m, selY, selM) {
      if (!selY) return true;
      if (Number(y) !== Number(selY)) return false;
      if (!selM) return true;
      return Number(m) === Number(selM);
    }

    function getFilters() {
      return {
        q: ((elSearch && elSearch.value) || "").toLowerCase().trim(),
        admission: ((elAdmission && elAdmission.value) || "").toLowerCase().trim(),
        student: ((elStudent && elStudent.value) || "").toLowerCase().trim(),
        type: (elType && elType.value || "").toLowerCase().trim(),
        datePreset: (elDatePreset && elDatePreset.value || "").toLowerCase().trim(),
        from: ((elFrom && elFrom.value) || "").trim(),
        to: ((elTo && elTo.value) || "").trim(),
      };
    }

    function setCount(n) {
      if (countBadge) countBadge.textContent = "Showing: " + n;
      if (countBadge2) countBadge2.textContent = "Showing: " + n;
    }

    function applyFilters() {
      const f = getFilters();
      let visible = 0;

      gridItems.forEach(item => {
        const name = item.getAttribute("data-name") || "";
        const student = item.getAttribute("data-student") || "";
        const admission = item.getAttribute("data-admission") || "";
        const family = item.getAttribute("data-family") || "";
        const type = item.getAttribute("data-type") || "";
        const dateRaw = item.getAttribute("data-date") || "";
        const dateObj = parseAnyDate(dateRaw);

        const y = item.getAttribute("data-year") || "0";
        const m = item.getAttribute("data-month") || "0";

        const ok =
          matchFolder(y, m, selectedYear, selectedMonth) &&
          (
            matchesText(name, f.q) ||
            matchesText(type, f.q) ||
            matchesText(student, f.q) ||
            matchesText(admission, f.q) ||
            matchesText(family, f.q)
          ) &&
          matchesText(admission, f.admission) &&
          matchesText(student, f.student) &&
          matchType(type, f.type) &&
          inDateRange(dateObj, f.datePreset, f.from, f.to);

        item.style.display = ok ? "" : "none";
        if (ok) visible++;
      });

      listRows.forEach(row => {
        const name = row.getAttribute("data-name") || "";
        const student = row.getAttribute("data-student") || "";
        const admission = row.getAttribute("data-admission") || "";
        const family = row.getAttribute("data-family") || "";
        const type = row.getAttribute("data-type") || "";
        const dateRaw = row.getAttribute("data-date") || "";
        const dateObj = parseAnyDate(dateRaw);

        const y = row.getAttribute("data-year") || "0";
        const m = row.getAttribute("data-month") || "0";

        const ok =
          matchFolder(y, m, selectedYear, selectedMonth) &&
          (
            matchesText(name, f.q) ||
            matchesText(type, f.q) ||
            matchesText(student, f.q) ||
            matchesText(admission, f.q) ||
            matchesText(family, f.q)
          ) &&
          matchesText(admission, f.admission) &&
          matchesText(student, f.student) &&
          matchType(type, f.type) &&
          inDateRange(dateObj, f.datePreset, f.from, f.to);

        row.style.display = ok ? "" : "none";
      });

      setCount(visible);

      if (emptyMonth) {
        const showEmpty = !!selectedYear && !!selectedMonth && visible === 0;
        emptyMonth.classList.toggle("vf-hidden", !showEmpty);
      }
    }

    function sortItems() {
      const mode = (elSort && elSort.value || "new").toLowerCase().trim();

      function keyFor(el) {
        const name = el.getAttribute("data-name") || "";
        const dateRaw = el.getAttribute("data-date") || "";
        const dateObj = parseAnyDate(dateRaw);
        const ts = dateObj ? dateObj.getTime() : 0;
        return { name, ts };
      }

      const gridSorted = gridItems.slice().sort((a, b) => {
        const ka = keyFor(a), kb = keyFor(b);
        if (mode === "old") return ka.ts - kb.ts;
        if (mode === "name_az") return ka.name.localeCompare(kb.name);
        if (mode === "name_za") return kb.name.localeCompare(ka.name);
        return kb.ts - ka.ts;
      });
      if (grid) gridSorted.forEach(el => grid.appendChild(el));

      const listSorted = listRows.slice().sort((a, b) => {
        const ka = keyFor(a), kb = keyFor(b);
        if (mode === "old") return ka.ts - kb.ts;
        if (mode === "name_az") return ka.name.localeCompare(kb.name);
        if (mode === "name_za") return kb.name.localeCompare(ka.name);
        return kb.ts - ka.ts;
      });
      const tbody = document.getElementById("vfListBody");
      if (tbody) listSorted.forEach(el => tbody.appendChild(el));
    }

    function updateDatePresetUi() {
      const preset = (elDatePreset && elDatePreset.value || "").toLowerCase().trim();
      const showCustom = preset === "custom";
      if (elFromWrap) elFromWrap.classList.toggle("vf-hidden", !showCustom);
      if (elToWrap) elToWrap.classList.toggle("vf-hidden", !showCustom);
      applyFilters();
    }

    function clearAll() {
      if (elSearch) elSearch.value = "";
      if (elAdmission) elAdmission.value = "";
      if (elStudent) elStudent.value = "";
      if (elType) elType.value = "";
      if (elDatePreset) elDatePreset.value = "";
      if (elFrom) elFrom.value = "";
      if (elTo) elTo.value = "";
      if (elSort) elSort.value = "new";

      if (elView) {
        elView.value = "md";
        saveView("md");
        applyViewMode("md");
      }

      updateDatePresetUi();
      sortItems();
      applyFilters();
    }

    const YEAR_DATA = <%- JSON.stringify(yearMap || {}) %>;
    const MONTHS = <%- JSON.stringify(MONTHS || []) %>;

    function labelOfMonth(m){
      const mm = MONTHS.find(x => Number(x.n) === Number(m));
      return mm ? mm.label : ("Month " + m);
    }

    function setCrumbs(y, m) {
      if (!crumbYear || !crumbMonth || !sep1 || !sep2) return;

      crumbRoot.classList.toggle("active", !y);

      if (!y) {
        crumbYear.style.display = "none";
        crumbMonth.style.display = "none";
        sep1.style.display = "none";
        sep2.style.display = "none";
        return;
      }

      crumbYear.style.display = "";
      crumbYear.textContent = " " + y;
      crumbYear.setAttribute("data-crumb-year", String(y));
      crumbYear.classList.toggle("active", !!y && !m);
      sep1.style.display = "";

      if (!m) {
        crumbMonth.style.display = "none";
        sep2.style.display = "none";
        return;
      }

      crumbMonth.style.display = "";
      crumbMonth.textContent = " " + labelOfMonth(m);
      crumbMonth.setAttribute("data-crumb-month", String(m));
      crumbMonth.classList.add("active");
      sep2.style.display = "";
    }

    function showDataArea(show) {
      if (!toolbar) return;
      toolbar.classList.toggle("vf-hidden", !show);
      if (monthHeader) monthHeader.classList.toggle("vf-hidden", !show);

      if (show) {
        const v = (elView && elView.value || "md").toLowerCase().trim();
        if (v === "list") {
          if (grid) grid.classList.add("vf-hidden");
          if (listWrap) listWrap.classList.remove("vf-hidden");
        } else {
          if (listWrap) listWrap.classList.add("vf-hidden");
          if (grid) grid.classList.remove("vf-hidden");
        }
      } else {
        if (grid) grid.classList.add("vf-hidden");
        if (listWrap) listWrap.classList.add("vf-hidden");
        if (emptyMonth) emptyMonth.classList.add("vf-hidden");
      }
    }

    function showYears() {
      selectedYear = null;
      selectedMonth = null;
      setCrumbs(null, null);

      if (yearsView) yearsView.classList.remove("vf-hidden");
      if (monthsView) monthsView.classList.add("vf-hidden");

      if (stageHint) stageHint.classList.remove("vf-hidden");
      showDataArea(false);
      setCount(0);
    }

    function showMonths(y) {
      selectedYear = Number(y);
      selectedMonth = null;
      setCrumbs(selectedYear, null);

      const yearInfo = YEAR_DATA[String(selectedYear)] || { months: {} };

      MONTHS.forEach(m => {
        const c = Number((yearInfo.months || {})[String(m.n)] || 0);
        const el = document.getElementById("vfMonthCount_" + m.n);
        if (el) el.textContent = "Total: " + c;

        const card = document.querySelector('[data-open-month="' + m.n + '"]');
        if (card) {
          card.classList.toggle("disabled", c === 0);
          card.setAttribute("data-month-count", String(c));
        }
      });

      if (yearsView) yearsView.classList.add("vf-hidden");
      if (monthsView) monthsView.classList.remove("vf-hidden");

      if (stageHint) stageHint.classList.remove("vf-hidden");
      showDataArea(false);
      setCount(0);
    }

    function openMonth(m) {
      selectedMonth = Number(m);
      setCrumbs(selectedYear, selectedMonth);

      if (monthHeaderText) monthHeaderText.textContent = `${selectedYear} / ${labelOfMonth(selectedMonth)} — Uploaded Files`;

      if (stageHint) stageHint.classList.add("vf-hidden");

      showDataArea(true);
      sortItems();
      applyFilters();

      try {
        if (monthHeader) monthHeader.scrollIntoView({ behavior: "smooth", block: "start" });
      } catch(e){}
    }

    const saved = getSavedView();
    if (saved && elView) elView.value = saved;

    applyViewMode((elView && elView.value || "md").toLowerCase().trim());
    updateDatePresetUi();
    sortItems();

    const IS_SINGLE_ADMISSION_VIEW = <%- JSON.stringify(!!IS_SINGLE_ADMISSION_VIEW) %>;
    if (IS_SINGLE_ADMISSION_VIEW) {
      if (stageHint) stageHint.classList.add("vf-hidden");
      if (yearsView) yearsView.classList.add("vf-hidden");
      if (monthsView) monthsView.classList.add("vf-hidden");
      setCrumbs(null, null);
      showDataArea(true);
      selectedYear = null;
      selectedMonth = null;
      sortItems();
      applyFilters();

      const IS_FAMILY_VIEW = <%- JSON.stringify(!!IS_FAMILY_VIEW) %>;
      const FAMILY_NUMBER = <%- JSON.stringify(FAMILY_NUMBER || "") %>;
      const FAMILY_COUNT = <%- JSON.stringify(FAMILY_COUNT || 0) %>;

      if (monthHeaderText) {
        monthHeaderText.textContent = IS_FAMILY_VIEW
          ? `Family Files · Family # ${FAMILY_NUMBER} · ${FAMILY_COUNT} Admissions`
          : `Admission ID Files`;
      }
    } else {
      showYears();
    }

    document.addEventListener("click", (e) => {
      const yBtn = e.target.closest("[data-open-year]");
      if (yBtn) {
        const y = yBtn.getAttribute("data-open-year");
        if (y) showMonths(y);
        return;
      }

      const mBtn = e.target.closest("[data-open-month]");
      if (mBtn) {
        const cnt = Number(mBtn.getAttribute("data-month-count") || "0");
        if (cnt === 0) return;
        const m = mBtn.getAttribute("data-open-month");
        if (m) openMonth(m);
        return;
      }
    });

    if (crumbRoot) crumbRoot.addEventListener("click", showYears);
    if (crumbYear) crumbYear.addEventListener("click", () => {
      const y = crumbYear.getAttribute("data-crumb-year");
      if (y) showMonths(y);
    });

    if (elSearch) elSearch.addEventListener("input", applyFilters);
    if (elAdmission) elAdmission.addEventListener("input", applyFilters);
    if (elStudent) elStudent.addEventListener("input", applyFilters);

    if (elType) elType.addEventListener("change", applyFilters);
    if (elDatePreset) elDatePreset.addEventListener("change", updateDatePresetUi);
    if (elFrom) elFrom.addEventListener("change", applyFilters);
    if (elTo) elTo.addEventListener("change", applyFilters);

    if (elSort) elSort.addEventListener("change", () => { sortItems(); applyFilters(); });

    if (elView) elView.addEventListener("change", () => {
      const v = (elView.value || "md").toLowerCase().trim();
      saveView(v);
      applyViewMode(v);
      applyFilters();
    });

    if (elClear) elClear.addEventListener("click", clearAll);

    document.addEventListener("keydown", (e) => {
      if (e.key !== "Enter") return;
      const active = document.activeElement;
      if (!active) return;

      if (active.hasAttribute("data-open-year")) {
        const y = active.getAttribute("data-open-year");
        if (y) showMonths(y);
      }
      if (active.hasAttribute("data-open-month")) {
        const cnt = Number(active.getAttribute("data-month-count") || "0");
        if (cnt === 0) return;
        const m = active.getAttribute("data-open-month");
        if (m) openMonth(m);
      }
    });
  })();
</script>

<script>
  (function () {
    const overlay = document.getElementById("url-upload-overlay");
    const successOverlay = document.getElementById("url-success-overlay");
    const btnOpen = document.getElementById("btnUploadUrl");
    const btnCancel = document.getElementById("url-cancel");
    const btnSave = document.getElementById("url-save");
    const btnCloseX = document.getElementById("url-close-x");
    const btnSuccessOk = document.getElementById("url-success-ok");

    const inputName = document.getElementById("urlName");
    const inputSummary = document.getElementById("urlSummary");
    const inputLink = document.getElementById("urlLink");

    if (!overlay || !btnOpen || !btnCancel || !btnSave || !inputName || !inputSummary || !inputLink) return;

    const CURRENT_USER = <%- JSON.stringify(user || null) %>;
    const ADMISSION_ID = <%- JSON.stringify(admissionId || null) %>;
    const CURRENT_YEAR = <%- JSON.stringify(CURRENT_YEAR) %>;
    const CURRENT_MONTH = <%- JSON.stringify(CURRENT_MONTH) %>;

    function getRoleKey(u) {
      if (!u) return "guest";
      const r = (u.role || "").toLowerCase();
      const t = (u.agentType || "").toLowerCase();

      if (r === "super_admin" || r === "superadmin" || t === "super_admin" || t === "superadmin") return "super";
      if (r === "admin") return "admin";
      if (r === "agent") return "agent";
      if (r === "sub_agent" || r === "sub-agent" || r === "subagent") return "sub_agent";
      return "other";
    }

    const URL_POST_ENDPOINTS = {
      super: "/dashboard/super/files/link",
      admin: "/dashboard/admin/files/link",
      agent: "/dashboard/agent/files/link",
      sub_agent: "/dashboard/sub-agent/files/link"
    };

    function closeOverlay(ov) {
      ov.classList.add("fade-out");
      setTimeout(() => {
        ov.classList.add("d-none");
        ov.classList.remove("fade-out");
      }, 260);
    }

    function openOverlay() {
      inputName.value = "";
      inputSummary.value = "";
      inputLink.value = "";
      overlay.classList.remove("d-none");
      setTimeout(() => inputName.focus(), 100);
    }

    btnOpen.addEventListener("click", openOverlay);
    btnCancel.addEventListener("click", () => closeOverlay(overlay));
    if (btnCloseX) btnCloseX.addEventListener("click", () => closeOverlay(overlay));

    if (btnSuccessOk) btnSuccessOk.addEventListener("click", () => {
      closeOverlay(successOverlay);
      window.location.reload();
    });

    btnSave.addEventListener("click", async () => {
      const name = (inputName.value || "").trim();
      const summary = (inputSummary.value || "").trim();
      let link = (inputLink.value || "").trim();

      if (!name) return alert("Name required hai.");
      if (!link) return alert("Link required hai.");

      if (!/^https?:\/\//i.test(link)) link = "https://" + link;

      try {
        btnSave.disabled = true;

        const roleKey = getRoleKey(CURRENT_USER);
        const url = URL_POST_ENDPOINTS[roleKey];

        if (!url) {
          alert("Your role is not allowed to upload URL.");
          btnSave.disabled = false;
          return;
        }

        const payload = {
          name,
          summary,
          link,
          admission_id: ADMISSION_ID,
          folder_year: CURRENT_YEAR,
          folder_month: CURRENT_MONTH
        };

        const res = await fetch(url, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });

        const data = await res.json().catch(() => ({}));

        if (!res.ok || !data.success) {
          alert((data && data.message) || "URL save failed");
          btnSave.disabled = false;
          return;
        }

        closeOverlay(overlay);
        successOverlay.classList.remove("d-none");

      } catch (e) {
        console.error(e);
        alert("URL save failed");
      } finally {
        btnSave.disabled = false;
      }
    });
  })();
</script>

<script>
  (function () {
    const overlay = document.getElementById("url-edit-overlay");
    const successOverlay = document.getElementById("url-success-overlay");

    const btnCancel = document.getElementById("url-edit-cancel");
    const btnSave = document.getElementById("url-edit-save");
    const btnCloseX = document.getElementById("url-edit-close-x");
    const btnSuccessOk = document.getElementById("url-success-ok");

    const inputId = document.getElementById("urlEditId");
    const inputName = document.getElementById("urlEditName");
    const inputSummary = document.getElementById("urlEditSummary");
    const inputLink = document.getElementById("urlEditLink");

    if (!overlay || !btnCancel || !btnSave || !inputId || !inputName || !inputSummary || !inputLink) return;

    const CURRENT_USER = <%- JSON.stringify(user || null) %>;
    const ADMISSION_ID = <%- JSON.stringify(admissionId || null) %>;
    const CURRENT_YEAR = <%- JSON.stringify(CURRENT_YEAR) %>;
    const CURRENT_MONTH = <%- JSON.stringify(CURRENT_MONTH) %>;

    function getRoleKey(u) {
      if (!u) return "guest";
      const r = (u.role || "").toLowerCase();
      const t = (u.agentType || "").toLowerCase();

      if (r === "super_admin" || r === "superadmin" || t === "super_admin" || t === "superadmin") return "super";
      if (r === "admin") return "admin";
      if (r === "agent") return "agent";
      if (r === "sub_agent" || r === "sub-agent" || r === "subagent") return "sub_agent";
      return "other";
    }

    const URL_EDIT_ENDPOINTS = {
      super: "/dashboard/super/files/link/",
      admin: "/dashboard/admin/files/link/",
      agent: "/dashboard/agent/files/link/",
      sub_agent: "/dashboard/sub-agent/files/link/"
    };

    function closeOverlay(ov) {
      ov.classList.add("fade-out");
      setTimeout(() => {
        ov.classList.add("d-none");
        ov.classList.remove("fade-out");
      }, 260);
    }

    function openEdit(payload) {
      inputId.value = payload.id || "";
      inputName.value = payload.name || "";
      inputSummary.value = payload.summary || "";
      inputLink.value = payload.link || "";

      overlay.classList.remove("d-none");
      setTimeout(() => inputName.focus(), 100);
    }

    btnCancel.addEventListener("click", () => closeOverlay(overlay));
    if (btnCloseX) btnCloseX.addEventListener("click", () => closeOverlay(overlay));
    if (btnSuccessOk) btnSuccessOk.addEventListener("click", () => {
      closeOverlay(successOverlay);
      window.location.reload();
    });

    document.addEventListener("click", (e) => {
      const btn = e.target.closest("[data-edit-url]");
      if (!btn) return;

      const raw = btn.getAttribute("data-url-json") || "";
      let payload = null;

      try {
        payload = JSON.parse(decodeURIComponent(raw));
      } catch (err) {
        console.error(err);
        alert("Edit data invalid");
        return;
      }

      if (!payload || !payload.id) {
        alert("Invalid item");
        return;
      }

      openEdit(payload);
    });

    btnSave.addEventListener("click", async () => {
      const id = (inputId.value || "").trim();
      const name = (inputName.value || "").trim();
      const summary = (inputSummary.value || "").trim();
      let link = (inputLink.value || "").trim();

      if (!id) return alert("Invalid item id.");
      if (!name) return alert("Name required hai.");
      if (!link) return alert("Link required hai.");

      if (!/^https?:\/\//i.test(link)) link = "https://" + link;

      const roleKey = getRoleKey(CURRENT_USER);
      const baseUrl = URL_EDIT_ENDPOINTS[roleKey];

      if (!baseUrl) {
        alert("Your role is not allowed to edit URL.");
        return;
      }

      try {
        btnSave.disabled = true;

        const payload = {
          name,
          summary,
          link,
          admission_id: ADMISSION_ID,
          folder_year: CURRENT_YEAR,
          folder_month: CURRENT_MONTH
        };

        const res = await fetch(baseUrl + encodeURIComponent(id) + "/edit", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });

        const data = await res.json().catch(() => ({}));

        if (!res.ok || !data.success) {
          alert((data && data.message) || "URL update failed");
          btnSave.disabled = false;
          return;
        }

        closeOverlay(overlay);
        successOverlay.classList.remove("d-none");

      } catch (err) {
        console.error(err);
        alert("URL update failed");
      } finally {
        btnSave.disabled = false;
      }
    });
  })();
</script>

<script>
  (function () {
    const confirmOverlay = document.getElementById("file-delete-overlay");
    const successOverlay = document.getElementById("file-success-overlay");

    const btnCancel = document.getElementById("file-delete-cancel");
    const btnOk = document.getElementById("file-delete-ok");
    const btnSuccessOk = document.getElementById("file-success-ok");

    if (!confirmOverlay || !successOverlay || !btnCancel || !btnOk || !btnSuccessOk) return;

    const CURRENT_USER = <%- JSON.stringify(user || null) %>;
    const ALLOW_DELETE = <%- JSON.stringify(!!ALLOW_DELETE) %>;

    function isSuperUser(u) {
      if (!u) return false;
      return (
        u.role === "super_admin" ||
        u.role === "superadmin" ||
        u.agentType === "super_admin" ||
        u.agentType === "superadmin" ||
        u.isSuperAdmin === true ||
        u.is_super_admin === true
      );
    }

    let pendingId = null;

    function closeOverlay(overlay) {
      overlay.classList.add("fade-out");
      setTimeout(() => {
        overlay.classList.add("d-none");
        overlay.classList.remove("fade-out");
      }, 260);
    }

    function openConfirm(id) {
      pendingId = id;
      confirmOverlay.classList.remove("d-none");
    }

    btnCancel.addEventListener("click", () => {
      pendingId = null;
      closeOverlay(confirmOverlay);
    });

    btnOk.addEventListener("click", async () => {
      if (!pendingId) return;

      if (!ALLOW_DELETE) {
        alert("You do not have permission to delete files.");
        pendingId = null;
        closeOverlay(confirmOverlay);
        return;
      }

      try {
        const url = isSuperUser(CURRENT_USER)
          ? `/dashboard/super/files/${pendingId}`
          : `/files/${pendingId}`;

        const res = await fetch(url, { method: "DELETE" });
        const data = await res.json().catch(() => ({}));

        if (!res.ok || !data.success) {
          alert((data && data.message) || "Delete failed");
          return;
        }

        const card = document.getElementById(`fileCard_${pendingId}`);
        if (card) card.remove();

        const row = document.getElementById(`fileRow_${pendingId}`);
        if (row) row.remove();

        closeOverlay(confirmOverlay);
        successOverlay.classList.remove("d-none");
        pendingId = null;

      } catch (e) {
        console.error(e);
        alert("Delete failed");
      }
    });

    btnSuccessOk.addEventListener("click", () => closeOverlay(successOverlay));

    document.addEventListener("click", (e) => {
      const btn = e.target.closest("[data-delete-id]");
      if (!btn) return;
      const id = btn.getAttribute("data-delete-id");
      openConfirm(id);
    });
  })();
</script>

