      <% if (!IS_SINGLE_ADMISSION_VIEW) { %>
        <div class="col-12 col-md-5">
          <label class="form-label small mb-1">Search (file / student / id)</label>
          <div class="input-group">
            <span class="input-group-text bg-white border-0" style="border-radius:14px 0 0 14px; border:1px solid rgba(15,23,42,.12); min-height:44px;">
              <i class="bi bi-search"></i>
            </span>
            <input id="vfSearch" type="text" class="form-control vf-input"
