      <div class="col-6 col-md-3">
        <label class="form-label small mb-1">Type</label>
        <select id="vfType" class="form-select vf-select">
          <option value="">All</option>
          <option value="image">Images</option>
          <option value="pdf">PDF</option>
          <option value="doc">Docs</option>
          <option value="xls">Sheets</option>
          <option value="link">Links</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div class="col-6 col-md-2">
        <label class="form-label small mb-1">Date</label>
        <select id="vfDatePreset" class="form-select vf-select">
          <option value="">All time</option>
          <option value="today">Today</option>
          <option value="month">This month</option>
          <option value="year">This year</option>
          <option value="custom">Custom</option>
        </select>
      </div>

      <div class="col-6 col-md-2 vf-hidden" id="vfFromWrap">
        <label class="form-label small mb-1">From</label>
        <input id="vfFrom" type="date" class="form-control vf-input">
      </div>

      <div class="col-6 col-md-2 vf-hidden" id="vfToWrap">
        <label class="form-label small mb-1">To</label>
        <input id="vfTo" type="date" class="form-control vf-input">
      </div>

      <div class="col-6 col-md-2">
        <label class="form-label small mb-1">Sort</label>
        <select id="vfSort" class="form-select vf-select">
          <option value="new">Newest first</option>
          <option value="old">Oldest first</option>
          <option value="name_az">Name A → Z</option>
          <option value="name_za">Name Z → A</option>
        </select>
      </div>

      <div class="col-6 col-md-3">
        <label class="form-label small mb-1">View</label>
        <div class="d-flex gap-2 flex-wrap">
          <select id="vfView" class="form-select vf-select" style="max-width: 230px;">
            <option value="lg">Large</option>
            <option value="md" selected>Medium</option>
            <option value="sm">Small</option>
            <option value="list">List</option>
          </select>

          <button id="vfClear" type="button" class="btn btn-sm btn-outline-secondary vf-viewbtn">
            <i class="bi bi-x-circle me-1"></i> Clear
          </button>
        </div>
      </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
      <div class="small text-muted" id="vfTipLine">
        Tip: Filters sirf selected month ke data par apply hongay.
      </div>
      <div class="small">
        <span class="vf-fileBadge" id="vfCountBadge2">Showing: <%= filesList.length %></span>
      </div>
    </div>
  </div>

  <div class="vf-empty mt-3 text-center vf-hidden" id="vfEmptyMonth">
    <div class="mb-2">
      <i class="bi bi-folder-x fs-1 text-muted"></i>
    </div>
    <div class="fw-semibold">No files found in this month.</div>
    <div class="text-muted small">Try another month, or clear filters.</div>
  </div>

  <% if (user && user.role === "super_admin") { %>
    <div class="vf-super-danger">
      <div class="vf-super-danger-row">
        <span class="vf-danger-note">Danger action for all uploaded files</span>

        <form id="deleteAllFilesForm" method="POST" action="/dashboard/super/files/delete-all" style="display:inline-block;">
          <button id="btnDeleteAllFiles" type="button" class="btn btn-danger btn-sm vf-delete-all-btn">
            <i class="bi bi-trash3 me-1"></i> Delete All Files
          </button>
        </form>
      </div>
    </div>
  <% } %>

  <div id="vfGrid" class="row g-3 vf-grid vf-hidden">
    <% (filesList || []).forEach((f, idx) => {
      const name = (f.original_name || f.name || f.title || 'File');
      const summary = _safeStr(f.summary || f.description || f.note || '');
      const mime = f.mime_type || '';
      const isLink = _isLinkItem(f);

      const href = _fileHref(f);

      let typeKey = 'other';
      const isImg = (!isLink) && _isImg(mime);
      const ext = _ext(name);

      if (isLink) typeKey = 'link';
      else if (isImg) typeKey = 'image';
      else if (ext === 'pdf') typeKey = 'pdf';
      else if (['doc','docx'].includes(ext)) typeKey = 'doc';
      else if (['xls','xlsx','csv'].includes(ext)) typeKey = 'xls';

      const student = _safeStr(f.student_name);
      const created = _safeStr(f.created_at);
      const linkedAdmissionId = _safeStr(f.linked_admission_id || f.admission_id);
      const linkedFamilyNumber = _safeStr(f.family_number || FAMILY_NUMBER);

      const ym = _getYearMonth(created);

      const dsName = _lower(name);
      const dsStudent = _lower(student);
      const dsAdmission = _lower(linkedAdmissionId);
      const dsType = typeKey;
      const dsDate = created;
      const dsFamily = _lower(linkedFamilyNumber);

      const editPayload = {
        id: f.id,
        name: name,
        summary: summary,
        link: href
      };

      const typeBadgeClass =
        typeKey === 'image' ? 'vf-type-image' :
        typeKey === 'pdf'   ? 'vf-type-pdf'   :
        typeKey === 'doc'   ? 'vf-type-doc'   :
        typeKey === 'xls'   ? 'vf-type-xls'   :
        typeKey === 'link'  ? 'vf-type-link'  :
                              'vf-type-other';

      const ribbonClass = ['family-a','family-b','family-c','family-d','family-e','family-f'][idx % 6];
    %>

      <div class="col-12 col-sm-6 col-md-4 col-lg-3 vf-col"
           id="fileCard_<%= f.id %>"
           data-name="<%= dsName %>"
           data-student="<%= dsStudent %>"
           data-admission="<%= dsAdmission %>"
           data-family="<%= dsFamily %>"
           data-type="<%= dsType %>"
           data-date="<%= dsDate %>"
           data-year="<%= ym.year %>"
           data-month="<%= ym.month %>">

        <div class="vf-card h-100">
          <div class="vf-card-topglow"></div>

          <% if (linkedFamilyNumber) { %>
            <div class="vf-family-ribbon <%= ribbonClass %>">Family # <%= linkedFamilyNumber %></div>
          <% } %>

          <div class="p-3">
            <div class="d-flex justify-content-between align-items-start gap-2">
              <div class="small vf-name" title="<%= name %>">
                <%= name %>
              </div>

              <span class="vf-fileBadge text-uppercase <%= typeBadgeClass %>">
                <%= (typeKey === 'link' ? 'LINK' : (isImg ? 'IMG' : (ext ? ext : 'FILE'))) %>
              </span>
            </div>

            <% if (summary) { %>
              <div class="text-muted small mt-1" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                <i class="bi bi-card-text me-1"></i><%= summary %>
              </div>
            <% } %>

            <div class="text-muted small mb-2 mt-2">
              <i class="bi bi-clock me-1"></i><%= _fmtDate(created) %>
            </div>

            <div class="vf-thumb mb-3">
              <% if (isImg && href) { %>
                <img src="<%= href %>" alt="preview">
              <% } else { %>
                <div class="text-center">
                  <div class="mb-1">
                    <% if (typeKey === 'link') { %>
                      <i class="bi bi-link-45deg fs-1 text-primary"></i>
                    <% } else if (ext === 'pdf') { %>
                      <i class="bi bi-file-earmark-pdf fs-1 text-danger"></i>
                    <% } else if (['doc','docx'].includes(ext)) { %>
                      <i class="bi bi-file-earmark-word fs-1 text-primary"></i>
                    <% } else if (['xls','xlsx','csv'].includes(ext)) { %>
                      <i class="bi bi-file-earmark-excel fs-1 text-success"></i>
                    <% } else { %>
                      <i class="bi bi-file-earmark fs-1 text-muted"></i>
                    <% } %>
                  </div>
                  <div class="text-muted small">Preview not available</div>
                </div>
              <% } %>
            </div>

            <div class="d-flex gap-2 flex-wrap vf-actions">
              <a class="btn btn-sm vf-btn-open px-3"
                 href="<%= href || '#' %>" target="_blank" rel="noopener">
                <i class="bi bi-box-arrow-up-right"></i><span>Open</span>
              </a>

              <% if (typeKey !== 'link') { %>
                <a class="btn btn-sm btn-outline-secondary px-3 vf-btn-save"
                   href="<%= href || '#' %>" download title="Save">
                  <i class="bi bi-download"></i><span>Save</span>
                </a>
              <% } %>

              <% if (typeKey === 'link') { %>
                <button type="button"
                        class="btn btn-sm btn-outline-secondary px-3 vf-btn-edit"
                        data-edit-url="1"
                        data-url-json="<%= _encJson(editPayload) %>">
                  <i class="bi bi-pencil-square"></i><span>Edit</span>
                </button>
              <% } %>

              <% if (ALLOW_DELETE) { %>
                <button type="button"
                        class="btn btn-sm px-3 vf-btn-delete"
                        data-delete-id="<%= f.id %>">
                  <i class="bi bi-trash"></i><span>Delete</span>
                </button>
              <% } %>
            </div>

            <% if (href) { %>
              <div class="small text-muted mt-2 text-truncate" title="<%= href %>">
                <i class="bi bi-link-45deg me-1"></i>
                <a href="<%= href %>" target="_blank" rel="noopener" class="text-muted text-decoration-none vf-url-line">
                  <%= href %>
                </a>
              </div>
            <% } %>

            <% if (linkedAdmissionId || student || linkedFamilyNumber) { %>
              <div class="text-muted small mt-3 d-flex flex-column gap-1">
                <div class="d-flex flex-wrap gap-3">
                  <% if (linkedAdmissionId) { %>
                    <span><i class="bi bi-hash me-1"></i>Admission: <strong><%= linkedAdmissionId %></strong></span>
                  <% } %>

                  <% if (student) { %>
                    <span><i class="bi bi-person me-1"></i>Student: <strong><%= student %></strong></span>
                  <% } %>
                </div>

                <% if (linkedFamilyNumber) { %>
                  <div>
                    <i class="bi bi-diagram-3 me-1"></i>Family #: <strong><%= linkedFamilyNumber %></strong>
                  </div>
                <% } %>
              </div>
            <% } %>
          </div>
        </div>
      </div>

    <% }) %>
  </div>

  <div id="vfListWrap" class="vf-hidden mt-3">
    <div class="table-responsive" style="max-height: 72vh; overflow:auto;">
      <table class="table table-sm mb-0 align-middle">
        <thead>
          <tr>
            <th style="width:70px;">Preview</th>
            <th>File</th>
            <th style="width:120px;">Type</th>
            <th style="width:190px;">Date</th>
            <th style="width:110px;">Admission</th>
            <th style="width:140px;">Family #</th>
            <th style="width:220px;">Student</th>
            <th class="text-end" style="width:260px;">Actions</th>
          </tr>
        </thead>
        <tbody id="vfListBody">
          <% (filesList || []).forEach((f, idx) => {
            const name = (f.original_name || f.name || f.title || 'File');
            const summary = _safeStr(f.summary || f.description || f.note || '');
            const mime = f.mime_type || '';
            const isLink = _isLinkItem(f);

            const href = _fileHref(f);

            let typeKey = 'other';
            const isImg = (!isLink) && _isImg(mime);
            const ext = _ext(name);

            if (isLink) typeKey = 'link';
            else if (isImg) typeKey = 'image';
            else if (ext === 'pdf') typeKey = 'pdf';
            else if (['doc','docx'].includes(ext)) typeKey = 'doc';
            else if (['xls','xlsx','csv'].includes(ext)) typeKey = 'xls';

            const student = _safeStr(f.student_name);
            const created = _safeStr(f.created_at);
            const linkedAdmissionId = _safeStr(f.linked_admission_id || f.admission_id);
            const linkedFamilyNumber = _safeStr(f.family_number || FAMILY_NUMBER);

            const ym = _getYearMonth(created);

            const dsName = _lower(name);
            const dsStudent = _lower(student);
            const dsAdmission = _lower(linkedAdmissionId);
            const dsType = typeKey;
            const dsDate = created;
            const dsFamily = _lower(linkedFamilyNumber);

            const editPayload = {
              id: f.id,
              name: name,
              summary: summary,
              link: href
            };

            const typeBadgeClass =
              typeKey === 'image' ? 'vf-type-image' :
              typeKey === 'pdf'   ? 'vf-type-pdf'   :
              typeKey === 'doc'   ? 'vf-type-doc'   :
              typeKey === 'xls'   ? 'vf-type-xls'   :
              typeKey === 'link'  ? 'vf-type-link'  :
                                    'vf-type-other';
          %>
            <tr id="fileRow_<%= f.id %>"
                data-name="<%= dsName %>"
                data-student="<%= dsStudent %>"
                data-admission="<%= dsAdmission %>"
                data-family="<%= dsFamily %>"
                data-type="<%= dsType %>"
                data-date="<%= dsDate %>"
                data-year="<%= ym.year %>"
                data-month="<%= ym.month %>">
              <td>
                <div class="vf-list-preview">
                  <% if (isImg && href) { %>
                    <img src="<%= href %>" alt="preview" style="width:100%;height:100%;object-fit:cover;">
                  <% } else if (typeKey === 'link') { %>
                    <i class="bi bi-link-45deg text-primary"></i>
                  <% } else { %>
                    <i class="bi bi-file-earmark text-muted"></i>
                  <% } %>
                </div>
              </td>

              <td>
                <div class="fw-semibold text-truncate" style="max-width:360px;" title="<%= name %>"><%= name %></div>

                <% if (summary) { %>
                  <div class="small text-muted text-truncate" style="max-width:360px;" title="<%= summary %>"><%= summary %></div>
                <% } %>

                <% if (href) { %>
                  <div class="small text-muted text-truncate" style="max-width:360px;" title="<%= href %>">
                    <a href="<%= href %>" target="_blank" rel="noopener" class="text-muted text-decoration-none vf-url-line">
                      <%= href %>
                    </a>
                  </div>
                <% } %>
              </td>

              <td class="text-uppercase">
                <span class="vf-fileBadge <%= typeBadgeClass %>"><%= (typeKey === 'link' ? 'link' : (isImg ? 'image' : (ext || 'file'))) %></span>
              </td>

              <td class="text-muted small"><%= _fmtDate(created) %></td>
              <td>
                <span class="vf-list-badge vf-list-adm"><%= linkedAdmissionId || '—' %></span>
              </td>
              <td>
                <span class="vf-list-badge vf-list-family"><%= linkedFamilyNumber || '—' %></span>
              </td>
              <td>
                <span class="vf-list-badge vf-list-student"><%= student || '—' %></span>
              </td>

              <td class="text-end">
                <div class="d-inline-flex gap-2 flex-wrap justify-content-end vf-actions">
                  <a class="btn btn-sm vf-btn-open px-3"
                     href="<%= href || '#' %>" target="_blank" rel="noopener">
                    <i class="bi bi-box-arrow-up-right"></i><span>Open</span>
                  </a>

                  <% if (typeKey !== 'link') { %>
                    <a class="btn btn-sm btn-outline-secondary px-3 vf-btn-save"
                       href="<%= href || '#' %>" download title="Save">
                      <i class="bi bi-download"></i><span>Save</span>
                    </a>
                  <% } %>

                  <% if (typeKey === 'link') { %>
                    <button type="button"
                            class="btn btn-sm btn-outline-secondary px-3 vf-btn-edit"
                            data-edit-url="1"
                            data-url-json="<%= _encJson(editPayload) %>">
                      <i class="bi bi-pencil-square"></i><span>Edit</span>
                    </button>
                  <% } %>

                  <% if (ALLOW_DELETE) { %>
                    <button type="button"
                            class="btn btn-sm px-3 vf-btn-delete"
                            data-delete-id="<%= f.id %>">
                      <i class="bi bi-trash"></i><span>Delete</span>
                    </button>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

</div>

