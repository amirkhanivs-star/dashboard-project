        return;
      }

      useMasterBankInput.value = useSaved ? 'true' : 'false';

      if (useSaved) {
        bankSelect.value = savedMasterBankName || '';
        collectionAccountInput.value = savedMasterBankName || '';
        bankSelect.classList.add('bank-locked');
        bankSelect.setAttribute('aria-disabled', 'true');

        bankUseSavedBtn?.classList.add('active');
        bankEditBtn?.classList.remove('active');

