<script>
  (() => {
    const form = document.getElementById('feeCollectionForm');
    const amountInput = document.getElementById('receivingAmount');
const registrationAmountInput = document.getElementById('registrationReceivingAmount');
    const totalDuesBox = document.getElementById('fcTotalDuesBox');
    const remainingBox = document.getElementById('fcRemainingBalance');
    const msgBox = document.getElementById('fcMsg');
    const receiveBtn = document.getElementById('receiveBtn');
    const resultCard = document.getElementById('fcResultCard');
    const resultBody = document.getElementById('fcResultBody');
    const tableBody = document.getElementById('fcDueTableBody');
    const totalRowsEl = document.getElementById('fcTotalRows');
    const summaryFeeEl = document.getElementById('fcSummaryTotalFee');
    const summaryRecvEl = document.getElementById('fcSummaryTotalReceived');
    const summaryDueEl = document.getElementById('fcSummaryTotalDues');
    const paidTableBody = document.getElementById('fcPaidTableBody');
const paidRowsCountEl = document.getElementById('fcPaidRowsCount');
const excludedTableBody = document.getElementById('fcExcludedTableBody');
const excludedRowsCountEl = document.getElementById('fcExcludedRowsCount');

const verificationInput = document.getElementById('verificationNumber');
const useMasterVerificationInput = document.getElementById('useMasterVerification');
const verificationUseSavedBtn = document.getElementById('verificationUseSavedBtn');
const verificationEditBtn = document.getElementById('verificationEditBtn');
const verificationHelpText = document.getElementById('verificationHelpText');
let savedMasterVerificationNumber = <%- JSON.stringify(masterVerificationNumberSafe) %>;
const canEditVerificationNumber = <%- JSON.stringify(!!canEditVerificationNumber) %>;

const bankSelect = document.getElementById('collectionAccountSelect');
const collectionAccountInput = document.getElementById('collectionAccount');
const useMasterBankInput = document.getElementById('useMasterBank');
const bankUseSavedBtn = document.getElementById('bankUseSavedBtn');
const bankEditBtn = document.getElementById('bankEditBtn');
const bankHelpText = document.getElementById('bankHelpText');
let savedMasterBankName = <%- JSON.stringify(masterBankNameSafe) %>;
const canEditBank = <%- JSON.stringify(!!canEditBank) %>;
const isPaidSlipWorkflowUser = <%- JSON.stringify(!!isPaidSlipWorkflowUserSafe) %>;
const feeCollectionBackUrl = <%- JSON.stringify(backUrl) %>;
const feeWorkflowDashboardUrl = '/dashboard';
const feeWorkflowDeptName = 'School Accounts Dept';
const feeWorkflowFromUserName = <%- JSON.stringify(
  String(U?.name || U?.username || U?.email || 'Current User').trim()
) %>;

const feeWorkflowAdmissionNamesById = <%- JSON.stringify(
  rowsSafe.reduce((acc, item) => {
    const id = Number(item?.id || item?.admissionId || 0);
    const name = String(
      item?.student_name ||
      item?.studentName ||
      item?.name ||
      ''
    ).trim();

    if (id && name) {
      acc[id] = name;
    }

    return acc;
  }, {})
) %>;

const feeWorkflowDefaultStudentNames = <%- JSON.stringify(
  [...new Set(
    rowsSafe
      .map((item) => String(
        item?.student_name ||
        item?.studentName ||
        item?.name ||
        ''
      ).trim())
      .filter(Boolean)
  )]
) %>;

const verificationApprovedInput = document.getElementById('verificationApproved');
const collectionAccountApprovedInput = document.getElementById('collectionAccountApproved');
const verificationApprovalChip = document.getElementById('verificationApprovalChip');
const bankApprovalChip = document.getElementById('bankApprovalChip');
const paidSlipApprovalHelp = document.getElementById('paidSlipApprovalHelp');

const workflowModalEl = document.getElementById('feeWorkflowForwardModal');
const workflowModalTitle = document.getElementById('feeWorkflowModalTitle');
const workflowModalDescription = document.getElementById('feeWorkflowModalDescription');
const workflowDestinationLabel = document.getElementById('feeWorkflowDestinationLabel');
const workflowIssueSection = document.getElementById('feeWorkflowIssueSection');
const workflowIssueVerification = document.getElementById('feeIssueVerification');
const workflowIssueCollectionAccount = document.getElementById('feeIssueCollectionAccount');
const workflowIssueMessage = document.getElementById('feeWorkflowIssueMessage');
const workflowTargetUserId = document.getElementById('feeWorkflowTargetUserId');
const workflowTargetUserHint = document.getElementById('feeWorkflowTargetUserHint');
const workflowModalError = document.getElementById('feeWorkflowModalError');
const workflowSubmitBtn = document.getElementById('feeWorkflowSubmitBtn');
const workflowCancelBtn = document.getElementById('feeWorkflowCancelBtn');
const workflowModalCloseBtn = document.getElementById('feeWorkflowModalCloseBtn');

let workflowMode = '';
let workflowToType = '';
let pendingWorkflowAdmissionIds = [];
let workflowUsersRequestToken = 0;
let receiveInProgress = false;
let awaitingRecordUpdateForward = false;

    const fmt = (v) => {
      const n = Number(v || 0);
      return Number.isFinite(n) ? String(n) : '-';
    };

    const getTotalDues = () => Number((summaryDueEl?.textContent || '0').trim() || 0);

    function getEnteredTotalAmount() {
      const monthlyAmount = Number(amountInput?.value || 0);
      const registrationAmount = Number(registrationAmountInput?.value || 0);

      return (
        (Number.isFinite(monthlyAmount) ? monthlyAmount : 0) +
        (Number.isFinite(registrationAmount) ? registrationAmount : 0)
      );
    }

    function escapeHtml(value) {
      return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }
    function cleanWorkflowText(value = '') {
      return String(value || '')
        .replace(/\s+/g, ' ')
        .trim();
    }

    function formatWorkflowPipelineType(value = '') {
      const key = String(value || '').trim().toLowerCase();

      if (key === 'print_record_update') {
        return 'Print + Record Update';
      }

      if (key === 'verification_registration') {
        return 'Verification & Registration';
      }

      if (key === 'paid_slip') {
        return 'Paid Slip';
      }

      return cleanWorkflowText(value)
        .replace(/_/g, ' ')
        .replace(/\b\w/g, (char) => char.toUpperCase()) || '-';
    }

    function getWorkflowSelectedTargetName() {
      const selectedOption =
        workflowTargetUserId?.options?.[workflowTargetUserId.selectedIndex];

      const selectedText = cleanWorkflowText(
        selectedOption?.textContent || ''
      );

      if (
        !selectedText ||
        selectedText.toLowerCase().includes('select')
      ) {
        return 'selected user';
      }

      return selectedText;
    }

    function getWorkflowStudentNames() {
      const namesFromIds = pendingWorkflowAdmissionIds
        .map((id) => {
          return feeWorkflowAdmissionNamesById[String(id)] ||
            feeWorkflowAdmissionNamesById[Number(id)] ||
            '';
        })
        .map((name) => cleanWorkflowText(name))
        .filter(Boolean);

      const finalNames =
        namesFromIds.length
          ? namesFromIds
          : feeWorkflowDefaultStudentNames;

      return [...new Set(finalNames)]
        .map((name) => cleanWorkflowText(name))
        .filter(Boolean);
    }

    function buildWorkflowForwardNotice() {
      const studentNames = getWorkflowStudentNames();
      const studentText =
        studentNames.length
          ? studentNames.join(', ')
          : 'this student';

      const targetUserName = getWorkflowSelectedTargetName();
      const pipelineType = formatWorkflowPipelineType(workflowToType);
      const destinationLabel = cleanWorkflowText(
        workflowDestinationLabel?.textContent || pipelineType
      );

      const message =
        `The admission of ${studentText} has been forwarded to ${targetUserName} in ${feeWorkflowDeptName}, ${pipelineType} pipeline.`;

      return {
        type: 'fee_workflow_forward_success',
        title: 'Admission Forwarded Successfully',
        message,
        studentNames,
        studentText,
        targetUserName,
        departmentName: feeWorkflowDeptName,
        pipelineType,
        destinationLabel,
        forwardedBy: feeWorkflowFromUserName,
        mode: workflowMode,
        createdAt: Date.now(),
      };
    }

    function saveWorkflowForwardNotice() {
      try {
        window.sessionStorage.setItem(
          'ivsFeeWorkflowForwardNotice',
          JSON.stringify(buildWorkflowForwardNotice())
        );
      } catch (error) {
        console.warn('Forward notice could not be saved.', error);
      }
    }
    function setApprovalChip(chip, label, state) {
      if (!chip) return;

      chip.classList.remove('pending', 'approved', 'incorrect');
      chip.classList.add(state);

      const stateLabel =
        state === 'approved'
          ? 'Approved'
          : state === 'incorrect'
            ? 'Incorrect'
            : 'Pending';

      chip.textContent = `${label}: ${stateLabel}`;
    }

    function updateReceiveAvailability() {
      if (!receiveBtn) return;

      if (!isPaidSlipWorkflowUser) {
        receiveBtn.disabled = receiveInProgress;
        return;
      }

      const enteredAmount = getEnteredTotalAmount();
      const requiresApprovals = enteredAmount > 0;
      const hasSelectedNotAdmittedMonths =
        !!document.querySelector(
          '.fc-not-admitted-check:checked'
        );

      const verificationApproved =
        verificationApprovedInput?.value === 'true';
      const collectionAccountApproved =
        collectionAccountApprovedInput?.value === 'true';

      const approvalsReady =
        requiresApprovals &&
        verificationApproved &&
        collectionAccountApproved;

      const hasValidAction =
        approvalsReady ||
        (!requiresApprovals && hasSelectedNotAdmittedMonths);

      receiveBtn.disabled =
        receiveInProgress ||
        awaitingRecordUpdateForward ||
        !hasValidAction;

      if (paidSlipApprovalHelp) {
        if (awaitingRecordUpdateForward) {
          paidSlipApprovalHelp.textContent =
            'Payment received. Forward this admission to Record to Update to finish the workflow.';
        } else if (!requiresApprovals && hasSelectedNotAdmittedMonths) {
          paidSlipApprovalHelp.textContent =
            'Not admitted-only update is ready. Payment approvals are not required.';
        } else if (!requiresApprovals) {
          paidSlipApprovalHelp.textContent =
            'Enter a payment amount, then approve both fields. Not admitted-only updates do not require approvals.';
        } else if (approvalsReady) {
          paidSlipApprovalHelp.textContent =
            'Both fields are approved. Receive is ready.';
        } else {
          paidSlipApprovalHelp.textContent =
            'Approve both Verification Number and Collection Account before receiving payment.';
        }
      }
    }

    function resetPaidSlipApprovals() {
      if (!isPaidSlipWorkflowUser) return;

      if (verificationApprovedInput) verificationApprovedInput.value = 'false';
      if (collectionAccountApprovedInput) collectionAccountApprovedInput.value = 'false';

      if (useMasterVerificationInput) useMasterVerificationInput.value = 'true';
      if (useMasterBankInput) useMasterBankInput.value = 'true';

      if (verificationInput) {
        verificationInput.value = savedMasterVerificationNumber || '';
        verificationInput.readOnly = true;
      }

      if (bankSelect) {
        bankSelect.value = savedMasterBankName || '';
        bankSelect.classList.add('bank-locked');
        bankSelect.setAttribute('aria-disabled', 'true');
      }

      if (collectionAccountInput) {
        collectionAccountInput.value = savedMasterBankName || '';
      }

      verificationUseSavedBtn?.classList.remove('active');
      verificationEditBtn?.classList.remove('active');
      bankUseSavedBtn?.classList.remove('active');
      bankEditBtn?.classList.remove('active');

      setApprovalChip(
        verificationApprovalChip,
        'Verification Number',
        'pending'
      );

      setApprovalChip(
        bankApprovalChip,
        'Collection Account',
        'pending'
      );

      if (verificationHelpText) {
        verificationHelpText.textContent =
          'Check the saved verification number. Tick ✓ approves it; cross ✕ sends it for correction.';
      }

      if (bankHelpText) {
        bankHelpText.textContent =
          'Check the saved collection account. Tick ✓ approves it; cross ✕ sends it for correction.';
      }

      updateReceiveAvailability();
    }

    function setVerificationMode(useSaved) {
      if (!verificationInput || !useMasterVerificationInput) return;

      if (isPaidSlipWorkflowUser) {
        useMasterVerificationInput.value = 'true';
        verificationInput.value = savedMasterVerificationNumber || '';
        verificationInput.readOnly = true;

        if (verificationApprovedInput) {
          verificationApprovedInput.value = useSaved ? 'true' : 'false';
        }

        verificationUseSavedBtn?.classList.toggle('active', useSaved);
        verificationEditBtn?.classList.toggle('active', !useSaved);

        setApprovalChip(
          verificationApprovalChip,
          'Verification Number',
          useSaved ? 'approved' : 'incorrect'
        );

        if (verificationHelpText) {
          verificationHelpText.textContent = useSaved
            ? 'Verification Number approved for this receive.'
            : 'Verification Number marked incorrect. Forward it to Verification & Registration.';
        }

        updateReceiveAvailability();
        return;
      }

      useMasterVerificationInput.value = useSaved ? 'true' : 'false';

      if (useSaved) {
        verificationInput.value = savedMasterVerificationNumber || '';
        verificationInput.readOnly = true;
        verificationInput.placeholder = savedMasterVerificationNumber
          ? 'Saved verification number'
          : 'No verification number saved';

        verificationUseSavedBtn?.classList.add('active');
        verificationEditBtn?.classList.remove('active');

        if (verificationHelpText) {
          verificationHelpText.textContent = 'Saved verification number will be used for this receive.';
        }
      } else {
        if (!canEditVerificationNumber) {
          useMasterVerificationInput.value = 'true';
          verificationInput.readOnly = true;
          verificationEditBtn?.classList.remove('active');
          verificationUseSavedBtn?.classList.add('active');

          if (verificationHelpText) {
            verificationHelpText.textContent = 'Saved verification number will be used. You do not have permission to change it.';
          }

          return;
        }

        verificationInput.readOnly = false;
        verificationInput.value = '';
        verificationInput.placeholder = 'Enter correct verification number';

        verificationUseSavedBtn?.classList.remove('active');
        verificationEditBtn?.classList.add('active');

        if (verificationHelpText) {
          verificationHelpText.textContent = 'Enter correct verification number. It will update everywhere after receive.';
        }

        setTimeout(() => verificationInput.focus(), 50);
      }
    }

    function setBankMode(useSaved) {
      if (!bankSelect || !collectionAccountInput || !useMasterBankInput) return;

      if (isPaidSlipWorkflowUser) {
        useMasterBankInput.value = 'true';
        bankSelect.value = savedMasterBankName || '';
        collectionAccountInput.value = savedMasterBankName || '';
        bankSelect.classList.add('bank-locked');
        bankSelect.setAttribute('aria-disabled', 'true');

        if (collectionAccountApprovedInput) {
          collectionAccountApprovedInput.value = useSaved ? 'true' : 'false';
        }

        bankUseSavedBtn?.classList.toggle('active', useSaved);
        bankEditBtn?.classList.toggle('active', !useSaved);

        setApprovalChip(
          bankApprovalChip,
          'Collection Account',
          useSaved ? 'approved' : 'incorrect'
        );

        if (bankHelpText) {
          bankHelpText.textContent = useSaved
            ? 'Collection Account approved for this receive.'
            : 'Collection Account marked incorrect. Forward it to Verification & Registration.';
        }

        updateReceiveAvailability();
        return;
      }

      useMasterBankInput.value = useSaved ? 'true' : 'false';

      if (useSaved) {
        bankSelect.value = savedMasterBankName || '';
        collectionAccountInput.value = savedMasterBankName || '';
        bankSelect.classList.add('bank-locked');
        bankSelect.setAttribute('aria-disabled', 'true');

        bankUseSavedBtn?.classList.add('active');
        bankEditBtn?.classList.remove('active');

        if (bankHelpText) {
          bankHelpText.textContent = savedMasterBankName
            ? 'Saved bank will be used for this receive.'
            : 'No saved bank found. Select a bank if you have permission.';
        }
      } else {
        if (!canEditBank) {
          useMasterBankInput.value = 'true';
          bankSelect.value = savedMasterBankName || '';
          collectionAccountInput.value = savedMasterBankName || '';
          bankSelect.classList.add('bank-locked');
          bankSelect.setAttribute('aria-disabled', 'true');

          bankEditBtn?.classList.remove('active');
          bankUseSavedBtn?.classList.add('active');

          if (bankHelpText) {
            bankHelpText.textContent = 'Saved bank will be used. You do not have permission to change it.';
          }

          return;
        }

        bankSelect.classList.remove('bank-locked');
        bankSelect.setAttribute('aria-disabled', 'false');

        bankUseSavedBtn?.classList.remove('active');
        bankEditBtn?.classList.add('active');

        if (bankHelpText) {
          bankHelpText.textContent = 'Select correct bank. It will update everywhere after receive.';
        }

        setTimeout(() => bankSelect.focus(), 50);
      }
    }

    function getWorkflowModalInstance() {
      if (!workflowModalEl || !window.bootstrap?.Modal) return null;

      return window.bootstrap.Modal.getOrCreateInstance(workflowModalEl, {
        backdrop: 'static',
        keyboard: false,
      });
    }

    function setWorkflowModalError(message = '') {
      if (!workflowModalError) return;

      workflowModalError.textContent = String(message || '');
      workflowModalError.classList.toggle('d-none', !message);
    }

    async function loadWorkflowTargetUsers(toType) {
      const requestToken = ++workflowUsersRequestToken;

      if (workflowTargetUserId) {
        workflowTargetUserId.disabled = true;
        workflowTargetUserId.innerHTML =
          '<option value="">Loading users...</option>';
      }

      if (workflowTargetUserHint) {
        workflowTargetUserHint.textContent =
          'Loading matching Accounts Agents and Sub-Agents...';
      }

      try {
        const response = await fetch(
          `/api/accounts/forward-users?toType=${encodeURIComponent(toType)}`,
          {
            credentials: 'same-origin',
            headers: {
              'Accept': 'application/json',
            },
          }
        );

        const data = await response.json().catch(() => ({}));

        if (requestToken !== workflowUsersRequestToken) return;

        if (!response.ok || data.success === false) {
          throw new Error(
            data.message ||
            'Could not load matching Accounts users.'
          );
        }

        const users = Array.isArray(data.users) ? data.users : [];

        if (!workflowTargetUserId) return;

        if (!users.length) {
          workflowTargetUserId.disabled = true;
          workflowTargetUserId.innerHTML =
            '<option value="">No matching user available</option>';

          if (workflowTargetUserHint) {
            workflowTargetUserHint.textContent =
              'Create or assign an Agent/Sub-Agent to this pipeline first.';
          }

          return;
        }

        workflowTargetUserId.innerHTML = [
          '<option value="">Select Agent / Sub-Agent</option>',
          ...users.map((item) => {
            const id = Number(item?.id || 0);
            const name = String(
              item?.name ||
              item?.email ||
              'User'
            ).trim();

            const userRole = String(item?.role || '')
              .replace(/_/g, ' ')
              .replace(/\b\w/g, (char) => char.toUpperCase());

            return `
              <option value="${id}">
                ${escapeHtml(name)}${userRole ? ` (${escapeHtml(userRole)})` : ''}
              </option>
            `;
          }),
        ].join('');

        workflowTargetUserId.disabled = false;

        if (workflowTargetUserHint) {
          workflowTargetUserHint.textContent =
            `${users.length} matching user${users.length === 1 ? '' : 's'} available.`;
        }
      } catch (error) {
        if (requestToken !== workflowUsersRequestToken) return;

        if (workflowTargetUserId) {
          workflowTargetUserId.disabled = true;
          workflowTargetUserId.innerHTML =
            '<option value="">Users could not be loaded</option>';
        }

        if (workflowTargetUserHint) {
          workflowTargetUserHint.textContent =
            error.message ||
            'Could not load matching Accounts users.';
        }

        setWorkflowModalError(
          error.message ||
          'Could not load matching Accounts users.'
        );
      }
    }

    function normalizeAdmissionIds(values = []) {
      return [...new Set(
        (Array.isArray(values) ? values : [values])
          .map((value) => Number(value || 0))
          .filter((value) => value > 0)
      )];
    }

    async function openFeeWorkflowModal(mode, options = {}) {
      if (!isPaidSlipWorkflowUser) return;

      workflowMode = mode;
      setWorkflowModalError('');

      const fallbackAdmissionId = Number(
        form?.querySelector('[name="admissionId"]')?.value || 0
      );

      pendingWorkflowAdmissionIds = normalizeAdmissionIds(
        options.admissionIds?.length
          ? options.admissionIds
          : [fallbackAdmissionId]
      );

      if (!pendingWorkflowAdmissionIds.length) {
        showMsg(
          'error',
          'Admission could not be identified for forwarding.'
        );
        return;
      }

      if (workflowIssueVerification) {
        workflowIssueVerification.checked =
          options.initialIssueField === 'verification' ||
          !!options.verificationIncorrect;
      }

      if (workflowIssueCollectionAccount) {
        workflowIssueCollectionAccount.checked =
          options.initialIssueField === 'collection_account' ||
          !!options.collectionAccountIncorrect;
      }

      if (workflowIssueMessage) {
        workflowIssueMessage.value = '';
      }

      if (mode === 'correction') {
        workflowToType = 'verification_registration';

        if (workflowModalTitle) {
          workflowModalTitle.textContent = 'Correction Required';
        }

        if (workflowModalDescription) {
          workflowModalDescription.textContent =
            'Select incorrect fields, write a message, and assign this admission to Verification & Registration.';
        }

        if (workflowDestinationLabel) {
          workflowDestinationLabel.textContent =
            'Verification & Registration';
        }

        workflowIssueSection?.classList.remove('d-none');
        workflowCancelBtn?.classList.remove('d-none');
        workflowModalCloseBtn?.classList.remove('d-none');

        if (workflowSubmitBtn) {
          workflowSubmitBtn.innerHTML =
            '<i class="bi bi-send-check me-1"></i> Send for Correction';
        }
      } else {
        workflowToType =
          String(options.toType || 'print_record_update').trim() ||
          'print_record_update';

        if (workflowModalTitle) {
          workflowModalTitle.textContent =
            'Send to Record to Update';
        }

        if (workflowModalDescription) {
          workflowModalDescription.textContent =
            'Payment is received. Select the Print & Record Update Agent/Sub-Agent who should complete the record.';
        }

        if (workflowDestinationLabel) {
          workflowDestinationLabel.textContent =
            String(
              options.destinationLabel ||
              'Print & Record Update — Record to Update'
            );
        }

        workflowIssueSection?.classList.add('d-none');
        workflowCancelBtn?.classList.add('d-none');
        workflowModalCloseBtn?.classList.add('d-none');

        if (workflowSubmitBtn) {
          workflowSubmitBtn.innerHTML =
            '<i class="bi bi-send-check me-1"></i> Forward to Record to Update';
        }
      }

      if (workflowTargetUserId) {
        workflowTargetUserId.value = '';
      }

      getWorkflowModalInstance()?.show();
      await loadWorkflowTargetUsers(workflowToType);
    }

    async function forwardWorkflowAdmissions({
      admissionIds,
      targetUserId,
      toType,
      workflowStage,
      issueMessage = '',
      issueFields = [],
      isIssueReturn = false,
    }) {
      const ids = normalizeAdmissionIds(admissionIds);

      for (const admissionId of ids) {
        const response = await fetch(
          `/api/admissions/${encodeURIComponent(admissionId)}/forward`,
          {
            method: 'POST',
            credentials: 'same-origin',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json',
            },
            body: JSON.stringify({
              toType,
              targetUserId,
              workflowStage,
              isIssueReturn,
              issueMessage,
              issueFields,
            }),
          }
        );

        const data = await response.json().catch(() => ({}));

        if (!response.ok || data.success === false) {
          throw new Error(
            data.message ||
            `Admission #${admissionId} could not be forwarded.`
          );
        }
      }
    }

    workflowSubmitBtn?.addEventListener('click', async () => {
      setWorkflowModalError('');

      const targetUserId = Number(workflowTargetUserId?.value || 0);

      if (!targetUserId) {
        setWorkflowModalError(
          'Please select the Agent or Sub-Agent who should receive this admission.'
        );
        return;
      }

      const issueFields = [];

      if (workflowIssueVerification?.checked) {
        issueFields.push('Verification Number');
      }

      if (workflowIssueCollectionAccount?.checked) {
        issueFields.push('Collection Account');
      }

      const issueMessage = String(
        workflowIssueMessage?.value || ''
      ).trim();

      if (workflowMode === 'correction') {
        if (!issueFields.length) {
          setWorkflowModalError(
            'Please select at least one incorrect field.'
          );
          return;
        }

        if (!issueMessage) {
          setWorkflowModalError(
            'Please write a correction message.'
          );
          workflowIssueMessage?.focus();
          return;
        }
      }

      workflowSubmitBtn.disabled = true;
      const originalButtonHtml = workflowSubmitBtn.innerHTML;
      workflowSubmitBtn.innerHTML =
        '<i class="bi bi-hourglass-split me-1"></i> Forwarding...';

      try {
        await forwardWorkflowAdmissions({
          admissionIds: pendingWorkflowAdmissionIds,
          targetUserId,
          toType: workflowToType,
          workflowStage:
            workflowMode === 'record_update'
              ? 'record_to_update'
              : 'new_admissions',
          issueMessage:
            workflowMode === 'correction'
              ? issueMessage
              : '',
          issueFields:
            workflowMode === 'correction'
              ? issueFields
              : [],
          isIssueReturn:
            workflowMode === 'correction',
        });

        getWorkflowModalInstance()?.hide();

        saveWorkflowForwardNotice();

        showMsg(
          'success',
          workflowMode === 'correction'
            ? 'Admission sent to Verification & Registration for correction.'
            : 'Admission sent to Record to Update successfully.'
        );

        setTimeout(() => {
          if (isPaidSlipWorkflowUser) {
            window.location.href = feeWorkflowDashboardUrl;
            return;
          }

          window.location.reload();
        }, 700);
      } catch (error) {
        setWorkflowModalError(
          error.message ||
          'Admission could not be forwarded.'
        );
      } finally {
        workflowSubmitBtn.disabled = false;
        workflowSubmitBtn.innerHTML = originalButtonHtml;
      }
    });

    verificationUseSavedBtn?.addEventListener('click', () => {
      setVerificationMode(true);
    });

    verificationEditBtn?.addEventListener('click', () => {
      if (isPaidSlipWorkflowUser) {
        setVerificationMode(false);

        openFeeWorkflowModal('correction', {
          initialIssueField: 'verification',
          verificationIncorrect: true,
          collectionAccountIncorrect:
            collectionAccountApprovedInput?.value === 'false' &&
            bankEditBtn?.classList.contains('active'),
        });

        return;
      }

      if (!canEditVerificationNumber) return;
      setVerificationMode(false);
    });

    bankUseSavedBtn?.addEventListener('click', () => {
      setBankMode(true);
    });

    bankEditBtn?.addEventListener('click', () => {
      if (isPaidSlipWorkflowUser) {
        setBankMode(false);

        openFeeWorkflowModal('correction', {
          initialIssueField: 'collection_account',
          verificationIncorrect:
            verificationApprovedInput?.value === 'false' &&
            verificationEditBtn?.classList.contains('active'),
          collectionAccountIncorrect: true,
        });

        return;
      }

      if (!canEditBank) return;
      setBankMode(false);
    });

    bankSelect?.addEventListener('change', () => {
      if (!useMasterBankInput || !collectionAccountInput) return;

      if (useMasterBankInput.value === 'false') {
        collectionAccountInput.value = bankSelect.value || '';
      }
    });

    if (isPaidSlipWorkflowUser) {
      resetPaidSlipApprovals();
    } else {
      setVerificationMode(true);
      setBankMode(true);
    }

function syncRegistrationFeeInput(rows = []) {
  if (!registrationAmountInput) return;

  const hasRegDue = Array.isArray(rows) && rows.some((r) => {
    return r && r.isRegistrationFee && Number(r.due || 0) > 0;
  });

  registrationAmountInput.disabled = !hasRegDue;

  if (!hasRegDue) {
    registrationAmountInput.value = '';
    registrationAmountInput.placeholder = 'Registration fee already fully received';
  } else {
    registrationAmountInput.placeholder = 'Enter registration fee amount';
  }

  updateRemainingPreview();
}
    function updateRemainingPreview() {
