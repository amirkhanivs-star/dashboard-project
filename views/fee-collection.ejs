                          ${escapeHtml(fmt(r.fee))}
                        </span>
                      `
                      : '<span class="text-muted">-</span>'
                  }
                </td>
              ` : ''}

              ${clientPermissions.receivedPayment ? `
                <td>
                  <span class="num recv-num">
                    ${escapeHtml(
                      fmt(
                        r.received ||
                        r.receivedAmount ||
                        r.amount
                      )
                    )}
                  </span>
                </td>
              ` : ''}

              ${clientPermissions.verificationNumber ? `
                <td>
                  <span class="text-muted small">
                    ${escapeHtml(
                      r.verificationNumber ||
                      r.verification_number ||
                      '-'
                    )}
                  </span>
                </td>
              ` : ''}
            </tr>
          `;
        }).join('');

      if (paidRowsCountEl) {
        paidRowsCountEl.textContent =
          String(rows.length);
      }
    }

    function setSummary(summary = {}) {
  if (summaryFeeEl) summaryFeeEl.textContent = fmt(summary.totalFee);
  if (summaryRecvEl) summaryRecvEl.textContent = fmt(summary.totalReceived);

  // top third card = full pending dues
  if (summaryDueEl) summaryDueEl.textContent = fmt(summary.totalFullPendingDues);

  // right side Total Dues = current month + previous pending only
  if (totalDuesBox) totalDuesBox.textContent = fmt(summary.totalDues);

  updateRemainingPreview();
}

    function showMsg(type, text) {
      if (!msgBox) return;
      const cls = type === 'success' ? 'alert-success' : 'alert-danger';
      msgBox.innerHTML = `<div class="alert ${cls} py-2 px-3 mb-0">${text}</div>`;
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!canReceivePayment) {
        showMsg(
          'error',
          'You do not have permission to receive or update billing data.'
        );
        return;
      }

      if (msgBox) msgBox.innerHTML = '';

      const totalEnteredAmount = getEnteredTotalAmount();

      if (
        isPaidSlipWorkflowUser &&
        totalEnteredAmount > 0 &&
        (
          verificationApprovedInput?.value !== 'true' ||
          collectionAccountApprovedInput?.value !== 'true'
        )
      ) {
        showMsg(
          'error',
          'Please approve both Verification Number and Collection Account before receiving payment.'
        );
        updateReceiveAvailability();
        return;
      }

      receiveInProgress = true;
      updateReceiveAvailability();

      if (receiveBtn) {
        receiveBtn.innerHTML =
          '<i class="bi bi-hourglass-split me-1"></i> Processing...';
      }

      try {
        const fd = new FormData(form);
        const payload = Object.fromEntries(fd.entries());

        payload.verificationApproved =
          verificationApprovedInput?.value || 'false';

        payload.collectionAccountApproved =
          collectionAccountApprovedInput?.value || 'false';

        if (
          !isPaidSlipWorkflowUser &&
          payload.useMasterVerification === 'false' &&
          !String(payload.verificationNumber || '').trim()
        ) {
          throw new Error('Please enter correct verification number.');
        }

        if (
          !isPaidSlipWorkflowUser &&
          payload.useMasterBank === 'false' &&
          !String(payload.collectionAccount || '').trim()
        ) {
          throw new Error('Please select correct collection account.');
        }

        const selectedNotAdmittedMonths = Array.from(
          document.querySelectorAll('.fc-not-admitted-check:checked')
        ).map((el) => ({
          admissionId: Number(
            el.getAttribute('data-admission-id') || 0
          ),
          monthKey: String(
            el.getAttribute('data-month-key') || ''
          ).trim().toLowerCase(),
        }));

        payload.selectedNotAdmittedMonths =
          selectedNotAdmittedMonths;

        const resp = await fetch('/api/fee-collection/receive', {
          method: 'POST',
          credentials: 'same-origin',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
          },
          body: JSON.stringify(payload),
        });

        const data = await resp.json().catch(() => ({}));

        if (!resp.ok || !data?.success) {
          const feeCollectionError = new Error(
            data?.message ||
            'Fee collection failed'
          );

          feeCollectionError.responseData =
            data && typeof data === 'object'
              ? data
              : {};

          throw feeCollectionError;
        }

        const webhookSuffix =
          data.n8nStatus === 'failed'
            ? ' Payment was saved; the webhook failed, but the workflow can continue.'
            : '';

        showMsg(
          'success',
          `${data.message || 'Fee received successfully'}${webhookSuffix}`
        );

        if (
          !isPaidSlipWorkflowUser &&
          payload.useMasterVerification === 'false'
        ) {
          savedMasterVerificationNumber =
            String(payload.verificationNumber || '').trim();
        }

        if (
          !isPaidSlipWorkflowUser &&
          payload.useMasterBank === 'false'
        ) {
          savedMasterBankName =
            String(payload.collectionAccount || '').trim();
        }

        const nextFeeRows =
          Array.isArray(data.feeRows)
            ? data.feeRows
            : [];

        renderRows(nextFeeRows);

        if (Array.isArray(data.excludedRows)) {
          renderExcludedRows(data.excludedRows);
        }

        syncRegistrationFeeInput(nextFeeRows);

        renderPaidRows(
          Array.isArray(data.paidRows)
            ? data.paidRows
            : []
        );

        setSummary(data.summary || {});

        const applied =
          Array.isArray(data.applied)
            ? data.applied
            : [];

        const nextWorkflowAction =
          data.nextWorkflowAction &&
          typeof data.nextWorkflowAction === 'object'
            ? data.nextWorkflowAction
            : null;

        if (resultCard && resultBody) {
          resultBody.innerHTML = applied.length
            ? applied.map((item) => {
                const lines = [
                  `
                    <div>
                      ${
                        clientPermissions.student
                          ? `<b>${escapeHtml(item.studentName || '-')}</b> `
                          : ''
                      }
                      (#${escapeHtml(item.admissionId || '-')})
                    </div>
                  `
                ];

                if (clientPermissions.receivedPayment) {
                  lines.push(`
                    <div>
                      Used Amount:
                      <b>${escapeHtml(fmt(item.usedAmount))}</b>
                    </div>
                  `);
                }

                if (clientPermissions.paidUpto) {
                  lines.push(`
                    <div>
                      Paid Upto:
                      <b>${escapeHtml(item.paidUpto || '-')}</b>
                    </div>
                  `);
                }

                if (clientPermissions.month) {
                  lines.push(`
                    <div>
                      Updated Months:
                      <b>${escapeHtml(
                        (item.touchedMonths || [])
                          .map((month) => month.monthKey)
                          .join(', ') || '-'
                      )}</b>
                    </div>
                  `);
                }

                return `
                  <div class="mb-2">
                    ${lines.join('')}
                  </div>
                `;
              }).join('')
            : '<div>No rows updated.</div>';

          resultCard.classList.remove('d-none');
        }

        const appliedAdmissionIds = normalizeAdmissionIds(
          applied.map((item) => item?.admissionId)
        );

        const fallbackAdmissionId = Number(
          form.querySelector('[name="admissionId"]')?.value || 0
        );

        form.reset();

        const dateInput =
          document.getElementById('receivingDate');

        if (dateInput) {
          dateInput.value =
            new Date().toISOString().slice(0, 10);
        }

        if (
          isPaidSlipWorkflowUser &&
          data.recordUpdateForwardRequired
        ) {
          awaitingRecordUpdateForward = true;
          resetPaidSlipApprovals();

          openFeeWorkflowModal('record_update', {
            admissionIds:
              appliedAdmissionIds.length
                ? appliedAdmissionIds
                : [fallbackAdmissionId],
            toType:
              nextWorkflowAction?.toType ||
              'print_record_update',
            destinationLabel:
              nextWorkflowAction?.label
                ? `Print & Record Update — ${nextWorkflowAction.label}`
                : 'Print & Record Update — Record to Update',
          });
        } else if (isPaidSlipWorkflowUser) {
          resetPaidSlipApprovals();
        } else {
          setVerificationMode(true);
          setBankMode(true);
        }

        updateRemainingPreview();
      } catch (err) {
        if (
          showDuplicateVerificationConflict(err)
        ) {
          return;
        }

        showMsg(
          'error',
          err.message ||
          'Fee collection failed'
        );
      } finally {
        receiveInProgress = false;

        if (receiveBtn) {
          receiveBtn.innerHTML =
            '<i class="bi bi-cash-coin me-1"></i> Receive';
        }

        updateReceiveAvailability();
      }
    });

  })();
</script>

<script>
(function () {
  const widget = document.getElementById("accountsNumberNoteWidget");
  const openBtn = document.getElementById("accountsNumberNoteOpenBtn");

  if (!widget) return;

  const listEl = document.getElementById("accountsNumberNoteList");
  const emptyEl = document.getElementById("accountsNumberNoteEmpty");
  const hideBtn = document.getElementById("accountsNumberNoteHideBtn");

  const storageKey =
    widget.getAttribute("data-hidden-storage-key") ||
    "ivs_accounts_number_note_hidden_fee_collection";

  const positionStorageKey = `${storageKey}_position_v2`;
  let currentNote = null;
  let openBtnDragMoved = false;

  window.ACCOUNTS_NUMBER_NOTE = <%- JSON.stringify(
    shouldRenderAccountsNumberNote
      ? accountsNumberNoteData
      : {
          enabled: false,
          highestNumbers: null,
          sidebarHighest: null,
          latestNumbers: null,
          notepadLatest: null,
          latestHighest: null,
          records: [],
          total: 0
        }
  ) %>;

  function isAccountsNumberNoteMobile() {
    return window.matchMedia("(max-width: 767.98px)").matches;
  }

  function clearAccountsNumberNoteInlinePosition(element) {
    if (!element) return;

    element.style.left = "";
    element.style.top = "";
    element.style.right = "";
    element.style.bottom = "";
  }

  function clampAccountsNumberNotePosition(left, top, element) {
    const rect = element.getBoundingClientRect();
    const margin = 10;
    const width = rect.width || 160;
    const height = rect.height || 44;

    return {
      left: Math.min(
        Math.max(margin, left),
        Math.max(margin, window.innerWidth - width - margin)
      ),
      top: Math.min(
        Math.max(margin, top),
        Math.max(margin, window.innerHeight - height - margin)
      )
    };
  }

  function setAccountsNumberNotePosition(element, left, top) {
    if (!element) return;

    element.style.left = `${Math.round(left)}px`;
    element.style.top = `${Math.round(top)}px`;
    element.style.right = "auto";
    element.style.bottom = "auto";
  }

  function saveAccountsNumberNotePosition(left, top) {
    localStorage.setItem(
      positionStorageKey,
      JSON.stringify({
        left: Math.round(left),
        top: Math.round(top)
      })
    );
  }

  function readAccountsNumberNotePosition() {
    try {
      const parsed = JSON.parse(localStorage.getItem(positionStorageKey) || "null");

      if (
        !parsed ||
        !Number.isFinite(Number(parsed.left)) ||
        !Number.isFinite(Number(parsed.top))
      ) {
        return null;
      }

      return {
        left: Number(parsed.left),
        top: Number(parsed.top)
      };
    } catch (err) {
      return null;
    }
  }

  function applySavedAccountsNumberNotePosition() {
    if (isAccountsNumberNoteMobile()) {
      clearAccountsNumberNoteInlinePosition(widget);
      clearAccountsNumberNoteInlinePosition(openBtn);
      return;
    }

    const savedPosition = readAccountsNumberNotePosition();

    if (!savedPosition) {
      return;
    }

    const activeElement =
      widget && !widget.classList.contains("d-none")
        ? widget
        : (openBtn || widget);

    const clamped = clampAccountsNumberNotePosition(
      savedPosition.left,
      savedPosition.top,
      activeElement
    );

    setAccountsNumberNotePosition(widget, clamped.left, clamped.top);
    setAccountsNumberNotePosition(openBtn, clamped.left, clamped.top);
    saveAccountsNumberNotePosition(clamped.left, clamped.top);
  }

  function startAccountsNumberNoteDrag(event, dragElement) {
    if (!dragElement || isAccountsNumberNoteMobile()) {
      return;
    }

    if (event.button !== undefined && event.button !== 0) {
      return;
    }

    if (
      dragElement === widget &&
      event.target.closest(".accounts-number-note-hide-btn")
    ) {
      return;
    }

    const startRect = dragElement.getBoundingClientRect();
    const startClientX = event.clientX;
    const startClientY = event.clientY;
    let latestLeft = startRect.left;
    let latestTop = startRect.top;
    let didMove = false;

    dragElement.classList.add("is-dragging");
    event.preventDefault();

    function handlePointerMove(moveEvent) {
      const deltaX = moveEvent.clientX - startClientX;
      const deltaY = moveEvent.clientY - startClientY;

      if (Math.abs(deltaX) > 2 || Math.abs(deltaY) > 2) {
        didMove = true;
      }

      const activeElement =
        widget && !widget.classList.contains("d-none")
          ? widget
          : dragElement;

      const nextPosition = clampAccountsNumberNotePosition(
        startRect.left + deltaX,
        startRect.top + deltaY,
        activeElement
      );

      latestLeft = nextPosition.left;
      latestTop = nextPosition.top;

      setAccountsNumberNotePosition(widget, latestLeft, latestTop);
      setAccountsNumberNotePosition(openBtn, latestLeft, latestTop);
    }

    function handlePointerUp() {
      document.removeEventListener("pointermove", handlePointerMove);
      dragElement.classList.remove("is-dragging");

      if (didMove) {
        saveAccountsNumberNotePosition(latestLeft, latestTop);

        if (dragElement === openBtn) {
          openBtnDragMoved = true;

          setTimeout(function () {
            openBtnDragMoved = false;
          }, 0);
        }
      }
    }

    document.addEventListener("pointermove", handlePointerMove);
    document.addEventListener("pointerup", handlePointerUp, { once: true });
  }

  function initAccountsNumberNoteDrag() {
    const noteHead = widget.querySelector(".accounts-number-note-head");

    if (noteHead) {
      noteHead.addEventListener("pointerdown", function (event) {
        startAccountsNumberNoteDrag(event, widget);
      });
    }

    if (openBtn) {
      openBtn.addEventListener("pointerdown", function (event) {
        startAccountsNumberNoteDrag(event, openBtn);
      });
    }

    applySavedAccountsNumberNotePosition();

    window.addEventListener("resize", applySavedAccountsNumberNotePosition);
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

   function normalizeLatestNumbers(data = {}) {
    const latest =
      (
        data &&
        (
          data.latestNumbers ||
          data.notepadLatest
        )
      ) ||
      null;

    const familyNumber =
      String(
        latest?.familyNumber || ""
      ).trim();

    const verificationNumber =
      String(
        latest?.verificationNumber || ""
      ).trim();

    const registrationNumber =
      String(
        latest?.registrationNumber || ""
      ).trim();

    const hasFamilyNumber =
      !!familyNumber;

    const hasVerificationNumber =
      !!verificationNumber;

    const hasRegistrationNumber =
      !!registrationNumber;

    const hasRecord =
      hasFamilyNumber ||
      hasVerificationNumber ||
      hasRegistrationNumber;

    const fallbackCopyText = [
      hasFamilyNumber
        ? `FAM: ${familyNumber}`
        : "",

      hasVerificationNumber
        ? `VERIF: ${verificationNumber}`
        : "",

      hasRegistrationNumber
        ? `REG: ${registrationNumber}`
        : ""
    ]
      .filter(Boolean)
      .join(" | ");

    const copyText =
      String(
        latest?.copyText ||
        fallbackCopyText
      ).trim();

    return {
      hasRecord,
      familyNumber,
      verificationNumber,
      registrationNumber,
      hasFamilyNumber,
      hasVerificationNumber,
      hasRegistrationNumber,
      copyText
    };
  }

  function makeAccountsNumberChip(label, value) {
    return `
      <span
        class="accounts-number-note-chip"
        title="${escapeHtml(value)}">

        <span class="accounts-number-note-chip-label">
          ${escapeHtml(label)}
        </span>

        <span class="accounts-number-note-chip-value">
          ${escapeHtml(value)}
        </span>
      </span>
    `;
  }

  function renderAccountsNumberNote(data = {}) {
    const note =
      normalizeLatestNumbers(data);

    currentNote = note;

    if (!note.hasRecord) {
      listEl.innerHTML = "";

      if (emptyEl) {
        emptyEl.classList.remove("d-none");
      }

      return;
    }

    if (emptyEl) {
      emptyEl.classList.add("d-none");
    }

    const numberChips = [
      note.hasFamilyNumber
        ? makeAccountsNumberChip(
            "FAM",
            note.familyNumber
          )
        : "",

      note.hasVerificationNumber
        ? makeAccountsNumberChip(
            "VERIF",
            note.verificationNumber
          )
        : "",

      note.hasRegistrationNumber
        ? makeAccountsNumberChip(
            "REG",
            note.registrationNumber
          )
        : ""
    ]
      .filter(Boolean)
      .join("");

    listEl.innerHTML = `
      <div class="accounts-number-note-row">
        <div class="accounts-number-note-numbers">
          ${numberChips}
        </div>

        <button
          type="button"
          class="accounts-number-note-copy"
          data-copy-note="1">

          <i class="bi bi-copy me-1"></i>
          Copy
        </button>
      </div>
    `;
  }


  function setNoteHidden(hidden) {
    const shouldHide = !!hidden;

    widget.classList.toggle("d-none", shouldHide);

    if (openBtn) {
      openBtn.classList.toggle("d-none", !shouldHide);
    }

    localStorage.setItem(storageKey, shouldHide ? "1" : "0");

    requestAnimationFrame(applySavedAccountsNumberNotePosition);
  }

  async function refreshAccountsNumberNote() {
    try {
      const response = await fetch("/api/accounts-number-note", {
        headers: {
          Accept: "application/json"
        }
      });

      const data = await response.json();

      const noteData =
        data.accountsNumberNote ||
        data.note ||
        {
          enabled: false,
          highestNumbers: null,
          sidebarHighest: null,
          latestNumbers: null,
          notepadLatest: null,
          latestHighest: null,
          records: [],
          total: 0
        };

      if (
        !response.ok ||
        data.success === false
      ) {
        return;
      }

      window.ACCOUNTS_NUMBER_NOTE = noteData;
      renderAccountsNumberNote(noteData);
    } catch (err) {
      console.warn("accounts number note refresh failed", err);
    }
  }

  if (hideBtn) {
    hideBtn.addEventListener("click", function () {
      setNoteHidden(true);
    });
  }

  if (openBtn) {
    openBtn.addEventListener("click", function () {
      if (openBtnDragMoved) {
        openBtnDragMoved = false;
        return;
      }

      setNoteHidden(false);
    });
  }

  widget.addEventListener("click", async function (event) {
    const copyBtn =
      event.target.closest("[data-copy-note]");

    if (
      !copyBtn ||
      !currentNote ||
      !currentNote.hasRecord
    ) {
      return;
    }

    try {
      await navigator.clipboard.writeText(
        currentNote.copyText || ""
      );

      const oldHtml = copyBtn.innerHTML;
      copyBtn.innerHTML =
        '<i class="bi bi-check2 me-1"></i> Copied';

      if (typeof window.showUploadFlash === "function") {
        window.showUploadFlash(
          "success",
          "Copied",
          "Latest family, verification and registration numbers copied."
        );
      }

      setTimeout(function () {
        copyBtn.innerHTML = oldHtml;
      }, 1200);
    } catch (err) {
      alert("Copy failed. Please copy manually.");
    }
  });

  initAccountsNumberNoteDrag();

  renderAccountsNumberNote(window.ACCOUNTS_NUMBER_NOTE || {});

  const hidden = localStorage.getItem(storageKey) === "1";
  setNoteHidden(hidden);

  setInterval(
    refreshAccountsNumberNote,
    60000
  );

  if (typeof io === "function") {
    try {
      const socket = io();

      socket.on("admission:changed", function () {
        refreshAccountsNumberNote();
      });
    } catch (err) {
      console.warn("accounts number note socket failed", err);
    }
  }
})();
</script>

