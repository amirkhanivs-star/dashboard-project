<%- include('partials/bootstrap-header', { user, pageTitle: pageTitle || 'Fee Collection' }) %>
<%- include('partials/flash') %>

<%
  const U = user || {};
  const role = String(U?.role || U?.agentType || '').toLowerCase();

  const backUrl =
    `/dashboard/admission/${admissionId || ''}`;

  const feeRowsSafe = Array.isArray(feeRows) ? feeRows : [];
  const rowsSafe = Array.isArray(rows) ? rows : [];
  const paidRowsSafe =
  Array.isArray(paidRows)
    ? paidRows
    : (Array.isArray(paidFeeRows) ? paidFeeRows : []);
    const excludedRowsSafe = Array.isArray(excludedRows) ? excludedRows : [];
  const bankOptionsSafe = Array.isArray(bankOptions) ? bankOptions : [];
  const summarySafe = summary || {};

  const fmt = (v) => {
    const n = Number(v || 0);
    if (!Number.isFinite(n)) return '-';
    return String(n);
  };

  const cleanFamilyNumber = String(familyNumber || '').trim();
const isAutoFamilyMatch =
  cleanFamilyNumber.toLowerCase() === 'auto' ||
  cleanFamilyNumber.toLowerCase().startsWith('auto-');

const familyLabel = cleanFamilyNumber
  ? (isAutoFamilyMatch ? 'Auto Matched' : cleanFamilyNumber)
  : '-';
  const currentYear = Number(billingYear || new Date().getFullYear());
  const hasRegistrationFeeDue = feeRowsSafe.some((r) => {
  return r && r.isRegistrationFee && Number(r.due || 0) > 0;
});

    const masterVerificationNumberSafe = String(masterVerificationNumber || '').trim();

  const firstRowSafe = rowsSafe[0] || {};
  const firstFeeBankRow =
    feeRowsSafe.find((r) => String(r?.bank || '').trim()) ||
    paidRowsSafe.find((r) => String(r?.bank || r?.bankName || '').trim()) ||
    excludedRowsSafe.find((r) => String(r?.bank || '').trim()) ||
    {};

  const masterBankNameSafe = String(
    (typeof masterBankName !== 'undefined' ? masterBankName : '') ||
    (typeof bankName !== 'undefined' ? bankName : '') ||
    (typeof admissionBank !== 'undefined' ? admissionBank : '') ||
    firstRowSafe.accounts_bank ||
    firstRowSafe.bank ||
    firstRowSafe?.accounts?.bank ||
    firstFeeBankRow.bank ||
    firstFeeBankRow.bankName ||
    ''
  ).trim();

    let rawPerms =
    (typeof perms !== 'undefined' && perms)
      ? perms
      : (
          U?.permissions ||
          U?.perms ||
          U?.permission ||
          U?.permissionMap ||
          {}
        );

  try {
    if (typeof rawPerms === 'string') {
      rawPerms = JSON.parse(rawPerms);
    }
  } catch (e) {
    rawPerms = {};
  }

  function getNestedPerm(obj, path) {
    try {
      const parts = String(path || '')
        .split('.')
        .filter(Boolean);

      let current = obj;

      for (const part of parts) {
        if (
          !current ||
          typeof current !== 'object' ||
          !(part in current)
        ) {
          return undefined;
        }

        current = current[part];
      }

      return current;
    } catch (e) {
      return undefined;
    }
  }

  function permissionEnabled(value) {
    if (value === true || value === 1) {
      return true;
    }

    if (
      value === false ||
      value === 0 ||
      value === null ||
      typeof value === 'undefined'
    ) {
      return false;
    }

    return [
      '1',
      'true',
      'on',
      'yes'
    ].includes(
      String(value)
        .trim()
        .toLowerCase()
    );
  }

  function hasOwnPermission(key) {
    return !!(
      rawPerms &&
      typeof rawPerms === 'object' &&
      !Array.isArray(rawPerms) &&
      Object.prototype.hasOwnProperty.call(
        rawPerms,
        key
      )
    );
  }

  function hasPermissionEntry(key) {
    const cleanKey =
      String(key || '').trim();

    if (!cleanKey || !rawPerms) {
      return false;
    }

    if (Array.isArray(rawPerms)) {
      return rawPerms.includes(cleanKey);
    }

    if (typeof rawPerms !== 'object') {
      return false;
    }

    if (hasOwnPermission(cleanKey)) {
      return true;
    }

    if (
      typeof getNestedPerm(
        rawPerms,
        cleanKey
      ) !== 'undefined'
    ) {
      return true;
    }

    const alt =
      cleanKey.replace(/\./g, '_');

    return hasOwnPermission(alt);
  }

  function hasKey(key) {
    const cleanKey =
      String(key || '').trim();

    if (!cleanKey || !rawPerms) {
      return false;
    }

    if (rawPerms === true) {
      return true;
    }

    if (Array.isArray(rawPerms)) {
      return (
        rawPerms.includes(cleanKey) ||
        rawPerms.includes('*') ||
        rawPerms.includes('all')
      );
    }

    if (typeof rawPerms === 'object') {
      if (hasOwnPermission(cleanKey)) {
        return permissionEnabled(
          rawPerms[cleanKey]
        );
      }

      const nested =
        getNestedPerm(
          rawPerms,
          cleanKey
        );

      if (typeof nested !== 'undefined') {
        return permissionEnabled(nested);
      }

      const alt =
        cleanKey.replace(/\./g, '_');

      if (hasOwnPermission(alt)) {
        return permissionEnabled(
          rawPerms[alt]
        );
      }
    }

    return false;
  }

  function canAny(keys) {
    return (keys || [])
      .filter(Boolean)
      .some(key => hasKey(key));
  }

  const COLUMN_VIEW_KEY_MAP =
    Object.freeze({
      status: 'colStatus',
      feeStatus: 'colFeeStatus',
      dept: 'colDept',
      student: 'colStudentName',
      father: 'colFatherName',
      fatherEmail: 'colFatherEmail',
      grade: 'colGrade',
      tuitionGrade: 'colTuitionGrade',
      phone: 'colPhone',
      processedBy: 'colProcessedBy',
      paymentStatus: 'colPaymentStatus',
      paidUpto: 'colPaidUpto',
      verificationNumber:
        'colVerificationNumber',
      registrationNumber:
        'colRegistrationNumber',
      familyNumber:
        'colFamilyNumber',
      registrationFee:
        'colRegistrationFee',
      fees: 'colFees',
      currency: 'colCurrency',
      bank: 'colBank',
      month: 'colMonth',
      totalFees: 'colTotalFees',
      pendingDues: 'colPendingDues',
      receivedPayment:
        'colReceivedPayment',
      comment: 'colComment',
      invoiceStatus:
        'colInvoiceStatus',
      invoiceStatusTimestamp:
        'colInvoiceStatusTimestamp',
      paidInvoiceStatus:
        'colPaidInvoiceStatus',
      paidInvoiceStatusTimestamp:
        'colPaidInvoiceStatusTimestamp',
      actionButtons:
        'colActionButtons'
    });

  const COLUMN_EDIT_KEY_MAP =
    Object.freeze({
      status: 'editStatus',
      feeStatus: 'editFeeStatus',
      dept: 'editDept',
      student: 'editStudentName',
      father: 'editFatherName',
      fatherEmail: 'editFatherEmail',
      grade: 'editGrade',
      tuitionGrade:
        'editTuitionGrade',
      phone: 'editPhone',
      paymentStatus:
        'editPaymentStatus',
      verificationNumber:
        'editVerificationNumber',
      registrationNumber:
        'editRegistrationNumber',
      familyNumber:
        'editFamilyNumber',
      registrationFee:
        'editRegistrationFee',
      fees: 'editFees',
      currency: 'editCurrency',
      bank: 'editBank',
      month: 'editMonth',
      comment: 'editComment'
    });

  const COLUMN_VIEW_LEGACY_KEY_MAP =
    Object.freeze({
      phone: [
        'showPhone'
      ],

      paymentStatus: [
        'showPaymentStatus'
      ],

      paidUpto: [
        'showPaidUpto'
      ],

      verificationNumber: [
        'showVerificationNumber'
      ],

      registrationNumber: [
        'showRegistrationNumber'
      ]
    });

  const hasExplicitEditSchema =
    Object.values(
      COLUMN_EDIT_KEY_MAP
    ).some(key =>
      hasPermissionEntry(key)
    );

  function canCol(name) {
    const key =
      String(name || '').trim();

    const permissionKey =
      COLUMN_VIEW_KEY_MAP[key];

    if (!permissionKey) {
      return false;
    }

    const legacyKeys =
      COLUMN_VIEW_LEGACY_KEY_MAP[key] ||
      [];

    const pascalKey =
      key.charAt(0).toUpperCase() +
      key.slice(1);

    return canAny([
      permissionKey,
      ...legacyKeys,

      `col.${key}`,
      `show_${key}`,
      `show${pascalKey}`,

      `super.col.${key}`,
      `super.column.${key}`,

      `admin.col.${key}`,
      `admin.column.${key}`,

      `agent.col.${key}`,
      `agent.column.${key}`,

      `subagent.col.${key}`,
      `subagent.column.${key}`,

      `sub_agent.col.${key}`,
      `sub_agent.column.${key}`,

      `dashboard_super.col.${key}`,
      `dashboard-super.col.${key}`,

      `dashboard_admin.col.${key}`,
      `dashboard-admin.col.${key}`,

      `dashboard_agent.col.${key}`,
      `dashboard-agent.col.${key}`,

      `dashboard_sub_agent.col.${key}`,
      `dashboard-sub-agent.col.${key}`,

      `perm.super.col.${key}`,
      `perm.admin.col.${key}`,
      `perm.agent.col.${key}`,
      `perm.sub_agent.col.${key}`,

      key
    ]);
  }

  function canEditCol(name) {
    const key =
      String(name || '').trim();

    const editPermissionKey =
      COLUMN_EDIT_KEY_MAP[key];

    if (
      !editPermissionKey ||
      !canCol(key)
    ) {
      return false;
    }

    /*
     * Legacy users:
     * Existing View permission old Edit access ko
     * preserve karegi jab tak user new Edit schema
     * ke saath re-save na ho.
     */
    if (!hasExplicitEditSchema) {
      return true;
    }

    return hasKey(
      editPermissionKey
    );
  }

  const BUTTON_PERMISSION_KEY_MAP =
    Object.freeze({
      billing: 'btnBilling',
      details: 'btnDetails'
    });

  function canBtn(name) {
    const key =
      String(name || '').trim();

    const permissionKey =
      BUTTON_PERMISSION_KEY_MAP[key];

    if (!permissionKey) {
      return false;
    }

    const pascalKey =
      key.charAt(0).toUpperCase() +
      key.slice(1);

    return canAny([
      permissionKey,

      `super.btn.${key}`,
      `super.button.${key}`,

      `admin.btn.${key}`,
      `admin.button.${key}`,

      `agent.btn.${key}`,
      `agent.button.${key}`,

      `subagent.btn.${key}`,
      `subagent.button.${key}`,

      `sub_agent.btn.${key}`,
      `sub_agent.button.${key}`,

      `dashboard_super.btn.${key}`,
      `dashboard-super.btn.${key}`,

      `dashboard_admin.btn.${key}`,
      `dashboard-admin.btn.${key}`,

      `dashboard_agent.btn.${key}`,
      `dashboard-agent.btn.${key}`,

      `dashboard_sub_agent.btn.${key}`,
      `dashboard-sub-agent.btn.${key}`,

      `perm.super.btn.${key}`,
      `perm.admin.btn.${key}`,
      `perm.agent.btn.${key}`,
      `perm.sub_agent.btn.${key}`,

      `btn_${key}`,
      `btn${pascalKey}`,
      key
    ]);
  }

  const P = {
    col: {
      status:
        canCol('status'),

      feeStatus:
        canCol('feeStatus'),

      dept:
        canCol('dept'),

      student:
        canCol('student'),

      father:
        canCol('father'),

      fatherEmail:
        canCol('fatherEmail'),

      grade:
        canCol('grade'),

      tuitionGrade:
        canCol('tuitionGrade'),

      phone:
        canCol('phone'),

      processedBy:
        canCol('processedBy'),

      paymentStatus:
        canCol('paymentStatus'),

      paidUpto:
        canCol('paidUpto'),

      verif:
        canCol('verificationNumber'),

      reg:
        canCol('registrationNumber'),

      family:
        canCol('familyNumber'),

      registrationFee:
        canCol('registrationFee'),

      fees:
        canCol('fees'),

      currency:
        canCol('currency'),

      bank:
        canCol('bank'),

      month:
        canCol('month'),

      totalFees:
        canCol('totalFees'),

      pendingDues:
        canCol('pendingDues'),

      receivedPayment:
        canCol('receivedPayment'),

      comment:
        canCol('comment'),

      invoiceStatus:
        canCol('invoiceStatus'),

      invoiceStatusTimestamp:
        canCol(
          'invoiceStatusTimestamp'
        ),

      paidInvoiceStatus:
        canCol('paidInvoiceStatus'),

      paidInvoiceStatusTimestamp:
        canCol(
          'paidInvoiceStatusTimestamp'
        ),

      actionButtons:
        canCol('actionButtons')
    },

    edit: {
      paymentStatus:
        canEditCol(
          'paymentStatus'
        ),

      verificationNumber:
        canEditCol(
          'verificationNumber'
        ),

      bank:
        canEditCol('bank')
    },

    btn: {
      billing:
        canBtn('billing'),

      details:
        canBtn('details')
    }
  };

  const canUseFeeCollectionActions =
    P.col.actionButtons &&
    P.btn.billing;

  const canEditVerificationNumber =
    canUseFeeCollectionActions &&
    P.edit.verificationNumber;

  const canEditBank =
    canUseFeeCollectionActions &&
    P.edit.bank;

  const canMarkNotAdmitted =
    canUseFeeCollectionActions &&
    P.col.month &&
    P.edit.paymentStatus;

  // Paid Slip tick/cross approval workflow is limited to Accounts Agent/Sub-Agent.
  // Super Admin and Admin keep the existing correction/edit behavior.
  const isPaidSlipWorkflowUserSafe =
    typeof isPaidSlipWorkflowUser !==
    'undefined'
      ? !!isPaidSlipWorkflowUser
      : false;

  const canReviewVerificationNumber =
    canUseFeeCollectionActions &&
    P.col.verif;

  const canReviewBank =
    canUseFeeCollectionActions &&
    P.col.bank;

  const canCompletePaidSlipReview =
    !isPaidSlipWorkflowUserSafe ||
    (
      canReviewVerificationNumber &&
      canReviewBank
    );

  const canReceivePayment =
    canUseFeeCollectionActions &&
    canCompletePaidSlipReview;

  const clientFamilyNumber =
    P.col.family
      ? cleanFamilyNumber
      : '';

  const clientFamilyLabel =
    P.col.family
      ? familyLabel
      : '';

  const clientMasterVerificationNumberSafe =
    P.col.verif
      ? masterVerificationNumberSafe
      : '';

  const clientMasterBankNameSafe =
    P.col.bank
      ? masterBankNameSafe
      : '';

  const clientBankOptionsSafe =
    P.col.bank
      ? bankOptionsSafe
      : [];

  const showFeeTypeColumn =
    P.col.registrationFee ||
    P.col.fees;

  const showStudentIdentityColumn =
    P.col.student ||
    P.col.reg;

  const pendingVisibleColumnCount = [
    true,
    canMarkNotAdmitted,
    showFeeTypeColumn,
    showStudentIdentityColumn,
    P.col.dept,
    P.col.grade,
    P.col.month,
    P.col.paymentStatus,
    showFeeTypeColumn,
    P.col.receivedPayment,
    P.col.pendingDues
  ].filter(Boolean).length;

  const excludedVisibleColumnCount = [
    true,
    showStudentIdentityColumn,
    P.col.dept,
    P.col.grade,
    P.col.month,
    P.col.paymentStatus,
    P.col.fees,
    P.col.pendingDues
  ].filter(Boolean).length;

  const paidVisibleColumnCount = [
    true,
    showFeeTypeColumn,
    showStudentIdentityColumn,
    P.col.month,
    P.col.paymentStatus,
    showFeeTypeColumn,
    P.col.receivedPayment,
    P.col.verif
  ].filter(Boolean).length;

  const accountsNumberNoteData =
    (
      typeof accountsNumberNote !==
      'undefined' &&
      accountsNumberNote
    )
      ? accountsNumberNote
      : {
          enabled: false,
          highestNumbers: null,
          sidebarHighest: null,
          latestNumbers: null,
          notepadLatest: null,
          latestHighest: null,
          records: [],
          total: 0
        };

  const feeCollectionUserDeptKey =
    String(
      (
        U &&
        (
          U.dept ||
          U.department ||
          U.userDept ||
          U.user_department
        )
      ) ||
      ''
    ).trim().toLowerCase();

  const isSuperFeeCollectionUser =
    !!(
      role === 'super_admin' ||
      role === 'superadmin' ||
      U?.isSuperAdmin === true ||
      U?.is_super_admin === true
    );

  const isAccountsFeeCollectionUser =
    feeCollectionUserDeptKey === 'accounts' ||
    feeCollectionUserDeptKey === 'school accounts' ||
    feeCollectionUserDeptKey === 'school_accounts';

  /*
   * Latest Numbers global Accounts summary hai.
   * Is mein student/admission details nahi hotin,
   * is liye column View permissions required nahi.
   */
  const shouldRenderAccountsNumberNote =
    !!(
      (
        isSuperFeeCollectionUser ||
        isAccountsFeeCollectionUser
      ) &&
      accountsNumberNoteData &&
      accountsNumberNoteData.enabled
    );
%>

<div class="container-fluid py-3 fee-collection-page">
  
  <% if (shouldRenderAccountsNumberNote) { %>
    <div
      class="accounts-number-note"
      id="accountsNumberNoteWidget"
      data-hidden-storage-key="ivs_accounts_number_note_hidden_fee_collection">

      <div class="accounts-number-note-head">
        <div>
          <div class="accounts-number-note-title">
            Latest Fam + Verif + Reg Numbers
          </div>
          <div class="accounts-number-note-subtitle">
            Latest update from each field
          </div>
        </div>

        <button
          type="button"
          class="accounts-number-note-hide-btn"
          id="accountsNumberNoteHideBtn"
          title="Hide note">
          <i class="bi bi-eye-slash"></i>
        </button>
      </div>

      <div
        class="accounts-number-note-list"
        id="accountsNumberNoteList">
      </div>

      <div
        class="accounts-number-note-empty d-none"
        id="accountsNumberNoteEmpty">
        No family, verification or registration number found yet.
      </div>
    </div>

    <button
      type="button"
      class="accounts-number-note-open d-none"
      id="accountsNumberNoteOpenBtn"
      title="Show latest numbers">
      <i class="bi bi-stickies"></i>
      Latest Numbers
    </button>
  <% } %>

  <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3 top-head">
    <div>
      <h4 class="mb-0 page-title">Fee Collection</h4>
      <div class="text-muted small mt-1">
        Mode: <b class="text-capitalize"><%= mode || 'single' %></b>
        <span class="mx-2">|</span>
        Billing Year: <b><%= currentYear %></b>
        <% if (P.col.family) { %>
          <span class="mx-2">|</span>
          Family #:
          <b><%= clientFamilyLabel || '-' %></b>
        <% } %>
      </div>
    </div>

    <a
      href="<%= backUrl %>"
      class="btn rounded-pill btn-premium-back btn-sm js-fee-collection-back-link">
      <i class="bi bi-arrow-left"></i> Back to Details
    </a>
  </div>

  <div class="row g-3 align-items-stretch">
    <div class="col-lg-8">
      <div class="card border-0 main-card h-100">
        <div class="card-body p-3">

          <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <div class="sec-title">Pending Months & Dues</div>
            <div class="text-muted small">
              Total Rows: <b id="fcTotalRows"><%= feeRowsSafe.length %></b>
            </div>
          </div>

          <% if (
            P.col.totalFees ||
            P.col.receivedPayment ||
            P.col.pendingDues
          ) { %>
            <div class="summary-grid mb-3">

              <% if (P.col.totalFees) { %>
                <div class="sum-item">
                  <div class="label">
                    Total Fee for the Session
                  </div>

                  <div
                    class="val"
                    id="fcSummaryTotalFee">
                    <%= fmt(summarySafe.totalFee) %>
                  </div>
                </div>
              <% } %>

              <% if (P.col.receivedPayment) { %>
                <div class="sum-item">
                  <div class="label">
                    Total Received
                  </div>

                  <div
                    class="val"
                    id="fcSummaryTotalReceived">
                    <%= fmt(summarySafe.totalReceived) %>
                  </div>
                </div>
              <% } %>

              <% if (P.col.pendingDues) { %>
                <div class="sum-item">
                  <div class="label">
                    Total Pending Dues
                  </div>

                  <div
                    class="val"
                    id="fcSummaryTotalDues">
                    <%= fmt(summarySafe.totalFullPendingDues) %>
                  </div>
                </div>
              <% } %>

            </div>
          <% } %>

          <div class="card border-0 inner-card">
            <div class="card-body p-3">
                          <div class="table-responsive">
                <table
                  class="table table-sm align-middle due-table mb-0"
                  id="fcDueTable">
                  <thead>
                    <tr>
                      <th style="width:6%">#</th>

                      <% if (canMarkNotAdmitted) { %>
                        <th style="width:8%">Select</th>
                      <% } %>

                      <% if (showFeeTypeColumn) { %>
                        <th style="width:14%">Fee Type</th>
                      <% } %>

                      <% if (showStudentIdentityColumn) { %>
                        <th style="width:16%">
                          <%= P.col.student
                            ? 'Student'
                            : 'Registration #' %>
                        </th>
                      <% } %>

                      <% if (P.col.dept) { %>
                        <th style="width:10%">Dept</th>
                      <% } %>

                      <% if (P.col.grade) { %>
                        <th style="width:10%">Grade</th>
                      <% } %>

                      <% if (P.col.month) { %>
                        <th style="width:10%">Month</th>
                      <% } %>

                      <% if (P.col.paymentStatus) { %>
                        <th style="width:12%">Status</th>
                      <% } %>

                      <% if (showFeeTypeColumn) { %>
                        <th style="width:8%">Fee</th>
                      <% } %>

                      <% if (P.col.receivedPayment) { %>
                        <th style="width:8%">Received</th>
                      <% } %>

                      <% if (P.col.pendingDues) { %>
                        <th style="width:8%">Due</th>
                      <% } %>
                    </tr>
                  </thead>

                  <tbody id="fcDueTableBody">
                    <% if (!feeRowsSafe.length) { %>
                      <tr>
                        <td
                          colspan="<%= pendingVisibleColumnCount %>"
                          class="text-muted small">
                          No pending dues found.
                        </td>
                      </tr>
                    <% } else { %>
                      <% feeRowsSafe.forEach((r, idx) => { %>
                        <tr class="<%= r.isRegistrationFee ? 'registration-fee-row' : '' %>">
                          <td>
                            <span class="pill-mini">
                              <%= idx + 1 %>
                            </span>
                          </td>

                          <% if (canMarkNotAdmitted) { %>
                            <td>
                              <% if (r.isRegistrationFee) { %>
                                <span class="text-muted tiny">
                                  N/A
                                </span>
                              <% } else { %>
                                <div class="form-check m-0 d-flex justify-content-center">
                                  <input
                                    class="form-check-input fc-not-admitted-check"
                                    type="checkbox"
                                    value="<%= `${r.admissionId}:${r.monthKey}` %>"
                                    data-admission-id="<%= r.admissionId %>"
                                    data-month-key="<%= r.monthKey %>"
                                    title="Mark this month as Not admitted">
                                </div>
                              <% } %>
                            </td>
                          <% } %>

                          <% if (showFeeTypeColumn) { %>
                            <td>
                              <% if (
                                (r.isRegistrationFee && P.col.registrationFee) ||
                                (!r.isRegistrationFee && P.col.fees)
                              ) { %>
                                <span class="<%= r.isRegistrationFee ? 'fee-type-chip reg-chip' : 'fee-type-chip monthly-chip' %>">
                                  <%= r.feeType || (
                                    r.isRegistrationFee
                                      ? 'Registration Fee'
                                      : 'Monthly Fee'
                                  ) %>
                                </span>
                              <% } else { %>
                                <span class="text-muted">-</span>
                              <% } %>
                            </td>
                          <% } %>

                          <% if (showStudentIdentityColumn) { %>
                            <td>
                              <% if (P.col.student) { %>
                                <div class="fw-semibold">
                                  <%= r.studentName || '-' %>
                                </div>
                              <% } %>

                              <% if (P.col.reg) { %>
                                <div class="text-muted tiny">
                                  <%= r.registrationNumber || '-' %>
                                </div>
                              <% } %>
                            </td>
                          <% } %>

                          <% if (P.col.dept) { %>
                            <td>
                              <span class="pill-light text-capitalize">
                                <%= r.dept || '-' %>
                              </span>
                            </td>
                          <% } %>

                          <% if (P.col.grade) { %>
                            <td><%= r.grade || '-' %></td>
                          <% } %>

                          <% if (P.col.month) { %>
                            <td>
                              <span class="pill-month">
                                <%= r.monthLabel || r.monthKey || '-' %>
                              </span>
                            </td>
                          <% } %>

                          <% if (P.col.paymentStatus) { %>
                            <td>
                              <span class="status-chip">
                                <%= r.status || '-' %>
                              </span>
                            </td>
                          <% } %>

                          <% if (showFeeTypeColumn) { %>
                            <td>
                              <% if (
                                (r.isRegistrationFee && P.col.registrationFee) ||
                                (!r.isRegistrationFee && P.col.fees)
                              ) { %>
                                <span class="num fee-num">
                                  <%= fmt(r.fee) %>
                                </span>
                              <% } else { %>
                                <span class="text-muted">-</span>
                              <% } %>
                            </td>
                          <% } %>

                          <% if (P.col.receivedPayment) { %>
                            <td>
                              <span class="num recv-num">
                                <%= fmt(r.received) %>
                              </span>
                            </td>
                          <% } %>

                          <% if (P.col.pendingDues) { %>
                            <td>
                              <span class="num due-num">
                                <%= fmt(r.due) %>
                              </span>
                            </td>
                          <% } %>
                        </tr>
                      <% }) %>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <% if (rowsSafe.length) { %>
            <div class="card border-0 inner-card mt-3">
              <div class="card-body p-3">
                <div class="sec-title mb-2">
                  Admissions in This Collection
                </div>

                <div class="d-flex flex-wrap gap-2">
                  <% rowsSafe.forEach((r) => { %>
                    <span class="admission-pill">
                      <% if (P.col.student) { %>
                        <b><%= r.student_name || '-' %></b>
                      <% } else { %>
                        <b>Admission</b>
                      <% } %>

                      <span class="text-muted">
                        (#<%= r.id %>)
                      </span>
                    </span>
                  <% }) %>
                </div>
              </div>
            </div>
          <% } %>
           
          <div class="card border-0 inner-card mt-3">
            <div class="card-body p-3">
              <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                <div class="sec-title">
                  Excluded / Not Admitted Months
                </div>

                <div class="text-muted small">
                  Excluded Rows:
                  <b id="fcExcludedRowsCount">
                    <%= excludedRowsSafe.length %>
                  </b>
                </div>
              </div>

              <div class="table-responsive">
                <table class="table table-sm align-middle excluded-table mb-0">
                  <thead>
                    <tr>
                      <th style="width:6%">#</th>

                      <% if (showStudentIdentityColumn) { %>
                        <th style="width:18%">
                          <%= P.col.student
                            ? 'Student'
                            : 'Registration #' %>
                        </th>
                      <% } %>

                      <% if (P.col.dept) { %>
                        <th style="width:12%">Dept</th>
                      <% } %>

                      <% if (P.col.grade) { %>
                        <th style="width:12%">Grade</th>
                      <% } %>

                      <% if (P.col.month) { %>
                        <th style="width:12%">Month</th>
                      <% } %>

                      <% if (P.col.paymentStatus) { %>
                        <th style="width:14%">Status</th>
                      <% } %>

                      <% if (P.col.fees) { %>
                        <th style="width:12%">Fee</th>
                      <% } %>

                      <% if (P.col.pendingDues) { %>
                        <th style="width:14%">Due</th>
                      <% } %>
                    </tr>
                  </thead>

                  <tbody id="fcExcludedTableBody">
                    <% if (!excludedRowsSafe.length) { %>
                      <tr>
                        <td
                          colspan="<%= excludedVisibleColumnCount %>"
                          class="text-muted small">
                          No excluded / not admitted months found.
                        </td>
                      </tr>
                    <% } else { %>
                      <% excludedRowsSafe.forEach((r, idx) => { %>
                        <tr class="excluded-month-row">
                          <td>
                            <span class="pill-mini">
                              <%= idx + 1 %>
                            </span>
                          </td>

                          <% if (showStudentIdentityColumn) { %>
                            <td>
                              <% if (P.col.student) { %>
                                <div class="fw-semibold">
                                  <%= r.studentName || '-' %>
                                </div>
                              <% } %>

                              <% if (P.col.reg) { %>
                                <div class="text-muted tiny">
                                  <%= r.registrationNumber || '-' %>
                                </div>
                              <% } %>
                            </td>
                          <% } %>

                          <% if (P.col.dept) { %>
                            <td>
                              <span class="pill-light text-capitalize">
                                <%= r.dept || '-' %>
                              </span>
                            </td>
                          <% } %>

                          <% if (P.col.grade) { %>
                            <td><%= r.grade || '-' %></td>
                          <% } %>

                          <% if (P.col.month) { %>
                            <td>
                              <span class="pill-month excluded-month-chip">
                                <%= r.monthLabel || r.monthKey || '-' %>
                              </span>
                            </td>
                          <% } %>

                          <% if (P.col.paymentStatus) { %>
                            <td>
                              <span class="excluded-status-chip">
                                <%= r.status || 'Not admitted' %>
                              </span>
                            </td>
                          <% } %>

                          <% if (P.col.fees) { %>
                            <td>
                              <span class="num text-muted">
                                <%= fmt(r.fee) %>
                              </span>
                            </td>
                          <% } %>

                          <% if (P.col.pendingDues) { %>
                            <td>
                              <span class="num text-muted">
                                <%= fmt(r.due) %>
                              </span>
                            </td>
                          <% } %>
                        </tr>
                      <% }) %>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <div class="card border-0 inner-card mt-3">
            <div class="card-body p-3">
              <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                <div class="sec-title">
                  Paid Months & Registration Fee
                </div>

                <div class="text-muted small">
                  Paid Rows:
                  <b id="fcPaidRowsCount">
                    <%= paidRowsSafe.length %>
                  </b>
                </div>
              </div>

              <div class="table-responsive">
                <table class="table table-sm align-middle paid-table mb-0">
                  <thead>
                    <tr>
                      <th style="width:6%">#</th>

                      <% if (showFeeTypeColumn) { %>
                        <th style="width:18%">Fee Type</th>
                      <% } %>

                      <% if (showStudentIdentityColumn) { %>
                        <th style="width:20%">
                          <%= P.col.student
                            ? 'Student'
                            : 'Registration #' %>
                        </th>
                      <% } %>

                      <% if (P.col.month) { %>
                        <th style="width:12%">Month</th>
                      <% } %>

                      <% if (P.col.paymentStatus) { %>
                        <th style="width:12%">Status</th>
                      <% } %>

                      <% if (showFeeTypeColumn) { %>
                        <th style="width:10%">Fee</th>
                      <% } %>

                      <% if (P.col.receivedPayment) { %>
                        <th style="width:10%">Received</th>
                      <% } %>

                      <% if (P.col.verif) { %>
                        <th style="width:12%">Verification #</th>
                      <% } %>
                    </tr>
                  </thead>

                  <tbody id="fcPaidTableBody">
                    <% if (!paidRowsSafe.length) { %>
                      <tr>
                        <td
                          colspan="<%= paidVisibleColumnCount %>"
                          class="text-muted small">
                          No paid months or registration fee found.
                        </td>
                      </tr>
                    <% } else { %>
                      <% paidRowsSafe.forEach((r, idx) => { %>
                        <tr class="<%= r.isRegistrationFee ? 'registration-fee-row' : '' %>">
                          <td>
                            <span class="pill-mini">
                              <%= idx + 1 %>
                            </span>
                          </td>

                          <% if (showFeeTypeColumn) { %>
                            <td>
                              <% if (
                                (r.isRegistrationFee && P.col.registrationFee) ||
                                (!r.isRegistrationFee && P.col.fees)
                              ) { %>
                                <span class="<%= r.isRegistrationFee ? 'fee-type-chip reg-chip' : 'fee-type-chip paid-chip' %>">
                                  <%= r.feeType || (
                                    r.isRegistrationFee
                                      ? 'Registration Fee'
                                      : 'Monthly Fee'
                                  ) %>
                                </span>
                              <% } else { %>
                                <span class="text-muted">-</span>
                              <% } %>
                            </td>
                          <% } %>

                          <% if (showStudentIdentityColumn) { %>
                            <td>
                              <% if (P.col.student) { %>
                                <div class="fw-semibold">
                                  <%= r.studentName || r.student_name || '-' %>
                                </div>
                              <% } %>

                              <% if (P.col.reg) { %>
                                <div class="text-muted tiny">
                                  <%= r.registrationNumber || r.registration_number || '-' %>
                                </div>
                              <% } %>
                            </td>
                          <% } %>

                          <% if (P.col.month) { %>
                            <td>
                              <span class="pill-month">
                                <%= r.monthLabel || r.monthKey || r.month || '-' %>
                              </span>
                            </td>
                          <% } %>

                          <% if (P.col.paymentStatus) { %>
                            <td>
                              <span class="paid-status-chip">
                                <%= r.status || 'Paid' %>
                              </span>
                            </td>
                          <% } %>

                          <% if (showFeeTypeColumn) { %>
                            <td>
                              <% if (
                                (r.isRegistrationFee && P.col.registrationFee) ||
                                (!r.isRegistrationFee && P.col.fees)
                              ) { %>
                                <span class="num fee-num">
                                  <%= fmt(r.fee) %>
                                </span>
                              <% } else { %>
                                <span class="text-muted">-</span>
                              <% } %>
                            </td>
                          <% } %>

                          <% if (P.col.receivedPayment) { %>
                            <td>
                              <span class="num recv-num">
                                <%= fmt(
                                  r.received ||
                                  r.receivedAmount ||
                                  r.amount
                                ) %>
                              </span>
                            </td>
                          <% } %>

                          <% if (P.col.verif) { %>
                            <td>
                              <span class="text-muted small">
                                <%= (
                                  r.verificationNumber ||
                                  r.verification_number ||
                                  '-'
                                ) %>
                              </span>
                            </td>
                          <% } %>
                        </tr>
                      <% }) %>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card border-0 side-card h-100">
        <div class="card-body p-3">

          <div class="sec-title mb-3">Receive Payment</div>

          <form id="feeCollectionForm">
            <input
              type="hidden"
              name="admissionId"
              value="<%= admissionId || '' %>">

            <input
              type="hidden"
              name="familyNumber"
              value="<%= clientFamilyNumber %>">

            <input
              type="hidden"
              name="year"
              value="<%= currentYear %>">

            <input
              type="hidden"
              id="useMasterVerification"
              name="useMasterVerification"
              value="true">

            <input
              type="hidden"
              id="verificationApproved"
              name="verificationApproved"
              value="<%= isPaidSlipWorkflowUserSafe ? 'false' : 'true' %>">

            <input
              type="hidden"
              id="useMasterBank"
              name="useMasterBank"
              value="true">

            <input
              type="hidden"
              id="collectionAccount"
              name="collectionAccount"
              value="<%= clientMasterBankNameSafe %>">

            <input
              type="hidden"
              id="collectionAccountApproved"
              name="collectionAccountApproved"
              value="<%= isPaidSlipWorkflowUserSafe ? 'false' : 'true' %>">

            <% if (P.col.pendingDues) { %>
              <div class="mb-3">
                <label class="form-label fw-semibold">
                  Total Dues
                </label>

                <div
                  class="read-box"
                  id="fcTotalDuesBox">
                  <%= fmt(summarySafe.totalDues) %>
                </div>
              </div>
            <% } %>

            <% if (P.col.registrationFee) { %>
              <div class="mb-3">
                <label
                  for="registrationReceivingAmount"
                  class="form-label fw-semibold">
                  Registration Fee Receiving Amount
                </label>

                <input
                  type="number"
                  step="0.01"
                  min="0"
                  class="form-control premium-input"
                  id="registrationReceivingAmount"
                  name="registrationReceivingAmount"
                  placeholder="<%= hasRegistrationFeeDue ? 'Enter registration fee amount' : 'Registration fee already fully received' %>"
                  <%= (
                    canReceivePayment &&
                    hasRegistrationFeeDue
                  ) ? '' : 'disabled' %>>

                <div class="tiny text-muted mt-1">
                  Registration fee will only be received in the admission month
                </div>
              </div>
            <% } %>

            <% if (P.col.fees) { %>
              <div class="mb-3">
                <label
                  for="receivingAmount"
                  class="form-label fw-semibold">
                  Monthly Fee Receiving Amount
                </label>

                <input
                  type="number"
                  step="0.01"
                  min="0"
                  class="form-control premium-input"
                  id="receivingAmount"
                  name="receivingAmount"
                  placeholder="Enter received amount"
                  <%= canReceivePayment ? '' : 'disabled' %>>
              </div>
            <% } %>

            <% if (P.col.pendingDues) { %>
              <div class="mb-3">
                <label class="form-label fw-semibold">
                  Remaining Balance After This Receive
                </label>

                <div
                  class="read-box"
                  id="fcRemainingBalance">
                  <%= fmt(summarySafe.totalDues) %>
                </div>
              </div>
            <% } %>

            <% if (P.col.verif) { %>
              <div class="mb-3">
                <label
                  for="verificationNumber"
                  class="form-label fw-semibold">
                  Verification Number
                </label>

                <div class="input-group verification-group">
                  <input
                    type="text"
                    class="form-control premium-input"
                    id="verificationNumber"
                    name="verificationNumber"
                    value="<%= clientMasterVerificationNumberSafe %>"
                    placeholder="No verification number saved"
                    readonly>

                  <button
                    type="button"
                    class="btn btn-verify-choice verify-yes <%= isPaidSlipWorkflowUserSafe ? '' : 'active' %>"
                    id="verificationUseSavedBtn"
                    title="<%= isPaidSlipWorkflowUserSafe ? 'Approve saved verification number' : 'Use saved verification number' %>"
                    <%= canReviewVerificationNumber ? '' : 'disabled' %>>
                    ✓
                  </button>

                  <button
                    type="button"
                    class="btn btn-verify-choice verify-no"
                    id="verificationEditBtn"
                    title="<%= isPaidSlipWorkflowUserSafe
                      ? 'Mark verification number incorrect'
                      : (
                          canEditVerificationNumber
                            ? 'Enter correct verification number'
                            : 'No permission to edit verification number'
                        ) %>"
                    <%= (
                      isPaidSlipWorkflowUserSafe
                        ? !canReviewVerificationNumber
                        : !canEditVerificationNumber
                    ) ? 'disabled' : '' %>>
                    ✕
                  </button>
                </div>

                <div
                  class="tiny text-muted mt-1"
                  id="verificationHelpText">
                  <% if (isPaidSlipWorkflowUserSafe) { %>
                    Check the saved verification number. Tick ✓ approves it; cross ✕ sends it for correction.
                  <% } else if (canEditVerificationNumber) { %>
                    Tick ✓ will use saved verification number. Cross ✕ will allow correction.
                  <% } else { %>
                    Saved verification number will be used. You do not have permission to change it.
                  <% } %>
                </div>
              </div>
            <% } %>

            <% if (P.col.bank) { %>
              <div class="mb-3">
                <label
                  for="collectionAccountSelect"
                  class="form-label fw-semibold">
                  Collection Account
                </label>

                <div class="input-group bank-group">
                  <select
                    class="form-select premium-input bank-locked"
                    id="collectionAccountSelect"
                    name="collectionAccountSelect"
                    aria-disabled="true">
                    <option value="">Select account</option>

                    <% clientBankOptionsSafe.forEach((b) => { %>
                      <option
                        value="<%= b.label %>"
                        <%= (
                          String(clientMasterBankNameSafe).trim() ===
                          String(b.label).trim()
                        ) ? 'selected' : '' %>>
                        <%= b.label %>
                      </option>
                    <% }) %>
                  </select>

                  <button
                    type="button"
                    class="btn btn-verify-choice verify-yes <%= isPaidSlipWorkflowUserSafe ? '' : 'active' %>"
                    id="bankUseSavedBtn"
                    title="<%= isPaidSlipWorkflowUserSafe ? 'Approve saved collection account' : 'Use saved bank' %>"
                    <%= canReviewBank ? '' : 'disabled' %>>
                    ✓
                  </button>

                  <button
                    type="button"
                    class="btn btn-verify-choice verify-no"
                    id="bankEditBtn"
                    title="<%= isPaidSlipWorkflowUserSafe
                      ? 'Mark collection account incorrect'
                      : (
                          canEditBank
                            ? 'Select correct bank'
                            : 'No permission to edit bank'
                        ) %>"
                    <%= (
                      isPaidSlipWorkflowUserSafe
                        ? !canReviewBank
                        : !canEditBank
                    ) ? 'disabled' : '' %>>
                    ✕
                  </button>
                </div>

                <div
                  class="tiny text-muted mt-1"
                  id="bankHelpText">
                  <% if (isPaidSlipWorkflowUserSafe) { %>
                    Check the saved collection account. Tick ✓ approves it; cross ✕ sends it for correction.
                  <% } else if (canEditBank) { %>
                    Tick ✓ will use saved bank. Cross ✕ will allow bank correction.
                  <% } else { %>
                    Saved bank will be used. You do not have permission to change it.
                  <% } %>
                </div>
              </div>
            <% } %>

            <div class="mb-3">
              <label
                for="receivingDate"
                class="form-label fw-semibold">
                Receiving Date
              </label>

              <input
                type="date"
                class="form-control premium-input"
                id="receivingDate"
                name="receivingDate"
                value="<%= new Date().toISOString().slice(0, 10) %>"
                required
                <%= canReceivePayment ? '' : 'disabled' %>>
            </div>

            <div class="mb-3">
              <label
                for="note"
                class="form-label fw-semibold">
                Note
              </label>

              <textarea
                class="form-control premium-input"
                id="note"
                name="note"
                rows="4"
                placeholder="Optional note"
                <%= canReceivePayment ? '' : 'disabled' %>
              ></textarea>
            </div>

            <% if (isPaidSlipWorkflowUserSafe) { %>
              <div
                class="paid-slip-approval-panel mb-3"
                id="paidSlipApprovalPanel">
                <div class="paid-slip-approval-title">
                  <i class="bi bi-shield-check"></i>
                  Paid Slip approvals
                </div>

                <div class="paid-slip-approval-items">
                  <% if (P.col.verif) { %>
                    <span
                      class="paid-slip-approval-chip pending"
                      id="verificationApprovalChip">
                      Verification Number: Pending
                    </span>
                  <% } %>

                  <% if (P.col.bank) { %>
                    <span
                      class="paid-slip-approval-chip pending"
                      id="bankApprovalChip">
                      Collection Account: Pending
                    </span>
                  <% } %>
                </div>

                <div
                  class="tiny text-muted mt-2"
                  id="paidSlipApprovalHelp">
                  <% if (canCompletePaidSlipReview) { %>
                    For a payment amount, approve both fields before Receive becomes available.
                  <% } else { %>
                    Verification Number and Collection Account View permissions are required for Paid Slip approval.
                  <% } %>
                </div>
              </div>
            <% } %>

            <% if (!canUseFeeCollectionActions) { %>
              <div class="alert alert-warning py-2 px-3">
                You do not have permission to receive or update billing data.
              </div>
            <% } %>

            <div class="d-grid">
              <button
                type="submit"
                class="btn btn-receive rounded-3"
                id="receiveBtn"
                <%= (
                  !canReceivePayment ||
                  isPaidSlipWorkflowUserSafe
                ) ? 'disabled' : '' %>>
                <i class="bi bi-cash-coin me-1"></i>
                Receive
              </button>
            </div>
          </form>

          <div id="fcMsg" class="mt-3"></div>

          <div class="card border-0 result-card mt-3 d-none" id="fcResultCard">
            <div class="card-body p-3">
              <div class="sec-title mb-2">Last Receive Result</div>
              <div id="fcResultBody" class="small text-muted"></div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>


<!-- Paid Slip correction / Record to Update forwarding modal -->
<div
  class="modal fade"
  id="feeWorkflowForwardModal"
  tabindex="-1"
  aria-hidden="true"
  data-bs-backdrop="static"
  data-bs-keyboard="false">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg rounded-4 fee-workflow-modal">
      <div class="modal-header border-0 pb-2">
        <div>
          <h5 class="modal-title mb-1" id="feeWorkflowModalTitle">
            Forward Admission
          </h5>
          <div class="small text-muted" id="feeWorkflowModalDescription">
            Select the user who should receive this admission.
          </div>
        </div>

        <button
          type="button"
          class="btn-close"
          id="feeWorkflowModalCloseBtn"
          data-bs-dismiss="modal"
          aria-label="Close">
        </button>
      </div>

      <div class="modal-body pt-1">
        <div class="fee-workflow-destination mb-3">
          <div class="tiny text-uppercase fw-bold text-muted">Destination</div>
          <div class="fw-bold mt-1" id="feeWorkflowDestinationLabel">-</div>
        </div>

        <div class="d-none" id="feeWorkflowIssueSection">
          <label class="form-label fw-semibold mb-2">Incorrect fields</label>

          <div class="d-grid gap-2 mb-3">
            <label class="fee-workflow-field-option">
              <input
                type="checkbox"
                class="form-check-input"
                id="feeIssueVerification"
                value="Verification Number">
              <span>
                <b>Verification Number</b>
                <small>The saved verification/reference number is incorrect.</small>
              </span>
            </label>

            <label class="fee-workflow-field-option">
              <input
                type="checkbox"
                class="form-check-input"
                id="feeIssueCollectionAccount"
                value="Collection Account">
              <span>
                <b>Collection Account</b>
                <small>The saved bank/collection account is incorrect.</small>
              </span>
            </label>
          </div>

          <div class="mb-3">
            <label for="feeWorkflowIssueMessage" class="form-label fw-semibold">
              Correction message
            </label>
            <textarea
              class="form-control premium-input"
              id="feeWorkflowIssueMessage"
              rows="3"
              placeholder="Explain what needs to be corrected"></textarea>
          </div>
        </div>

        <div class="mb-2">
          <label for="feeWorkflowTargetUserId" class="form-label fw-semibold">
            Assign to Agent / Sub-Agent
          </label>

          <select
            class="form-select premium-input"
            id="feeWorkflowTargetUserId"
            disabled>
            <option value="">Select destination first</option>
          </select>

          <div class="tiny text-muted mt-1" id="feeWorkflowTargetUserHint">
            Matching users will load automatically.
          </div>
        </div>

        <div class="alert alert-danger py-2 px-3 mt-3 mb-0 d-none" id="feeWorkflowModalError"></div>
      </div>

