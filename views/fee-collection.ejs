let feeCollectionNavigationStarted = false;

function isDashboardPath(pathname) {
  const cleanPath =
    String(pathname || '').trim();

  if (cleanPath === '/dashboard') {
    return true;
  }

  if (!cleanPath.startsWith('/dashboard/')) {
    return false;
  }

  const isNestedDashboardPage =
    cleanPath.includes('/admission/') ||
    cleanPath.includes('/fee-collection') ||
    cleanPath.includes('/files');

  return !isNestedDashboardPage;
}

function isAdmissionDetailsPath(pathname) {
  const cleanPath =
    String(pathname || '').trim();

  return /^\/dashboard\/admission\/[^/]+\/?$/
    .test(cleanPath);
}

function getSafeFeeCollectionReturnUrl() {
  const params =
    new URLSearchParams(
      window.location.search
    );

  const rawReturnTo =
    String(
      params.get('returnTo') || ''
    ).trim();

  if (!rawReturnTo) {
    return '';
  }

  try {
    const targetUrl =
      new URL(
        rawReturnTo,
        window.location.origin
      );

    const isSafe =
      targetUrl.origin ===
        window.location.origin &&
      isDashboardPath(
        targetUrl.pathname
      );

    if (!isSafe) {
      return '';
    }

    return (
      targetUrl.pathname +
      targetUrl.search +
      targetUrl.hash
    );
  } catch (error) {
    return '';
  }
}

function buildFeeCollectionDetailsUrl(
  rawUrl,
  billingYear,
  returnUrl
) {
  const safeAbsoluteUrl =
    getSafeFeeCollectionNavigationUrl(
      rawUrl
    );

  if (!safeAbsoluteUrl) {
    return '';
  }

  try {
    const targetUrl =
      new URL(safeAbsoluteUrl);

    if (
      !isAdmissionDetailsPath(
        targetUrl.pathname
      )
    ) {
      return '';
    }

    const yearNumber =
      Number(billingYear || 0);

    if (
      Number.isInteger(yearNumber) &&
      yearNumber >= 2020 &&
      yearNumber <= 2100
    ) {
      targetUrl.searchParams.set(
        'year',
        String(yearNumber)
      );
    }

    if (returnUrl) {
      targetUrl.searchParams.set(
        'returnTo',
        returnUrl
      );
    }

    return (
      targetUrl.pathname +
      targetUrl.search +
      targetUrl.hash
    );
  } catch (error) {
    return '';
  }
}

function didComeFromAdmissionDetails() {
  if (!document.referrer) {
    return false;
  }

  try {
    const previousUrl =
      new URL(document.referrer);

    return (
      previousUrl.origin ===
        window.location.origin &&
      isAdmissionDetailsPath(
        previousUrl.pathname
      )
    );
  } catch (error) {
    return false;
  }
}

function isPlainFeeCollectionNavigationClick(event) {
  return !!(
    event &&
    !event.defaultPrevented &&
    event.button === 0 &&
    !event.metaKey &&
    !event.ctrlKey &&
    !event.shiftKey &&
    !event.altKey
  );
}

function getSafeFeeCollectionNavigationUrl(rawUrl) {
  const cleanUrl =
    String(rawUrl || '').trim();

  if (!cleanUrl) {
    return '';
  }

  try {
    const targetUrl =
      new URL(
        cleanUrl,
        window.location.origin
      );

    if (
      targetUrl.origin !==
      window.location.origin
    ) {
      return '';
    }

    return targetUrl.href;
  } catch (error) {
    return '';
  }
}

function navigateFeeCollectionWithLoader(
  targetUrl,
  options = {}
) {
  const shouldReload =
    options.reload === true;

  const safeTarget =
    shouldReload
      ? window.location.href
      : getSafeFeeCollectionNavigationUrl(
          targetUrl
        );

  if (
    !safeTarget ||
    feeCollectionNavigationStarted
  ) {
    return false;
  }

  feeCollectionNavigationStarted = true;

  const commitNavigation = function () {
    if (shouldReload) {
      window.location.reload();
      return;
    }

    window.location.assign(
      safeTarget
    );
  };

  if (
    window.IVSLoader &&
    typeof window.IVSLoader.show ===
      'function'
  ) {
    window.IVSLoader.show({
      persist: true
    });

    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        setTimeout(
          commitNavigation,
          FEE_COLLECTION_NAVIGATION_HOLD_MS
        );
      });
    });

    return true;
  }

  commitNavigation();
  return true;
}

function goBackFeeCollectionWithLoader() {
  if (feeCollectionNavigationStarted) {
    return false;
  }

  feeCollectionNavigationStarted = true;

  const commitNavigation =
    function () {
      window.history.back();
    };

  if (
    window.IVSLoader &&
    typeof window.IVSLoader.show ===
      'function'
  ) {
    window.IVSLoader.show({
      persist: true
    });

    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        setTimeout(
          commitNavigation,
          FEE_COLLECTION_NAVIGATION_HOLD_MS
        );
      });
    });

    return true;
  }

  commitNavigation();
  return true;
}

feeCollectionBackLink?.addEventListener(
  'click',
  function (event) {
    if (
      !isPlainFeeCollectionNavigationClick(
        event
      )
    ) {
      return;
    }

    const targetName =
      String(
        feeCollectionBackLink.getAttribute(
          'target'
        ) || ''
      )
        .trim()
        .toLowerCase();

    if (
      targetName &&
      targetName !== '_self'
    ) {
      return;
    }

    const targetUrl =
      feeCollectionBackLink.getAttribute(
        'href'
      ) ||
      feeCollectionBackUrl;

    if (
      !getSafeFeeCollectionNavigationUrl(
        targetUrl
      )
    ) {
      return;
    }

    event.preventDefault();

    if (
      window.history.length > 1 &&
      cameFromFeeCollectionDetails
    ) {
      goBackFeeCollectionWithLoader();
      return;
    }

    navigateFeeCollectionWithLoader(
      targetUrl
    );
  }
);

