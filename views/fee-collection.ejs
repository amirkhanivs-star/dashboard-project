        if (collectionAccountApprovedInput) {
          collectionAccountApprovedInput.value = useSaved ? 'true' : 'false';
        }

        bankUseSavedBtn?.classList.toggle('active', useSaved);
        bankEditBtn?.classList.toggle('active', !useSaved);

