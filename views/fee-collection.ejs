    function formatWorkflowPipelineType(value = '') {
      const key = String(value || '').trim().toLowerCase();

      if (key === 'print_record_update') {
        return 'Print + Record Update';
      }

      if (key === 'verification_registration') {
        return 'Verification & Registration';
      }

      if (key === 'paid_slip') {
        return 'Paid Slip';
      }

      return cleanWorkflowText(value)
        .replace(/_/g, ' ')
        .replace(/\b\w/g, (char) => char.toUpperCase()) || '-';
    }

