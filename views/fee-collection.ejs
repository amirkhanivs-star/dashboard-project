    function showDuplicateVerificationConflict(error) {
      const responseData =
        error &&
        error.responseData &&
        typeof error.responseData === 'object'
          ? error.responseData
          : {};

      const detail =
        responseData.duplicateVerification &&
        typeof responseData.duplicateVerification === 'object'
          ? responseData.duplicateVerification
          : {};

      const code = String(
        responseData.code ||
        detail.code ||
        ''
      ).trim();

      const field = String(
        responseData.field ||
        detail.field ||
        ''
      ).trim();

      if (
        code !== 'DUPLICATE_VERIFICATION_NUMBER' &&
        field !== 'verificationNumber'
      ) {
        return false;
      }

      const admissions =
        Array.isArray(responseData.admissions)
          ? responseData.admissions
          : (
              Array.isArray(detail.admissions)
                ? detail.admissions
                : []
            );

      const duplicateType = String(
        responseData.duplicateType ||
        detail.duplicateType ||
        ''
      ).trim();

      const isFamily =
        responseData.isFamily === true ||
        detail.isFamily === true ||
        duplicateType === 'family' ||
        admissions.length > 1;

      const familyNumber = String(
        responseData.familyNumber ||
        detail.familyNumber ||
        ''
      ).trim();

      const matchedVerificationNumber = String(
        detail.matchedVerificationNumber ||
        detail.submittedVerificationNumber ||
        verificationInput?.value ||
        ''
      ).trim();

      const familyLabel =
        familyNumber
          ? `Family #${familyNumber}`
          : (
              isFamily
                ? 'Auto-matched family (Family Number not assigned)'
                : ''
            );

      const conflictTypeLabel =
        isFamily
          ? 'Family'
          : 'Single Admission';

      const conflictMessage = String(
        responseData.message ||
        detail.message ||
        error.message ||
        'This Verification Number is already in use.'
      ).trim();

      clearVerificationDuplicateState();

      if (verificationInput) {
        verificationInput.classList.add(
          'verification-duplicate-input'
        );

        verificationInput.setAttribute(
          'aria-invalid',
          'true'
        );

        verificationInput.scrollIntoView({
          behavior: 'smooth',
          block: 'center'
        });
      }

      if (verificationConflictSummaryEl) {
        const summaryParts = [
          conflictMessage,

          `Verification Number: ${
            matchedVerificationNumber ||
            'Entered number'
          }`,

          `Conflict Type: ${conflictTypeLabel}`
        ];

        if (familyLabel) {
          summaryParts.push(
            `Family: ${familyLabel}`
          );
        }

        verificationConflictSummaryEl.textContent =
          summaryParts.join(' | ');
      }

      if (verificationConflictListEl) {
        if (admissions.length) {
          verificationConflictListEl.innerHTML =
            admissions.map(function (admission) {
              const studentName = String(
                admission?.studentName ||
                admission?.student_name ||
                'Unnamed Student'
              ).trim();

              const admissionId = Number(
                admission?.admissionId ||
                admission?.id ||
                0
              );

              const entryNumber = String(
                admission?.entryNumber ||
                admission?.entry_number ||
                ''
              ).trim();

              const admissionText =
                admissionId
                  ? `Admission ID #${admissionId}`
                  : 'Admission ID not available';

              const entryText =
                entryNumber &&
                entryNumber !== String(admissionId || '')
                  ? ` | Entry #${entryNumber}`
                  : '';

              return `
                <div class="fee-verification-conflict-item">
                  <div class="fee-verification-conflict-name">
                    ${escapeHtml(studentName)}
                  </div>

                  <div class="fee-verification-conflict-meta">
                    ${escapeHtml(admissionText + entryText)}
                  </div>
                </div>
              `;
            }).join('');
        } else {
          verificationConflictListEl.innerHTML = `
            <div class="fee-verification-conflict-item">
              <div class="fee-verification-conflict-name">
                Conflict details
              </div>

              <div class="fee-verification-conflict-meta">
                ${escapeHtml(
                  responseData.message ||
                  detail.message ||
                  error.message ||
                  'This Verification Number is already in use.'
                )}
              </div>
            </div>
          `;
        }
      }

      const modalInstance =
        getVerificationConflictModalInstance();

      if (modalInstance) {
        modalInstance.show();
      } else {
        showMsg(
          'error',
          escapeHtml(conflictMessage)
        );
      }

      return true;
    }

