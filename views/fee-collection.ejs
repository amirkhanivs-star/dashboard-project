    function clearVerificationDuplicateState() {
      if (!verificationInput) return;

      verificationInput.classList.remove(
        'verification-duplicate-input'
      );

      verificationInput.removeAttribute(
        'aria-invalid'
      );
    }

    function getVerificationConflictModalInstance() {
      if (
        !verificationConflictModalEl ||
        !window.bootstrap?.Modal
      ) {
        return null;
      }

      return window.bootstrap.Modal.getOrCreateInstance(
        verificationConflictModalEl
      );
