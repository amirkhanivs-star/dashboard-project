</div>

<% if (safePipelineTransferInfo.eligible && !isAgentRoute) { %>
  <div class="col-12">
    <div
      class="pipeline-transfer-warning"
      id="pipelineTransferWarning">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <div class="small fw-bold text-danger text-uppercase mb-1">
            <i class="bi bi-arrow-left-right me-1"></i>
            Pipeline Transfer Required
          </div>
          <div class="fw-semibold">
            <span class="transfer-count-badge me-1">
              <%= safePipelineTransferInfo.count || 0 %>
            </span>
            assigned admission(s) are currently in
            <%= safePipelineTransferInfo.currentPipelineLabel || 'this pipeline' %>.
          </div>
          <div class="small text-muted mt-1">
            If you change this user's School Accounts pipeline type, these admissions must be transferred to another
            <%= safePipelineTransferInfo.currentPipelineLabel || 'same pipeline' %> Agent/Sub-Agent.
          </div>
