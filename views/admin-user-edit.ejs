  }

  .agent-edit-purple .accordion-button{
    color: #0f172a !important;
  }

  .agent-edit-purple .accordion-button:not(.collapsed){
    background: #cfe2ff !important;
    color: #084298 !important;
    box-shadow: none !important;
  }
    .agent-role-circle{
    background: linear-gradient(135deg, #8b5cf6, #5b21b6) !important;
    color: #fff !important;
    box-shadow: 0 8px 18px rgba(124, 58, 237, 0.22);
  }

  .agent-role-badge-edit{
    background: rgba(124, 58, 237, 0.14) !important;
    color: #5b21b6 !important;
    border: 1px solid rgba(124, 58, 237, 0.30) !important;
    box-shadow: 0 4px 12px rgba(124, 58, 237, 0.10);
  }

  .agent-role-badge-edit i{
    color: #5b21b6 !important;
  }
  .subagent-role-circle{
    background: linear-gradient(135deg, #60a5fa 0%, #2563eb 100%) !important;
    color: #fff !important;
    box-shadow: 0 8px 18px rgba(37, 99, 235, 0.22);
  }

  .subagent-role-badge{
    background: rgba(59, 130, 246, 0.12) !important;
    color: #1d4ed8 !important;
    border: 1px solid rgba(59, 130, 246, 0.28) !important;
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.10);
  }
  .edit-user-link-preview{
    margin-top: 8px;
    width: 100%;
  }

  .edit-user-link-mini{
    display: flex;
    align-items: flex-start;
    gap: 7px;
    width: 100%;
    padding: 6px 8px;
    border-radius: 10px;
    font-size: .70rem;
    font-weight: 800;
    line-height: 1.25;
    border: 1px solid transparent;
  }

  .edit-user-link-mini i{
    font-size: .74rem;
    line-height: 1.2;
    margin-top: 1px;
    flex: 0 0 auto;
  }

  .edit-user-link-text{
    flex: 1 1 auto;
    min-width: 0;
    white-space: normal;
    overflow: visible;
    text-overflow: unset;
    overflow-wrap: anywhere;
    word-break: break-word;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: .66rem;
    font-weight: 800;
  }

  .edit-user-link-copy{
    width: 23px;
