    font-size: .66rem;
    font-weight: 700;
  }

  .permission-groups-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .permission-group-card {
    min-width: 0;
    overflow: hidden;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    background: #ffffff;
  }

  .permission-group-title {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 9px 10px;
    border-bottom: 1px solid #e5e7eb;
    background: #f8fafc;
    color: #1f2937;
    font-size: .74rem;
    font-weight: 800;
  }

  .permission-group-title i {
    font-size: .78rem;
  }

  .permission-matrix-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 43px 43px;
    align-items: stretch;
    min-height: 34px;
    border-top: 1px solid #f1f5f9;
  }

  .permission-matrix-row:first-of-type {
    border-top: 0;
