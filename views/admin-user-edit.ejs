            </div>
<div class="mb-2">
  <h6 class="mb-1">2. Column View/Edit &amp; Button Permissions</h6>
    <p class="text-muted small mb-2">
  Review the user's saved Can View, Can Edit, button, and special permissions.
</p>
</div>

            <div class="accordion" id="permAccordion">

              <!-- Columns -->
              <div class="accordion-item border-0 shadow-sm rounded-4 mb-2">
                <h2 class="accordion-header" id="headingCols">
                  <button class="accordion-button rounded-4" type="button" data-bs-toggle="collapse" data-bs-target="#collapseCols" aria-expanded="true" aria-controls="collapseCols">
                    <i class="bi bi-table me-2 <%= themeAccordionBtnIconClass %>"></i>
                   Admissions pipeline Columns
                  </button>
                </h2>

                <div
                  id="collapseCols"
                  class="accordion-collapse collapse show"
                  aria-labelledby="headingCols"
                  data-bs-parent="#permAccordion">

                  <div class="accordion-body">
                    <div class="permission-legend">
                      <span class="permission-legend-item">
                        <i class="bi bi-eye text-success"></i>
                        Can View
                      </span>

                      <span class="permission-legend-item">
                        <i class="bi bi-pencil-square text-primary"></i>
                        Can Edit
                      </span>

                      <span class="permission-legend-item">
                        <i class="bi bi-lock-fill text-secondary"></i>
                        Not available
                      </span>
                    </div>

                    <!--
                      Parent ke paas View permission nahi hai to field
                      show nahi hogi, lekin explicit OFF submit hoga.
                    -->
                    <% COLUMN_PERMISSION_GROUPS.forEach(function(group) { %>
                      <% group.items.forEach(function(item) { %>
                        <% if (!isAllowed(item.view)) { %>
                          <input
                            type="hidden"
                            name="<%= item.view %>"
                            value="">

                          <% if (item.edit) { %>
                            <input
                              type="hidden"
                              name="<%= item.edit %>"
                              value="">
                          <% } %>
                        <% } %>
                      <% }) %>
                    <% }) %>

                    <%
                      const visibleColumnGroups =
                        COLUMN_PERMISSION_GROUPS
                          .map(function(group) {
                            return {
                              title: group.title,
                              icon: group.icon,
                              items: group.items.filter(function(item) {
                                return isAllowed(item.view);
                              })
                            };
                          })
                          .filter(function(group) {
                            return group.items.length > 0;
                          });
                    %>

                    <% if (!visibleColumnGroups.length) { %>
                      <div class="alert alert-light border small mb-0">
                        You do not currently have any column permissions
                        that can be assigned to this user.
                      </div>
                    <% } else { %>
                      <div class="permission-groups-grid">
                        <% visibleColumnGroups.forEach(function(group) { %>
                          <div class="permission-group-card">
                            <div class="permission-group-title">
                              <i class="bi <%= group.icon %> <%= themeAccordionBtnIconClass %>"></i>
                              <span><%= group.title %></span>
                            </div>

                            <div class="permission-matrix-row permission-matrix-head">
                              <span>Column</span>
                              <span class="permission-cell">View</span>
                              <span class="permission-cell">Edit</span>
                            </div>

                            <% group.items.forEach(function(item) { %>
                              <%
                                const canGrantEdit =
                                  !!item.edit &&
                                  isAllowed(item.edit);
                              %>

                              <div class="permission-matrix-row">
                                <label
                                  class="permission-field-label"
                                  for="<%= item.view %>">
                                  <%= item.label %>
                                </label>

                                <div class="permission-cell">
                                  <input
                                    type="hidden"
                                    name="<%= item.view %>"
                                    value="">

                                  <input
                                    class="form-check-input col-toggle view-toggle"
                                    type="checkbox"
                                    id="<%= item.view %>"
                                    name="<%= item.view %>"
                                    value="on"
                                    data-edit-target="<%= canGrantEdit ? item.edit : '' %>"
                                    title="Can View: <%= item.label %>"
                                    aria-label="Can View <%= item.label %>"
                                    <%= isChecked(item.view) ? 'checked' : '' %>>
                                </div>

                                <div class="permission-cell">
                                  <% if (canGrantEdit) { %>
                                    <input
                                      type="hidden"
                                      name="<%= item.edit %>"
                                      value="">

                                    <input
                                      class="form-check-input edit-toggle"
                                      type="checkbox"
                                      id="<%= item.edit %>"
                                      name="<%= item.edit %>"
                                      value="on"
                                      data-view-target="<%= item.view %>"
                                      title="Can Edit: <%= item.label %>"
                                      aria-label="Can Edit <%= item.label %>"
                                      <%= (
                                        isChecked(item.view) &&
                                        isChecked(item.edit)
                                      ) ? 'checked' : '' %>>
                                  <% } else { %>
                                    <% if (item.edit) { %>
                                      <input
                                        type="hidden"
                                        name="<%= item.edit %>"
                                        value="">
                                    <% } %>

                                    <span
                                      class="permission-lock"
                                      title="<%= item.edit
                                        ? 'You do not have Can Edit permission for this column'
                                        : 'This value is calculated or system controlled' %>">
                                      <i class="bi bi-lock-fill"></i>
                                    </span>
                                  <% } %>
                                </div>
                              </div>
                            <% }) %>
                          </div>
                        <% }) %>
                      </div>
                    <% } %>
                  </div>
                </div>
              </div>

              <!-- Buttons -->
              <div class="accordion-item border-0 shadow-sm rounded-4">
                <h2 class="accordion-header" id="headingBtns">
                  <button class="accordion-button collapsed rounded-4" type="button" data-bs-toggle="collapse" data-bs-target="#collapseBtns" aria-expanded="false" aria-controls="collapseBtns">
                    <i class="bi bi-hand-index-thumb me-2 <%= themeButtonsIconClass %>"></i>
                    Buttons
                  </button>
                </h2>

                <div id="collapseBtns" class="accordion-collapse collapse" aria-labelledby="headingBtns" data-bs-parent="#permAccordion">
                  <div class="accordion-body">
                    <% if (!BTN_KEYS.length) { %>
                      <div class="alert alert-light border small mb-0">
                        Only the buttons allowed for this admin can be assigned here.
                      </div>
                    <% } else { %>
                      <div class="row g-2">
                        <% BTN_KEYS.forEach(function(k){ %>
                          <div class="col-md-4">
                            <div class="form-check small">
                             <% if (canEditPerms) { %>
  <input type="hidden" name="<%= k %>" value="">
  <input class="form-check-input perm-toggle" type="checkbox" id="<%= k %>" name="<%= k %>" value="on"
         <%= isChecked(k) ? 'checked' : '' %>>
<% } else { %>
  <input type="hidden" name="<%= k %>" value="<%= isChecked(k) ? 'on' : '' %>">
  <input class="form-check-input perm-toggle" type="checkbox" id="<%= k %>" value="on"
         <%= isChecked(k) ? 'checked' : '' %> disabled>
<% } %>
                              <label class="form-check-label" for="<%= k %>"><%= BTN_LABELS[k] %></label>
                            </div>
                          </div>
                        <% }) %>
                      </div>
                    <% } %>
                  </div>
                </div>
              </div>

            </div>

            <hr>

            <div class="d-flex justify-content-between">
              <!-- ✅ FIXED: Cancel link -->
              <a href="<%= BASE_PATH %>/users" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                Cancel
              </a>

              <button type="submit" class="btn <%= themeBtnClass %> rounded-pill px-4">
                <i class="bi bi-save me-1"></i>
                Save Changes
              </button>
            </div>

          </form>

          <% if (safePipelineTransferInfo.eligible && !isAgentRoute) { %>
          <div class="modal fade" id="pipelineTransferModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
              <div class="modal-content pipeline-transfer-modal-card shadow-lg">
                <div class="modal-header pipeline-transfer-modal-head border-0">
                  <div>
                    <h5 class="modal-title fw-bold mb-1">
                      <i class="bi bi-arrow-left-right me-2"></i>
                      Transfer Assigned Admissions
                    </h5>
                    <div class="small opacity-75">
                      Required before changing this School Accounts pipeline type.
                    </div>
                  </div>
                  <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                  <div class="pipeline-transfer-target-card mb-3">
                    <div class="row g-3 align-items-center">
                      <div class="col-md-4">
                        <div class="small text-muted">Current user</div>
                        <div class="fw-bold"><%= safePipelineTransferInfo.sourceUserName || editUser.name || 'Current user' %></div>
                      </div>
                      <div class="col-md-4">
                        <div class="small text-muted">Old pipeline type</div>
                        <div class="fw-bold"><%= safePipelineTransferInfo.currentPipelineLabel || '—' %></div>
                      </div>
                      <div class="col-md-4">
                        <div class="small text-muted">Admissions to transfer</div>
                        <div class="fw-bold text-danger"><%= safePipelineTransferInfo.count || 0 %></div>
                      </div>
                    </div>
                  </div>

                  <label class="form-label small fw-semibold">
                    Select target <%= safePipelineTransferInfo.currentPipelineLabel || 'same pipeline' %> Agent/Sub-Agent
                  </label>

                  <select id="pipelineTransferTargetSelect" class="form-select">
                    <option value="">Select user to receive admissions</option>
                    <% (safePipelineTransferInfo.targets || []).forEach(function(target) { %>
                      <option value="<%= target.id %>">
                        <%= target.name %>
                        <% if (target.role) { %>
                          - <%= String(target.role).replace(/_/g, ' ') %>
                        <% } %>
                        <% if (target.email) { %>
                          (<%= target.email %>)
                        <% } %>
                      </option>
                    <% }) %>
                  </select>

                  <% if (!(safePipelineTransferInfo.targets || []).length) { %>
                    <div class="alert alert-warning small mt-3 mb-0">
                      No same pipeline Agent/Sub-Agent found. Please create another
                      <%= safePipelineTransferInfo.currentPipelineLabel || 'same pipeline' %>
                      user first, then come back and change this user.
                    </div>
                  <% } %>

                  <div class="pipeline-transfer-note mt-3" id="pipelineTransferNotePreview">
                    Transfer note will be saved in admission history after selecting a target user.
                  </div>
                </div>

                <div class="modal-footer border-0">
                  <button type="button" class="btn btn-outline-secondary rounded-pill px-3" data-bs-dismiss="modal">
                    Cancel
                  </button>
                  <button
                    type="button"
                    class="btn btn-danger rounded-pill px-4"
                    id="confirmPipelineTransferBtn"
                    <%= !(safePipelineTransferInfo.targets || []).length ? 'disabled' : '' %>>
                    <i class="bi bi-check2-circle me-1"></i>
                    Transfer & Save
                  </button>
                </div>
              </div>
            </div>
          </div>
          <% } %>

        </div>
      </div>
    </div>
  </div>

</div>

<script>
  (function () {
    const btnViewAll = document.getElementById("btnViewAll");
    const btnViewNone = document.getElementById("btnViewNone");
    const btnEditAll = document.getElementById("btnEditAll");
    const btnEditNone = document.getElementById("btnEditNone");
    const btnButtonsAll = document.getElementById("btnButtonsAll");
    const btnButtonsNone = document.getElementById("btnButtonsNone");
    const editUserForm = document.getElementById("editUserForm");
    const agentTypeSelect = document.getElementById("agentTypeSelect");
    const pipelineTransferTargetUserIdInput = document.getElementById("pipelineTransferTargetUserId");
    const pipelineTransferWarning = document.getElementById("pipelineTransferWarning");
    const pipelineTransferModalEl = document.getElementById("pipelineTransferModal");
    const pipelineTransferTargetSelect = document.getElementById("pipelineTransferTargetSelect");
    const confirmPipelineTransferBtn = document.getElementById("confirmPipelineTransferBtn");
    const pipelineTransferNotePreview = document.getElementById("pipelineTransferNotePreview");

    const pipelineTransferInfo = <%- pipelineTransferInfoJson %>;
    let pipelineTransferConfirmed = false;

        const editUserNameInput = document.getElementById("editUserNameInput");
    const editUserAdmissionLinkPreview = document.getElementById("editUserAdmissionLinkPreview");
    const copyEditUserAdmissionLinkBtn = document.getElementById("copyEditUserAdmissionLinkBtn");

    const admissionFormBaseUrl = "<%= typeof admissionFormBaseUrl !== 'undefined' ? admissionFormBaseUrl : 'https://ivs-admission-form.onrender.com/' %>";
        function buildAdmissionLinkFromName(name) {
      const cleanName = String(name || "").trim();
      const baseUrl = String(admissionFormBaseUrl || "https://ivs-admission-form.onrender.com/")
        .trim()
        .replace(/\?+$/, "")
        .replace(/\/+$/, "/");

      if (!cleanName) return "";

      return baseUrl + "?sentBy=" + encodeURIComponent(cleanName);
    }

    function syncEditUserAdmissionLinkPreview() {
      if (!editUserNameInput || !editUserAdmissionLinkPreview) return;

      const link = buildAdmissionLinkFromName(editUserNameInput.value);
      editUserAdmissionLinkPreview.textContent = link || "Type name to generate link";

      const linkWrap = editUserAdmissionLinkPreview.closest(".edit-user-link-mini");
      if (linkWrap) {
        linkWrap.setAttribute("title", link || "");
      }

      if (copyEditUserAdmissionLinkBtn) {
        copyEditUserAdmissionLinkBtn.disabled = !link;
      }
    }

    async function copyEditUserAdmissionLink(text) {
      const cleanText = String(text || "").trim();
      if (!cleanText) return false;

      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(cleanText);
          return true;
        }

        const textarea = document.createElement("textarea");
        textarea.value = cleanText;
        textarea.style.position = "fixed";
        textarea.style.left = "-9999px";
        textarea.style.top = "-9999px";
        document.body.appendChild(textarea);
        textarea.focus();
        textarea.select();

        const copied = document.execCommand("copy");
        document.body.removeChild(textarea);

        return copied;
      } catch (err) {
        console.error("Admin/Agent edit user admission link copy failed:", err);
        return false;
      }
    }

    function getPipelineTransferTargetName(targetId) {
      const cleanId = String(targetId || "");
      const target = (pipelineTransferInfo.targets || []).find(function (item) {
        return String(item.id || "") === cleanId;
      });

      return target ? String(target.name || target.email || "selected user") : "";
    }

    function shouldShowPipelineTransferPopup() {
      if (pipelineTransferInfo.isAgentRoute) return false;

      if (!pipelineTransferInfo.eligible || Number(pipelineTransferInfo.count || 0) <= 0) {
        return false;
      }

      if (!agentTypeSelect) return false;

      const selectedAgentType = String(agentTypeSelect.value || "");
      const oldPipelineType = String(pipelineTransferInfo.currentPipelineType || "");

      if (!oldPipelineType) return false;

      return selectedAgentType !== oldPipelineType;
    }

    function syncPipelineTransferWarning() {
      if (!pipelineTransferWarning) return;

      if (shouldShowPipelineTransferPopup()) {
        pipelineTransferWarning.classList.add("is-visible");
      } else {
        pipelineTransferWarning.classList.remove("is-visible");

        if (pipelineTransferTargetUserIdInput) {
          pipelineTransferTargetUserIdInput.value = "";
        }

        pipelineTransferConfirmed = false;
      }
    }

    function updatePipelineTransferNotePreview() {
      if (!pipelineTransferNotePreview) return;

      const targetId = pipelineTransferTargetSelect ? pipelineTransferTargetSelect.value : "";
      const targetName = getPipelineTransferTargetName(targetId);

      if (!targetName) {
        pipelineTransferNotePreview.textContent =
          "Transfer note will be saved in admission history after selecting a target user.";
        return;
      }

      const sourceName = pipelineTransferInfo.sourceUserName || "current user";

      pipelineTransferNotePreview.textContent =
        "Transferred by " +
        "<%= user && user.name ? user.name : 'Admin' %>" +
        " from " +
        sourceName +
        " to " +
        targetName +
        " due to pipeline type change.";
    }

    function openPipelineTransferModal() {
      updatePipelineTransferNotePreview();

      if (window.bootstrap && pipelineTransferModalEl) {
        const modal = bootstrap.Modal.getOrCreateInstance(pipelineTransferModalEl);
        modal.show();
        return;
      }

      alert(
        "This user has " +
        pipelineTransferInfo.count +
        " assigned admissions. Please select a target user before saving."
      );
    }
    function syncViewEditPair(viewCheckbox) {
      if (!viewCheckbox) return;

      const editTargetId = String(
        viewCheckbox.getAttribute("data-edit-target") || ""
      ).trim();

      if (!editTargetId) return;

      const editCheckbox = document.getElementById(editTargetId);
      if (!editCheckbox) return;

      if (!viewCheckbox.checked) {
        editCheckbox.checked = false;
        editCheckbox.disabled = true;
      } else {
        editCheckbox.disabled = false;
      }
    }

    function setAllViews(enabled) {
      document.querySelectorAll(".view-toggle").forEach((viewCheckbox) => {
        if (viewCheckbox.disabled) return;

        viewCheckbox.checked = !!enabled;
        syncViewEditPair(viewCheckbox);
      });
    }

    function setAllEdits(enabled) {
      document.querySelectorAll(".edit-toggle").forEach((editCheckbox) => {
        const viewTargetId = String(
          editCheckbox.getAttribute("data-view-target") || ""
        ).trim();

        const viewCheckbox = viewTargetId
          ? document.getElementById(viewTargetId)
          : null;

        if (enabled) {
          if (!viewCheckbox || viewCheckbox.disabled) return;

          viewCheckbox.checked = true;
          editCheckbox.disabled = false;
          editCheckbox.checked = true;
        } else {
          editCheckbox.checked = false;

          if (viewCheckbox) {
            syncViewEditPair(viewCheckbox);
          }
        }
      });
    }

    function setAllButtons(enabled) {
      document.querySelectorAll(".perm-toggle").forEach((checkbox) => {
        if (checkbox.disabled) return;
        checkbox.checked = !!enabled;
      });
    }

    function bindViewEditPermissionRules() {
      document.querySelectorAll(".view-toggle").forEach((viewCheckbox) => {
        viewCheckbox.addEventListener("change", function () {
          syncViewEditPair(this);
        });

        syncViewEditPair(viewCheckbox);
      });

      document.querySelectorAll(".edit-toggle").forEach((editCheckbox) => {
        editCheckbox.addEventListener("change", function () {
          if (!this.checked) return;

          const viewTargetId = String(
            this.getAttribute("data-view-target") || ""
          ).trim();

          const viewCheckbox = viewTargetId
            ? document.getElementById(viewTargetId)
            : null;

          if (viewCheckbox) {
            viewCheckbox.checked = true;
            syncViewEditPair(viewCheckbox);
          }
        });
      });
    }
        if (editUserNameInput) {
      editUserNameInput.addEventListener("input", syncEditUserAdmissionLinkPreview);
    }

    if (copyEditUserAdmissionLinkBtn) {
      copyEditUserAdmissionLinkBtn.addEventListener("click", async function () {
        const link = editUserAdmissionLinkPreview
  ? editUserAdmissionLinkPreview.textContent.trim()
  : "";
if (!link || link === "Type name to generate link") return;

        const oldHtml = copyEditUserAdmissionLinkBtn.innerHTML;
        copyEditUserAdmissionLinkBtn.disabled = true;
        copyEditUserAdmissionLinkBtn.innerHTML = '<i class="bi bi-hourglass-split"></i>';

        const copied = await copyEditUserAdmissionLink(link);

        if (copied) {
          copyEditUserAdmissionLinkBtn.innerHTML = '<i class="bi bi-check2-circle"></i>';
          copyEditUserAdmissionLinkBtn.title = "Copied";
        } else {
          prompt("Copy this admission form link:", link);
          copyEditUserAdmissionLinkBtn.innerHTML = oldHtml;
        }

        setTimeout(function () {
          copyEditUserAdmissionLinkBtn.disabled = false;
          copyEditUserAdmissionLinkBtn.innerHTML = oldHtml;
          copyEditUserAdmissionLinkBtn.title = "Copy admission form link";
          syncEditUserAdmissionLinkPreview();
        }, 1200);
      });
    }
    if (agentTypeSelect) {
      agentTypeSelect.addEventListener("change", function () {
        pipelineTransferConfirmed = false;
        syncPipelineTransferWarning();
      });
    }

    if (pipelineTransferTargetSelect) {
      pipelineTransferTargetSelect.addEventListener("change", updatePipelineTransferNotePreview);
    }

    if (confirmPipelineTransferBtn) {
      confirmPipelineTransferBtn.addEventListener("click", function () {
        const selectedTargetId = pipelineTransferTargetSelect
          ? String(pipelineTransferTargetSelect.value || "").trim()
          : "";

        if (!selectedTargetId) {
          alert("Please select a target user to receive these admissions.");
          return;
        }

        if (pipelineTransferTargetUserIdInput) {
          pipelineTransferTargetUserIdInput.value = selectedTargetId;
        }

        pipelineTransferConfirmed = true;

        if (pipelineTransferModalEl && window.bootstrap) {
          const modal = bootstrap.Modal.getOrCreateInstance(pipelineTransferModalEl);
          modal.hide();
        }

        if (editUserForm) {
          if (typeof editUserForm.requestSubmit === "function") {
            editUserForm.requestSubmit();
          } else {
            editUserForm.submit();
          }
        }
      });
    }

    if (editUserForm) {
      editUserForm.addEventListener("submit", function (event) {
        if (!shouldShowPipelineTransferPopup()) {
          return;
        }

        if (pipelineTransferConfirmed) {
          return;
        }

        event.preventDefault();

        if (pipelineTransferTargetUserIdInput) {
          pipelineTransferTargetUserIdInput.value = "";
        }

        openPipelineTransferModal();
      });
    }

    if (btnViewAll) {
      btnViewAll.addEventListener("click", function () {
        setAllViews(true);
      });
    }

    if (btnViewNone) {
      btnViewNone.addEventListener("click", function () {
        setAllViews(false);
      });
    }

    if (btnEditAll) {
      btnEditAll.addEventListener("click", function () {
        setAllEdits(true);
      });
    }

    if (btnEditNone) {
      btnEditNone.addEventListener("click", function () {
        setAllEdits(false);
      });
    }

    if (btnButtonsAll) {
      btnButtonsAll.addEventListener("click", function () {
        setAllButtons(true);
      });
    }

    if (btnButtonsNone) {
      btnButtonsNone.addEventListener("click", function () {
        setAllButtons(false);
      });
    }

    bindViewEditPermissionRules();
    syncEditUserAdmissionLinkPreview();
    syncPipelineTransferWarning();
  })();
</script>

<%- include('partials/bootstrap-footer') %>
