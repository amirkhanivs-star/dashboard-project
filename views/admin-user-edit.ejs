<%- include('partials/bootstrap-header', { user, pageTitle: 'Edit User' }) %>

<%
  // ✅ FIX: basePath fallback (route se pass na ho to default)
  const BASE_PATH = (typeof basePath !== 'undefined' && basePath) ? basePath : '/dashboard/admin';

  // Parent perms (Admin ki permissions)
  let parentPerms = (typeof perms !== 'undefined' && perms) ? perms : (user.permissions || {});
  try { if (typeof parentPerms === 'string') parentPerms = JSON.parse(parentPerms); } catch(e) { parentPerms = {}; }

  // Child perms (Edited user ki permissions)
  let childPermsRaw = (editUser && editUser.permissions) ? editUser.permissions : {};
  try { if (typeof childPermsRaw === 'string') childPermsRaw = JSON.parse(childPermsRaw); } catch(e) { childPermsRaw = {}; }

   const permissionOn = (value) => {
    return (
      value === true ||
      value === 1 ||
      value === '1' ||
      value === 'true' ||
      value === 'on'
    );
  };

  const isAllowed = (key) => {
    return permissionOn(parentPerms[key]);
  };

  const isChecked = (key) => {
    return permissionOn(childPermsRaw[key]);
  };

  const COLUMN_PERMISSION_GROUPS = [
    {
      title: 'Admission Details',
      icon: 'bi-person-vcard',
      items: [
        { view: 'colStatus', edit: 'editStatus', label: 'Current Status' },
        { view: 'colFeeStatus', edit: 'editFeeStatus', label: 'Fee Status' },
        { view: 'colDept', edit: 'editDept', label: 'Department' },
        { view: 'colStudentName', edit: 'editStudentName', label: 'Student' },
        { view: 'colFatherName', edit: 'editFatherName', label: 'Father' },
        { view: 'colFatherEmail', edit: 'editFatherEmail', label: 'Father Email' },
        { view: 'colGrade', edit: 'editGrade', label: 'Grade' },
        { view: 'colTuitionGrade', edit: 'editTuitionGrade', label: 'Grade Section' },
        { view: 'colPhone', edit: 'editPhone', label: 'Phone Number' },
        { view: 'colProcessedBy', edit: '', label: 'Processed By' }
      ]
    },
    {
      title: 'Accounts & Fees',
      icon: 'bi-cash-stack',
      items: [
        { view: 'colPaymentStatus', edit: 'editPaymentStatus', label: 'Payment Status' },
        { view: 'colPaidUpto', edit: '', label: 'Paid Upto' },
        { view: 'colVerificationNumber', edit: 'editVerificationNumber', label: 'Verification #' },
        { view: 'colRegistrationNumber', edit: 'editRegistrationNumber', label: 'Registration #' },
        { view: 'colFamilyNumber', edit: 'editFamilyNumber', label: 'Family #' },
        { view: 'colRegistrationFee', edit: 'editRegistrationFee', label: 'Registration Fee' },
        { view: 'colFees', edit: 'editFees', label: 'Fees' },
        { view: 'colCurrency', edit: 'editCurrency', label: 'Currency' },
        { view: 'colBank', edit: 'editBank', label: 'Bank' },
        { view: 'colMonth', edit: 'editMonth', label: 'Month' }
      ]
    },
    {
      title: 'Totals & Invoice',
      icon: 'bi-receipt',
      items: [
        { view: 'colTotalFees', edit: '', label: 'Total Fees' },
        { view: 'colPendingDues', edit: '', label: 'Pending Dues' },
        { view: 'colReceivedPayment', edit: '', label: 'Received Payment' },
        { view: 'colComment', edit: 'editComment', label: 'Comment' },
        { view: 'colInvoiceStatus', edit: '', label: 'Invoice Status' },
        { view: 'colInvoiceStatusTimestamp', edit: '', label: 'Invoice Status Time' },
        { view: 'colPaidInvoiceStatus', edit: '', label: 'Paid Invoice Status' },
        { view: 'colPaidInvoiceStatusTimestamp', edit: '', label: 'Paid Invoice Time' },
        { view: 'colActionButtons', edit: '', label: 'Action Buttons' }
      ]
    }
  ];

  const BTN_LABELS = {
    btnEditRow: 'Show Edit Button',
    btnDetails: 'Show View Details Button',
    btnUpdateRow: 'Show Update/Save Button',
    btnPdf: 'Show PDF Button',
    btnBilling: 'Show Billing Button',
    btnWhatsApp: 'Show WhatsApp Button',
    btnUpload: 'Show Upload Button',
    btnFiles: 'Show Files Button',
    canDeleteFiles: 'Can Delete Files',
    canDeleteAdmissions: 'Can Delete Admissions'
  };

  const BTN_KEYS = Object.keys(BTN_LABELS).filter(function (key) {
    return isAllowed(key);
  });
const isAgentRoute = BASE_PATH.includes('/dashboard/agent');

const themeTextClass = isAgentRoute ? 'agent-purple-text' : 'text-success';
const themeBtnClass = isAgentRoute ? 'agent-purple-btn' : 'btn-success';
const themeBackClass = isAgentRoute ? 'agent-purple-text' : 'text-success';
const themeAccordionBtnIconClass = isAgentRoute ? 'agent-purple-text' : 'text-success';
const themeButtonsIconClass = isAgentRoute ? 'agent-purple-text' : 'text-success';

const roleCircleClass =
  editUser.role === 'admin' ? 'bg-success text-white'
  : editUser.role === 'agent' ? 'agent-role-circle'
  : 'subagent-role-circle';

const roleBadgeClass =
  editUser.role === 'admin' ? 'bg-success-subtle text-success'
  : editUser.role === 'agent' ? 'agent-role-badge-edit'
  : 'subagent-role-badge';
    const canEditPerms = true;

const assignedAdminDisplay =
  editUser.assignedAdminName ||
  editUser.assigned_admin_name ||
  editUser.assignedAdmin ||
  editUser.assigned_admin ||
  (Number(editUser.assigned_admin_id || 0) === Number(user.id || 0) ? 'You' : '') ||
  (editUser.assigned_admin_id ? ('Admin ID #' + editUser.assigned_admin_id) : 'You');

const createdByDisplay =
  editUser.createdByName ||
  editUser.created_by_name ||
  editUser.createdBy ||
  editUser.created_by_user ||
  (Number(editUser.created_by || 0) === Number(user.id || 0) ? 'You' : '') ||
  (editUser.created_by ? ('User ID #' + editUser.created_by) : '—');

const accessScopeLabel =
  String(editUser.access_scope || '').trim() === 'all' ? 'All Admissions' :
  String(editUser.access_scope || '').trim() === 'team' ? 'Team Admissions' :
  String(editUser.access_scope || '').trim() === 'department' ? 'Department Admissions' :
  String(editUser.access_scope || '').trim() === 'own' ? 'Own Admissions' :
  'Own Admissions';
  const deptDisplay =
  String(editUser.dept || '').trim().toLowerCase() === 'accounts'
    ? 'School Accounts'
    : (editUser.dept || '—');
    const isSchoolAccountsDept =
  String(user.dept || editUser.dept || '').trim().toLowerCase() === 'accounts' ||
  String(user.dept || editUser.dept || '').trim().toLowerCase() === 'school accounts' ||
  String(user.dept || editUser.dept || '').trim().toLowerCase() === 'school_accounts';

const pipelineTypeOptions = isSchoolAccountsDept
  ? [
      { value: 'print_record_update', label: 'Print + Record update' },
      { value: 'verification_registration', label: 'Verification & Registration' },
      { value: 'paid_slip', label: 'Paid slip' }
    ]
  : [
      { value: 'accounts', label: 'Accounts' },
      { value: 'admission', label: 'Admission' },
      { value: 'management', label: 'Management' }
    ];

const pipelineTypeLabel = (value) => {
  const found = pipelineTypeOptions.find((x) => x.value === value);
  return found ? found.label : (value ? String(value).replace(/_/g, ' ') : '—');
};

  const editUserAdmissionLink =
    editUser.admissionLink || editUser.admission_link || '';

  const safePipelineTransferInfo =
    (typeof pipelineTransferInfo !== "undefined" && pipelineTransferInfo)
      ? pipelineTransferInfo
      : {
          eligible: false,
          count: 0,
          currentPipelineType: "",
          currentPipelineLabel: "",
          sourceUserId: editUser.id,
          sourceUserName: editUser.name || "",
          targets: [],
        };

  const pipelineTransferInfoJson =
    JSON.stringify({
      eligible: !!safePipelineTransferInfo.eligible,
      count: Number(safePipelineTransferInfo.count || 0),
      currentPipelineType: safePipelineTransferInfo.currentPipelineType || "",
      currentPipelineLabel: safePipelineTransferInfo.currentPipelineLabel || "",
      sourceUserName: safePipelineTransferInfo.sourceUserName || editUser.name || "",
      targets: safePipelineTransferInfo.targets || [],
      isAgentRoute: !!isAgentRoute,
    }).replace(/</g, "\\u003c");
  %>

