<%- include('partials/bootstrap-header', { user, pageTitle: 'Edit User' }) %>

<%
  // ✅ FIX: basePath fallback (route se pass na ho to default)
  const BASE_PATH = (typeof basePath !== 'undefined' && basePath) ? basePath : '/dashboard/admin';

  // Parent perms (Admin ki permissions)
  let parentPerms = (typeof perms !== 'undefined' && perms) ? perms : (user.permissions || {});
  try { if (typeof parentPerms === 'string') parentPerms = JSON.parse(parentPerms); } catch(e) { parentPerms = {}; }

  // Child perms (Edited user ki permissions)
  let childPermsRaw = (editUser && editUser.permissions) ? editUser.permissions : {};
  try { if (typeof childPermsRaw === 'string') childPermsRaw = JSON.parse(childPermsRaw); } catch(e) { childPermsRaw = {}; }

  const isAllowed = (key) => !!parentPerms[key];
  const isChecked = (key) => !!childPermsRaw[key];

 const COL_LABELS = {
  colStatus: "Current Status",
  colFeeStatus: "Fee Status",
  colDept: "Dept",
  colStudentName: "Student",
  colFatherName: "Father",
  colFatherEmail: "Father Email",
  colGrade: "Grade",
  colTuitionGrade: "Grade Section",
  colPhone: "Phone Number",
  colProcessedBy: "Processed By",
  colPaymentStatus: "Payment Status",
  colPaidUpto: "Paid Upto",
  colVerificationNumber: "Verification #",
  colRegistrationNumber: "Reg #",
  colFamilyNumber: "Family Number",
  colRegistrationFee: "Registration Fee",
  colFees: "Fees",
  colCurrency: "Currency",
  colBank: "Bank",
  colMonth: "Month",
  colTotalFees: "Total Fees",
  colPendingDues: "Pending Dues",
  colReceivedPayment: "Received Payment",
  colComment: "Comment",
  colInvoiceStatus: "Invoice Status",
  colInvoiceStatusTimestamp: "Invoice Status Timestamp",
  colPaidInvoiceStatus: "Paid Invoice Status",
  colPaidInvoiceStatusTimestamp: "Paid Invoice Status Timestamp",
  colActionButtons: "Action Buttons"
};

const BTN_LABELS = {
  btnEditRow: "Show Edit Button",
  btnDetails: "Show View Details Button",
  btnUpdateRow: "Show Update/Save Button",
  btnPdf: "Show PDF Button",
  btnBilling: "Show Billing Button",
  btnWhatsApp: "Show WhatsApp Button",
  btnUpload: "Show Upload Button",
  btnFiles: "Show Files Button",
  canDeleteFiles: "Can Delete Files",
  canDeleteAdmissions: "Can Delete Admissions"
};

  const COL_KEYS = Object.keys(COL_LABELS).filter(k => isAllowed(k));
  const BTN_KEYS = Object.keys(BTN_LABELS).filter(k => isAllowed(k));
const isAgentRoute = BASE_PATH.includes('/dashboard/agent');

const themeTextClass = isAgentRoute ? 'agent-purple-text' : 'text-success';
const themeBtnClass = isAgentRoute ? 'agent-purple-btn' : 'btn-success';
const themeBackClass = isAgentRoute ? 'agent-purple-text' : 'text-success';
const themeAccordionBtnIconClass = isAgentRoute ? 'agent-purple-text' : 'text-success';
const themeButtonsIconClass = isAgentRoute ? 'agent-purple-text' : 'text-success';

const roleCircleClass =
  editUser.role === 'admin' ? 'bg-success text-white'
  : editUser.role === 'agent' ? 'agent-role-circle'
  : 'subagent-role-circle';

const roleBadgeClass =
  editUser.role === 'admin' ? 'bg-success-subtle text-success'
  : editUser.role === 'agent' ? 'agent-role-badge-edit'
  : 'subagent-role-badge';
    const canEditPerms = true;

const assignedAdminDisplay =
  editUser.assignedAdminName ||
  editUser.assigned_admin_name ||
  editUser.assignedAdmin ||
  editUser.assigned_admin ||
  (Number(editUser.assigned_admin_id || 0) === Number(user.id || 0) ? 'You' : '') ||
  (editUser.assigned_admin_id ? ('Admin ID #' + editUser.assigned_admin_id) : 'You');

const createdByDisplay =
  editUser.createdByName ||
  editUser.created_by_name ||
  editUser.createdBy ||
  editUser.created_by_user ||
  (Number(editUser.created_by || 0) === Number(user.id || 0) ? 'You' : '') ||
  (editUser.created_by ? ('User ID #' + editUser.created_by) : '—');

const accessScopeLabel =
  String(editUser.access_scope || '').trim() === 'all' ? 'All Admissions' :
  String(editUser.access_scope || '').trim() === 'team' ? 'Team Admissions' :
  String(editUser.access_scope || '').trim() === 'department' ? 'Department Admissions' :
  String(editUser.access_scope || '').trim() === 'own' ? 'Own Admissions' :
  'Own Admissions';
  const deptDisplay =
  String(editUser.dept || '').trim().toLowerCase() === 'accounts'
    ? 'School Accounts'
    : (editUser.dept || '—');

  const editUserAdmissionLink =
    editUser.admissionLink || editUser.admission_link || '';
  %>

<style>
    /* Agent edit user page: only yellow to purple, admin stays same */
  .agent-purple-text{
    color: #7c3aed !important;
  }

  .agent-purple-btn{
    background: linear-gradient(135deg, #7c3aed, #5b21b6) !important;
    border-color: #5b21b6 !important;
    color: #fff !important;
    font-weight: 700 !important;
    box-shadow: 0 8px 18px rgba(124,58,237,.22);
  }

  .agent-purple-btn:hover,
  .agent-purple-btn:focus{
    background: linear-gradient(135deg, #6d28d9, #4c1d95) !important;
    border-color: #4c1d95 !important;
    color: #fff !important;
  }

  .agent-blue-text{
    color: #0d6efd !important;
  }

  .agent-edit-purple .form-check-input:checked{
    background-color: #0d6efd !important;
    border-color: #0d6efd !important;
  }

  .agent-edit-purple .form-check-input:focus{
    border-color: #86b7fe !important;
    box-shadow: 0 0 0 .2rem rgba(13,110,253,.25) !important;
  }

  .agent-edit-purple .accordion-button{
    color: #0f172a !important;
  }

  .agent-edit-purple .accordion-button:not(.collapsed){
    background: #cfe2ff !important;
    color: #084298 !important;
    box-shadow: none !important;
  }
    .agent-role-circle{
    background: linear-gradient(135deg, #8b5cf6, #5b21b6) !important;
    color: #fff !important;
    box-shadow: 0 8px 18px rgba(124, 58, 237, 0.22);
  }

  .agent-role-badge-edit{
    background: rgba(124, 58, 237, 0.14) !important;
    color: #5b21b6 !important;
    border: 1px solid rgba(124, 58, 237, 0.30) !important;
    box-shadow: 0 4px 12px rgba(124, 58, 237, 0.10);
  }

  .agent-role-badge-edit i{
    color: #5b21b6 !important;
  }
  .subagent-role-circle{
    background: linear-gradient(135deg, #60a5fa 0%, #2563eb 100%) !important;
    color: #fff !important;
    box-shadow: 0 8px 18px rgba(37, 99, 235, 0.22);
  }

  .subagent-role-badge{
    background: rgba(59, 130, 246, 0.12) !important;
    color: #1d4ed8 !important;
    border: 1px solid rgba(59, 130, 246, 0.28) !important;
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.10);
  }
  .edit-user-link-preview{
    margin-top: 8px;
    width: 100%;
  }

  .edit-user-link-mini{
    display: flex;
    align-items: flex-start;
    gap: 7px;
    width: 100%;
    padding: 6px 8px;
    border-radius: 10px;
    font-size: .70rem;
    font-weight: 800;
    line-height: 1.25;
    border: 1px solid transparent;
  }

  .edit-user-link-mini i{
    font-size: .74rem;
    line-height: 1.2;
    margin-top: 1px;
    flex: 0 0 auto;
  }

  .edit-user-link-text{
    flex: 1 1 auto;
    min-width: 0;
    white-space: normal;
    overflow: visible;
    text-overflow: unset;
    overflow-wrap: anywhere;
    word-break: break-word;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: .66rem;
    font-weight: 800;
  }

  .edit-user-link-copy{
    width: 23px;
    height: 23px;
    border: 0;
    border-radius: 8px;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 23px;
    transition: all .16s ease;
  }

  .edit-user-link-copy i{
    font-size: .72rem;
    line-height: 1;
  }

  .edit-user-link-copy:hover{
    transform: translateY(-1px);
    filter: brightness(.98);
  }

  .edit-user-link-copy:disabled{
    opacity: .75;
    cursor: not-allowed;
    transform: none;
  }

  .edit-user-link-mini.link-role-admin{
    background: rgba(25, 135, 84, 0.08);
    border-color: rgba(25, 135, 84, 0.24);
    color: #157347;
  }

  .edit-user-link-mini.link-role-admin .edit-user-link-copy{
    background: rgba(25, 135, 84, 0.14);
    color: #157347;
  }

  .edit-user-link-mini.link-role-agent{
    background: rgba(124, 58, 237, 0.09);
    border-color: rgba(124, 58, 237, 0.26);
    color: #5b21b6;
  }

  .edit-user-link-mini.link-role-agent .edit-user-link-copy{
    background: rgba(124, 58, 237, 0.15);
    color: #5b21b6;
  }

  .edit-user-link-mini.link-role-sub-agent{
    background: rgba(37, 99, 235, 0.08);
    border-color: rgba(37, 99, 235, 0.24);
    color: #1d4ed8;
  }

  .edit-user-link-mini.link-role-sub-agent .edit-user-link-copy{
    background: rgba(37, 99, 235, 0.14);
    color: #1d4ed8;
  }
</style>

<div class="container-fluid py-4 <%= isAgentRoute ? 'agent-edit-purple' : '' %>">

  <!-- ✅ FIXED: Back link -->
 <a href="<%= BASE_PATH %>/users" class="small <%= themeBackClass %> text-decoration-none mb-3 d-inline-flex align-items-center fw-semibold">
  <i class="bi bi-arrow-left me-1"></i> Back to Users
</a>

