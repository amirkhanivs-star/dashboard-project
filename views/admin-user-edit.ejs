                        <div class="mt-3">
              <div class="rounded-4 border bg-light p-3">
                <div class="d-flex align-items-start gap-2">
                  <div class="mt-1">
                    <i class="bi bi-diagram-3 <%= themeTextClass %>"></i>
                  </div>
                  <div>
                    <h6 class="mb-1">Assignment & Data Access</h6>

                    <% if (isAgentRoute) { %>
                      <p class="text-muted small mb-0">
                        This Sub Agent remains under your assigned Admin team. You can assign only the permissions that are already allowed for your own Agent account.
                      </p>
                    <% } else { %>
                      <p class="text-muted small mb-0">
                        This user is assigned to you. You can edit permissions, but reassignment is controlled by Super Admin.
                      </p>
                    <% } %>

                    <div class="d-flex flex-wrap gap-2 mt-2">
                      <span class="badge rounded-pill bg-white text-dark border">
                        Assigned: <strong><%= assignedAdminDisplay %></strong>
                      </span>
                      <span class="badge rounded-pill bg-white text-dark border">
