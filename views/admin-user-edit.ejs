      data-current-agent-type="<%= editUser.agentType || '' %>">
  <% pipelineTypeOptions.forEach(function(opt){ %>
    <option value="<%= opt.value %>" <%= editUser.agentType === opt.value ? 'selected' : '' %>>
      <%= opt.label %>
