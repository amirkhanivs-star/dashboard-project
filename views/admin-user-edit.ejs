  }

  .edit-user-link-mini.link-role-sub-agent{
    background: rgba(37, 99, 235, 0.08);
    border-color: rgba(37, 99, 235, 0.24);
    color: #1d4ed8;
  }

  .edit-user-link-mini.link-role-sub-agent .edit-user-link-copy{
    background: rgba(37, 99, 235, 0.14);
    color: #1d4ed8;
  }

  .pipeline-transfer-warning{
    margin-top: 12px;
    border: 1px solid rgba(220, 53, 69, 0.22);
    background: linear-gradient(135deg, rgba(220, 53, 69, 0.06), rgba(255, 255, 255, 0.95));
    border-radius: 16px;
    padding: 12px 14px;
    display: none;
  }

  .pipeline-transfer-warning.is-visible{
    display: block;
  }

  .pipeline-transfer-warning .transfer-count-badge{
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 28px;
    height: 28px;
    padding: 0 9px;
    border-radius: 999px;
    background: rgba(220, 53, 69, 0.12);
    color: #b42318;
    font-weight: 900;
    border: 1px solid rgba(220, 53, 69, 0.24);
  }

  .pipeline-transfer-modal-card{
    border-radius: 22px;
    border: 0;
    overflow: hidden;
  }

  .pipeline-transfer-modal-head{
    background: linear-gradient(135deg, #dc3545, #9f1239);
    color: #fff;
  }

  .pipeline-transfer-target-card{
    border: 1px solid rgba(220, 53, 69, 0.16);
    border-radius: 16px;
    background: rgba(220, 53, 69, 0.04);
    padding: 12px;
  }

  .pipeline-transfer-note{
    border-radius: 14px;
    background: #fff7ed;
    border: 1px solid #fed7aa;
    color: #9a3412;
    padding: 10px 12px;
    font-size: .78rem;
    line-height: 1.45;
  }
</style>

<div class="container-fluid py-4 <%= isAgentRoute ? 'agent-edit-purple' : '' %>">

  <!-- ✅ FIXED: Back link -->
 <a href="<%= BASE_PATH %>/users" class="small <%= themeBackClass %> text-decoration-none mb-3 d-inline-flex align-items-center fw-semibold">
  <i class="bi bi-arrow-left me-1"></i> Back to Users
</a>

  <!-- Top Info Card (same feel like super) -->
  <div class="card border-0 shadow-sm rounded-4 mb-3">
    <div class="card-body d-flex flex-wrap align-items-center justify-content-between gap-2 small">
      <div class="d-flex align-items-center gap-2">
        <span class="d-inline-flex align-items-center justify-content-center rounded-circle <%= roleCircleClass %>"
              style="width:30px;height:30px;">
          <%= (editUser.name || 'U').charAt(0).toUpperCase() %>
        </span>
        <div>
          <div class="fw-semibold"><%= editUser.name %></div>
          <div class="text-muted"><%= editUser.email %></div>
        </div>
      </div>

      <div class="d-flex flex-wrap gap-2">
        <span class="badge rounded-pill bg-light text-muted border">
          ID: <strong class="ms-1">#<%= editUser.id %></strong>
        </span>

       <span class="badge rounded-pill <%= roleBadgeClass %> text-capitalize">
        <i class="bi bi-person-badge me-1"></i><%= String(editUser.role || '').replace(/_/g,' ') %>
       </span>

        <span class="badge rounded-pill bg-light text-muted text-capitalize">
         Dept: <span class="ms-1"><%= deptDisplay %></span>
        </span>
                <span class="badge rounded-pill bg-light text-muted border">
          <i class="bi bi-diagram-3 me-1 <%= themeTextClass %>"></i>
          Assigned: <strong class="ms-1"><%= assignedAdminDisplay %></strong>
        </span>

        <span class="badge rounded-pill bg-light text-muted border">
          <i class="bi bi-shield-check me-1 <%= themeTextClass %>"></i>
          Scope: <strong class="ms-1"><%= accessScopeLabel %></strong>
        </span>

        <span class="badge rounded-pill bg-light text-muted border">
          <i class="bi bi-person-plus me-1 <%= themeTextClass %>"></i>
          Created By: <strong class="ms-1"><%= createdByDisplay %></strong>
        </span>
      </div>
    </div>
  </div>



  <div class="row g-3">
    <div class="col-lg-3">
      <div class="card shadow-sm h-100 small border-0 rounded-4">
        <div class="card-body">
          <h6 class="mb-2 d-flex align-items-center">
            <i class="bi bi-sliders2-vertical me-2 <%= themeTextClass %>"></i>
            Editing: <%= editUser.name %>
          </h6>

          <p class="text-muted mb-2">
            ID: <strong><%= editUser.id %></strong><br>
            Role: <span class="text-capitalize"><%= String(editUser.role || '').replace(/_/g,' ') %></span><br>
           Dept: <span><%= deptDisplay %></span>
          </p>

                    <p class="text-muted mb-0">
            From here, you can update the name, email, pipeline type, and allowed permissions.
          </p>
        </div>
      </div>
    </div>

    <div class="col-lg-9">
      <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header border-0 bg-white bg-opacity-75">
          <h5 class="mb-0 d-flex align-items-center">
            <i class="bi bi-pencil-square me-2 <%= themeTextClass %>"></i>
            Edit Agent / Sub Agent
          </h5>
          <small class="text-muted">
            Permissions that are not enabled for the parent account will not appear here.
          </small>
        </div>

        <div class="card-body">
          <% if (error) { %>
            <div class="alert alert-danger py-2 small"><%= error %></div>
          <% } %>

          <!-- ✅ FIXED: form action -->
          <form
            method="POST"
            action="<%= BASE_PATH %>/users/<%= editUser.id %>/edit"
            id="editUserForm">
            <input
              type="hidden"
              name="pipelineTransferTargetUserId"
              id="pipelineTransferTargetUserId"
              value="">

            <!-- Basic info -->
            <div class="row g-3">
              <div class="col-12">
                <h6 class="mb-1">1) Basic information</h6>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Name</label>
                <input
                  type="text"
                  name="name"
                  id="editUserNameInput"
                  class="form-control"
                  value="<%= editUser.name %>"
                  required>

                               <% const editLinkRoleClass =
                  editUser.role === 'admin' ? 'link-role-admin' :
                  editUser.role === 'agent' ? 'link-role-agent' :
                  'link-role-sub-agent';
                %>

                <div class="edit-user-link-preview">
                  <div class="edit-user-link-mini <%= editLinkRoleClass %>" title="<%= editUserAdmissionLink %>">
                    <i class="bi bi-link-45deg"></i>

                    <span
                      id="editUserAdmissionLinkPreview"
                      class="edit-user-link-text">
                      <%= editUserAdmissionLink || 'Type name to generate link' %>
                    </span>

                    <button
                      type="button"
                      class="edit-user-link-copy"
                      id="copyEditUserAdmissionLinkBtn"
                      title="Copy admission form link"
                      aria-label="Copy admission form link">
                      <i class="bi bi-clipboard"></i>
                    </button>
                  </div>
                </div>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Email</label>
                <input type="email" name="email" class="form-control" value="<%= editUser.email %>" required>
              </div>

             <div class="col-md-4">
  <label class="form-label small">Pipeline / Agent Type</label>

  <% if (isAgentRoute) { %>
    <input type="text"
           class="form-control bg-light"
           value="<%= pipelineTypeLabel(editUser.agentType) %>"
           disabled>
    <input type="hidden" name="agentType" value="<%= editUser.agentType || '' %>">
    <small class="text-muted d-block mt-1">
      Agent cannot change pipeline / agent type.
    </small>
  <% } else { %>
    <select
      name="agentType"
      id="agentTypeSelect"
      class="form-select"
      data-current-agent-type="<%= editUser.agentType || '' %>">
  <% pipelineTypeOptions.forEach(function(opt){ %>
    <option value="<%= opt.value %>" <%= editUser.agentType === opt.value ? 'selected' : '' %>>
      <%= opt.label %>
    </option>
  <% }) %>
</select>
    <small class="text-muted d-block mt-1">
      Only admin can change pipeline / agent type.
    </small>
  <% } %>
</div>

<% if (safePipelineTransferInfo.eligible && !isAgentRoute) { %>
  <div class="col-12">
    <div
      class="pipeline-transfer-warning"
      id="pipelineTransferWarning">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <div class="small fw-bold text-danger text-uppercase mb-1">
            <i class="bi bi-arrow-left-right me-1"></i>
            Pipeline Transfer Required
          </div>
          <div class="fw-semibold">
            <span class="transfer-count-badge me-1">
              <%= safePipelineTransferInfo.count || 0 %>
            </span>
            assigned admission(s) are currently in
            <%= safePipelineTransferInfo.currentPipelineLabel || 'this pipeline' %>.
          </div>
          <div class="small text-muted mt-1">
            If you change this user's School Accounts pipeline type, these admissions must be transferred to another
            <%= safePipelineTransferInfo.currentPipelineLabel || 'same pipeline' %> Agent/Sub-Agent.
          </div>
        </div>
        <div class="small text-muted">
          Source user:
          <strong><%= safePipelineTransferInfo.sourceUserName || editUser.name || 'Current user' %></strong>
        </div>
      </div>
    </div>
  </div>
<% } %>
</div>
                        <div class="mt-3">
              <div class="rounded-4 border bg-light p-3">
                <div class="d-flex align-items-start gap-2">
                  <div class="mt-1">
                    <i class="bi bi-diagram-3 <%= themeTextClass %>"></i>
                  </div>
                  <div>
                    <h6 class="mb-1">Assignment & Data Access</h6>

                    <% if (isAgentRoute) { %>
                      <p class="text-muted small mb-0">
                        This Sub Agent remains under your assigned Admin team. You can assign only the permissions that are already allowed for your own Agent account.
                      </p>
                    <% } else { %>
                      <p class="text-muted small mb-0">
                        This user is assigned to you. You can edit permissions, but reassignment is controlled by Super Admin.
                      </p>
                    <% } %>

                    <div class="d-flex flex-wrap gap-2 mt-2">
                      <span class="badge rounded-pill bg-white text-dark border">
                        Assigned: <strong><%= assignedAdminDisplay %></strong>
                      </span>
                      <span class="badge rounded-pill bg-white text-dark border">
                        Scope: <strong><%= accessScopeLabel %></strong>
                      </span>
                      <span class="badge rounded-pill bg-white text-dark border">
                        Created By: <strong><%= createdByDisplay %></strong>
                      </span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <hr>
           <div class="mb-2">
  <div class="d-flex flex-wrap align-items-center gap-2 small">
    <span class="text-dark fw-semibold">Quick:</span>

    <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill px-3 py-1" id="btnSelectAll">
      Select all
    </button>

    <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill px-3 py-1" id="btnSelectNone">
      Select none
    </button>

    <% if (isAgentRoute) { %>
      <span class="text-muted">
        Only your own allowed permissions can be assigned to this Sub Agent.
      </span>
    <% } %>
  </div>
</div>
<div class="mb-2">
  <h6 class="mb-1">2. Columns & Buttons Permissions</h6>
    <p class="text-muted small mb-2">Turn columns, buttons, and special permissions on or off.</p>
</div>

            <div class="accordion" id="permAccordion">

              <!-- Columns -->
              <div class="accordion-item border-0 shadow-sm rounded-4 mb-2">
                <h2 class="accordion-header" id="headingCols">
                  <button class="accordion-button rounded-4" type="button" data-bs-toggle="collapse" data-bs-target="#collapseCols" aria-expanded="true" aria-controls="collapseCols">
                    <i class="bi bi-table me-2 <%= themeAccordionBtnIconClass %>"></i>
                   Admissions pipeline Columns
                  </button>
                </h2>

                <div id="collapseCols" class="accordion-collapse collapse show" aria-labelledby="headingCols" data-bs-parent="#permAccordion">
                  <div class="accordion-body">
                    <% if (!COL_KEYS.length) { %>
                      <div class="alert alert-light border small mb-0">
                        Only the columns allowed for this admin can be assigned here.
                      </div>
                    <% } else { %>
                      <div class="row g-2">
                        <% COL_KEYS.forEach(function(k){ %>
                          <div class="col-md-4">
                            <div class="form-check small">
                              <% if (canEditPerms) { %>
  <input type="hidden" name="<%= k %>" value="">
  <input class="form-check-input perm-toggle" type="checkbox" id="<%= k %>" name="<%= k %>" value="on"
         <%= isChecked(k) ? 'checked' : '' %>>
<% } else { %>
  <input type="hidden" name="<%= k %>" value="<%= isChecked(k) ? 'on' : '' %>">
  <input class="form-check-input perm-toggle" type="checkbox" id="<%= k %>" value="on"
         <%= isChecked(k) ? 'checked' : '' %> disabled>
<% } %>
                              <label class="form-check-label" for="<%= k %>"><%= COL_LABELS[k] %></label>
                            </div>
                          </div>
                        <% }) %>
                      </div>
                    <% } %>
                  </div>
                </div>
              </div>

              <!-- Buttons -->
              <div class="accordion-item border-0 shadow-sm rounded-4">
                <h2 class="accordion-header" id="headingBtns">
                  <button class="accordion-button collapsed rounded-4" type="button" data-bs-toggle="collapse" data-bs-target="#collapseBtns" aria-expanded="false" aria-controls="collapseBtns">
                    <i class="bi bi-hand-index-thumb me-2 <%= themeButtonsIconClass %>"></i>
                    Buttons
                  </button>
                </h2>

                <div id="collapseBtns" class="accordion-collapse collapse" aria-labelledby="headingBtns" data-bs-parent="#permAccordion">
                  <div class="accordion-body">
                    <% if (!BTN_KEYS.length) { %>
                      <div class="alert alert-light border small mb-0">
                        Only the buttons allowed for this admin can be assigned here.
                      </div>
                    <% } else { %>
                      <div class="row g-2">
                        <% BTN_KEYS.forEach(function(k){ %>
                          <div class="col-md-4">
                            <div class="form-check small">
                             <% if (canEditPerms) { %>
  <input type="hidden" name="<%= k %>" value="">
  <input class="form-check-input perm-toggle" type="checkbox" id="<%= k %>" name="<%= k %>" value="on"
         <%= isChecked(k) ? 'checked' : '' %>>
<% } else { %>
  <input type="hidden" name="<%= k %>" value="<%= isChecked(k) ? 'on' : '' %>">
  <input class="form-check-input perm-toggle" type="checkbox" id="<%= k %>" value="on"
         <%= isChecked(k) ? 'checked' : '' %> disabled>
<% } %>
                              <label class="form-check-label" for="<%= k %>"><%= BTN_LABELS[k] %></label>
                            </div>
                          </div>
                        <% }) %>
                      </div>
                    <% } %>
                  </div>
                </div>
              </div>

            </div>

            <hr>

            <div class="d-flex justify-content-between">
              <!-- ✅ FIXED: Cancel link -->
              <a href="<%= BASE_PATH %>/users" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                Cancel
              </a>

              <button type="submit" class="btn <%= themeBtnClass %> rounded-pill px-4">
                <i class="bi bi-save me-1"></i>
                Save Changes
              </button>
            </div>

          </form>

          <% if (safePipelineTransferInfo.eligible && !isAgentRoute) { %>
          <div class="modal fade" id="pipelineTransferModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
              <div class="modal-content pipeline-transfer-modal-card shadow-lg">
                <div class="modal-header pipeline-transfer-modal-head border-0">
                  <div>
                    <h5 class="modal-title fw-bold mb-1">
                      <i class="bi bi-arrow-left-right me-2"></i>
                      Transfer Assigned Admissions
                    </h5>
                    <div class="small opacity-75">
                      Required before changing this School Accounts pipeline type.
                    </div>
                  </div>
                  <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                  <div class="pipeline-transfer-target-card mb-3">
                    <div class="row g-3 align-items-center">
                      <div class="col-md-4">
                        <div class="small text-muted">Current user</div>
                        <div class="fw-bold"><%= safePipelineTransferInfo.sourceUserName || editUser.name || 'Current user' %></div>
                      </div>
                      <div class="col-md-4">
                        <div class="small text-muted">Old pipeline type</div>
                        <div class="fw-bold"><%= safePipelineTransferInfo.currentPipelineLabel || '—' %></div>
                      </div>
                      <div class="col-md-4">
                        <div class="small text-muted">Admissions to transfer</div>
                        <div class="fw-bold text-danger"><%= safePipelineTransferInfo.count || 0 %></div>
                      </div>
                    </div>
                  </div>

                  <label class="form-label small fw-semibold">
                    Select target <%= safePipelineTransferInfo.currentPipelineLabel || 'same pipeline' %> Agent/Sub-Agent
                  </label>

                  <select id="pipelineTransferTargetSelect" class="form-select">
                    <option value="">Select user to receive admissions</option>
                    <% (safePipelineTransferInfo.targets || []).forEach(function(target) { %>
                      <option value="<%= target.id %>">
                        <%= target.name %>
                        <% if (target.role) { %>
                          - <%= String(target.role).replace(/_/g, ' ') %>
                        <% } %>
                        <% if (target.email) { %>
                          (<%= target.email %>)
                        <% } %>
                      </option>
                    <% }) %>
                  </select>

                  <% if (!(safePipelineTransferInfo.targets || []).length) { %>
                    <div class="alert alert-warning small mt-3 mb-0">
                      No same pipeline Agent/Sub-Agent found. Please create another
                      <%= safePipelineTransferInfo.currentPipelineLabel || 'same pipeline' %>
                      user first, then come back and change this user.
                    </div>
                  <% } %>

                  <div class="pipeline-transfer-note mt-3" id="pipelineTransferNotePreview">
                    Transfer note will be saved in admission history after selecting a target user.
                  </div>
                </div>

                <div class="modal-footer border-0">
                  <button type="button" class="btn btn-outline-secondary rounded-pill px-3" data-bs-dismiss="modal">
                    Cancel
                  </button>
                  <button
                    type="button"
                    class="btn btn-danger rounded-pill px-4"
                    id="confirmPipelineTransferBtn"
                    <%= !(safePipelineTransferInfo.targets || []).length ? 'disabled' : '' %>>
                    <i class="bi bi-check2-circle me-1"></i>
                    Transfer & Save
                  </button>
                </div>
              </div>
            </div>
          </div>
          <% } %>

        </div>
      </div>
    </div>
  </div>

</div>

<script>
  (function () {
    const btnSelectAll = document.getElementById("btnSelectAll");
    const btnSelectNone = document.getElementById("btnSelectNone");
    const editUserForm = document.getElementById("editUserForm");
    const agentTypeSelect = document.getElementById("agentTypeSelect");
    const pipelineTransferTargetUserIdInput = document.getElementById("pipelineTransferTargetUserId");
    const pipelineTransferWarning = document.getElementById("pipelineTransferWarning");
    const pipelineTransferModalEl = document.getElementById("pipelineTransferModal");
    const pipelineTransferTargetSelect = document.getElementById("pipelineTransferTargetSelect");
    const confirmPipelineTransferBtn = document.getElementById("confirmPipelineTransferBtn");
    const pipelineTransferNotePreview = document.getElementById("pipelineTransferNotePreview");

    const pipelineTransferInfo = <%- pipelineTransferInfoJson %>;
    let pipelineTransferConfirmed = false;

        const editUserNameInput = document.getElementById("editUserNameInput");
    const editUserAdmissionLinkPreview = document.getElementById("editUserAdmissionLinkPreview");
    const copyEditUserAdmissionLinkBtn = document.getElementById("copyEditUserAdmissionLinkBtn");

    const admissionFormBaseUrl = "<%= typeof admissionFormBaseUrl !== 'undefined' ? admissionFormBaseUrl : 'https://ivs-admission-form.onrender.com/' %>";
        function buildAdmissionLinkFromName(name) {
      const cleanName = String(name || "").trim();
      const baseUrl = String(admissionFormBaseUrl || "https://ivs-admission-form.onrender.com/")
        .trim()
        .replace(/\?+$/, "")
        .replace(/\/+$/, "/");

      if (!cleanName) return "";

      return baseUrl + "?sentBy=" + encodeURIComponent(cleanName);
    }

    function syncEditUserAdmissionLinkPreview() {
      if (!editUserNameInput || !editUserAdmissionLinkPreview) return;

      const link = buildAdmissionLinkFromName(editUserNameInput.value);
      editUserAdmissionLinkPreview.textContent = link || "Type name to generate link";

      const linkWrap = editUserAdmissionLinkPreview.closest(".edit-user-link-mini");
      if (linkWrap) {
        linkWrap.setAttribute("title", link || "");
      }

      if (copyEditUserAdmissionLinkBtn) {
        copyEditUserAdmissionLinkBtn.disabled = !link;
      }
    }

    async function copyEditUserAdmissionLink(text) {
      const cleanText = String(text || "").trim();
      if (!cleanText) return false;

      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(cleanText);
          return true;
        }

        const textarea = document.createElement("textarea");
        textarea.value = cleanText;
        textarea.style.position = "fixed";
        textarea.style.left = "-9999px";
        textarea.style.top = "-9999px";
        document.body.appendChild(textarea);
        textarea.focus();
        textarea.select();

        const copied = document.execCommand("copy");
        document.body.removeChild(textarea);

        return copied;
      } catch (err) {
        console.error("Admin/Agent edit user admission link copy failed:", err);
        return false;
      }
    }

    function getPipelineTransferTargetName(targetId) {
      const cleanId = String(targetId || "");
      const target = (pipelineTransferInfo.targets || []).find(function (item) {
        return String(item.id || "") === cleanId;
      });

      return target ? String(target.name || target.email || "selected user") : "";
    }

    function shouldShowPipelineTransferPopup() {
      if (pipelineTransferInfo.isAgentRoute) return false;

      if (!pipelineTransferInfo.eligible || Number(pipelineTransferInfo.count || 0) <= 0) {
        return false;
      }

      if (!agentTypeSelect) return false;

      const selectedAgentType = String(agentTypeSelect.value || "");
      const oldPipelineType = String(pipelineTransferInfo.currentPipelineType || "");

      if (!oldPipelineType) return false;

      return selectedAgentType !== oldPipelineType;
    }

    function syncPipelineTransferWarning() {
      if (!pipelineTransferWarning) return;

      if (shouldShowPipelineTransferPopup()) {
        pipelineTransferWarning.classList.add("is-visible");
      } else {
        pipelineTransferWarning.classList.remove("is-visible");

        if (pipelineTransferTargetUserIdInput) {
          pipelineTransferTargetUserIdInput.value = "";
        }

        pipelineTransferConfirmed = false;
      }
    }

    function updatePipelineTransferNotePreview() {
      if (!pipelineTransferNotePreview) return;

      const targetId = pipelineTransferTargetSelect ? pipelineTransferTargetSelect.value : "";
      const targetName = getPipelineTransferTargetName(targetId);

      if (!targetName) {
        pipelineTransferNotePreview.textContent =
          "Transfer note will be saved in admission history after selecting a target user.";
        return;
      }

      const sourceName = pipelineTransferInfo.sourceUserName || "current user";

      pipelineTransferNotePreview.textContent =
        "Transferred by " +
        "<%= user && user.name ? user.name : 'Admin' %>" +
        " from " +
        sourceName +
        " to " +
        targetName +
        " due to pipeline type change.";
    }

    function openPipelineTransferModal() {
      updatePipelineTransferNotePreview();

      if (window.bootstrap && pipelineTransferModalEl) {
        const modal = bootstrap.Modal.getOrCreateInstance(pipelineTransferModalEl);
        modal.show();
        return;
      }

      alert(
        "This user has " +
        pipelineTransferInfo.count +
        " assigned admissions. Please select a target user before saving."
      );
    }
    function toggleAll(on) {
      document.querySelectorAll(".perm-toggle").forEach((cb) => {
        if (cb.disabled) return;
        cb.checked = !!on;
      });
    }
        if (editUserNameInput) {
      editUserNameInput.addEventListener("input", syncEditUserAdmissionLinkPreview);
    }

    if (copyEditUserAdmissionLinkBtn) {
      copyEditUserAdmissionLinkBtn.addEventListener("click", async function () {
        const link = editUserAdmissionLinkPreview
  ? editUserAdmissionLinkPreview.textContent.trim()
  : "";
if (!link || link === "Type name to generate link") return;

        const oldHtml = copyEditUserAdmissionLinkBtn.innerHTML;
        copyEditUserAdmissionLinkBtn.disabled = true;
        copyEditUserAdmissionLinkBtn.innerHTML = '<i class="bi bi-hourglass-split"></i>';

        const copied = await copyEditUserAdmissionLink(link);

        if (copied) {
          copyEditUserAdmissionLinkBtn.innerHTML = '<i class="bi bi-check2-circle"></i>';
          copyEditUserAdmissionLinkBtn.title = "Copied";
        } else {
          prompt("Copy this admission form link:", link);
          copyEditUserAdmissionLinkBtn.innerHTML = oldHtml;
        }

        setTimeout(function () {
          copyEditUserAdmissionLinkBtn.disabled = false;
          copyEditUserAdmissionLinkBtn.innerHTML = oldHtml;
          copyEditUserAdmissionLinkBtn.title = "Copy admission form link";
          syncEditUserAdmissionLinkPreview();
        }, 1200);
      });
    }
    if (agentTypeSelect) {
      agentTypeSelect.addEventListener("change", function () {
        pipelineTransferConfirmed = false;
        syncPipelineTransferWarning();
      });
    }

    if (pipelineTransferTargetSelect) {
      pipelineTransferTargetSelect.addEventListener("change", updatePipelineTransferNotePreview);
    }

    if (confirmPipelineTransferBtn) {
      confirmPipelineTransferBtn.addEventListener("click", function () {
        const selectedTargetId = pipelineTransferTargetSelect
          ? String(pipelineTransferTargetSelect.value || "").trim()
          : "";

        if (!selectedTargetId) {
          alert("Please select a target user to receive these admissions.");
          return;
        }

        if (pipelineTransferTargetUserIdInput) {
          pipelineTransferTargetUserIdInput.value = selectedTargetId;
        }

        pipelineTransferConfirmed = true;

        if (pipelineTransferModalEl && window.bootstrap) {
          const modal = bootstrap.Modal.getOrCreateInstance(pipelineTransferModalEl);
          modal.hide();
        }

        if (editUserForm) {
          if (typeof editUserForm.requestSubmit === "function") {
            editUserForm.requestSubmit();
          } else {
            editUserForm.submit();
          }
        }
      });
    }

    if (editUserForm) {
      editUserForm.addEventListener("submit", function (event) {
        if (!shouldShowPipelineTransferPopup()) {
          return;
        }

        if (pipelineTransferConfirmed) {
          return;
        }

        event.preventDefault();

        if (pipelineTransferTargetUserIdInput) {
          pipelineTransferTargetUserIdInput.value = "";
        }

        openPipelineTransferModal();
      });
    }

    if (btnSelectAll) btnSelectAll.addEventListener("click", () => toggleAll(true));
    if (btnSelectNone) btnSelectNone.addEventListener("click", () => toggleAll(false));

        syncEditUserAdmissionLinkPreview();
    syncPipelineTransferWarning();
  })();
</script>

<%- include('partials/bootstrap-footer') %>
