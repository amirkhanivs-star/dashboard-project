                </button>

                <button
                  type="button"
                  class="btn btn-outline-secondary btn-sm rounded-pill"
                  id="btnEditAll">
                  Edit all
                </button>

                <button
                  type="button"
                  class="btn btn-outline-secondary btn-sm rounded-pill"
                  id="btnEditNone">
                  Edit none
                </button>

                <span class="permission-quickbar-label ms-md-2">
                  <i class="bi bi-hand-index-thumb me-1"></i>
                  Buttons:
                </span>

                <button
                  type="button"
                  class="btn btn-outline-secondary btn-sm rounded-pill"
                  id="btnButtonsAll">
                  All on
                </button>

                <button
                  type="button"
                  class="btn btn-outline-secondary btn-sm rounded-pill"
                  id="btnButtonsNone">
                  All off
                </button>

                <span class="permission-default-note">
