  const moneyFormatter = new Intl.NumberFormat('en-PK', {
    maximumFractionDigits: 0
  });

  const numberFormatter = new Intl.NumberFormat('en-PK', {
    maximumFractionDigits: 0
  });

  const allowedApiKeys = [
    'APP_BASE_URL',
