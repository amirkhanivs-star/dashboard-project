  }

  .developer-profile-actions{
    width:100%;
  }

  .developer-profile-upload-btn,
  .developer-profile-close-btn{
    flex:1;
  }
}
/* ================== DEVELOPER IMAGE CROPPER ================== */

.developer-crop-modal .modal-dialog{
  max-width:920px;
}

.developer-crop-content{
  overflow:hidden;
  border:0 !important;
  border-radius:24px !important;
  background:#ffffff;
  box-shadow:0 35px 100px rgba(15,23,42,.35);
}

.developer-crop-header{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
  padding:15px 18px;
  border-bottom:1px solid var(--line);
  background:#ffffff;
}

.developer-crop-title{
  display:flex;
  align-items:center;
  gap:10px;
  color:#111827;
  font-size:15px;
  font-weight:950;
}

.developer-crop-title-icon{
  width:34px;
  height:34px;
  border-radius:11px;
  display:flex;
  align-items:center;
  justify-content:center;
  color:#ffffff;
  background:linear-gradient(135deg, #6558f5, #ec4899);
}

.developer-crop-close{
  width:34px;
  height:34px;
  border:1px solid var(--line);
  border-radius:11px;
  background:#f9fafb;
  color:#111827;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
}

.developer-crop-close:hover{
  background:#111827;
  color:#ffffff;
}

.developer-crop-body{
  padding:18px;
  background:#f8fafc;
}

.developer-crop-layout{
  display:grid;
  grid-template-columns:minmax(0, 1fr) 190px;
  gap:16px;
}

.developer-crop-stage{
  width:100%;
  height:min(62vh, 570px);
  min-height:440px;
  overflow:hidden;
  border-radius:20px;
  border:1px solid #1f2937;
  background:
    linear-gradient(45deg, #111827 25%, transparent 25%),
    linear-gradient(-45deg, #111827 25%, transparent 25%),
    linear-gradient(45deg, transparent 75%, #111827 75%),
    linear-gradient(-45deg, transparent 75%, #111827 75%),
    #0b1220;
  background-size:22px 22px;
  background-position:0 0, 0 11px, 11px -11px, -11px 0;
}

#developerCropImage{
  display:block;
  max-width:100%;
  opacity:0;
}

.developer-crop-side{
  display:flex;
  flex-direction:column;
  gap:12px;
}

.developer-crop-preview-card{
  padding:14px;
  border:1px solid var(--line);
  border-radius:17px;
  background:#ffffff;
}

.developer-crop-preview-title{
  margin-bottom:10px;
  color:#6b7280;
  font-size:10px;
  font-weight:950;
  letter-spacing:.06em;
  text-transform:uppercase;
}

.developer-crop-preview{
  width:132px;
  height:132px;
  margin:0 auto;
  overflow:hidden;
  border:5px solid #ffffff;
  border-radius:28px;
  background:#111827;
  box-shadow:0 10px 25px rgba(15,23,42,.20);
}

.developer-crop-help{
  color:#6b7280;
  font-size:10px;
  line-height:1.5;
  font-weight:750;
}

.developer-crop-tools{
  display:grid;
  grid-template-columns:repeat(2, minmax(0, 1fr));
  gap:8px;
}

.developer-crop-tool-btn{
  min-height:38px;
  border:1px solid var(--line);
  border-radius:12px;
  background:#ffffff;
  color:#111827;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:7px;
  cursor:pointer;
  font-size:10px;
  font-weight:900;
}

.developer-crop-tool-btn:hover{
  background:#111827;
  color:#ffffff;
  border-color:#111827;
}

.developer-crop-footer{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
  padding:14px 18px;
  border-top:1px solid var(--line);
  background:#ffffff;
}

.developer-crop-output-note{
  color:#6b7280;
  font-size:10px;
  font-weight:750;
}

.developer-crop-actions{
  display:flex;
  align-items:center;
  gap:9px;
}

.developer-crop-cancel-btn,
.developer-crop-upload-btn{
  min-height:40px;
  padding:9px 15px;
  border-radius:13px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:8px;
  cursor:pointer;
  font-size:11px;
  font-weight:950;
}

.developer-crop-cancel-btn{
  border:1px solid var(--line);
  background:#ffffff;
  color:#111827;
}

.developer-crop-upload-btn{
  border:0;
  color:#ffffff;
  background:linear-gradient(135deg, #6558f5, #8b5cf6);
  box-shadow:0 10px 22px rgba(99,88,245,.26);
}

.developer-crop-upload-btn:disabled{
  opacity:.65;
  cursor:not-allowed;
}

.developer-crop-modal .cropper-view-box,
.developer-crop-modal .cropper-face{
  border-radius:24px;
}

.developer-crop-modal .cropper-line,
.developer-crop-modal .cropper-point{
  background-color:#6558f5;
}

@media (max-width:760px){
  .developer-crop-modal .modal-dialog{
    margin:10px;
  }

  .developer-crop-layout{
    grid-template-columns:1fr;
  }

  .developer-crop-stage{
    height:460px;
    min-height:360px;
  }

  .developer-crop-side{
    display:grid;
    grid-template-columns:150px 1fr;
  }

  .developer-crop-preview{
    width:110px;
    height:110px;
  }

  .developer-crop-footer{
    align-items:flex-start;
    flex-direction:column;
  }

  .developer-crop-actions{
    width:100%;
  }

  .developer-crop-cancel-btn,
  .developer-crop-upload-btn{
    flex:1;
  }
}

@media (max-width:520px){
  .developer-crop-side{
    grid-template-columns:1fr;
  }

  .developer-crop-stage{
    height:390px;
    min-height:320px;
  }
}
    .toast-box{
      position:fixed;
      right:14px;
      bottom:14px;
      z-index:2000;
      display:grid;
      gap:8px;
      width:min(360px, calc(100vw - 28px));
    }

    .dev-toast{
      border:1px solid var(--line);
      background:#fff;
      border-radius:16px;
      padding:10px 12px;
      box-shadow:0 18px 45px rgba(15,23,42,.16);
      font-size:12px;
      font-weight:850;
      color:#111827;
      display:flex;
      align-items:flex-start;
      gap:9px;
      animation:toastIn .18s ease-out;
    }

    .dev-toast.ok{
      border-color:#bbf7d0;
      background:#f0fdf4;
      color:#166534;
    }

    .dev-toast.danger{
      border-color:#fecaca;
      background:#fef2f2;
      color:#991b1b;
    }

    @keyframes toastIn{
      from{ opacity:0; transform:translateY(8px); }
      to{ opacity:1; transform:translateY(0); }
    }

    @media (max-width:1200px){
      .card-grid{
        grid-template-columns:repeat(3, minmax(0, 1fr));
      }

      .hero-grid,
      .panel-grid,
      .panel-grid.three{
        grid-template-columns:1fr;
      }
    }

    @media (max-width:720px){
      .top-inner{
        align-items:flex-start;
        flex-direction:column;
      }

      .top-actions{
        width:100%;
        justify-content:flex-start;
      }

      .card-grid{
        grid-template-columns:repeat(2, minmax(0, 1fr));
      }

      .api-grid{
        grid-template-columns:1fr;
      }

      .section{
        min-height:auto;
      }
    }

    @media (max-width:480px){
      .dev-shell{
        padding:12px 10px 28px;
      }

      .card-grid{
        grid-template-columns:1fr;
      }

      .hero-title{
        font-size:19px;
      }
    }
  </style>
</head>

<%
  const devName =
    (typeof developer !== 'undefined' && developer && developer.name)
      ? developer.name
      : 'Developer';

  const devUsername =
    (typeof developer !== 'undefined' && developer && developer.username)
      ? developer.username
      : '';

  const devEmail =
    (typeof developer !== 'undefined' && developer && developer.email)
      ? developer.email
      : '';

  const devProfileImageUrl =
    (
      typeof developer !== 'undefined' &&
      developer &&
      developer.profileImageUrl
    )
      ? developer.profileImageUrl
      : '';

  const devInitials =
    String(devName || 'Developer')
      .trim()
      .split(/\s+/)
      .filter(Boolean)
      .slice(0, 2)
      .map((part) => part.charAt(0))
      .join('')
      .toUpperCase() || 'D';
%>

<body>

<header class="dev-topbar">
  <div class="top-inner">
    <div class="brand">
  <button
    class="brand-avatar-button"
    type="button"
    id="openDeveloperProfileBtn"
    title="Open Developer Profile"
    aria-label="Open Developer Profile"
    data-developer-name="<%= devName %>"
    data-developer-username="<%= devUsername %>"
    data-developer-email="<%= devEmail %>"
    data-profile-image-url="<%= devProfileImageUrl %>"
  >
    <img
      id="developerHeaderAvatarImage"
      class="brand-avatar-image <%= devProfileImageUrl ? '' : 'd-none' %>"
      <% if (devProfileImageUrl) { %>
        src="<%= devProfileImageUrl %>"
      <% } %>
      alt="<%= devName %> profile picture"
    >

    <span
      id="developerHeaderAvatarFallback"
      class="brand-avatar-fallback <%= devProfileImageUrl ? 'd-none' : '' %>"
    ><%= devInitials %></span>
  </button>

  <div>
        <div class="brand-title">Developer Dashboard</div>
        <div class="brand-sub" id="developerIdentityText">
  Logged in as <%= devName %>
  <%= devUsername ? '(' + devUsername + ')' : '' %>
  <%= devEmail ? ' • ' + devEmail : '' %>
</div>
      </div>
    </div>

    <div class="top-actions">
      <button class="tiny-btn soft" type="button" id="refreshBtn">
        <i class="bi bi-arrow-clockwise"></i>
        Refresh
      </button>

      <button class="tiny-btn soft" type="button" id="downloadAllBtn">
        <i class="bi bi-download"></i>
        Export Data
      </button>

      <form method="POST" action="/developer/logout" class="m-0">
        <button class="tiny-btn danger" type="submit">
          <i class="bi bi-box-arrow-right"></i>
          Logout
        </button>
      </form>
    </div>
  </div>

  <nav class="nav-strip" id="navStrip">
    <a class="nav-btn active" href="#overview"><i class="bi bi-grid"></i>Overview</a>
    <a class="nav-btn" href="#school"><i class="bi bi-mortarboard"></i>School</a>
    <a class="nav-btn" href="#quran"><i class="bi bi-book"></i>Quran</a>
    <a class="nav-btn" href="#tuition"><i class="bi bi-journal-text"></i>Tuition</a>
    <a class="nav-btn" href="#users"><i class="bi bi-people"></i>Users</a>
    <a class="nav-btn" href="#payments"><i class="bi bi-cash-stack"></i>Payments</a>
    <a class="nav-btn" href="#online"><i class="bi bi-wifi"></i>Online</a>
    <a class="nav-btn" href="#usage"><i class="bi bi-activity"></i>Usage</a>
    <a class="nav-btn" href="#apis"><i class="bi bi-sliders"></i>APIs</a>
    <a class="nav-btn" href="#database"><i class="bi bi-database"></i>Database</a>
  </nav>
</header>

<main class="dev-shell">

  <section class="hero">
    <div class="hero-grid">
      <div>
        <div class="hero-title">Control Center</div>
        <div class="hero-text">
          Compact developer view for users, admissions, payments, online activity, usage, APIs and exports.
        </div>
      </div>

      <div class="search-box">
        <i class="bi bi-search"></i>
        <input type="search" id="globalSearch" placeholder="Search users, email, role, department, API key, page or any visible data">
      </div>

      <div class="quick-box">
        <div class="quick-title">
          <i class="bi bi-lightning-charge"></i>
          Live Snapshot
        </div>
        <div class="quick-list">
          <div class="quick-row"><span>Total Users</span><span id="quickUsers">0</span></div>
          <div class="quick-row"><span>Total Admissions</span><span id="quickAdmissions">0</span></div>
          <div class="quick-row"><span>Online Now</span><span id="quickOnline">0</span></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="overview">
    <div class="section-head">
      <div>
        <div class="section-title">Overview</div>
        <div class="section-sub">Complete website snapshot in small cards.</div>
      </div>
      <div class="section-tools">
        <button class="tiny-btn" type="button" onclick="downloadJSON('developer-stats.json', state.stats)">
          <i class="bi bi-filetype-json"></i>
          Stats JSON
        </button>
      </div>
    </div>

    <div class="card-grid">
      <div class="stat-card">
        <div class="stat-top"><div class="stat-icon"><i class="bi bi-people"></i></div><div class="stat-chip">Users</div></div>
        <div class="stat-value" data-stat="totalUsers">0</div>
        <div class="stat-label">Total Users</div>
      </div>

      <div class="stat-card">
        <div class="stat-top"><div class="stat-icon"><i class="bi bi-person-check"></i></div><div class="stat-chip">Live</div></div>
        <div class="stat-value" data-stat="onlineUsers">0</div>
        <div class="stat-label">Online Users</div>
      </div>

      <div class="stat-card">
        <div class="stat-top"><div class="stat-icon"><i class="bi bi-card-checklist"></i></div><div class="stat-chip">Admissions</div></div>
        <div class="stat-value" data-stat="totalAdmissions">0</div>
        <div class="stat-label">Total Admissions</div>
      </div>

      <div class="stat-card">
        <div class="stat-top"><div class="stat-icon"><i class="bi bi-calendar-day"></i></div><div class="stat-chip">Today</div></div>
        <div class="stat-value" data-stat="todayUsage">0</div>
        <div class="stat-label">Today Active Time</div>
      </div>

      <div class="stat-card">
        <div class="stat-top"><div class="stat-icon"><i class="bi bi-calendar-week"></i></div><div class="stat-chip">Week</div></div>
        <div class="stat-value" data-stat="weeklyUsage">0</div>
        <div class="stat-label">Weekly Active Time</div>
