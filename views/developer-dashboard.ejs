  function toggleInputVisibility(button){
    const targetId = String(
      button?.getAttribute('data-visibility-target') || ''
    ).trim();

    if (!targetId) return;

    const input = document.getElementById(targetId);
    if (!input) return;

    const isCurrentlyVisible = input.type === 'text';

    input.type = isCurrentlyVisible ? 'password' : 'text';

    const icon = button.querySelector('i');

    if (icon) {
      icon.className = isCurrentlyVisible
        ? 'bi bi-eye'
        : 'bi bi-eye-slash';
    }

    button.title = isCurrentlyVisible
      ? 'Show value'
      : 'Hide value';

    button.setAttribute(
      'aria-label',
      isCurrentlyVisible ? 'Show value' : 'Hide value'
    );
  }

 function getDeveloperInitials(value){
  const parts = cleanText(value)
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2);

  const initials = parts
    .map((part) => part.charAt(0))
    .join('')
    .toUpperCase();

  return initials || 'D';
}

function renderDeveloperAvatar(
  imageSelector,
  fallbackSelector,
  imageUrl,
  name
){
  const image = qs(imageSelector);
  const fallback = qs(fallbackSelector);

  if (!image || !fallback) return;

  const initials = getDeveloperInitials(name);
  const cleanImageUrl = cleanText(imageUrl);

  fallback.textContent = initials;

  const showFallback = () => {
    image.classList.add('d-none');
    image.removeAttribute('src');
    fallback.classList.remove('d-none');
  };

  if (!cleanImageUrl) {
    showFallback();
    return;
  }

  image.onerror = showFallback;
  image.src = cleanImageUrl;
  image.classList.remove('d-none');
  fallback.classList.add('d-none');
}

