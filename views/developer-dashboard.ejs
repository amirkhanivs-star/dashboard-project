    const username = cleanText(
      qs('#developerProfileUsername')?.value
    );

    const email = cleanText(
      qs('#developerProfileEmail')?.value
    ).toLowerCase();

    const currentPassword =
      qs('#developerCurrentPassword')?.value || '';

    const newPassword =
      qs('#developerNewPassword')?.value || '';

    const confirmPassword =
      qs('#developerConfirmPassword')?.value || '';

    if (!name) {
      toast('Developer name is required.', 'danger');
      return;
    }

    if (!username) {
      toast('Developer username is required.', 'danger');
      return;
    }

    if (!email) {
      toast('Developer email is required.', 'danger');
      return;
    }

    if (!currentPassword) {
      toast(
        'Current password is required to save Developer login settings.',
        'danger'
      );
      return;
    }

    if (
      (newPassword || confirmPassword) &&
      newPassword !== confirmPassword
    ) {
      toast(
        'New password and confirm password do not match.',
        'danger'
      );
      return;
    }

    const button = qs('#saveDeveloperProfileBtn');
    const originalButtonHtml = button?.innerHTML || '';

    if (button) {
      button.disabled = true;
      button.innerHTML =
        '<span class="spinner-border spinner-border-sm"></span> Saving...';
    }

    try {
      const result = await apiPost(
        '/api/developer/profile/update',
        {
          name,
          username,
          email,
          currentPassword,
          newPassword,
          confirmPassword
        }
      );

      state.developerProfile =
        result.profile || {
          ...state.developerProfile,
          name,
          username,
          email
        };

      state.profileDirty = false;

      const currentPasswordInput =
        qs('#developerCurrentPassword');

      const newPasswordInput =
        qs('#developerNewPassword');

      const confirmPasswordInput =
        qs('#developerConfirmPassword');

      if (currentPasswordInput) {
        currentPasswordInput.value = '';
        currentPasswordInput.type = 'password';
      }

      if (newPasswordInput) {
        newPasswordInput.value = '';
        newPasswordInput.type = 'password';
      }

      if (confirmPasswordInput) {
        confirmPasswordInput.value = '';
        confirmPasswordInput.type = 'password';
      }

      renderDeveloperProfile();

      toast(
        result.message ||
        'Developer login settings updated successfully.'
      );
    } catch (err) {
      toast(
        err.message ||
        'Developer login settings update failed.',
        'danger'
      );
    } finally {
      if (button) {
        button.disabled = false;
        button.innerHTML = originalButtonHtml;
      }
    }
  }

  function statCard(label, value, icon, chip){
    return `
      <div class="stat-card">
        <div class="stat-top">
          <div class="stat-icon"><i class="bi ${icon}"></i></div>
          <div class="stat-chip">${escapeHtml(chip || '')}</div>
        </div>
        <div class="stat-value">${typeof value === 'number' ? fmtNumber(value) : escapeHtml(value)}</div>
