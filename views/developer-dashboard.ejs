      .replaceAll('_', ' ')
      .replace(/^./, function (x) {
        return x.toUpperCase();
      });
  }

  function permissionEnabled(value){
    if (value === true || value === 1) {
      return true;
    }

    if (
      value === false ||
      value === 0 ||
      value === null ||
      typeof value === 'undefined'
    ) {
      return false;
    }

    return [
      '1',
      'true',
      'on',
      'yes'
    ].includes(
      String(value)
        .trim()
        .toLowerCase()
    );
  }

  function normalizePermissionObject(rawPermissions){
    let source = rawPermissions;

    try {
      if (typeof source === 'string') {
        source = JSON.parse(source);
      }
    } catch (err) {
      source = {};
    }

    if (Array.isArray(source)) {
      return source.reduce((map, key) => {
        const cleanKey =
          String(key || '').trim();

        if (
          cleanKey &&
          ALL_PERMISSION_KEYS.includes(cleanKey)
        ) {
          map[cleanKey] = true;
        }

        return map;
      }, {});
    }

    if (
      !source ||
      typeof source !== 'object'
    ) {
      return {};
    }

    return source;
  }

  function hasExplicitEditPermissionSchema(permissions){
    return EDIT_PERMISSION_KEYS.some((key) =>
      Object.prototype.hasOwnProperty.call(
        permissions || {},
        key
      )
    );
  }

  function getPermissionKeysFromUsers(){
    return [...ALL_PERMISSION_KEYS];
  }

  function syncPermissionDependencies(containerSelector){
    const box = qs(containerSelector);
    if (!box) return;

    qsa(
      containerSelector +
      ' .permission-view-checkbox'
    ).forEach((viewInput) => {
      const editKey =
        viewInput.dataset.editKey || '';

      if (!editKey) {
        return;
      }

      const editInput = box.querySelector(
        '.permission-edit-checkbox' +
        '[data-permission-key="' +
        editKey +
        '"]'
      );

      if (!editInput) {
        return;
      }

      if (!viewInput.checked) {
        editInput.checked = false;
        editInput.disabled = true;
      } else {
        editInput.disabled = false;
      }
    });

    qsa(
      containerSelector +
      ' .permission-edit-checkbox'
    ).forEach((editInput) => {
      if (!editInput.checked) {
        return;
      }

      const viewKey =
        editInput.dataset.viewKey || '';

      const viewInput = box.querySelector(
        '.permission-view-checkbox' +
        '[data-permission-key="' +
        viewKey +
        '"]'
      );

      if (viewInput) {
        viewInput.checked = true;
        editInput.disabled = false;
      }
    });
  }

  function renderPermissionCheckboxes(containerSelector, permissions){
    const box = qs(containerSelector);
    if (!box) return;

    const finalPermissions =
      normalizePermissionObject(permissions);

    const hasExplicitEditSchema =
      hasExplicitEditPermissionSchema(
        finalPermissions
      );

    const keys = getPermissionKeysFromUsers();

    box.innerHTML = keys.map((key) => {
      const isView =
        VIEW_PERMISSION_KEYS.includes(key);

      const isEdit =
        EDIT_PERMISSION_KEYS.includes(key);

      const viewKey =
        isEdit
          ? VIEW_PERMISSION_BY_EDIT[key]
          : '';

      const editKey =
        isView
          ? EDIT_PERMISSION_BY_VIEW[key] || ''
          : '';

      let checked =
        permissionEnabled(
          finalPermissions[key]
        );

      /*
       * Legacy user:
       * Edit keys save nahi hue to existing View permission
       * matching Edit access ko preserve karegi.
       */
      if (
        isEdit &&
        !hasExplicitEditSchema &&
        viewKey
      ) {
        checked =
          permissionEnabled(
            finalPermissions[viewKey]
          );
      }

      if (
        isEdit &&
        viewKey &&
        !permissionEnabled(
          finalPermissions[viewKey]
        ) &&
        hasExplicitEditSchema
      ) {
        checked = false;
      }

      const typeClass =
        isView
          ? 'permission-view-checkbox'
          : (
              isEdit
                ? 'permission-edit-checkbox'
                : 'permission-action-checkbox'
            );

      return `
        <label
          class="perm-item"
          title="${escapeHtml(key)}">
          <input
            type="checkbox"
            class="permission-checkbox ${typeClass}"
            data-permission-key="${escapeHtml(key)}"
            data-edit-key="${escapeHtml(editKey)}"
            data-view-key="${escapeHtml(viewKey)}"
            ${checked ? 'checked' : ''}>

          <span>
            ${escapeHtml(permissionLabel(key))}
          </span>
        </label>
      `;
    }).join('');

    box.onchange = (event) => {
      const input = event.target.closest(
        '.permission-checkbox'
      );

      if (!input) {
        return;
      }

      if (
        input.classList.contains(
          'permission-view-checkbox'
        ) &&
        !input.checked
      ) {
        const editKey =
          input.dataset.editKey || '';

        const editInput = editKey
          ? box.querySelector(
              '.permission-edit-checkbox' +
              '[data-permission-key="' +
              editKey +
              '"]'
            )
          : null;

        if (editInput) {
          editInput.checked = false;
        }
      }

      if (
        input.classList.contains(
          'permission-edit-checkbox'
        ) &&
        input.checked
      ) {
        const viewKey =
          input.dataset.viewKey || '';

        const viewInput = viewKey
          ? box.querySelector(
              '.permission-view-checkbox' +
              '[data-permission-key="' +
              viewKey +
              '"]'
            )
          : null;

        if (viewInput) {
          viewInput.checked = true;
        }
      }

      syncPermissionDependencies(
        containerSelector
      );
    };

    syncPermissionDependencies(
      containerSelector
    );
  }

  function readPermissionCheckboxes(containerSelector){
    const permissions =
      Object.fromEntries(
        ALL_PERMISSION_KEYS.map((key) => [
          key,
          false
        ])
      );

    qsa(
      containerSelector +
      ' .permission-checkbox'
    ).forEach((input) => {
      const key =
        input.dataset.permissionKey;

      if (
        !key ||
        !ALL_PERMISSION_KEYS.includes(key)
      ) {
        return;
      }

      permissions[key] =
        !!input.checked;
    });

    EDIT_PERMISSION_KEYS.forEach((editKey) => {
      const viewKey =
        VIEW_PERMISSION_BY_EDIT[editKey];

      if (!permissions[viewKey]) {
        permissions[editKey] = false;
      }
    });

    return permissions;
  }

  function setAllPermissionCheckboxes(containerSelector, checked){
    qsa(
      containerSelector +
      ' .permission-checkbox'
    ).forEach((input) => {
      input.checked = !!checked;
    });

    syncPermissionDependencies(
      containerSelector
    );
  }

  function applyCreateRolePermissionDefaults(){
    const containerSelector =
      '#createPermissionsGrid';

    qsa(
      containerSelector +
      ' .permission-checkbox'
    ).forEach((input) => {
      const key =
        input.dataset.permissionKey || '';

      input.checked =
        VIEW_PERMISSION_KEYS.includes(key) ||
        ACTION_PERMISSION_KEYS.includes(key);
    });

    syncPermissionDependencies(
      containerSelector
    );
  }

