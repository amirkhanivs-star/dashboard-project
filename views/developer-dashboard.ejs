function canvasToDeveloperProfileBlob(
  canvas,
  quality
){
  return new Promise((resolve) => {
    canvas.toBlob(
      resolve,
      'image/jpeg',
      quality
    );
  });
}

async function uploadCroppedDeveloperProfileImage(){
  if (
    state.profileImageUploading ||
    !state.developerCropper
  ) {
    return;
  }

  const canvas =
    state.developerCropper.getCroppedCanvas({
      width:1080,
      height:1080,
      minWidth:1080,
      minHeight:1080,
      maxWidth:1080,
      maxHeight:1080,
      fillColor:'#ffffff',
      imageSmoothingEnabled:true,
      imageSmoothingQuality:'high'
    });

  if (!canvas) {
    toast(
      'The cropped profile picture could not be generated.',
      'danger'
    );

    return;
  }

  let croppedBlob =
    await canvasToDeveloperProfileBlob(
      canvas,
      0.98
    );

  if (!croppedBlob) {
    toast(
      'The cropped profile picture could not be generated.',
      'danger'
    );

    return;
  }

  if (
    croppedBlob.size >
    15 * 1024 * 1024
  ) {
    croppedBlob =
      await canvasToDeveloperProfileBlob(
        canvas,
        0.90
      );
  }

  if (
    !croppedBlob ||
    croppedBlob.size >
      15 * 1024 * 1024
  ) {
    toast(
      'The cropped image is larger than 15 MB.',
      'danger'
    );

    return;
  }

  const formData = new FormData();

  formData.append(
    'profileImage',
    croppedBlob,
    'developer-profile-1080.jpg'
  );

  setDeveloperProfileUploadBusy(true);

  try {
    const response = await fetch(
      '/api/developer/profile/image',
      {
        method:'POST',
        headers:{
          Accept:'application/json'
        },
        body:formData
      }
    );

    const result = await response
      .json()
      .catch(() => ({}));

    if (
      !response.ok ||
      result.success === false
    ) {
      throw new Error(
        result.message ||
        'Developer profile picture upload failed.'
      );
    }

    state.developerProfile =
      result.profile || {
        ...state.developerProfile,
        profileImageUrl:
          result.profileImageUrl || ''
      };

    renderDeveloperProfile();

    toast(
      result.message ||
      'Cropped HD profile picture uploaded successfully.'
    );

    const cropModalElement =
      qs('#developerCropModal');

    if (cropModalElement) {
      bootstrap.Modal
        .getOrCreateInstance(cropModalElement)
        .hide();
    }
  } catch (err) {
    console.error(
      'Developer cropped image upload error:',
      err
    );

    toast(
      err.message ||
      'Developer profile picture upload failed.',
      'danger'
    );
  } finally {
    setDeveloperProfileUploadBusy(false);
  }
}
  async function saveDeveloperProfile(){
