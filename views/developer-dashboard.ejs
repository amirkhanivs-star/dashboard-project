async function createDeveloperUser(){
  const name =
    cleanText(
      qs('#createName').value
    );

  const email =
    cleanText(
      qs('#createEmail').value
    ).toLowerCase();

  const role =
    normalize(
      qs('#createRole').value
    );

  const dept =
    normalizeUserDepartmentKey(
      qs('#createDept').value
    );

  const agentType =
    getValidatedDeveloperAgentType(
      role,
      dept,
      qs('#createAgentType').value
    );

  const accessScope =
    getDeveloperAccessScope(
      role,
      dept
    );

  const assignedAdminId =
    getValidatedDeveloperAssignedAdminId(
      role,
      dept,
      qs('#createAssignedAdmin').value
    );

  if (!name || !email) {
    toast(
      'Name and email are required.',
      'danger'
    );

    return;
  }

  if (agentType === null) {
    toast(
      'Please select a valid Pipeline / Agent Type for this Agent or Sub Agent.',
      'danger'
    );

    return;
  }

  if (assignedAdminId === null) {
    toast(
      'Please select a valid Assigned Admin from the same department for this Agent or Sub Agent.',
      'danger'
    );

    return;
  }

  try {
    const result = await apiPost(
      '/api/developer/users/create',
      {
        name,

        email,

        password:
          qs('#createPassword').value,

        role,

        dept,

        agentType,

        access_scope:
          accessScope,

        assigned_admin_id:
          assignedAdminId || null,

        managerId:
          assignedAdminId || null,

        permissions:
          readPermissionCheckboxes(
            '#createPermissionsGrid'
          )
      }
    );

    qs('#createdUserEmail').value =
      result.email || email;

    qs('#createdUserPassword').value =
      result.temporaryPassword || '';

    qs('#createResultBox')
      .classList.remove('d-none');

    toast(
      result.message ||
      'User created successfully.'
    );

    await loadAll();
  } catch (err) {
    toast(
      err.message ||
      'User create failed.',
      'danger'
    );
  }
}

async function openPermissionsModal(id){
  const localUser = state.users.find((u) => Number(u.id) === Number(id));

  if (!localUser) {
    toast('User not found.', 'danger');
    return;
  }

  try {
    const result = await apiGet('/api/developer/users/' + id + '/permissions');
    const user = result.user || localUser;

    qs('#permissionsUserId').value = user.id || localUser.id || '';
    qs('#permissionsUserName').value = user.name || localUser.name || '';
    qs('#permissionsUserEmail').value = user.email || localUser.email || '';
    qs('#permissionsUserRole').value = formatRole(user.role || localUser.role || '');

    renderPermissionCheckboxes('#permissionsGrid', user.permissions || localUser.permissions || {});

    const modal = bootstrap.Modal.getOrCreateInstance(qs('#permissionsModal'));
    modal.show();
  } catch (err) {
    toast(err.message || 'Could not load permissions.', 'danger');
  }
}

async function saveUserPermissions(){
  const id = Number(qs('#permissionsUserId').value || 0);

  if (!id) {
    toast('Invalid user selected.', 'danger');
    return;
  }

  try {
    const result = await apiPost('/api/developer/users/' + id + '/permissions', {
      permissions: readPermissionCheckboxes('#permissionsGrid')
    });

    toast(result.message || 'Permissions updated successfully.');
    await loadAll();
  } catch (err) {
    toast(err.message || 'Permissions update failed.', 'danger');
  }
}

function copyCreatedPassword(){
  const input = qs('#createdUserPassword');
  if (!input || !input.value) return;

  navigator.clipboard.writeText(input.value).then(() => {
    toast('Password copied.');
  }).catch(() => {
    input.select();
    document.execCommand('copy');
    toast('Password copied.');
  });
}

