  function drawBars(selector, rows, money = false){
    const el = qs(selector);
    if (!el) return;

    const safeRows = Array.isArray(rows) ? rows : [];
    const max = Math.max(...safeRows.map((r) => Number(r[1] || 0)), 1);

    if (!safeRows.length) {
      el.innerHTML = `<div class="empty">No chart data available.</div>`;
      return;
    }

    el.innerHTML = safeRows.map(([label, value]) => {
      const n = Number(value || 0);
      const width = Math.max(2, Math.round((n / max) * 100));
      const display = money ? fmtMoney(n) : fmtNumber(n);

      return `
        <div class="bar-row">
          <div class="bar-label" title="${escapeHtml(label)}">${escapeHtml(label)}</div>
          <div class="bar-track">
            <div class="bar-fill" style="width:${width}%"></div>
          </div>
          <div class="bar-value">${display}</div>
        </div>
      `;
    }).join('');
  }
  function drawTimeBars(selector, rows){
    const el = qs(selector);
    if (!el) return;

    const safeRows = Array.isArray(rows) ? rows : [];
    const max = Math.max(...safeRows.map((r) => Number(r[1] || 0)), 1);

    if (!safeRows.length) {
      el.innerHTML = `<div class="empty">No usage data available yet.</div>`;
      return;
    }

    el.innerHTML = safeRows.map(([label, value]) => {
      const n = Math.max(0, Math.round(Number(value || 0)));
      const width = n > 0 ? Math.max(2, Math.round((n / max) * 100)) : 2;

      return `
        <div class="bar-row">
          <div class="bar-label" title="${escapeHtml(label)}">${escapeHtml(label)}</div>
          <div class="bar-track">
            <div class="bar-fill" style="width:${width}%"></div>
          </div>
          <div class="bar-value">${fmtActiveTime(n)}</div>
        </div>
      `;
    }).join('');
  }
