<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Developer Dashboard' %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <link
  href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.css"
  rel="stylesheet"
>
  <link rel="icon" type="image/png" sizes="32x32" href="/img/tabLogo.png" />

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    :root{
      --black:#050505;
      --dark:#111827;
      --text:#111827;
      --muted:#6b7280;
      --soft:#f8fafc;
      --soft2:#f3f4f6;
      --line:#e5e7eb;
      --line2:#d1d5db;
      --white:#ffffff;
      --danger:#991b1b;
      --danger-bg:#fef2f2;
      --ok:#166534;
      --ok-bg:#f0fdf4;
      --warn:#92400e;
      --warn-bg:#fffbeb;
    }

    html{
      scroll-behavior:smooth;
    }

    body{
      min-height:100vh;
      font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
      color:var(--text);
      background:
        linear-gradient(rgba(17,24,39,.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(17,24,39,.035) 1px, transparent 1px),
        #ffffff;
      background-size:32px 32px;
      font-size:12px;
      overflow-x:hidden;
    }

    body::before{
      content:"";
      position:fixed;
      right:-130px;
      top:-130px;
      width:360px;
      height:360px;
      border-radius:999px;
      background:#111827;
      opacity:.045;
      z-index:-1;
    }

    body::after{
      content:"";
      position:fixed;
      left:-130px;
      bottom:-130px;
      width:330px;
      height:330px;
      border-radius:999px;
      background:#111827;
      opacity:.035;
      z-index:-1;
    }

    .dev-topbar{
      position:sticky;
      top:0;
      z-index:999;
      background:rgba(255,255,255,.92);
      backdrop-filter:blur(18px);
      -webkit-backdrop-filter:blur(18px);
      border-bottom:1px solid var(--line);
    }

    .top-inner{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      padding:10px 16px;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:9px;
      min-width:210px;
    }

    .brand-avatar-button{
  width:56px;
  height:56px;
  border:3px solid #111827;
  border-radius:50%;
  padding:0;
  background:#050505;
  color:#ffffff;
  display:flex;
  align-items:center;
  justify-content:center;
  flex-shrink:0;
  overflow:hidden;
  cursor:pointer;
  position:relative;
  box-shadow:
    0 8px 22px rgba(15,23,42,.20),
    0 0 0 3px rgba(255,255,255,.95);
  transition:
    transform .18s ease,
    box-shadow .18s ease,
    border-color .18s ease;
}

.brand-avatar-button:hover,
.brand-avatar-button:focus{
  transform:translateY(-1px) scale(1.05);
  border-color:#7c3aed;
  box-shadow:0 10px 25px rgba(15,23,42,.25);
  outline:none;
}

.brand-avatar-image{
  width:100%;
  height:100%;
  display:block;
  object-fit:cover;
  object-position:center;
  image-rendering:auto;
  filter:none !important;
  transform:translateZ(0);
  backface-visibility:hidden;
}

.brand-avatar-fallback{
  width:100%;
  height:100%;
  display:flex;
  align-items:center;
  justify-content:center;
  color:#ffffff;
  font-size:12px;
  line-height:1;
  font-weight:950;
  letter-spacing:.02em;
  background:linear-gradient(
    135deg,
    #635bff 0%,
    #a855f7 52%,
    #ec4899 100%
  );
}

    .brand-title{
      font-size:13px;
      font-weight:950;
      letter-spacing:-.2px;
      color:#050505;
      line-height:1.1;
    }

    .brand-sub{
      font-size:10px;
      color:var(--muted);
      font-weight:750;
      margin-top:2px;
    }

    .top-actions{
      display:flex;
      align-items:center;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
    }

    .nav-strip{
      display:flex;
      gap:7px;
      overflow-x:auto;
      padding:0 16px 10px;
      scrollbar-width:thin;
    }

    .nav-btn{
      border:1px solid var(--line);
      background:#fff;
      color:#111827;
      border-radius:999px;
      padding:6px 10px;
      font-size:11px;
      font-weight:900;
      white-space:nowrap;
      text-decoration:none;
      transition:.16s ease;
      display:inline-flex;
      align-items:center;
      gap:6px;
    }

    .nav-btn:hover,
    .nav-btn.active{
      background:#050505;
      color:#fff;
      border-color:#050505;
    }

    .tiny-btn{
      border:1px solid var(--line);
      background:#fff;
      color:#111827;
      border-radius:10px;
      padding:6px 9px;
      font-size:11px;
      font-weight:900;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:5px;
      text-decoration:none;
      transition:.16s ease;
      min-height:30px;
    }

    .tiny-btn:hover{
      background:#050505;
      color:#fff;
      border-color:#050505;
    }

    .tiny-btn.dark{
      background:#050505;
      color:#fff;
      border-color:#050505;
    }

    .tiny-btn.danger{
      background:#fff;
      color:#991b1b;
      border-color:#fecaca;
    }

    .tiny-btn.danger:hover{
      background:#991b1b;
      color:#fff;
      border-color:#991b1b;
    }

    .tiny-btn.soft{
      background:#f9fafb;
    }

    .top-actions .tiny-btn.soft:hover,
    .top-actions .tiny-btn.soft:focus{
      background:#050505;
      color:#ffffff;
      border-color:#050505;
    }

    .top-actions .tiny-btn.soft:hover i,
    .top-actions .tiny-btn.soft:focus i{
      color:#ffffff;
    }

    .dev-shell{
      max-width:1500px;
      margin:0 auto;
      padding:14px 16px 34px;
    }

    .hero{
      border:1px solid var(--line);
      background:rgba(255,255,255,.94);
      border-radius:24px;
      padding:14px;
      box-shadow:0 18px 54px rgba(15,23,42,.08);
      margin-bottom:12px;
    }

    .hero-grid{
      display:grid;
      grid-template-columns:minmax(220px, .9fr) minmax(280px, 1.5fr) minmax(240px, .9fr);
      gap:12px;
      align-items:stretch;
    }

    .hero-title{
      font-size:22px;
      line-height:1;
      font-weight:950;
      letter-spacing:-.7px;
      color:#050505;
      margin-bottom:7px;
    }

    .hero-text{
      color:var(--muted);
      font-size:12px;
      line-height:1.5;
      font-weight:650;
      max-width:520px;
    }

    .search-box{
      position:relative;
    }

    .search-box i{
      position:absolute;
      left:12px;
      top:50%;
      transform:translateY(-50%);
      color:#9ca3af;
      font-size:13px;
    }

    .search-box input{
      width:100%;
      height:36px;
      border:1px solid var(--line);
      border-radius:13px;
      padding:0 12px 0 34px;
      font-size:12px;
      font-weight:750;
      background:#fff;
      outline:none;
    }

    .search-box input:focus{
      border-color:#050505;
      box-shadow:0 0 0 4px rgba(17,24,39,.08);
    }

    .quick-box{
      border:1px solid var(--line);
      background:#f9fafb;
      border-radius:18px;
      padding:11px;
      height:100%;
    }

    .quick-title{
      color:#050505;
      font-weight:950;
      font-size:12px;
      margin-bottom:8px;
      display:flex;
      align-items:center;
      gap:6px;
    }

    .quick-list{
      display:grid;
      gap:6px;
    }

    .quick-row{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:8px;
      color:#4b5563;
      font-size:11px;
      font-weight:800;
    }

    .quick-row span:last-child{
      color:#050505;
      font-weight:950;
    }

    .section{
      min-height:calc(100vh - 92px);
      scroll-margin-top:92px;
      padding:10px 0 18px;
    }

    .section-head{
      display:flex;
      align-items:flex-end;
      justify-content:space-between;
      gap:12px;
      margin:2px 0 10px;
    }

    .section-title{
      font-size:17px;
      font-weight:950;
      letter-spacing:-.4px;
      color:#050505;
      line-height:1;
    }

    .section-sub{
      color:var(--muted);
      font-size:11px;
      font-weight:750;
      margin-top:4px;
    }

    .section-tools{
      display:flex;
      align-items:center;
      gap:7px;
      flex-wrap:wrap;
      justify-content:flex-end;
    }

    .card-grid{
      display:grid;
      grid-template-columns:repeat(6, minmax(0, 1fr));
      gap:9px;
      margin-bottom:10px;
    }

    .stat-card{
      background:#fff;
      border:1px solid var(--line);
      border-radius:17px;
      padding:11px;
      min-height:86px;
      box-shadow:0 12px 30px rgba(15,23,42,.045);
      position:relative;
      overflow:hidden;
    }

    .stat-card::after{
      content:"";
      position:absolute;
      right:-22px;
      top:-22px;
      width:70px;
      height:70px;
      border-radius:999px;
      background:#050505;
      opacity:.035;
    }

    .stat-top{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:8px;
      margin-bottom:9px;
    }

    .stat-icon{
      width:27px;
      height:27px;
      border-radius:10px;
      background:#050505;
      color:#fff;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:13px;
    }

    .stat-chip{
      font-size:9px;
      color:#6b7280;
      border:1px solid var(--line);
      background:#f9fafb;
      border-radius:999px;
      padding:3px 6px;
      font-weight:900;
      white-space:nowrap;
    }

    .stat-value{
      font-size:22px;
      font-weight:950;
      color:#050505;
      line-height:1;
      letter-spacing:-.6px;
    }

    .stat-label{
      margin-top:5px;
      font-size:11px;
      font-weight:850;
      color:#4b5563;
      line-height:1.25;
    }

    .panel-grid{
      display:grid;
      grid-template-columns:1.15fr .85fr;
      gap:10px;
      margin-bottom:10px;
    }

    .panel-grid.three{
      grid-template-columns:1fr 1fr 1fr;
    }

    .panel{
      background:#fff;
      border:1px solid var(--line);
      border-radius:18px;
      box-shadow:0 12px 30px rgba(15,23,42,.045);
      overflow:hidden;
    }

    .panel-head{
      padding:10px 12px;
      border-bottom:1px solid var(--line);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      background:#fff;
    }

    .panel-title{
      font-size:12px;
      font-weight:950;
      color:#050505;
      display:flex;
      align-items:center;
      gap:7px;
    }

    .panel-title i{
      color:#050505;
    }

    .panel-body{
      padding:11px;
    }

    .small-chart{
      width:100%;
      min-height:180px;
      display:grid;
      gap:8px;
    }

    .bar-row{
      display:grid;
      grid-template-columns:96px 1fr 54px;
      gap:8px;
      align-items:center;
      font-size:11px;
      font-weight:850;
      color:#374151;
    }

    .bar-label{
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .bar-track{
      height:11px;
      border-radius:999px;
      background:#f3f4f6;
      overflow:hidden;
      border:1px solid #e5e7eb;
    }

    .bar-fill{
      height:100%;
      border-radius:999px;
      background:#050505;
      min-width:3px;
      transition:.35s ease;
    }

    .bar-value{
      text-align:right;
      color:#050505;
      font-weight:950;
    }

    .mini-table-wrap{
      overflow:auto;
      max-height:420px;
      border-radius:14px;
      border:1px solid var(--line);
    }

    table.dev-table{
      width:100%;
      border-collapse:separate;
      border-spacing:0;
      background:#fff;
      min-width:780px;
    }

    .dev-table th,
    .dev-table td{
      padding:8px 9px;
      border-bottom:1px solid var(--line);
      font-size:11px;
      vertical-align:middle;
      white-space:nowrap;
    }

    .dev-table th{
      position:sticky;
      top:0;
      z-index:2;
      background:#f9fafb;
      color:#374151;
      font-size:10px;
      text-transform:uppercase;
      letter-spacing:.06em;
      font-weight:950;
    }

    .dev-table td{
      color:#111827;
      font-weight:700;
    }

    .dev-table tr:hover td{
      background:#fafafa;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      gap:5px;
      padding:4px 8px;
      border-radius:999px;
      font-size:10px;
      font-weight:950;
      border:1px solid var(--line);
      background:#f9fafb;
      color:#111827;
    }

    .pill.ok{
      background:var(--ok-bg);
      color:var(--ok);
      border-color:#bbf7d0;
    }

    .pill.warn{
      background:var(--warn-bg);
      color:var(--warn);
      border-color:#fde68a;
    }

    .pill.danger{
      background:var(--danger-bg);
      color:var(--danger);
      border-color:#fecaca;
    }

    .form-mini{
      display:grid;
      gap:8px;
    }

    .mini-label{
      font-size:10px;
      color:#4b5563;
      font-weight:950;
      margin-bottom:4px;
      text-transform:uppercase;
      letter-spacing:.04em;
    }

    .mini-input,
    .mini-select,
    .mini-textarea{
      width:100%;
      border:1px solid var(--line);
      border-radius:12px;
      height:34px;
      padding:0 10px;
      font-size:12px;
      font-weight:750;
      color:#111827;
      background:#fff;
      outline:none;
    }

    .mini-textarea{
      height:80px;
      padding:10px;
      resize:vertical;
    }

    .mini-input:focus,
    .mini-select:focus,
    .mini-textarea:focus{
      border-color:#050505;
      box-shadow:0 0 0 4px rgba(17,24,39,.08);
    }

    .api-grid{
      display:grid;
      grid-template-columns:repeat(2, minmax(0, 1fr));
      gap:9px;
    }

    .setting-card{
      border:1px solid var(--line);
      background:#fff;
      border-radius:15px;
      padding:10px;
    }

    .setting-key{
      font-size:10px;
      color:#6b7280;
      font-weight:950;
      letter-spacing:.05em;
      text-transform:uppercase;
      margin-bottom:6px;
    }
    .input-action-wrap{
  position:relative;
  width:100%;
}

.input-action-wrap .mini-input{
  padding-right:42px;
}

.input-action-btn{
  position:absolute;
  right:4px;
  top:50%;
  transform:translateY(-50%);
  width:28px;
  height:27px;
  border:1px solid var(--line);
  border-radius:9px;
  background:#f9fafb;
  color:#111827;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  font-size:12px;
  transition:.16s ease;
}

.input-action-btn:hover,
.input-action-btn:focus{
  background:#050505;
  border-color:#050505;
  color:#ffffff;
  outline:none;
}

.developer-profile-grid{
  display:grid;
  grid-template-columns:repeat(3, minmax(0, 1fr));
  gap:9px;
}

.setting-note{
  margin-top:7px;
  color:#6b7280;
  font-size:10px;
  line-height:1.45;
  font-weight:750;
}

.security-note{
  border:1px solid #fde68a;
  background:#fffbeb;
  color:#92400e;
  border-radius:13px;
  padding:9px 10px;
  font-size:11px;
  font-weight:800;
  line-height:1.5;
}

@media (max-width:900px){
  .developer-profile-grid{
    grid-template-columns:repeat(2, minmax(0, 1fr));
  }
}

@media (max-width:620px){
  .developer-profile-grid{
    grid-template-columns:1fr;
  }
}
    .footer-nav{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:8px;
      margin-top:10px;
      padding-top:10px;
      border-top:1px solid var(--line);
    }

    .empty{
      border:1px dashed #d1d5db;
      border-radius:14px;
      padding:18px 12px;
      color:#6b7280;
      background:#f9fafb;
      text-align:center;
      font-size:12px;
      font-weight:800;
    }
    .perm-grid{
  display:grid;
  grid-template-columns:repeat(3, minmax(0, 1fr));
  gap:7px;
  max-height:260px;
  overflow:auto;
  border:1px solid var(--line);
  background:#f9fafb;
  border-radius:14px;
  padding:9px;
}

.perm-item{
  display:flex;
  align-items:center;
  gap:7px;
  min-height:31px;
  border:1px solid var(--line);
  background:#fff;
  border-radius:11px;
  padding:6px 8px;
  font-size:10px;
  font-weight:850;
  color:#111827;
}

.perm-item input{
  width:14px;
  height:14px;
  accent-color:#050505;
  flex-shrink:0;
}

.perm-item span{
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
}

.result-box{
  border:1px solid #bbf7d0;
  background:#f0fdf4;
  color:#166534;
  border-radius:14px;
  padding:10px;
  font-size:12px;
  font-weight:850;
}

@media (max-width:900px){
  .perm-grid{
    grid-template-columns:repeat(2, minmax(0, 1fr));
  }
}

@media (max-width:520px){
  .perm-grid{
    grid-template-columns:1fr;
  }
}
    .modal-content{
      border-radius:22px;
      border:1px solid var(--line);
      box-shadow:0 26px 80px rgba(0,0,0,.16);
    }

    .modal-header{
      border-bottom:1px solid var(--line);
      padding:12px 14px;
    }

    .modal-title{
      font-size:14px;
      font-weight:950;
    }

    .modal-body{
      padding:14px;
    }

    .modal-footer{
      border-top:1px solid var(--line);
      padding:12px 14px;
    }
   /* ================== DEVELOPER PROFILE CARD ================== */

.developer-profile-modal .modal-dialog{
  max-width:980px;
}

.developer-profile-modal-content{
  border:0 !important;
  border-radius:30px !important;
  background:transparent !important;
  box-shadow:none !important;
  overflow:visible;
}

.developer-profile-card{
  position:relative;
  overflow:hidden;
  border-radius:30px;
  border:1px solid rgba(255,255,255,.78);
  background:linear-gradient(
    135deg,
    rgba(237,233,254,.99) 0%,
    rgba(243,232,255,.99) 48%,
    rgba(252,231,243,.99) 100%
  );
  box-shadow:
    0 35px 100px rgba(23,16,54,.34),
    0 12px 35px rgba(124,58,237,.17);
}

.developer-profile-cover{
  position:relative;
  min-height:250px;
  padding:22px 28px 30px;
  overflow:hidden;
  background:
    linear-gradient(
      180deg,
      rgba(255,255,255,0) 0%,
      rgba(255,255,255,0) 53%,
      rgba(255,255,255,.45) 53%,
      rgba(255,255,255,.45) 100%
    ),
    radial-gradient(
      circle at 18% 18%,
      rgba(255,255,255,.20) 0 2px,
      transparent 2px 100%
    ),
    linear-gradient(
      115deg,
      #8174fa 0%,
      #ae72ee 48%,
      #eb75bc 100%
    );
  background-size:auto, 22px 22px, auto;
}

.developer-profile-cover::after{
  content:"";
  position:absolute;
  width:280px;
  height:280px;
  right:-100px;
  top:-145px;
  border-radius:50%;
  background:rgba(255,255,255,.12);
  pointer-events:none;
}

.developer-profile-top-row{
  position:relative;
  z-index:2;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
}

.developer-profile-top-chip{
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding:9px 13px;
  border-radius:16px;
  background:rgba(255,255,255,.93);
  color:#302d49;
  font-size:11px;
  font-weight:950;
  letter-spacing:.03em;
  box-shadow:0 10px 28px rgba(41,29,90,.16);
}

.developer-profile-chip-number{
  min-width:32px;
  height:30px;
  padding:0 8px;
  border-radius:999px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  color:#ffffff;
  background:#635bff;
  font-size:10px;
  font-weight:950;
}

.developer-profile-close{
  width:36px;
  height:36px;
  border:1px solid rgba(255,255,255,.7);
  border-radius:12px;
  background:rgba(17,24,39,.88);
  color:#ffffff;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  transition:.16s ease;
}

.developer-profile-close:hover{
  background:#ffffff;
  color:#111827;
  transform:rotate(4deg);
}

.developer-profile-identity{
  position:relative;
  z-index:2;
  display:flex;
  align-items:flex-end;
  gap:25px;
  margin-top:45px;
}

.developer-card-avatar-shell{
  position:relative;
  width:170px;
  height:170px;
  border-radius:30px;
  flex-shrink:0;
  border:6px solid rgba(255,255,255,.96);
  background:#111827;
  box-shadow:
    0 22px 38px rgba(37,26,82,.28),
    0 4px 12px rgba(0,0,0,.12);
}

.developer-card-avatar-image,
.developer-card-avatar-fallback{
  width:100%;
  height:100%;
  border-radius:22px;
}

.developer-card-avatar-image{
  display:block;
  object-fit:cover;
  object-position:center top;
  background:#ffffff;
  image-rendering:auto;
  filter:none !important;
}

.developer-card-avatar-fallback{
  display:flex;
  align-items:center;
  justify-content:center;
  color:#ffffff;
  font-size:38px;
  font-weight:950;
  letter-spacing:-.04em;
  background:linear-gradient(
    135deg,
    #111827 0%,
    #5b21b6 48%,
    #db2777 100%
  );
}

.developer-card-camera-button{
  position:absolute;
  right:-10px;
  bottom:-10px;
  width:42px;
  height:42px;
  border:4px solid #ffffff;
  border-radius:50%;
  background:#111827;
  color:#ffffff;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  font-size:15px;
  box-shadow:0 9px 22px rgba(0,0,0,.24);
  transition:.16s ease;
}

.developer-card-camera-button:hover{
  background:#635bff;
  transform:scale(1.06);
}

.developer-card-camera-button:disabled{
  opacity:.6;
  cursor:not-allowed;
  transform:none;
}

.developer-profile-main-info{
  min-width:0;
  padding-bottom:7px;
}

.developer-profile-eyebrow{
  display:flex;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
  margin-bottom:7px;
}

.developer-profile-role-badge{
  display:inline-flex;
  align-items:center;
  gap:6px;
  padding:6px 10px;
  border-radius:999px;
  background:rgba(255,255,255,.87);
  color:#5b4fe8;
  font-size:10px;
  font-weight:950;
  letter-spacing:.05em;
  text-transform:uppercase;
}

.developer-profile-online{
  display:inline-flex;
  align-items:center;
  gap:7px;
  color:#059669;
  font-size:11px;
  font-weight:950;
}

.developer-profile-online-dot{
  width:8px;
  height:8px;
  border-radius:50%;
  background:#10b981;
  box-shadow:0 0 0 4px rgba(16,185,129,.14);
}

.developer-profile-name{
  margin:0;
  color:#17152d;
  font-size:38px;
  line-height:1.05;
  font-weight:950;
  letter-spacing:-1.3px;
  word-break:break-word;
}

.developer-profile-name-id{
  color:#6558f5;
}

.developer-profile-meta-line{
  display:flex;
  align-items:center;
  gap:16px;
  flex-wrap:wrap;
  margin-top:11px;
  color:#706e8c;
  font-size:13px;
  font-weight:800;
}

.developer-profile-meta-line span{
  display:inline-flex;
  align-items:center;
  gap:7px;
}

.developer-profile-body{
  padding:26px 28px 24px;
}

.developer-card-info-grid{
  display:grid;
  grid-template-columns:repeat(3, minmax(0, 1fr));
  gap:15px;
}

.developer-info-card{
  min-height:102px;
  border:1px solid rgba(255,255,255,.80);
  border-radius:19px;
  padding:16px;
  background:rgba(255,255,255,.58);
  box-shadow:inset 0 1px 0 rgba(255,255,255,.88);
  backdrop-filter:blur(13px);
  -webkit-backdrop-filter:blur(13px);
}

.developer-info-head{
  display:flex;
  align-items:center;
  gap:10px;
  margin-bottom:12px;
  color:#9290b0;
  font-size:10px;
  line-height:1;
  font-weight:950;
  letter-spacing:.08em;
  text-transform:uppercase;
}

.developer-info-icon{
  width:32px;
  height:32px;
  border-radius:10px;
  background:#ffffff;
  color:#6558f5;
  display:flex;
  align-items:center;
  justify-content:center;
  flex-shrink:0;
  font-size:14px;
  box-shadow:0 5px 13px rgba(79,70,229,.10);
}

.developer-info-value{
  color:#34324a;
  font-size:14px;
  line-height:1.4;
  font-weight:900;
  overflow-wrap:anywhere;
}

.developer-profile-divider{
  height:1px;
  margin:23px 0 18px;
  background:rgba(113,99,178,.16);
}

.developer-profile-footer{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:16px;
  flex-wrap:wrap;
}

.developer-profile-dates{
  display:flex;
  align-items:center;
  gap:18px;
  flex-wrap:wrap;
  color:#77758e;
  font-size:10px;
  font-weight:800;
}

.developer-profile-dates strong{
  display:block;
  margin-top:3px;
  color:#34324a;
  font-size:11px;
  font-weight:950;
}

.developer-profile-actions{
  display:flex;
  align-items:center;
  gap:9px;
  flex-wrap:wrap;
}

.developer-profile-upload-btn{
  border:0;
  border-radius:13px;
  min-height:40px;
  padding:9px 15px;
  background:linear-gradient(
    135deg,
    #6558f5,
    #8b5cf6
  );
  color:#ffffff;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:8px;
  font-size:11px;
  font-weight:950;
  cursor:pointer;
  box-shadow:0 10px 22px rgba(99,88,245,.25);
  transition:.16s ease;
}

.developer-profile-upload-btn:hover{
  transform:translateY(-1px);
  box-shadow:0 13px 26px rgba(99,88,245,.32);
}

.developer-profile-upload-btn:disabled{
  opacity:.65;
  cursor:not-allowed;
  transform:none;
}

.developer-profile-close-btn{
  min-height:40px;
  padding:9px 15px;
  border:1px solid rgba(98,87,180,.18);
  border-radius:13px;
  background:rgba(255,255,255,.72);
  color:#34324a;
  font-size:11px;
  font-weight:950;
  cursor:pointer;
}

.developer-profile-close-btn:hover{
  background:#ffffff;
}

.developer-profile-upload-note{
  margin-top:8px;
  color:#85829d;
  font-size:9px;
  font-weight:750;
}

@media (max-width:760px){
  .developer-profile-modal .modal-dialog{
    margin:10px;
  }

  .developer-profile-cover{
    min-height:auto;
    padding:18px;
  }

  .developer-profile-identity{
    align-items:center;
    flex-direction:column;
    text-align:center;
    margin-top:28px;
  }

  .developer-profile-eyebrow,
  .developer-profile-meta-line{
    justify-content:center;
  }

