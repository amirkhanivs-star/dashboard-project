    btnEditRow: 'Edit Button',
    btnUpdateRow: 'Update / Save Button',
    btnPdf: 'PDF Button',
    btnBilling: 'Billing Button',
    btnWhatsApp: 'WhatsApp Button',
    btnUpload: 'Upload Button',
    btnFiles: 'Files Button',
    btnDetails: 'View Details Button',
    canDeleteFiles: 'Delete Files',
    canDeleteAdmissions: 'Delete Admissions'
  };

  const PERMISSION_LABELS = Object.freeze({
    ...VIEW_PERMISSION_LABELS,

    ...Object.entries(EDIT_PERMISSION_BY_VIEW)
      .reduce((map, [viewKey, editKey]) => {
        map[editKey] = String(
          VIEW_PERMISSION_LABELS[viewKey] ||
          viewKey
        ).replace(
          /^Can View:/,
          'Can Edit:'
        );

        return map;
      }, {}),

    ...ACTION_PERMISSION_LABELS
  });

  function qs(selector){
    return document.querySelector(selector);
  }

  function qsa(selector){
    return Array.from(document.querySelectorAll(selector));
  }

  function fmtNumber(value){
    const n = Number(value || 0);
    return numberFormatter.format(Number.isFinite(n) ? n : 0);
  }

  function fmtMoney(value){
    const n = Number(value || 0);
    return moneyFormatter.format(Number.isFinite(n) ? n : 0);
  }
    function fmtActiveTime(value){
    const minutes = Math.max(0, Math.round(Number(value || 0)));

    if (!Number.isFinite(minutes) || minutes <= 0) {
      return '0 min';
    }

    const hours = Math.floor(minutes / 60);
    const mins = minutes % 60;

    if (hours <= 0) {
      return minutes + ' min';
    }

    if (mins <= 0) {
      return hours + 'h';
    }

    return hours + 'h ' + mins + 'm';
  }

  function cleanText(value){
    return String(value || '').trim();
  }

  function normalize(value){
    return cleanText(value).toLowerCase();
  }

  function normalizeUserDepartmentKey(value){
    const cleanValue = normalize(value)
      .replace(/[_-]+/g, ' ')
      .replace(/\s+/g, ' ')
      .trim();

    if (
      [
        'accounts',
        'account',
        'school account',
        'school accounts',
        'accounts department',
        'account department',
        'school accounts department'
      ].includes(cleanValue)
    ) {
      return 'accounts';
    }

    if (
      [
        'school',
        'school dept',
        'school department'
      ].includes(cleanValue)
    ) {
      return 'school';
    }

    if (
      [
        'quran',
        'quran dept',
        'quran department'
      ].includes(cleanValue)
    ) {
      return 'quran';
    }

    if (
      [
        'tuition',
        'tuition dept',
        'tuition department'
      ].includes(cleanValue)
    ) {
      return 'tuition';
    }

    return cleanValue;
  }

  const SCHOOL_AGENT_TYPE_OPTIONS = [
    {
      value: 'accounts',
      label: 'Accounts'
    },
    {
      value: 'admission',
      label: 'Admission'
    },
    {
      value: 'management',
      label: 'Management'
    }
  ];

  const SCHOOL_ACCOUNTS_AGENT_TYPE_OPTIONS = [
    {
      value: 'print_record_update',
      label: 'Print + Record Update'
    },
    {
      value: 'verification_registration',
      label: 'Verification & Registration'
    },
    {
      value: 'paid_slip',
      label: 'Paid Slip'
    }
  ];

  function isDeveloperPipelineRole(role){
    const cleanRole = normalize(role);

    return (
      cleanRole === 'agent' ||
      cleanRole === 'sub_agent'
    );
  }

  function getDeveloperAgentTypeOptions(dept){
    return (
      normalizeUserDepartmentKey(dept) ===
      'accounts'
    )
      ? SCHOOL_ACCOUNTS_AGENT_TYPE_OPTIONS
      : SCHOOL_AGENT_TYPE_OPTIONS;
  }

  function getDeveloperAccessScope(
    role,
    dept
  ){
    const cleanRole =
      normalize(role);

    const cleanDept =
      normalizeUserDepartmentKey(
        dept
      );

    if (cleanRole === 'super_admin') {
      return 'all';
    }

    if (cleanDept === 'accounts') {
      return 'school_accounts';
    }

    if (cleanRole === 'admin') {
      return 'team';
    }

    return 'own';
  }

  function syncDeveloperAccessScope(
    roleSelector,
    deptSelector,
    accessScopeSelector
  ){
    const roleInput =
      qs(roleSelector);

    const deptInput =
      qs(deptSelector);

    const accessScopeInput =
      qs(accessScopeSelector);

    if (
      !roleInput ||
      !deptInput ||
      !accessScopeInput
    ) {
      return;
    }

    accessScopeInput.value =
      getDeveloperAccessScope(
        roleInput.value,
        deptInput.value
      );
  }

  function getDeveloperAssignableAdmins(
    dept,
    excludedUserId
  ){
    const cleanDept =
      normalizeUserDepartmentKey(
        dept
      );

    const excludedId =
      Number(excludedUserId || 0);

    return state.users
      .filter((userRow) => {
        if (
          !userRow ||
          typeof userRow !== 'object'
        ) {
          return false;
        }

        if (
          normalize(userRow.role) !==
          'admin'
        ) {
          return false;
        }

        if (
          normalizeUserDepartmentKey(
            userRow.dept
          ) !== cleanDept
        ) {
          return false;
        }

        if (
          excludedId &&
          Number(userRow.id) ===
          excludedId
        ) {
          return false;
        }

        return Number(userRow.id || 0) > 0;
      })
      .sort((firstAdmin, secondAdmin) =>
        cleanText(firstAdmin.name)
          .localeCompare(
            cleanText(secondAdmin.name)
          )
      );
  }

  function syncDeveloperAssignedAdminSelect(
    roleSelector,
    deptSelector,
    adminSelector,
    preferredValue,
    excludedUserId
  ){
    const roleInput =
      qs(roleSelector);

    const deptInput =
      qs(deptSelector);

    const adminInput =
      qs(adminSelector);

    if (
      !roleInput ||
      !deptInput ||
      !adminInput
    ) {
      return;
    }

    const role =
      normalize(roleInput.value);

    const dept =
      normalizeUserDepartmentKey(
        deptInput.value
      );

    const currentValue =
      String(
        typeof preferredValue ===
          'undefined'
          ? adminInput.value || ''
          : preferredValue || ''
      );

    const admins =
      getDeveloperAssignableAdmins(
        dept,
        excludedUserId
      );

    adminInput.innerHTML =
      '<option value="">' +
      'Select assigned admin' +
      '</option>';

    admins.forEach((admin) => {
      const option =
        document.createElement('option');

      option.value =
        String(admin.id);

      option.textContent =
        cleanText(admin.name) +
        (
          cleanText(admin.email)
            ? ' (' +
              cleanText(admin.email) +
              ')'
            : ''
        );

      adminInput.appendChild(option);
    });

    if (!isDeveloperPipelineRole(role)) {
      adminInput.value = '';
      adminInput.disabled = true;
      adminInput.required = false;
      return;
    }

    adminInput.disabled = false;
    adminInput.required = true;

    adminInput.value =
      admins.some(
        (admin) =>
          String(admin.id) ===
          currentValue
      )
        ? currentValue
        : '';

    if (!admins.length) {
      const noAdminOption =
        document.createElement('option');

      noAdminOption.value = '';
      noAdminOption.textContent =
        'No Admin found for this department';

      adminInput.innerHTML = '';
      adminInput.appendChild(
        noAdminOption
      );
    }
  }

  function getValidatedDeveloperAssignedAdminId(
    role,
    dept,
    value,
    excludedUserId
  ){
    if (!isDeveloperPipelineRole(role)) {
      return 0;
    }

    const selectedAdminId =
      Number(value || 0);

    if (!selectedAdminId) {
      return null;
    }

    const isValidAdmin =
      getDeveloperAssignableAdmins(
        dept,
        excludedUserId
      ).some(
        (admin) =>
          Number(admin.id) ===
          selectedAdminId
      );

    return isValidAdmin
      ? selectedAdminId
      : null;
  }

  function syncDeveloperAgentTypeSelect(
    roleSelector,
    deptSelector,
    agentTypeSelector,
    preferredValue
  ){
    const roleInput = qs(roleSelector);
    const deptInput = qs(deptSelector);
    const agentTypeInput =
      qs(agentTypeSelector);

    if (
      !roleInput ||
      !deptInput ||
      !agentTypeInput
    ) {
      return;
    }

    const role = normalize(
      roleInput.value
    );

    const dept =
      normalizeUserDepartmentKey(
        deptInput.value
      );

    const currentValue =
      cleanText(
        typeof preferredValue ===
          'undefined'
          ? agentTypeInput.value
          : preferredValue
      );

    const options =
      getDeveloperAgentTypeOptions(
        dept
      );

    agentTypeInput.innerHTML =
      '<option value="">' +
      'Select pipeline / agent type' +
      '</option>';

    options.forEach((item) => {
      const option =
        document.createElement('option');

      option.value = item.value;
      option.textContent = item.label;

      agentTypeInput.appendChild(option);
    });

    if (!isDeveloperPipelineRole(role)) {
      agentTypeInput.value = '';
      agentTypeInput.disabled = true;
      agentTypeInput.required = false;
      return;
    }

    agentTypeInput.disabled = false;
    agentTypeInput.required = true;

    agentTypeInput.value =
      options.some(
        (item) =>
          item.value === currentValue
      )
        ? currentValue
        : '';
  }

  function getValidatedDeveloperAgentType(
    role,
    dept,
    value
  ){
    if (!isDeveloperPipelineRole(role)) {
      return '';
    }

    const cleanValue =
      cleanText(value);

    const allowedValues =
      getDeveloperAgentTypeOptions(dept)
        .map((item) => item.value);

    return allowedValues.includes(
      cleanValue
    )
      ? cleanValue
      : null;
  }

  function getDeptData(dept){
    const stats = state.stats || {};
    const income = stats.income || {};
    return {
      users: Number(stats.usersByDept?.[dept] || 0),
      admissions: Number(stats.admissionsByDept?.[dept] || 0),
      income: income[dept] || { daily:0, weekly:0, monthly:0, total:0 },
      monthlyAdmissions: Number(stats.departmentDetails?.[dept]?.monthlyAdmissions || 0),
      yearlyAdmissions: Number(stats.departmentDetails?.[dept]?.yearlyAdmissions || 0),
      dailyAdmissions: Number(stats.departmentDetails?.[dept]?.dailyAdmissions || 0),
      timeline: stats.departmentDetails?.[dept]?.timeline || {}
    };
  }

  function toast(message, type = 'ok'){
    const box = qs('#toastBox');
    if (!box) return;

    const el = document.createElement('div');
    el.className = 'dev-toast ' + (type === 'danger' ? 'danger' : 'ok');
    el.innerHTML = `
      <i class="bi ${type === 'danger' ? 'bi-exclamation-triangle-fill' : 'bi-check-circle-fill'}"></i>
      <div>${escapeHtml(message)}</div>
    `;
    box.appendChild(el);

    setTimeout(() => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(8px)';
      setTimeout(() => el.remove(), 200);
    }, 3500);
  }

  function escapeHtml(value){
    return String(value ?? '')
      .replaceAll('&','&amp;')
      .replaceAll('<','&lt;')
      .replaceAll('>','&gt;')
      .replaceAll('"','&quot;')
      .replaceAll("'","&#039;");
  }

  async function apiGet(url){
    const res = await fetch(url, {
      headers: { 'Accept':'application/json' }
    });

    const data = await res.json().catch(() => ({}));

    if (!res.ok || data.success === false) {
      throw new Error(data.message || 'Request failed');
    }

    return data;
  }

  async function apiPost(url, body){
    const res = await fetch(url, {
      method:'POST',
      headers:{
        'Accept':'application/json',
        'Content-Type':'application/json'
      },
      body: JSON.stringify(body || {})
    });

    const data = await res.json().catch(() => ({}));

    if (!res.ok || data.success === false) {
      throw new Error(data.message || 'Request failed');
    }

    return data;
  }

  async function loadAll(){
    if (state.loading) return;
    state.loading = true;

    try {
      const [statsRes, usersRes, apiRes, profileRes] = await Promise.all([
        apiGet('/api/developer/stats'),
        apiGet('/api/developer/users'),
        apiGet('/api/developer/api-settings'),
        apiGet('/api/developer/profile')
      ]);

      state.stats = statsRes.stats || {};
      state.users =
        Array.isArray(usersRes.users)
          ? usersRes.users
              .filter(function(userRow) {
                return (
                  userRow &&
                  typeof userRow === 'object' &&
                  !Array.isArray(userRow)
                );
              })
              .map(function(userRow) {
                const safeUser = {
                  ...userRow
                };

                /*
                 * Passwords, password hashes aur reset
                 * tokens browser state, table aur normal
                 * dashboard exports mein kabhi nahi rakhne.
                 */
                delete safeUser.password;
                delete safeUser.passwordHash;
                delete safeUser.password_hash;

                delete safeUser.resetToken;
                delete safeUser.reset_token;

                delete safeUser.passwordResetToken;
                delete safeUser.password_reset_token;

                return safeUser;
              })
          : [];
      state.apiSettings = normalizeApiSettings(
  apiRes.settings ??
  apiRes.values ??
  apiRes.data ??
  apiRes
);
      state.developerProfile = profileRes.profile || {};

      renderAll();
      toast('Developer dashboard refreshed.');
    } catch (err) {
      console.error(err);
      toast(err.message || 'Could not load developer dashboard.', 'danger');
    } finally {
      state.loading = false;
    }
  }

  function normalizeApiSettings(settings){
  const out = {};

  function saveSetting(key, rawValue){
    const cleanKey = String(key || '').trim();
    if (!cleanKey) return;

    let finalValue = rawValue;

    if (
      finalValue &&
      typeof finalValue === 'object' &&
      !Array.isArray(finalValue)
    ) {
      finalValue =
        finalValue.value ??
        finalValue.setting_value ??
        finalValue.settingValue ??
        finalValue.api_value ??
        finalValue.apiValue ??
        finalValue.key_value ??
        finalValue.current_value ??
        finalValue.currentValue ??
        finalValue.val ??
        '';
    }

    out[cleanKey] = String(finalValue ?? '');
  }

  let source = settings;

  // Nested response formats handle karo.
  if (
    source &&
    typeof source === 'object' &&
    !Array.isArray(source)
  ) {
    source =
      source.values ??
      source.settings ??
      source.data ??
      source;
  }

  // Array rows format:
  // [{ key: 'APP_BASE_URL', value: '...' }]
  if (Array.isArray(source)) {
    source.forEach((item) => {
      if (!item || typeof item !== 'object') return;

      const key =
        item.key ??
        item.setting_key ??
        item.settingKey ??
        item.api_key ??
        item.apiKey ??
        item.key_name ??
        item.name ??
        item.opt_key;

      const value =
        item.value ??
        item.setting_value ??
        item.settingValue ??
        item.api_value ??
        item.apiValue ??
        item.key_value ??
        item.current_value ??
        item.currentValue ??
        item.val ??
        '';

      saveSetting(key, value);
    });

    return out;
  }

  // Direct object format:
  // { APP_BASE_URL: '...', ADMISSIONS_API_KEY: '...' }
  if (source && typeof source === 'object') {
    Object.entries(source).forEach(([key, value]) => {
      saveSetting(key, value);
    });
  }

  return out;
}

