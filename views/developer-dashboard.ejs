  function downloadJSON(filename, data){
    const blob = new Blob([JSON.stringify(data || {}, null, 2)], {
      type:'application/json'
    });

    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    a.click();

    URL.revokeObjectURL(url);
  }

  function downloadUsersCsv(){
    const headers = ['id','name','email','role','dept','agentType','access_scope','createdAt','updatedAt','lastUpdatedAt'];
    const rows = state.filteredUsers.length ? state.filteredUsers : state.users;

    const csv = [
      headers.join(','),
      ...rows.map((u) => headers.map((h) => csvCell(u[h])).join(','))
    ].join('\n');

    const blob = new Blob([csv], { type:'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);

    const a = document.createElement('a');
    a.href = url;
    a.download = 'developer-users.csv';
    a.click();

    URL.revokeObjectURL(url);
  }

  function csvCell(value){
    const s = String(value ?? '');
    if (s.includes('"') || s.includes(',') || s.includes('\n')) {
      return '"' + s.replaceAll('"','""') + '"';
    }
    return s;
  }

  function setupNavSpy(){
    const links = qsa('.nav-btn');
    const sections = links
      .map((link) => qs(link.getAttribute('href')))
      .filter(Boolean);

    const update = () => {
      let activeId = 'overview';

      for (const section of sections) {
        const rect = section.getBoundingClientRect();
        if (rect.top <= 130) {
          activeId = section.id;
        }
      }

      links.forEach((link) => {
        link.classList.toggle('active', link.getAttribute('href') === '#' + activeId);
      });
    };

    document.addEventListener('scroll', update, { passive:true });
    update();
  }

