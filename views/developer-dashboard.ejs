function getDeveloperImageDimensions(file){
  return new Promise((resolve, reject) => {
    const objectUrl = URL.createObjectURL(file);
    const image = new Image();

    image.onload = () => {
      const dimensions = {
        width:Number(image.naturalWidth || 0),
        height:Number(image.naturalHeight || 0)
      };

      URL.revokeObjectURL(objectUrl);
      resolve(dimensions);
    };

    image.onerror = () => {
      URL.revokeObjectURL(objectUrl);

      reject(
        new Error(
          'The selected profile image could not be read.'
        )
      );
    };

    image.src = objectUrl;
  });
}

function destroyDeveloperCropperInstance(){
  if (state.developerCropper) {
    state.developerCropper.destroy();
    state.developerCropper = null;
  }
}

function cleanupDeveloperCropSession(){
  destroyDeveloperCropperInstance();

  if (state.developerCropObjectUrl) {
    URL.revokeObjectURL(
      state.developerCropObjectUrl
    );

    state.developerCropObjectUrl = '';
  }

  state.developerCropFile = null;

  const cropImage = qs('#developerCropImage');

  if (cropImage) {
    cropImage.removeAttribute('src');
    cropImage.style.opacity = '0';
  }

  const input = qs('#developerProfileImageInput');

  if (input) {
    input.value = '';
  }
}

function initializeDeveloperCropper(){
  const cropImage = qs('#developerCropImage');

  if (!cropImage || !cropImage.src) {
    return;
  }

  if (typeof Cropper === 'undefined') {
    toast(
      'Image cropper library could not be loaded.',
      'danger'
    );

    return;
  }

  destroyDeveloperCropperInstance();

  const createCropper = () => {
    destroyDeveloperCropperInstance();

    cropImage.style.opacity = '1';

    state.developerCropper = new Cropper(
      cropImage,
      {
        aspectRatio:1,
        viewMode:1,
        dragMode:'move',
        autoCropArea:1,
        responsive:true,
        restore:false,
        guides:true,
        center:true,
        highlight:false,
        background:false,
        movable:true,
        zoomable:true,
        zoomOnWheel:true,
        rotatable:true,
        scalable:false,
        toggleDragModeOnDblclick:false,
        preview:'.developer-crop-preview'
      }
    );
  };

  if (
    cropImage.complete &&
    cropImage.naturalWidth > 0
  ) {
    createCropper();
  } else {
    cropImage.onload = createCropper;
  }
}

async function handleDeveloperProfileImageSelection(event){
  const input =
    event?.target ||
    qs('#developerProfileImageInput');

  const file = input?.files?.[0];

  if (!file) {
    return;
  }

  const allowedTypes = new Set([
    'image/jpeg',
    'image/jpg',
    'image/png',
    'image/webp'
  ]);

  const allowedExtensions = new Set([
    'jpg',
    'jpeg',
    'png',
    'webp'
  ]);

  const fileType =
    String(file.type || '').toLowerCase();

  const fileExtension =
    String(file.name || '')
      .split('.')
      .pop()
      .toLowerCase();

  if (
    !allowedTypes.has(fileType) &&
    !allowedExtensions.has(fileExtension)
  ) {
    toast(
      'Only JPG, JPEG, PNG and WebP profile images are allowed.',
      'danger'
    );

    input.value = '';
    return;
  }

  if (
    Number(file.size || 0) >
    15 * 1024 * 1024
  ) {
    toast(
      'Profile image must not be larger than 15 MB.',
      'danger'
    );

    input.value = '';
    return;
  }

  let imageDimensions;

  try {
    imageDimensions =
      await getDeveloperImageDimensions(file);
  } catch (err) {
    toast(
      err.message ||
      'The selected profile image could not be read.',
      'danger'
    );

    input.value = '';
    return;
  }

  if (
    imageDimensions.width < 800 ||
    imageDimensions.height < 800
  ) {
    toast(
      'Please select an original image of at least 800 × 800 pixels. Recommended size is 1080 × 1080 pixels or larger.',
      'danger'
    );

    input.value = '';
    return;
  }

  cleanupDeveloperCropSession();

  state.developerCropFile = file;

  state.developerCropObjectUrl =
    URL.createObjectURL(file);

  const cropImage =
    qs('#developerCropImage');

  const cropModalElement =
    qs('#developerCropModal');

  if (!cropImage || !cropModalElement) {
    toast(
      'Profile image crop window is unavailable.',
      'danger'
    );

    cleanupDeveloperCropSession();
    return;
  }

  cropImage.src =
    state.developerCropObjectUrl;

  cropImage.style.opacity = '0';

  state.reopenDeveloperProfileAfterCrop = true;

  const profileModalElement =
    qs('#developerProfileModal');

  const showCropModal = () => {
    bootstrap.Modal
      .getOrCreateInstance(cropModalElement)
      .show();
  };

  const profileModal =
    profileModalElement
      ? bootstrap.Modal.getInstance(
          profileModalElement
        )
      : null;

  if (profileModal && profileModalElement) {
    profileModalElement.addEventListener(
      'hidden.bs.modal',
      showCropModal,
      { once:true }
    );

    profileModal.hide();
  } else {
    showCropModal();
  }
}

