    function getAdmissionValue(admission, ...paths) {
      for (const path of paths) {
        const parts = String(path || "").split(".");
        let value = admission;

        for (const part of parts) {
          if (value == null || typeof value !== "object") {
            value = undefined;
            break;
          }
          value = value[part];
        }

        if (value !== undefined && value !== null && String(value).trim() !== "") {
          return value;
        }
      }
      return "";
    }

    function renderOldAdmissionCard(admission) {
      const id = String(admission?.id || "");
      if (!id) return "";

      const student = String(
        getAdmissionValue(admission, "studentName", "student", "student_name") || "No Name"
      );
      const father = String(
        getAdmissionValue(admission, "fatherName", "father", "father_name") || "-"
      );
      const entryNo = String(
        getAdmissionValue(admission, "entryNumber", "entry_number", "id") || "-"
      );
      const regNo = String(
        getAdmissionValue(admission, "accounts.registrationNumber", "accounts_registration_number") || "-"
      );
      const familyNo = String(
        getAdmissionValue(admission, "accounts.familyNumber", "accounts_family_number") || "-"
      );
      const verifNo = String(
        getAdmissionValue(admission, "latestBillingVerificationNumber", "accounts.verificationNumber") || "-"
      );
      const grade = String(getAdmissionValue(admission, "grade") || "-");
      const phone = String(getAdmissionValue(admission, "phone", "contactNumber") || "-");
      const paymentStatus = String(
        getAdmissionValue(admission, "accounts.paymentStatus") || "-"
      );
      const fees = String(getAdmissionValue(admission, "admission.fees") || "-");
      const currency = String(
        getAdmissionValue(admission, "admission.currency", "admission.currencyCode", "currency") || "-"
      );
      const bank = String(
        getAdmissionValue(admission, "admission.bankName", "accounts.bankName", "bankName") || "-"
      );
      const sourceType = normalizeAccountsSourceTypeClient(
        getAdmissionValue(admission, "forwardedFromType", "forward.fromType") || "school"
      );
      const pipelineType = normalizeAccountsPipelineType(
        getAdmissionValue(admission, "forwardedToType", "forward.toType") || currentUserForwardType
      );
      const owner = String(
        getAdmissionValue(admission, "forwardedOwnerUserName", "forward.forwardedOwnerUserName") || ""
      );
      const issueMessage = String(
        getAdmissionValue(admission, "accountsIssueMessage", "forward.issueMessage") || ""
      );
      const issueFields = normalizeIssueFieldsClient(
        getAdmissionValue(admission, "accountsIssueFields", "forward.issueFields") || []
      );
      const completedAt = String(
        getAdmissionValue(admission, "accountsCompletedAt", "forward.completedAt") || ""
      );
      const latestUpload = admission?.latestUpload || null;

      const fieldPairs = [
        ["No.", entryNo],
        ["Reg #", regNo],
        ["Family #", familyNo],
        ["Verif #", verifNo],
        ["Student", student],
        ["Father", father],
        ["Grade", grade],
        ["Phone Number", phone],
        ["Payment Status", paymentStatus],
        ["Monthly Fees", fees],
        ["Currency", currency],
        ["Bank", bank],
      ];

      const fieldsHtml = fieldPairs.map(([label, value]) => `
        <span class="admission-field-link no-edit-field">
          <span class="field-label">${escapeHtml(label)}</span>
          <span class="field-value">${escapeHtml(value || "-")}</span>
        </span>
      `).join("");

      const fileHtml =
        latestUpload && clientCardPermissions?.btn?.files && latestUpload.fileUrl
          ? `
            <a href="${escapeHtml(latestUpload.fileUrl)}" target="_blank" rel="noopener noreferrer"
               class="admission-file-bill-icon seen-file-icon" title="Open file">
              <i class="bi bi-receipt-cutoff"></i>
            </a>
          `
          : "";

      const detailsHtml = clientCardPermissions?.btn?.details
        ? `<a href="/admin/admission/${encodeURIComponent(id)}" class="mini-action-btn mini-dark"><i class="bi bi-eye"></i> Details</a>`
        : "";

      const pdfHtml = clientCardPermissions?.btn?.pdf
        ? `<a href="/admissions/${encodeURIComponent(id)}/pdf" target="_blank" class="mini-action-btn mini-pdf"><i class="bi bi-file-earmark-pdf-fill"></i> PDF</a>`
        : "";

      const filesHtml = clientCardPermissions?.btn?.files
        ? `<a href="/admin/files?admission_id=${encodeURIComponent(id)}" class="mini-action-btn mini-blue"><i class="bi bi-folder2-open"></i> Files</a>`
        : "";

      const issueHtml = issueMessage
        ? `
          <div class="accounts-issue-note">
            <div class="accounts-issue-note-title"><i class="bi bi-exclamation-triangle-fill"></i> Correction Required</div>
            <div class="accounts-issue-note-message">${escapeHtml(issueMessage)}</div>
            ${issueFields.length ? `<div class="accounts-issue-note-fields">Incorrect: ${escapeHtml(issueFields.join(", "))}</div>` : ""}
          </div>
        `
        : "";

      return `
        <div class="admission-card agent-admission-card accounts-old-dynamic-card"
             data-admission-id="${escapeHtml(id)}"
             data-dept="school"
             data-forward-status="forwarded"
             data-forward-sub-status="${escapeHtml(String(admission?.forwardSubStatus || ""))}"
             data-forwarded-to="${escapeHtml(String(admission?.forwardedToDepartment || ""))}"
             data-forwarded-to-type="${escapeHtml(pipelineType)}"
             data-forwarded-from="${escapeHtml(String(admission?.forwardedFromDepartment || ""))}"
             data-forwarded-from-type="${escapeHtml(sourceType)}"
             data-accounts-workflow-stage="old_admissions"
             data-accounts-issue-message="${escapeHtml(issueMessage)}"
             data-forwarded-owner-user-name="${escapeHtml(owner)}"
             data-can-forward="0">
          <div class="admission-card-top">
            <div class="d-flex align-items-center gap-2">
              <div class="admission-avatar agent-admission-avatar">${escapeHtml(student.charAt(0).toUpperCase() || "A")}</div>
              <div>
                <div class="admission-title">${escapeHtml(student)}</div>
                <div class="admission-subtitle">${escapeHtml(father)}</div>
              </div>
            </div>
            <div class="admission-card-top-right">
              ${fileHtml}
              <span class="admission-role-pill agent-role-pill">School</span>
            </div>
          </div>

          <div class="admission-card-fields">${fieldsHtml}</div>

          ${(detailsHtml || pdfHtml || filesHtml) ? `<div class="admission-card-actions">${detailsHtml}${pdfHtml}${filesHtml}</div>` : ""}

          <div class="school-accounts-workflow-meta">
            <span><b>Pipeline:</b> <span class="accounts-pipeline-label">${escapeHtml(getAccountsPipelineLabelClient(pipelineType))}</span></span>
            <span><b>Source:</b> <span class="accounts-source-label">${escapeHtml(getAccountsSourceLabelClient(sourceType))}</span></span>
            ${owner ? `<span><b>Assigned to:</b> <span class="accounts-owner-label">${escapeHtml(owner)}</span></span>` : ""}
            <span><b>Stage:</b> <span class="accounts-stage-label">Old Admissions</span></span>
            ${completedAt ? `<span><b>Completed:</b> ${escapeHtml(formatDateForCard(completedAt))}</span>` : ""}
          </div>

          ${issueHtml}
        </div>
      `;
    }

    function syncAccountsEmptyState(stage) {
  const grid = document.querySelector(".admission-card-grid");
  if (!grid) return;

  const empty = grid.querySelector(".accounts-old-empty");

  if (empty) {
    empty.classList.add("d-none");
    empty.remove();
  }
}

    async function loadOldAdmissionsCards() {
      if (!shouldShowSchoolAccountsWorkflow || oldAdmissionsLoaded || oldAdmissionsLoading) return;

      const grid = document.querySelector(".admission-card-grid");
      if (!grid) return;

      oldAdmissionsLoading = true;
      let loading = grid.querySelector(".accounts-old-loading");

      if (!loading) {
        loading = document.createElement("div");
        loading.className = "accounts-old-loading d-none";
        loading.innerHTML = '<i class="bi bi-hourglass-split me-1"></i> Loading Old Admissions...';
        grid.appendChild(loading);
      }

      if (activeAccountsStageFilter === "old_admissions") {
        loading.classList.remove("d-none");
      }

      try {
        const response = await fetch('/api/admissions?view=old_admissions', {
          credentials: 'same-origin',
          headers: { Accept: 'application/json' },
        });

        const data = await response.json().catch(() => []);
        if (!response.ok) {
          throw new Error(data?.message || 'Could not load Old Admissions.');
        }

        grid.querySelectorAll('.accounts-old-dynamic-card').forEach(card => card.remove());

        (Array.isArray(data) ? data : []).forEach(admission => {
          const html = renderOldAdmissionCard(admission);
          if (html) grid.insertAdjacentHTML('beforeend', html);
        });

        oldAdmissionsLoaded = true;
        updateForwardCounts();

        if (activeAccountsStageFilter === 'old_admissions') {
          applySchoolAccountsWorkflowFilter('old_admissions', '');
        }
      } catch (error) {
        console.error(error);
        showPopup('danger', 'Old Admissions', error.message || 'Could not load Old Admissions.');
      } finally {
        oldAdmissionsLoading = false;
        loading?.classList.add('d-none');
        syncAccountsEmptyState(activeAccountsStageFilter || 'new_admissions');
      }
    }

    document.addEventListener('click', async function (event) {
      const button = event.target.closest('.btn-complete-record-update');
      if (!button || !canCompleteRecordUpdate) return;

      event.preventDefault();

      const admissionId = String(button.getAttribute('data-admission-id') || '').trim();
      const studentName = String(button.getAttribute('data-student-name') || 'Student').trim();
      if (!admissionId) return;

      const confirmed = window.confirm(
        `Mark ${studentName}'s Record to Update work as complete and move it to Old Admissions?`
      );
      if (!confirmed) return;

      const oldHtml = button.innerHTML;
      button.disabled = true;
      button.innerHTML = '<i class="bi bi-hourglass-split"></i> Completing...';

      try {
        const response = await fetch(
          `/api/admissions/${encodeURIComponent(admissionId)}/accounts/complete-record-update`,
          {
            method: 'POST',
            credentials: 'same-origin',
            headers: { Accept: 'application/json' },
          }
        );

        const data = await response.json().catch(() => ({}));
        if (!response.ok || data.success === false) {
          throw new Error(data.message || 'Could not complete Record Update.');
        }

        const card = button.closest('.admission-card');
        if (card) {
          card.setAttribute('data-accounts-workflow-stage', 'old_admissions');
          button.remove();
          updateAdmissionWorkflowCard(card, {
            id: admissionId,
            accountsWorkflowStage: 'old_admissions',
            forwardedToType: card.getAttribute('data-forwarded-to-type') || currentUserForwardType,
            forwardedFromType: card.getAttribute('data-forwarded-from-type') || 'paid_slip',
            forwardStatus: 'forwarded',
          });
        }

        oldAdmissionsLoaded = false;
        updateForwardCounts();
        applySchoolAccountsWorkflowFilter('new_admissions', activeAccountsSourceFilter);
        showPopup('success', 'Record Completed', data.message || 'Admission moved to Old Admissions.');
      } catch (error) {
        console.error(error);
        showPopup('danger', 'Completion Failed', error.message || 'Could not complete Record Update.');
        button.disabled = false;
        button.innerHTML = oldHtml;
      }
    });

    function initializeForwardWorkflow() {
      const params =
        new URLSearchParams(window.location.search);

      const requestedSchoolFilter =
        String(params.get("schoolForwardFilter") || "")
          .trim()
          .toLowerCase();

      const requestedForwardedSubFilter =
        String(params.get("forwardedSubFilter") || "")
          .trim()
          .toLowerCase();

      const requestedAccountsStageFilter =
        String(params.get("accountsStageFilter") || "")
          .trim()
          .toLowerCase();

      const requestedAccountsSourceFilter =
        String(params.get("accountsSourceFilter") || "")
          .trim()
          .toLowerCase();

      if (
        shouldShowSchoolAccountsWorkflow &&
        requestedAccountsStageFilter
      ) {
        applySchoolAccountsWorkflowFilter(
          requestedAccountsStageFilter,
          requestedAccountsSourceFilter
        );

        applyWorkflowDateFilters();
        return;
      }

      if (
        shouldShowSchoolForwardFilters &&
        requestedSchoolFilter
      ) {
        applySchoolForwardFilter(
          requestedSchoolFilter,
          requestedSchoolFilter === "forwarded"
            ? (
                requestedForwardedSubFilter ||
                "not_verified"
              )
            : ""
        );

        applyWorkflowDateFilters();
        return;
      }

      toggleForwardedSubfilters(false);
      toggleAccountsSourceFilters(false);
      setActiveForwardFilter("");
      setActiveForwardSubFilter("");
      setActiveForwardStageFilter("");
      setActiveAccountsSourceFilter("");
      applyWorkflowDateFilters();
      updateForwardCounts();

      if (shouldShowSchoolAccountsWorkflow) {
        showAccountsPipelineHome();
      }

      if (
        shouldShowSchoolForwardFilters &&
        !shouldShowSchoolAccountsWorkflow
      ) {
        showSchoolForwardHome();
      }
    }

    document.addEventListener(
      "DOMContentLoaded",
      initializeForwardWorkflow
    );

    if (
      document.readyState !== "loading"
    ) {
      initializeForwardWorkflow();
    }
  })();
</script>
