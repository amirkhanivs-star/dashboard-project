    const dateFilterElements = {
      registrationExact:
        document.getElementById(
          "registrationDateExactFilter"
        ),

      registrationFrom:
        document.getElementById(
          "registrationDateFromFilter"
        ),

      registrationTo:
        document.getElementById(
          "registrationDateToFilter"
        ),

      assignedExact:
        document.getElementById(
          "assignedDateExactFilter"
        ),

      assignedFrom:
        document.getElementById(
          "assignedDateFromFilter"
        ),

      assignedTo:
        document.getElementById(
          "assignedDateToFilter"
        ),
    };

    function getDateFilterValues() {
      return Object.fromEntries(
        Object.entries(dateFilterElements).map(
          ([key, element]) => [
            key,
            String(element?.value || "").trim(),
          ]
        )
      );
    }

    function hasActiveDateFilters(filters) {
      return Object
        .values(filters || {})
        .some(Boolean);
    }

    function matchesOneDateFilter(
      cardDate,
      exact,
      from,
      to
    ) {
      const dateOnly = normalizeDateOnly(cardDate);

      if (exact) {
        return dateOnly === exact;
      }

      if (
        from &&
        (!dateOnly || dateOnly < from)
      ) {
        return false;
      }

      if (
        to &&
        (!dateOnly || dateOnly > to)
      ) {
        return false;
      }

      return true;
    }

    function applyWorkflowDateFilters() {
      const filters = getDateFilterValues();

      document
        .querySelectorAll(".admission-card")
        .forEach(card => {
          const registrationDate =
            card.getAttribute(
              "data-registration-date"
            ) || "";

          const assignedDate =
            card.getAttribute(
              "data-registration-assigned-date"
            ) || "";

          const registrationMatches =
            matchesOneDateFilter(
              registrationDate,
              filters.registrationExact,
              filters.registrationFrom,
              filters.registrationTo
            );

          const assignedMatches =
            matchesOneDateFilter(
              assignedDate,
              filters.assignedExact,
              filters.assignedFrom,
              filters.assignedTo
            );

          card.classList.toggle(
            "workflow-date-filter-hidden",
            !(
              registrationMatches &&
              assignedMatches
            )
          );
        });

      const badge = document.getElementById(
        "workflowDateFilterActiveBadge"
      );

      if (badge) {
        badge.classList.toggle(
          "d-none",
          !hasActiveDateFilters(filters)
        );
      }

      updateForwardCounts();
    }

    window.applyWorkflowDateFilters =
      applyWorkflowDateFilters;

    function clearWorkflowDateFilters() {
      Object
        .values(dateFilterElements)
        .forEach(element => {
          if (element) {
            element.value = "";
          }
        });

      applyWorkflowDateFilters();
    }

    const exactRangePairs = [
      {
        exact: dateFilterElements.registrationExact,
        from: dateFilterElements.registrationFrom,
        to: dateFilterElements.registrationTo,
      },
      {
        exact: dateFilterElements.assignedExact,
        from: dateFilterElements.assignedFrom,
        to: dateFilterElements.assignedTo,
      },
    ];

    exactRangePairs.forEach(group => {
      group.exact?.addEventListener(
        "change",
        function () {
          if (!this.value) return;

          if (group.from) {
            group.from.value = "";
          }

          if (group.to) {
            group.to.value = "";
          }
        }
      );

      [group.from, group.to].forEach(element => {
        element?.addEventListener(
          "change",
          function () {
            if (
              this.value &&
              group.exact
            ) {
              group.exact.value = "";
            }
          }
        );
      });
    });

