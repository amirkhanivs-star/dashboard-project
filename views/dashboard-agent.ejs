<script>

  // Upload flash overlay helper
  (function () {
    const overlay = document.getElementById('upload-flash-overlay');
    const iconWrap = document.getElementById('upload-flash-icon-wrap');
    const titleEl  = document.getElementById('upload-flash-title');
    const msgEl    = document.getElementById('upload-flash-message');
    const closeBtn = document.getElementById('upload-flash-close-btn');

    if (!overlay || !iconWrap || !titleEl || !msgEl || !closeBtn) return;

    function setIcon(type) {
      if (type === 'success') {
        iconWrap.innerHTML = `
          <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center"
               style="width:56px;height:56px;background:linear-gradient(135deg,#22c55e,#16a34a);">
            <i class="bi bi-check-lg text-white fs-3"></i>
          </div>`;
      } else if (type === 'danger' || type === 'error') {
        iconWrap.innerHTML = `
          <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center"
               style="width:56px;height:56px;background:linear-gradient(135deg,#ef4444,#b91c1c);">
            <i class="bi bi-exclamation-lg text-white fs-3"></i>
          </div>`;
      } else {
        iconWrap.innerHTML = `
          <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center bg-primary"
               style="width:56px;height:56px;">
            <i class="bi bi-info-lg text-white fs-4"></i>
          </div>`;
      }
    }

    window.showUploadFlash = function(type, title, message) {
      setIcon(type || 'info');
      titleEl.textContent = title || 'Notification';
      msgEl.textContent = message || '';
      overlay.classList.remove('d-none');
    };

    function close() {
      overlay.classList.add('fade-out');
      setTimeout(() => {
        overlay.classList.add('d-none');
        overlay.classList.remove('fade-out');
      }, 260);
    }

    closeBtn.addEventListener('click', close);
  })();

   (function () {
    const flash = <%- JSON.stringify(typeof flash !== 'undefined' ? flash : null) %>;
    if (!flash || !flash.message) return;

    if (typeof window.showUploadFlash === 'function') {
      window.showUploadFlash(
        flash.type || 'info',
        flash.title || 'Notification',
        flash.message || ''
      );
    }
  })();

  (function () {
    const STORAGE_KEY = 'ivsFeeWorkflowForwardNotice';

    function cleanText(value) {
      return String(value || '')
        .replace(/\s+/g, ' ')
        .trim();
    }

    function readForwardNotice() {
      try {
        const raw = window.sessionStorage.getItem(STORAGE_KEY);
        if (!raw) return null;

        const parsed = JSON.parse(raw);
        return parsed && typeof parsed === 'object' ? parsed : null;
      } catch (error) {
        return null;
      }
    }

    function removeForwardNotice() {
      try {
        window.sessionStorage.removeItem(STORAGE_KEY);
      } catch (error) {}
    }

    function buildForwardMessage(notice) {
      const existingMessage = cleanText(notice && notice.message);
      if (existingMessage) return existingMessage;

      const studentText =
        cleanText(notice && notice.studentText) ||
        (
          Array.isArray(notice && notice.studentNames) &&
          notice.studentNames.length
            ? notice.studentNames.map(cleanText).filter(Boolean).join(', ')
            : ''
        ) ||
        'this student';

      const targetUserName =
        cleanText(notice && notice.targetUserName) ||
        'selected user';

      const departmentName =
        cleanText(notice && notice.departmentName) ||
        'School Accounts Dept';

      const pipelineType =
        cleanText(notice && notice.pipelineType) ||
        'selected pipeline';

      return `The admission of ${studentText} has been forwarded to ${targetUserName} in ${departmentName}, ${pipelineType} pipeline.`;
    }

    function showForwardNotice() {
      const notice = readForwardNotice();

      if (
        !notice ||
        notice.type !== 'fee_workflow_forward_success'
      ) {
        return;
      }

      removeForwardNotice();

      const createdAt = Number(notice.createdAt || 0);
      const isOldNotice =
        createdAt > 0 &&
        Date.now() - createdAt > 5 * 60 * 1000;

      if (isOldNotice) return;

      const title =
        cleanText(notice.title) ||
        'Admission Forwarded Successfully';

      const message = buildForwardMessage(notice);

      setTimeout(function () {
        if (typeof window.showUploadFlash === 'function') {
          window.showUploadFlash('success', title, message);
        } else {
          alert(message || title);
        }
      }, 250);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', showForwardNotice);
    } else {
      showForwardNotice();
    }
  })();

  /* ✅ Apply colors to Current Status + Fee Status selects (Agent) */
  (function () {
    function applyStatusClass(sel) {
      if (!sel) return;
      sel.classList.remove('status-running','status-leave','status-stop','status-left','status-freez');

      const v = (sel.value || '').toLowerCase().trim();
      if (v === 'running') sel.classList.add('status-running');
      else if (v === 'leave') sel.classList.add('status-leave');
      else if (v === 'stop') sel.classList.add('status-stop');
      else if (v === 'left') sel.classList.add('status-left');
      else if (v === 'freez') sel.classList.add('status-freez');
    }

    function applyFeeClass(sel) {
      if (!sel) return;
      sel.classList.remove('fee-dues','fee-nodues');

      const v = (sel.value || '').toLowerCase().trim();
      if (v === 'present + dues') sel.classList.add('fee-dues');
      else if (v === 'present + no dues') sel.classList.add('fee-nodues');
    }

    function init() {
      document.querySelectorAll('.js-status-select').forEach(s => {
        applyStatusClass(s);
        s.addEventListener('change', function(){ applyStatusClass(s); });
      });

      document.querySelectorAll('.js-fee-select').forEach(s => {
        applyFeeClass(s);
        s.addEventListener('change', function(){ applyFeeClass(s); });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
<script>
  (function () {
    const STORAGE_KEY = "agent_dashboard_viewport";
    const RECENT_KEY = "agent_dashboard_recent_submit";

    function getPipelineScroll() {
      return document.querySelector(".pipeline-scroll");
    }

    function getMainScrollTop() {
      return (
        window.pageYOffset ||
        document.documentElement.scrollTop ||
        document.body.scrollTop ||
        0
      );
    }

    function setMainScrollTop(value) {
      window.scrollTo(0, Number(value || 0));
      document.documentElement.scrollTop = Number(value || 0);
      document.body.scrollTop = Number(value || 0);
    }

    window.saveViewportState = function () {
      const wrap = getPipelineScroll();

      const state = {
        pageY: getMainScrollTop(),
        tableLeft: wrap ? wrap.scrollLeft : 0,
        tableTop: wrap ? wrap.scrollTop : 0
      };

      sessionStorage.setItem(STORAGE_KEY, JSON.stringify(state));
    };

    window.smoothDashboardReload = function (delay) {
  if (typeof window.saveViewportState === "function") {
    window.saveViewportState();
  }

  document.documentElement.classList.add("ivs-page-leaving");
  document.documentElement.classList.add("ivs-loading");

  setTimeout(function () {
    window.location.reload();
  }, Number(delay || 2000));
};

    function restoreViewportState() {
      const raw = sessionStorage.getItem(STORAGE_KEY);
      if (!raw) return;

      try {
        const state = JSON.parse(raw);
        const wrap = getPipelineScroll();

        const applyRestore = function () {
          setMainScrollTop(state.pageY || 0);

          if (wrap) {
            wrap.scrollLeft = Number(state.tableLeft || 0);
            wrap.scrollTop = Number(state.tableTop || 0);
          }
        };

        applyRestore();

        requestAnimationFrame(() => {
          applyRestore();

          requestAnimationFrame(() => {
            applyRestore();

            setTimeout(() => {
              applyRestore();
            }, 120);
          });
        });
      } catch (err) {
        console.error("Viewport restore failed:", err);
      }

      sessionStorage.removeItem(STORAGE_KEY);
    }

    function bindSaveEvents() {
      document.querySelectorAll('form[id^="rowForm_"]').forEach(form => {
        if (form.dataset.viewportBound === "1") return;
        form.dataset.viewportBound = "1";

        form.addEventListener("submit", function () {
          window.saveViewportState();
          sessionStorage.setItem(RECENT_KEY, "1");
        });
      });

      document.querySelectorAll(".action-update").forEach(btn => {
        if (btn.dataset.viewportBound === "1") return;
        btn.dataset.viewportBound = "1";

        btn.addEventListener("click", function () {
          window.saveViewportState();
          sessionStorage.setItem(RECENT_KEY, "1");
        });
      });
    }

    document.addEventListener("DOMContentLoaded", function () {
      bindSaveEvents();
    });

    window.addEventListener("load", function () {
      restoreViewportState();

      setTimeout(function () {
        sessionStorage.removeItem(RECENT_KEY);
      }, 8000);
    });
  })();
</script>
<script>
  (function () {
    const canUseSchoolForwarding = <%- JSON.stringify(!!canUseSchoolForwarding) %>;
    const shouldShowSchoolForwardFilters = <%- JSON.stringify(!!shouldShowSchoolForwardFilters) %>;
    const shouldShowSchoolAccountsWorkflow = <%- JSON.stringify(!!shouldShowSchoolAccountsWorkflow) %>;
    const shouldShowSchoolAccountsNewAdmissions = shouldShowSchoolAccountsWorkflow;
    const isSuper = <%- JSON.stringify(!!_isSuper) %>;
    const isSchoolAccountsUser = <%- JSON.stringify(!!isSchoolAccountsUser) %>;
    const currentUserRole = <%- JSON.stringify(String(user?.role || '').trim().toLowerCase()) %>;
    const currentUserDept = <%- JSON.stringify(currentUserDept || '') %>;
    const currentUserForwardType = <%- JSON.stringify(currentAccountsPipelineType || '') %>;
    const allowedAccountsSourceFilters = new Set(
      <%- JSON.stringify((currentAccountsSourceFilters || []).map(item => item.value)) %>
    );
        const serverAccountsPipelineCounts = <%- JSON.stringify(accountsPipelineCountData || {}) %>;
    const serverSchoolForwardCounts = <%- JSON.stringify(schoolForwardCountData || {}) %>;
    const canCompleteRecordUpdate = <%- JSON.stringify(!!canCompleteRecordUpdate) %>;
    const clientCardPermissions = <%- JSON.stringify(P) %>;

    if (!canUseSchoolForwarding) return;

    let activeForwardAdmissionId = "";
    let activeForwardStudentName = "";
    let activeForwardMainFilter = "";
    let activeForwardSubFilter = "";
    let activeAccountsStageFilter = "";
    let activeAccountsSourceFilter = "";

    function getDashboardReturnUrlForEdit() {
      const returnUrl = new URL(window.location.href);

      if (activeForwardMainFilter) {
        returnUrl.searchParams.set(
          "schoolForwardFilter",
          activeForwardMainFilter
        );

        if (activeForwardSubFilter) {
          returnUrl.searchParams.set(
            "forwardedSubFilter",
            activeForwardSubFilter
          );
        } else {
          returnUrl.searchParams.delete("forwardedSubFilter");
        }
      } else {
        returnUrl.searchParams.delete("schoolForwardFilter");
        returnUrl.searchParams.delete("forwardedSubFilter");
      }

      if (activeAccountsStageFilter) {
        returnUrl.searchParams.set(
          "accountsStageFilter",
          activeAccountsStageFilter
        );

        if (activeAccountsSourceFilter) {
          returnUrl.searchParams.set(
            "accountsSourceFilter",
            activeAccountsSourceFilter
          );
        } else {
          returnUrl.searchParams.delete("accountsSourceFilter");
        }
      } else {
        returnUrl.searchParams.delete("accountsStageFilter");
        returnUrl.searchParams.delete("accountsSourceFilter");
      }

      return (
        returnUrl.pathname +
        returnUrl.search +
        returnUrl.hash
      );
    }

    function attachDashboardReturnToEditLink(link) {
      if (!link) return;

      try {
        const editUrl = new URL(
          link.getAttribute("href") || "",
          window.location.origin
        );

        editUrl.searchParams.set(
          "returnTo",
          getDashboardReturnUrlForEdit()
        );

        link.setAttribute(
          "href",
          editUrl.pathname + editUrl.search + editUrl.hash
        );
      } catch (err) {
        console.error(
          "attachDashboardReturnToEditLink error:",
          err.message
        );
      }
    }

    document.addEventListener(
      "click",
      function (event) {
        const editLink = event.target.closest(
          ".js-dashboard-edit-return-link"
        );

        if (!editLink) return;

        attachDashboardReturnToEditLink(editLink);
      },
      true
    );

    let oldAdmissionsLoaded = false;
    let oldAdmissionsLoading = false;

    function showPopup(type, title, message) {
      if (typeof window.showUploadFlash === "function") {
        window.showUploadFlash(type, title, message);
      } else {
        alert(message || title || "Notification");
      }
    }

    function escapeHtml(value) {
      return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function normalizeStatusText(value) {
      return String(value || "")
        .trim()
        .toLowerCase()
        .replace(/[_-]+/g, " ")
        .replace(/\s+/g, " ");
    }

    function normalizeDateOnly(value) {
      const raw = String(value || "").trim();
      if (!raw) return "";

      const direct = raw.match(/^(\d{4}-\d{2}-\d{2})/);
      if (direct) return direct[1];

      const parsed = new Date(raw);
      if (Number.isNaN(parsed.getTime())) return "";

      return parsed.toISOString().slice(0, 10);
    }

    function formatDateForCard(value) {
      const dateOnly = normalizeDateOnly(value);
      if (!dateOnly) return "Not Assigned";

      const parts = dateOnly.split("-");
      return `${parts[2]}-${parts[1]}-${parts[0]}`;
    }

    function getWorkflowTagClass(tag) {
      const clean = String(tag || "").trim().toLowerCase();

      if (clean === "reupload") {
        return "workflow-tag-reupload";
      }

      if (
        clean === "not received" ||
        clean === "registration number removed"
      ) {
        return "workflow-tag-danger";
      }

      return "";
    }

    function deriveWorkflowTag({
      directTag = "",
      schoolReturnStatus = "",
      reuploadTagActive = false,
      registrationNumberRemoved = false,
    } = {}) {
      const returnStatus = String(
        schoolReturnStatus || ""
      )
        .trim()
        .toLowerCase();

      if (returnStatus === "not_received") {
        return "Not Received";
      }

      if (
        returnStatus === "reupload" ||
        reuploadTagActive
      ) {
        return "Reupload";
      }

      const cleanDirect = String(
        directTag || ""
      ).trim();

      if (cleanDirect) {
        return cleanDirect;
      }

      return registrationNumberRemoved
        ? "Registration Number Removed"
        : "";
    }

    function upsertForwardDisplayText(card, text) {
      if (!card) return;

      const cleanText = String(text || "").trim();
      let note = card.querySelector(".admission-forward-note");

      if (!cleanText) {
        if (note) note.classList.add("d-none");
        return;
      }

      if (!note) {
        note = document.createElement("div");
        note.className = "admission-forward-note";
        note.innerHTML = `
          <i class="bi bi-send-check"></i>
          <span class="admission-forward-note-text"></span>
        `;
        card.appendChild(note);
      }

      const textEl = note.querySelector(".admission-forward-note-text");

      if (textEl) {
        textEl.innerHTML = escapeHtml(cleanText);
      }

      note.classList.remove("d-none");
    }

    function upsertWorkflowTag(card, tag) {
      if (!card) return;

      const cleanTag = String(tag || "").trim();
      let tagEl = card.querySelector(".admission-workflow-tag");

      if (!tagEl) {
        const topRight = card.querySelector(".admission-card-top-right");

        if (topRight) {
          tagEl = document.createElement("span");
          tagEl.className = "admission-workflow-tag d-none";

          const rolePill = topRight.querySelector(".admission-role-pill");

          if (rolePill) {
            topRight.insertBefore(tagEl, rolePill);
          } else {
            topRight.appendChild(tagEl);
          }
        }
      }

      if (!tagEl) return;

      tagEl.classList.remove(
        "workflow-tag-danger",
        "workflow-tag-reupload"
      );

      const tagClass = getWorkflowTagClass(cleanTag);

      if (tagClass) {
        tagEl.classList.add(tagClass);
      }

      tagEl.textContent = cleanTag;
      tagEl.classList.toggle("d-none", !cleanTag);

      card.setAttribute("data-workflow-tag", cleanTag);
    }

    function upsertWorkflowDates(card, registrationDate, assignedDate) {
      if (!card) return;

      const registrationDateOnly = normalizeDateOnly(registrationDate);
      const assignedDateOnly = normalizeDateOnly(assignedDate);

      card.setAttribute(
        "data-registration-date",
        registrationDateOnly
      );

      card.setAttribute(
        "data-registration-assigned-date",
        assignedDateOnly
      );

      let datesWrap = card.querySelector(".admission-workflow-dates");

      if (!datesWrap) {
        datesWrap = document.createElement("div");
        datesWrap.className = "admission-workflow-dates";

        datesWrap.innerHTML = `
          <span>
            <b>Registration:</b>
            <span class="workflow-registration-date-text"></span>
          </span>

          <span class="workflow-date-separator">•</span>

          <span>
            <b>Reg. No. Assigned:</b>
            <span class="workflow-assigned-date-text"></span>
          </span>
        `;

        const forwardNote = card.querySelector(".admission-forward-note");

        if (forwardNote) {
          card.insertBefore(datesWrap, forwardNote);
        } else {
          card.appendChild(datesWrap);
        }
      }

      const registrationText = datesWrap.querySelector(
        ".workflow-registration-date-text"
      );

      const assignedText = datesWrap.querySelector(
        ".workflow-assigned-date-text"
      );

      if (registrationText) {
        registrationText.textContent =
          formatDateForCard(registrationDateOnly);
      }

      if (assignedText) {
        assignedText.textContent =
          formatDateForCard(assignedDateOnly);
      }
    }

    function normalizeAccountsPipelineType(value) {
      const clean = String(value || "")
        .trim()
        .toLowerCase()
        .replace(/[\s-]+/g, "_");

      const aliases = {
        "print_+_record_update": "print_record_update",
        "print_&_record_update": "print_record_update",
        print_record_update: "print_record_update",
        verification_registration: "verification_registration",
        "verification_&_registration": "verification_registration",
        paid_slip: "paid_slip",
        fee_slip: "paid_slip",
      };

      return aliases[clean] || clean;
    }

    function getAccountsPipelineLabelClient(type) {
      const labels = {
        print_record_update: "Print & Record Update",
        verification_registration: "Verification & Registration",
        paid_slip: "Paid Slip",
        school: "School Department",
        school_return: "School Department",
      };

      return labels[normalizeAccountsPipelineType(type)] || "";
    }

    function normalizeAccountsSourceTypeClient(value) {
      const clean = String(value || "")
        .trim()
        .toLowerCase()
        .replace(/[\s-]+/g, "_");

      const aliases = {
        school: "school",
        school_department: "school",
        internal_department: "internal_department",
        internal: "internal_department",
        print_record_update: "print_record_update",
        "print_+_record_update": "print_record_update",
        "print_&_record_update": "print_record_update",
        verification_registration: "verification_registration",
        "verification_&_registration": "verification_registration",
        paid_slip: "paid_slip",
        fee_slip: "paid_slip",
        record_to_update: "record_to_update",
        record_update: "record_to_update",
      };

      return aliases[clean] || clean || "school";
    }

    function getAccountsSourceLabelClient(type) {
      const labels = {
        school: "School Department",
        print_record_update: "Print & Record Update Department",
        verification_registration: "Verification & Registration Department",
        paid_slip: "Paid Slip Department",
        record_to_update: "Record to Update",
        internal_department: "Internal Department",
      };

      return labels[normalizeAccountsSourceTypeClient(type)] || "";
    }


    function normalizeAccountsWorkflowStageClient(value) {
      const clean = String(value || "")
        .trim()
        .toLowerCase()
        .replace(/[\s-]+/g, "_");

      const aliases = {
        new: "new_admissions",
        new_admission: "new_admissions",
        new_admissions: "new_admissions",
        record_update: "record_to_update",
        record_to_update: "record_to_update",
        old: "old_admissions",
        old_admission: "old_admissions",
        old_admissions: "old_admissions",
      };

      return aliases[clean] || "new_admissions";
    }

    function getAccountsWorkflowStageLabelClient(stage) {
      const labels = {
        new_admissions: "New Admissions",
        record_to_update: "Record to Update",
        old_admissions: "Old Admissions",
      };

      return labels[
        normalizeAccountsWorkflowStageClient(stage)
      ] || "New Admissions";
    }

    function normalizeIssueFieldsClient(value) {
      if (Array.isArray(value)) {
        return value
          .map(item => String(item || "").trim())
          .filter(Boolean);
      }

      const raw = String(value || "").trim();
      if (!raw) return [];

      try {
        const parsed = JSON.parse(raw);

        return Array.isArray(parsed)
          ? parsed
              .map(item => String(item || "").trim())
              .filter(Boolean)
          : [];
      } catch (error) {
        return raw
          .split(",")
          .map(item => item.trim())
          .filter(Boolean);
      }
    }

    function upsertAccountsWorkflowMeta(card, details = {}) {
      if (!card) return;

      const pipelineType =
        normalizeAccountsPipelineType(
          details.pipelineType || ""
        );

      const forwardStatus = String(
        details.forwardStatus || ""
      )
        .trim()
        .toLowerCase();

      let meta = card.querySelector(
        ".school-accounts-workflow-meta"
      );

      const shouldShow =
        forwardStatus === "forwarded" &&
        !!pipelineType &&
        pipelineType !== "school_return";

      if (!shouldShow) {
        if (meta) {
          meta.classList.add("d-none");
        }
        return;
      }

      if (!meta) {
        meta = document.createElement("div");
        meta.className = "school-accounts-workflow-meta";

        const issueNote = card.querySelector(
          ".accounts-issue-note"
        );

        const forwardNote = card.querySelector(
          ".admission-forward-note"
        );

        if (issueNote) {
          card.insertBefore(meta, issueNote);
        } else if (forwardNote) {
          card.insertBefore(meta, forwardNote);
        } else {
          card.appendChild(meta);
        }
      }

      const pipelineLabel =
        getAccountsPipelineLabelClient(pipelineType) ||
        String(details.pipelineDepartment || "").trim() ||
        "School Accounts";

      const sourceLabel =
        String(details.sourceDepartment || "").trim() ||
        getAccountsPipelineLabelClient(
          details.sourceType || ""
        ) ||
        "School Department";

      const ownerName = String(
        details.ownerName || ""
      ).trim();

      const stageLabel =
        getAccountsWorkflowStageLabelClient(
          details.workflowStage || ""
        );

      meta.innerHTML = `
        <span>
          <b>Pipeline:</b>
          <span class="accounts-pipeline-label">${escapeHtml(pipelineLabel)}</span>
        </span>

        <span>
          <b>Source:</b>
          <span class="accounts-source-label">${escapeHtml(sourceLabel)}</span>
        </span>

        ${ownerName ? `
          <span>
            <b>Assigned to:</b>
            <span class="accounts-owner-label">${escapeHtml(ownerName)}</span>
          </span>
        ` : ""}

        <span>
          <b>Stage:</b>
          <span class="accounts-stage-label">${escapeHtml(stageLabel)}</span>
        </span>
      `;

      meta.classList.remove("d-none");
    }

    function upsertAccountsIssueNote(
      card,
      issueMessage,
      issueFields = []
    ) {
      if (!card) return;

      const cleanMessage = String(
        issueMessage || ""
      ).trim();

      const cleanFields =
        normalizeIssueFieldsClient(issueFields);

      let note = card.querySelector(
        ".accounts-issue-note"
      );

      if (!cleanMessage) {
        if (note) {
          note.classList.add("d-none");
        }
        return;
      }

      if (!note) {
        note = document.createElement("div");
        note.className = "accounts-issue-note";

        const forwardNote = card.querySelector(
          ".admission-forward-note"
        );

        if (forwardNote) {
          card.insertBefore(note, forwardNote);
        } else {
          card.appendChild(note);
        }
      }

      note.innerHTML = `
        <div class="accounts-issue-note-title">
          <i class="bi bi-exclamation-triangle-fill"></i>
          Correction Required
        </div>

        <div class="accounts-issue-note-message">${escapeHtml(cleanMessage)}</div>

        ${cleanFields.length ? `
          <div class="accounts-issue-note-fields">
            Incorrect: ${escapeHtml(cleanFields.join(", "))}
          </div>
        ` : ""}
      `;

      note.classList.remove("d-none");
    }

    function parseForwardTimerClientDate(value = "") {
      const raw = String(value || "").trim();
      if (!raw) return null;

      const direct = new Date(raw);
      if (!Number.isNaN(direct.getTime())) {
        return direct;
      }

      const sqliteLike = new Date(raw.replace(" ", "T"));
      if (!Number.isNaN(sqliteLike.getTime())) {
        return sqliteLike;
      }

      return null;
    }

    function formatForwardTimerClientDuration(seconds = 0) {
      const totalSeconds = Math.max(0, Number(seconds || 0));
      const totalMinutes = Math.floor(totalSeconds / 60);
      const days = Math.floor(totalMinutes / 1440);
      const hours = Math.floor((totalMinutes % 1440) / 60);
      const minutes = totalMinutes % 60;

      return `${days}d ${hours}h ${minutes}m`;
    }

    function getForwardTimerFromAdmission(admission = {}) {
      const forward = admission?.forward || {};

      return (
        admission?.currentForwardTimer ||
        admission?.forwardTimer ||
        forward?.currentTimer ||
        forward?.forwardTimer ||
        forward?.timer ||
        null
      );
    }

    function getForwardTimerStartedAt(timer = {}) {
      return String(
        timer?.startedAt ||
        timer?.started_at ||
        timer?.startAt ||
        timer?.started ||
        ""
      ).trim();
    }

    function getForwardTimerName(timer = {}, card = null) {
      return String(
        timer?.name ||
        timer?.holderUserName ||
        timer?.holder_user_name ||
        timer?.userName ||
        timer?.user_name ||
        card?.getAttribute("data-forward-timer-name") ||
        card?.getAttribute("data-forwarded-owner-user-name") ||
        ""
      ).trim();
    }

    function getForwardTimerDept(timer = {}, card = null) {
      return String(
        timer?.department ||
        timer?.holderDepartment ||
        timer?.holder_department ||
        timer?.dept ||
        card?.getAttribute("data-forward-timer-dept") ||
        card?.getAttribute("data-forwarded-to") ||
        ""
      ).trim();
    }

    function getForwardTimerType(timer = {}, card = null) {
      return String(
        timer?.type ||
        timer?.holderType ||
        timer?.holder_type ||
        timer?.forwardType ||
        card?.getAttribute("data-forward-timer-type") ||
        card?.getAttribute("data-forwarded-to-type") ||
        ""
      ).trim();
    }

    function getForwardTimerDurationLabelFromStart(startedAt = "") {
      const parsed = parseForwardTimerClientDate(startedAt);
      if (!parsed) return "0d 0h 0m";

      return formatForwardTimerClientDuration(
        Math.floor((Date.now() - parsed.getTime()) / 1000)
      );
    }

    function getForwardTimerContextText(dept = "", type = "") {
      return [
        String(dept || "").trim(),
        getAccountsPipelineLabelClient(type) || String(type || "").trim(),
      ].filter(Boolean).join(" | ");
    }

       function getForwardTimerLogsFromAdmission(admission = {}) {
      const forward = admission?.forward || {};

      if (Array.isArray(admission?.forwardTimeLogs)) {
        return admission.forwardTimeLogs;
      }

      if (Array.isArray(admission?.forward_time_logs)) {
        return admission.forward_time_logs;
      }

      if (Array.isArray(admission?.timeLogs)) {
        return admission.timeLogs;
      }

      if (Array.isArray(forward?.timeLogs)) {
        return forward.timeLogs;
      }

      if (Array.isArray(forward?.forwardTimeLogs)) {
        return forward.forwardTimeLogs;
      }

      return [];
    }

    function getForwardTimerLogsFromCard(card) {
      if (!card) return [];

      const raw =
        card.getAttribute("data-forward-time-logs") || "";

      if (!raw) return [];

      try {
        const parsed = JSON.parse(raw);
        return Array.isArray(parsed) ? parsed : [];
      } catch (e) {
        return [];
      }
    }

    function getForwardTimerLogName(log = {}) {
      return String(
        log.name ||
        log.holderUserName ||
        log.holder_user_name ||
        log.userName ||
        log.user_name ||
        ""
      ).trim();
    }

    function getForwardTimerLogDept(log = {}) {
      return String(
        log.department ||
        log.holderDepartment ||
        log.holder_department ||
        log.dept ||
        ""
      ).trim();
    }

    function getForwardTimerLogType(log = {}) {
      return String(
        log.type ||
        log.holderType ||
        log.holder_type ||
        log.forwardType ||
        ""
      ).trim();
    }

    function getForwardTimerLogDuration(log = {}) {
      const savedLabel = String(
        log.durationLabel ||
        log.duration_label ||
        ""
      ).trim();

      if (savedLabel) {
        return savedLabel;
      }

      const seconds = Number(
        log.durationSeconds ||
        log.duration_seconds ||
        0
      );

      return formatForwardTimerClientDuration(seconds);
    }

    function renderForwardTimerTooltip({
      name = "",
      contextText = "",
      durationLabel = "",
      logs = [],
    } = {}) {
      const cleanLogs = Array.isArray(logs) ? logs : [];

      const historyRows = cleanLogs.map(log => {
        const logName =
          getForwardTimerLogName(log) || "Selected user";

        const logDept =
          getForwardTimerLogDept(log) || "-";

        const rawType =
          getForwardTimerLogType(log);

        const logType =
          getAccountsPipelineLabelClient(rawType) ||
          rawType ||
          "-";

        const logDuration =
          getForwardTimerLogDuration(log);

        return `
          <span class="timer-tooltip-section-title">Previous Holder</span>
          <span class="timer-tooltip-row"><b>Name:</b> ${escapeHtml(logName)}</span>
          <span class="timer-tooltip-row"><b>Dept:</b> ${escapeHtml(logDept)}</span>
          <span class="timer-tooltip-row"><b>Type:</b> ${escapeHtml(logType)}</span>
          <span class="timer-tooltip-row"><b>Time:</b> ${escapeHtml(logDuration)}</span>
        `;
      }).join("");

      return `
        <span class="timer-tooltip-title">Current Timer</span>
        <span class="timer-tooltip-row"><b>Name:</b> ${escapeHtml(name || "selected user")}</span>
        ${contextText ? `<span class="timer-tooltip-row"><b>Target:</b> ${escapeHtml(contextText)}</span>` : ""}
        <span class="timer-tooltip-row"><b>Time:</b> ${escapeHtml(durationLabel)}</span>
        ${historyRows || ""}
      `;
    }

    function ensureAdmissionForwardTimerPill(card) {
      if (!card) return null;

      let pill = card.querySelector("[data-forward-timer-pill]");
      if (pill) return pill;

      const topRight = card.querySelector(".admission-card-top-right");
      if (!topRight) return null;

      pill = document.createElement("span");
      pill.className = "admission-forward-timer-pill d-none";
      pill.setAttribute("data-forward-timer-pill", "1");
      pill.innerHTML = `
        <i class="bi bi-stopwatch"></i>
        <b class="admission-forward-timer-time" data-forward-timer-time></b>
        <span class="admission-forward-timer-tooltip" data-forward-timer-tooltip></span>
      `;

      const workflowTag = topRight.querySelector(".admission-workflow-tag");
      const rolePill = topRight.querySelector(".admission-role-pill");

      if (workflowTag) {
        topRight.insertBefore(pill, workflowTag);
      } else if (rolePill) {
        topRight.insertBefore(pill, rolePill);
      } else {
        topRight.appendChild(pill);
      }

      return pill;
    }

    function ensureAdmissionForwardTimerNote(card) {
      if (!card) return null;

      const existingNote =
        card.querySelector("[data-forward-timer-note]");

      if (existingNote) {
        existingNote.remove();
      }

      return null;
    }

    function refreshAdmissionForwardTimerCard(card) {
      if (!card) return;

      const isActive =
        card.getAttribute("data-forward-timer-active") === "1";

      const startedAt =
        card.getAttribute("data-forward-timer-started-at") || "";

      const name =
        card.getAttribute("data-forward-timer-name") || "selected user";

      const dept =
        card.getAttribute("data-forward-timer-dept") || "";

      const type =
        card.getAttribute("data-forward-timer-type") || "";

      const contextText =
        getForwardTimerContextText(dept, type);

      const logs =
        getForwardTimerLogsFromCard(card);

      const pill = ensureAdmissionForwardTimerPill(card);
      const note = ensureAdmissionForwardTimerNote(card);

      if (!isActive || !startedAt) {
        if (pill) pill.classList.add("d-none");
        if (note) note.classList.add("d-none");
        return;
      }

      const durationLabel =
        getForwardTimerDurationLabelFromStart(startedAt);

      if (pill) {
        pill.querySelectorAll("[data-forward-timer-time]").forEach(el => {
          el.textContent = durationLabel;
        });

        const tooltip =
          pill.querySelector("[data-forward-timer-tooltip]");

        if (tooltip) {
          tooltip.innerHTML = renderForwardTimerTooltip({
            name,
            contextText,
            durationLabel,
            logs,
          });
        }

        pill.removeAttribute("title");
        pill.classList.remove("d-none");
      }

      if (note) {
        note.classList.add("d-none");
      }
    }

    function refreshAllAdmissionForwardTimers() {
      document
        .querySelectorAll(".admission-card")
        .forEach(refreshAdmissionForwardTimerCard);
    }

    function upsertAdmissionForwardTimer(card, admission = {}, options = {}) {
      if (!card) return;

      const timer =
        getForwardTimerFromAdmission(admission) ||
        (
          admission &&
          (
            admission.startedAt ||
            admission.started_at ||
            admission.holderUserName ||
            admission.holder_user_name
          )
            ? admission
            : null
        );

      const forwardStatus = String(
        options.forwardStatus ||
        admission?.forwardStatus ||
        admission?.forward?.status ||
        card.getAttribute("data-forward-status") ||
        ""
      ).trim().toLowerCase();

      const workflowStage = String(
        options.workflowStage ||
        admission?.accountsWorkflowStage ||
        admission?.accounts_workflow_stage ||
        admission?.forward?.workflowStage ||
        card.getAttribute("data-accounts-workflow-stage") ||
        ""
      ).trim().toLowerCase();

      const startedAt =
        getForwardTimerStartedAt(timer || {});

      const shouldShow =
        forwardStatus === "forwarded" &&
        workflowStage !== "old_admissions" &&
        !!timer &&
        !!startedAt;

      if (!shouldShow) {
        card.setAttribute("data-forward-timer-active", "0");
        card.setAttribute("data-forward-timer-started-at", "");
        refreshAdmissionForwardTimerCard(card);
        return;
      }

      const name =
        getForwardTimerName(timer, card) || "selected user";

      const dept =
        getForwardTimerDept(timer, card);

      const type =
        getForwardTimerType(timer, card);

      const logs =
        getForwardTimerLogsFromAdmission(admission);

      card.setAttribute("data-forward-timer-active", "1");
      card.setAttribute("data-forward-timer-started-at", startedAt);
      card.setAttribute("data-forward-timer-name", name);
      card.setAttribute("data-forward-timer-dept", dept);
      card.setAttribute("data-forward-timer-type", type);

      if (logs.length) {
        card.setAttribute(
          "data-forward-time-logs",
          JSON.stringify(logs)
        );
      }

      refreshAdmissionForwardTimerCard(card);
    }

    function syncForwardAction(
      card,
      admission = {}
    ) {
      if (!card) return;

      const actions =
        card.querySelector(
          ".admission-card-actions"
        );

      if (!actions) return;

      const admissionCanForward =
        admission?.canShowForwardButton === true ||
        admission?.canShowForwardButton === 1 ||
        admission?.canShowForwardButton === "1";

      if (
        typeof admission?.canShowForwardButton !==
        "undefined"
      ) {
        card.setAttribute(
          "data-can-forward",
          admissionCanForward ? "1" : "0"
        );
      }

      const state =
        getCardForwardState(card);

      const admissionId = String(
        admission?.id ||
        card.getAttribute(
          "data-admission-id"
        ) ||
        ""
      );

      const studentName = String(
        admission?.student ||
        admission?.studentName ||
        card.querySelector(
          ".admission-title"
        )?.textContent ||
        "Student"
      ).trim();

      const canReforwardAfterReupload =
        currentUserDept === "school" &&
        state.schoolReturnStatus ===
          "reupload";

      const shouldShowForwardButton =
        state.isSchool &&
        state.canForward &&
        (
          isSchoolAccountsUser ||
          state.status !== "forwarded" ||
          canReforwardAfterReupload
        );

      let forwardButton =
        actions.querySelector(
          ".btn-forward-admission"
        );

      let forwardedDone =
        actions.querySelector(
          ".mini-forwarded-done"
        );

      if (shouldShowForwardButton) {
        if (forwardedDone) {
          forwardedDone.remove();
          forwardedDone = null;
        }

        if (!forwardButton) {
          forwardButton =
            document.createElement(
              "button"
            );

          forwardButton.type =
            "button";

          forwardButton.className =
            "mini-action-btn mini-forward btn-forward-admission";

          forwardButton.innerHTML = `
            <i class="bi bi-send"></i>
            Forward
          `;

          actions.appendChild(
            forwardButton
          );
        }

        forwardButton.setAttribute(
          "data-admission-id",
          admissionId
        );

        forwardButton.setAttribute(
          "data-student",
          studentName
        );

        forwardButton.classList.remove(
          "d-none"
        );

        return;
      }

      if (forwardButton) {
        forwardButton.remove();
      }

      if (state.isForwarded) {
        const forwardedTo =
          String(
            card.getAttribute(
              "data-forwarded-to"
            ) || ""
          ).trim();

        if (!forwardedDone) {
          forwardedDone =
            document.createElement(
              "span"
            );

          forwardedDone.className =
            "mini-action-btn mini-forwarded-done";

          actions.appendChild(
            forwardedDone
          );
        }

        forwardedDone.innerHTML = `
          <i class="bi bi-send-check"></i>
          Forwarded${
            forwardedTo
              ? ` to ${escapeHtml(forwardedTo)}`
              : ""
          }
        `;
      } else if (forwardedDone) {
        forwardedDone.remove();
      }
    }
    function updateAdmissionWorkflowCard(card, admission = {}) {
      if (!card) return;

      const forward = admission?.forward || {};

      const forwardStatus = String(
        admission?.forwardStatus ||
        forward?.status ||
        card.getAttribute("data-forward-status") ||
        "not_forwarded"
      )
        .trim()
        .toLowerCase();

      const forwardSubStatus = String(
        admission?.forwardSubStatus ||
        forward?.subStatus ||
        card.getAttribute("data-forward-sub-status") ||
        ""
      )
        .trim()
        .toLowerCase();

      const schoolReturnStatus = String(
        admission?.schoolReturnStatus ||
        admission?.school_return_status ||
        forward?.schoolReturnStatus ||
        card.getAttribute("data-school-return-status") ||
        ""
      )
        .trim()
        .toLowerCase();

      const hasExplicitReuploadTag =
        Object.prototype.hasOwnProperty.call(
          admission || {},
          "reuploadTagActive"
        ) ||
        Object.prototype.hasOwnProperty.call(
          admission || {},
          "reupload_tag_active"
        );

      const reuploadTagActive =
        hasExplicitReuploadTag
          ? Number(
              admission?.reuploadTagActive ??
              admission?.reupload_tag_active ??
              0
            ) === 1
          : card.getAttribute(
              "data-reupload-tag-active"
            ) === "1";

      const registrationNumberRemoved =
        Number(
          admission?.registrationNumberRemoved ||
          admission?.registration_number_removed ||
          admission?.accounts?.registrationNumberRemoved ||
          card.getAttribute("data-registration-number-removed") ||
          0
        ) === 1;

      const hasExplicitCanForward =
        Object.prototype.hasOwnProperty.call(
          admission || {},
          "canShowForwardButton"
        ) ||
        Object.prototype.hasOwnProperty.call(
          admission || {},
          "canForward"
        );

      const admissionCanForward =
        admission?.canShowForwardButton === true ||
        admission?.canShowForwardButton === 1 ||
        admission?.canShowForwardButton === "1" ||
        admission?.canForward === true ||
        admission?.canForward === 1 ||
        admission?.canForward === "1";

      const canForward =
        schoolReturnStatus === "not_received"
          ? false
          : hasExplicitCanForward
            ? admissionCanForward
            : card.getAttribute(
                "data-can-forward"
              ) === "1";

      const workflowTag = deriveWorkflowTag({
        directTag: admission?.workflowTag || "",
        schoolReturnStatus,
        reuploadTagActive,
        registrationNumberRemoved,
      });

      const registrationDate =
        admission?.registrationDate ||
        admission?.registration_date ||
        card.getAttribute("data-registration-date") ||
        "";

      const assignedDate =
        admission?.registrationNumberAssignedAt ||
        admission?.accounts_registration_number_assigned_at ||
        admission?.accounts?.registrationNumberAssignedAt ||
        card.getAttribute("data-registration-assigned-date") ||
        "";

      const forwardDisplayText = String(
        admission?.forwardDisplayText ||
        forward?.displayText ||
        card.getAttribute("data-forward-display-text") ||
        ""
      ).trim();

      const forwardedFromDepartment = String(
        admission?.forwardedFromDepartment ||
        admission?.forwarded_from_department ||
        forward?.fromDepartment ||
        card.getAttribute("data-forwarded-from") ||
        ""
      ).trim();

      const forwardedFromType =
        normalizeAccountsPipelineType(
          admission?.forwardedFromType ||
          admission?.forwarded_from_type ||
          forward?.fromType ||
          card.getAttribute("data-forwarded-from-type") ||
          ""
        );

      const accountsWorkflowStage =
        normalizeAccountsWorkflowStageClient(
          admission?.accountsWorkflowStage ||
          admission?.accounts_workflow_stage ||
          forward?.workflowStage ||
          card.getAttribute("data-accounts-workflow-stage") ||
          "new_admissions"
        );

      const accountsIssueMessage = String(
        admission?.accountsIssueMessage ||
        admission?.accounts_issue_message ||
        admission?.issueMessage ||
        forward?.issueMessage ||
        card.getAttribute("data-accounts-issue-message") ||
        ""
      ).trim();

      const accountsIssueFields =
        normalizeIssueFieldsClient(
          admission?.accountsIssueFields ||
          admission?.accounts_issue_fields ||
          admission?.issueFields ||
          forward?.issueFields ||
          []
        );

      const forwardedOwnerUserName = String(
        admission?.forwardedOwnerUserName ||
        admission?.forwarded_owner_user_name ||
        forward?.forwardedOwnerUserName ||
        card.getAttribute("data-forwarded-owner-user-name") ||
        ""
      ).trim();

      card.setAttribute(
        "data-forward-status",
        forwardStatus
      );

      card.setAttribute(
        "data-forward-sub-status",
        forwardSubStatus
      );

      card.setAttribute(
        "data-school-return-status",
        schoolReturnStatus
      );

      card.setAttribute(
        "data-reupload-tag-active",
        reuploadTagActive ? "1" : "0"
      );

      card.setAttribute(
        "data-can-forward",
        canForward ? "1" : "0"
      );

      const forwardButton = card.querySelector(
        ".btn-forward-admission"
      );

      if (forwardButton) {
        forwardButton.classList.toggle(
          "d-none",
          !canForward
        );
      }

      card.setAttribute(
        "data-registration-number-removed",
        registrationNumberRemoved ? "1" : "0"
      );

      card.setAttribute(
        "data-not-received-visible-for-current-user",
        admission?.notReceivedVisibleForCurrentUser === true ||
        schoolReturnStatus === "not_received" ||
        schoolReturnStatus === "reupload"
          ? "1"
          : "0"
      );

      if (
        admission?.forwardedToDepartment ||
        forward?.toDepartment
      ) {
        card.setAttribute(
          "data-forwarded-to",
          admission?.forwardedToDepartment ||
          forward?.toDepartment ||
          ""
        );
      }

      if (
        admission?.forwardedToType ||
        forward?.toType
      ) {
        card.setAttribute(
          "data-forwarded-to-type",
          normalizeAccountsPipelineType(
            admission?.forwardedToType ||
            forward?.toType ||
            ""
          )
        );
      }

      card.setAttribute(
        "data-forwarded-from",
        forwardedFromDepartment
      );

      card.setAttribute(
        "data-forwarded-from-type",
        forwardedFromType
      );

      card.setAttribute(
        "data-accounts-workflow-stage",
        accountsWorkflowStage
      );

      card.setAttribute(
        "data-accounts-issue-message",
        accountsIssueMessage
      );

      card.setAttribute(
        "data-forwarded-owner-user-name",
        forwardedOwnerUserName
      );

      card.setAttribute(
        "data-forward-display-text",
        forwardDisplayText
      );

      upsertAdmissionForwardTimer(card, admission, {
        forwardStatus,
        workflowStage: accountsWorkflowStage,
      });

      upsertWorkflowTag(card, workflowTag);
      upsertWorkflowDates(card, registrationDate, assignedDate);
      upsertAccountsWorkflowMeta(card, {
        forwardStatus,
        pipelineType:
          card.getAttribute("data-forwarded-to-type") || "",
        pipelineDepartment:
          card.getAttribute("data-forwarded-to") || "",
        sourceDepartment: forwardedFromDepartment,
        sourceType: forwardedFromType,
        workflowStage: accountsWorkflowStage,
        ownerName: forwardedOwnerUserName,
      });
      upsertAccountsIssueNote(
        card,
        accountsIssueMessage,
        accountsIssueFields
      );
      upsertForwardDisplayText(card, forwardDisplayText);
      syncForwardAction(card, admission);

      if (
        typeof window.applyWorkflowDateFilters === "function"
      ) {
        window.applyWorkflowDateFilters();
      }

      if (activeAccountsStageFilter) {
        applySchoolAccountsWorkflowFilter(
          activeAccountsStageFilter,
          activeAccountsSourceFilter
        );
      } else if (activeForwardMainFilter) {
        applySchoolForwardFilter(
          activeForwardMainFilter,
          activeForwardSubFilter
        );
      } else {
        updateForwardCounts();
      }
    }

    window.updateAdmissionWorkflowCard =
      updateAdmissionWorkflowCard;

    window.upsertAdmissionForwardDisplayText =
      upsertForwardDisplayText;

    window.upsertAdmissionForwardTimer =
      upsertAdmissionForwardTimer;

    window.refreshAllAdmissionForwardTimers =
      refreshAllAdmissionForwardTimers;

    document.addEventListener(
      "DOMContentLoaded",
      refreshAllAdmissionForwardTimers
    );

    if (document.readyState !== "loading") {
      refreshAllAdmissionForwardTimers();
    }

    setInterval(
      refreshAllAdmissionForwardTimers,
      60000
    );

    const ACCOUNTS_PIPELINE_TYPES = new Set([
      "print_record_update",
      "verification_registration",
      "paid_slip",
    ]);

    function getCardForwardState(card) {
      const dept = String(card?.getAttribute("data-dept") || "")
        .trim()
        .toLowerCase();

      const currentStatus = normalizeStatusText(
        card?.getAttribute("data-current-status") || ""
      );

      const feeStatus = normalizeStatusText(
        card?.getAttribute("data-fee-status") || ""
      );

      const status = String(
        card?.getAttribute("data-forward-status") || "not_forwarded"
      ).trim().toLowerCase();

      const forwardSubStatus = String(
        card?.getAttribute("data-forward-sub-status") || ""
      ).trim().toLowerCase();

      const schoolReturnStatus = String(
        card?.getAttribute("data-school-return-status") || ""
      ).trim().toLowerCase();

      const forwardedByCurrentUser = String(
        card?.getAttribute("data-forwarded-by-current-user") || ""
      ) === "1";

      const notForwardedVisibleForCurrentUser = String(
        card?.getAttribute("data-not-forwarded-visible-for-current-user") || ""
      ) === "1";

      const notReceivedVisibleForCurrentUser = String(
        card?.getAttribute("data-not-received-visible-for-current-user") || ""
      ) === "1";

      const forwardScopeVisibleForCurrentUser = String(
        card?.getAttribute("data-forward-scope-visible-for-current-user") || ""
      ) === "1";

      const canForward = String(
        card?.getAttribute("data-can-forward") || ""
      ) === "1";

      const forwardedToType = normalizeAccountsPipelineType(
        card?.getAttribute("data-forwarded-to-type") || ""
      );

      const forwardedFromType = normalizeAccountsSourceTypeClient(
        card?.getAttribute("data-forwarded-from-type") || "school"
      );

      const accountsWorkflowStage = normalizeAccountsWorkflowStageClient(
        card?.getAttribute("data-accounts-workflow-stage") || "new_admissions"
      );

      const effectiveAccountsSource =
        accountsWorkflowStage === "record_to_update"
          ? "record_to_update"
          : (
              forwardedFromType === forwardedToType &&
              forwardedToType &&
              accountsWorkflowStage !== "old_admissions"
                ? "internal_department"
                : forwardedFromType
            );

      const isSchool = dept === "school";
      const isForwarded = status === "forwarded";
      const isNewAdmissionStage =
        currentStatus === "new admission" &&
        feeStatus === "new admission";

      const isForwardedForThisUser =
        isSchool &&
        isForwarded &&
        (
          isSuper ||
          forwardedByCurrentUser ||
          forwardScopeVisibleForCurrentUser
        );

      const isNotReceived =
        isForwarded &&
        (
          forwardSubStatus === "not_received" ||
          schoolReturnStatus === "not_received" ||
          schoolReturnStatus === "reupload"
        ) &&
        (
          isSuper ||
          notReceivedVisibleForCurrentUser ||
          forwardScopeVisibleForCurrentUser
        );

      const isSchoolAccountsAdmission =
        isSchool &&
        isForwarded &&
        !!forwardedToType &&
        forwardedToType !== "school_return" &&
        (
          isSuper ||
          (
            isSchoolAccountsUser &&
            (!currentUserForwardType || forwardedToType === currentUserForwardType)
          )
        );

      const isAccountsOldAdmission =
        isSchoolAccountsAdmission &&
        accountsWorkflowStage === "old_admissions";

      const isAccountsNewAdmission =
        isSchoolAccountsAdmission &&
        !isAccountsOldAdmission;

      return {
        dept,
        currentStatus,
        feeStatus,
        status,
        forwardSubStatus,
        schoolReturnStatus,
        forwardedByCurrentUser,
        notForwardedVisibleForCurrentUser,
        notReceivedVisibleForCurrentUser,
        forwardScopeVisibleForCurrentUser,
        canForward,
        forwardedToType,
        forwardedFromType,
        effectiveAccountsSource,
        accountsWorkflowStage,
        isSchool,
        isForwarded,
        isNewAdmissionStage,
        isForwardedForThisUser,
        isNotReceived,
        isSchoolAccountsAdmission,
        isAccountsNewAdmission,
        isAccountsOldAdmission,
        isSchoolAccountsNewAdmission: isAccountsNewAdmission,
        isNotForwardedVisibleForThisUser:
          isSchool &&
          status !== "forwarded" &&
          (
            isSuper ||
            notForwardedVisibleForCurrentUser
          ),
      };
    }

    function updateForwardCounts() {
      const cards = Array.from(
        document.querySelectorAll(".admission-card")
      );

      let forwarded = 0;
      let notForwarded = 0;
      let notVerified = 0;
      let verified = 0;
      let notReceived = 0;
      let accountsNewAdmissions = 0;
      let accountsOldAdmissions = 0;

      const sourceCounts = {
        school: 0,
        print_record_update: 0,
        verification_registration: 0,
        paid_slip: 0,
        record_to_update: 0,
        internal_department: 0,
      };

      cards.forEach(card => {
        if (card.classList.contains("workflow-date-filter-hidden")) return;

        const state = getCardForwardState(card);
        if (!state.isSchool) return;

        if (state.isForwardedForThisUser) forwarded += 1;
        if (state.isNotForwardedVisibleForThisUser) notForwarded += 1;

        if (state.isForwardedForThisUser && state.forwardSubStatus === "not_verified") {
          notVerified += 1;
        }

        if (state.isForwardedForThisUser && state.forwardSubStatus === "verified") {
          verified += 1;
        }

        if (state.isNotReceived) notReceived += 1;

        if (state.isAccountsNewAdmission) {
          accountsNewAdmissions += 1;
          if (sourceCounts[state.effectiveAccountsSource] !== undefined) {
            sourceCounts[state.effectiveAccountsSource] += 1;
          }
        }

        if (state.isAccountsOldAdmission) accountsOldAdmissions += 1;
      });

      const serverSources = serverAccountsPipelineCounts?.sources || {};
      const useServerAccountsCounts =
        shouldShowSchoolAccountsWorkflow &&
        serverAccountsPipelineCounts &&
        (
          Number(serverAccountsPipelineCounts.newAdmissions || 0) > 0 ||
          Number(serverAccountsPipelineCounts.oldAdmissions || 0) > 0 ||
          Number(serverSources.school || 0) > 0 ||
          Number(serverSources.internal_department || 0) > 0 ||
          Number(serverSources.print_record_update || 0) > 0 ||
          Number(serverSources.verification_registration || 0) > 0 ||
          Number(serverSources.paid_slip || 0) > 0 ||
          Number(serverSources.record_to_update || 0) > 0
        );

      const finalAccountsNewAdmissions = useServerAccountsCounts
        ? Number(serverAccountsPipelineCounts.newAdmissions || 0)
        : accountsNewAdmissions;

      const finalAccountsOldAdmissions = useServerAccountsCounts
        ? Number(serverAccountsPipelineCounts.oldAdmissions || 0)
        : accountsOldAdmissions;

           const finalSourceCounts = useServerAccountsCounts
        ? {
            school: Number(serverSources.school || 0),
            print_record_update: Number(serverSources.print_record_update || 0),
            verification_registration: Number(serverSources.verification_registration || 0),
            paid_slip: Number(serverSources.paid_slip || 0),
            record_to_update: Number(serverSources.record_to_update || 0),
            internal_department: Number(
              serverAccountsPipelineCounts.internalDepartment ||
              serverSources.internal_department ||
              0
            ),
          }
        : sourceCounts;

      const hasWorkflowDateFilter =
        cards.some(card =>
          card.classList.contains(
            "workflow-date-filter-hidden"
          )
        );

      const useServerSchoolCounts =
        shouldShowSchoolForwardFilters &&
        !hasWorkflowDateFilter &&
        serverSchoolForwardCounts &&
        (
          Number(serverSchoolForwardCounts.forwarded || 0) > 0 ||
          Number(serverSchoolForwardCounts.notForwarded || 0) > 0 ||
          Number(serverSchoolForwardCounts.notVerified || 0) > 0 ||
          Number(serverSchoolForwardCounts.verified || 0) > 0 ||
          Number(serverSchoolForwardCounts.notReceived || 0) > 0
        );

      const finalSchoolForwarded = useServerSchoolCounts
        ? Number(serverSchoolForwardCounts.forwarded || 0)
        : forwarded;

      const finalSchoolNotForwarded = useServerSchoolCounts
        ? Number(serverSchoolForwardCounts.notForwarded || 0)
        : notForwarded;

      const finalSchoolNotVerified = useServerSchoolCounts
        ? Number(serverSchoolForwardCounts.notVerified || 0)
        : notVerified;

      const finalSchoolVerified = useServerSchoolCounts
        ? Number(serverSchoolForwardCounts.verified || 0)
        : verified;

      const finalSchoolNotReceived = useServerSchoolCounts
        ? Number(serverSchoolForwardCounts.notReceived || 0)
        : notReceived;

      const countMap = {
        schoolForwardedCount: finalSchoolForwarded,
        schoolNotForwardedCount: finalSchoolNotForwarded,
        schoolNotVerifiedCount: finalSchoolNotVerified,
        schoolVerifiedCount: finalSchoolVerified,
        schoolNotReceivedCount: finalSchoolNotReceived,
        schoolHomeForwardedCount: finalSchoolForwarded,
        schoolHomeNotForwardedCount: finalSchoolNotForwarded,
        accountsNewAdmissionsCount: finalAccountsNewAdmissions,
        accountsOldAdmissionsCount: finalAccountsOldAdmissions,
        accountsHomeNewCount: finalAccountsNewAdmissions,
        accountsHomeOldCount: finalAccountsOldAdmissions,
        accountsSourceSchoolCount: finalSourceCounts.school,
        accountsSourcePrintCount: finalSourceCounts.print_record_update,
        accountsSourceVerificationCount: finalSourceCounts.verification_registration,
        accountsSourcePaidSlipCount: finalSourceCounts.paid_slip,
        accountsSourceRecordUpdateCount: finalSourceCounts.record_to_update,
        accountsSourceInternalCount: finalSourceCounts.internal_department,
      };

      Object.entries(countMap).forEach(([id, value]) => {
        const el = document.getElementById(id);
        if (el) el.textContent = String(value);
      });
    }

    window.updateSchoolForwardCounts =
      updateForwardCounts;

