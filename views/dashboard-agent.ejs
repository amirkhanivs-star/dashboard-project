  return labels[clean] || 'New Admissions';
}

function parseDashboardJsonArray(value) {
  if (Array.isArray(value)) {
    return value
      .map(item => String(item || '').trim())
      .filter(Boolean);
  }

  const raw = String(value || '').trim();
  if (!raw) return [];

  try {
    const parsed = JSON.parse(raw);
    return Array.isArray(parsed)
      ? parsed.map(item => String(item || '').trim()).filter(Boolean)
      : [];
  } catch (e) {
    return raw.split(',').map(item => item.trim()).filter(Boolean);
  }
}

function getDashboardForwardTimer(admission) {
  const forward = (admission && admission.forward) || {};

  return (
    (admission && admission.currentForwardTimer) ||
    (admission && admission.forwardTimer) ||
    forward.currentTimer ||
    forward.forwardTimer ||
    forward.timer ||
    null
  );
}

function getDashboardForwardTimerStartedAt(timer) {
  return String(
    (timer && (
      timer.startedAt ||
      timer.started_at ||
      timer.startAt ||
      timer.started
    )) ||
    ''
  ).trim();
}

function getDashboardForwardTimerName(timer) {
  return String(
    (timer && (
      timer.name ||
      timer.holderUserName ||
      timer.holder_user_name ||
      timer.userName ||
      timer.user_name
    )) ||
    ''
  ).trim();
}

function getDashboardForwardTimerDept(timer) {
  return String(
    (timer && (
      timer.department ||
      timer.holderDepartment ||
      timer.holder_department ||
      timer.dept
    )) ||
    ''
  ).trim();
}

function getDashboardForwardTimerType(timer) {
  return String(
    (timer && (
      timer.type ||
      timer.holderType ||
      timer.holder_type ||
      timer.forwardType
    )) ||
    ''
  ).trim();
}

function getDashboardForwardTimerDurationSeconds(timer) {
  const directSeconds = Number(
    (timer && (
      timer.durationSeconds ||
      timer.duration_seconds
    )) ||
    0
  );

  const startedAt = getDashboardForwardTimerStartedAt(timer);

  if (startedAt) {
    const parsed = new Date(startedAt);

    if (!Number.isNaN(parsed.getTime())) {
      return Math.max(
        0,
        Math.floor((Date.now() - parsed.getTime()) / 1000)
      );
    }
  }

  return Math.max(0, directSeconds);
}

function formatDashboardForwardTimerDuration(seconds) {
  const totalSeconds = Math.max(0, Number(seconds || 0));
  const totalMinutes = Math.floor(totalSeconds / 60);
  const days = Math.floor(totalMinutes / 1440);
  const hours = Math.floor((totalMinutes % 1440) / 60);
  const minutes = totalMinutes % 60;

  return `${days}d ${hours}h ${minutes}m`;
}

function getDashboardForwardTimerDurationLabel(timer) {
  const savedLabel = String(
    (timer && (
      timer.durationLabel ||
      timer.duration_label
    )) ||
    ''
  ).trim();

  if (savedLabel) {
    return savedLabel;
  }

  return formatDashboardForwardTimerDuration(
    getDashboardForwardTimerDurationSeconds(timer)
  );
}

