<!-- ✅ Admission Forward Modal -->
<div class="modal fade" id="admissionForwardModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg rounded-4">
      <div class="modal-header border-0">
        <div>
          <h5 class="modal-title mb-0">
            <i class="bi bi-send me-1"></i> Forward Admission
          </h5>
          <div class="small text-muted">
            Select department and send this admission forward.
          </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body pt-0">
        <div class="p-3 rounded-4 bg-light mb-3">
          <div class="small"><b>Student:</b> <span id="forwardStudentName">-</span></div>
          <div class="small mt-1"><b>Admission ID:</b> <span id="forwardAdmissionId">-</span></div>
        </div>

        <label class="form-label fw-semibold">Forward to department</label>

        <div class="d-grid gap-2">
          <label class="forward-dept-option">
            <input type="radio" name="forwardType" value="print_record_update" data-label="Print & Record Update">
            <span>
              <b>Print &amp; Record Update</b>
              <small>For print and record update work.</small>
            </span>
          </label>

          <label class="forward-dept-option">
            <input type="radio" name="forwardType" value="verification_registration" data-label="Verification & Registration">
            <span>
              <b>Verification & Registration</b>
              <small>For verification number and registration process.</small>
            </span>
          </label>

          <label class="forward-dept-option">
            <input type="radio" name="forwardType" value="paid_slip" data-label="Paid Slip">
            <span>
              <b>Paid Slip</b>
              <small>For paid slip related work.</small>
            </span>
          </label>

          <label
            class="forward-dept-option forward-return-school-option d-none"
            data-school-return-option>

            <input
              type="radio"
              name="forwardType"
              value="school_return"
              data-label="School Department">

            <span>
              <b>Return to School Department</b>

              <small>
                Use this when Accounts sends the admission back for correction or file re-upload.
              </small>
            </span>
          </label>
        </div>

        <div
          class="forward-target-user-wrap d-none"
          id="forwardTargetUserWrap">
          <label class="form-label fw-semibold mb-1" for="forwardTargetUserId">
            Assign to Agent / Sub-Agent
          </label>

