function findCardStatusColor(type, value) {
  const clean = String(value || '').trim().toLowerCase();

  const list =
    type === 'fee'
      ? DEFAULT_FEE_STATUS_OPTIONS
      : DEFAULT_CURRENT_STATUS_OPTIONS;

  const found = (list || []).find(opt =>
    String(opt.value || opt.label || '').trim().toLowerCase() === clean
  );

  return found && found.color ? found.color : '';
}

function hexToRgba(hex, alpha) {
  const clean = String(hex || '').replace('#', '').trim();

  if (clean.length !== 6) return 'rgba(100,116,139,' + alpha + ')';

  const r = parseInt(clean.substring(0, 2), 16);
  const g = parseInt(clean.substring(2, 4), 16);
  const b = parseInt(clean.substring(4, 6), 16);

  return `rgba(${r},${g},${b},${alpha})`;
}

function getCardFieldStyle(field) {
  if (!field || !field.key) return '';

  let color = '';

  if (field.key === 'status') {
    color = findCardStatusColor('current', field.value);
  }

  if (field.key === 'feeStatus') {
    color = findCardStatusColor('fee', field.value);
  }

  if (!color) return '';

  return `--chip-color:${color};--chip-bg:${hexToRgba(color, 0.14)};--chip-bd:${hexToRgba(color, 0.34)};`;
}

function getCardFieldClass(field) {
  if (!field || !field.key) return '';

  if (field.key === 'status') return 'status-card-chip';
  if (field.key === 'feeStatus') return 'fee-card-chip';

  return '';
}

function toDashboardDateOnly(value) {
  const raw = String(value || '').trim();

  if (!raw) return '';

  const directDate = raw.match(/^(\d{4}-\d{2}-\d{2})/);

  if (directDate) {
    return directDate[1];
  }

  const parsedDate = new Date(raw);

  if (Number.isNaN(parsedDate.getTime())) {
    return '';
  }

  return parsedDate.toISOString().slice(0, 10);
}

function formatDashboardDate(value) {
  const dateOnly = toDashboardDateOnly(value);

  if (!dateOnly) {
    return 'Not Assigned';
  }

  const parts = dateOnly.split('-');

  return `${parts[2]}-${parts[1]}-${parts[0]}`;
}

function getDashboardWorkflowTag(admission) {
  const returnStatus = String(
    admission?.schoolReturnStatus ||
    admission?.school_return_status ||
    ''
  )
    .trim()
    .toLowerCase();

  /*
   * Not Received sabse high priority par rahega.
   * Dobara upload hone tak Forward available nahi hoga.
   */
  if (returnStatus === 'not_received') {
    return 'Not Received';
  }

  const reuploadTagActive = Number(
    admission?.reuploadTagActive ||
    admission?.reupload_tag_active ||
    0
  ) === 1;

  /*
   * Forward ke baad return status clear ho jaye,
   * phir bhi orange Reupload tag show hoga.
   */
  if (
    returnStatus === 'reupload' ||
    reuploadTagActive
  ) {
    return 'Reupload';
  }

  const directTag = String(
    admission?.workflowTag || ''
  ).trim();

  if (directTag) {
    return directTag;
  }

  const registrationNumberRemoved = Number(
    admission?.registrationNumberRemoved ||
    admission?.registration_number_removed ||
    admission?.accounts?.registrationNumberRemoved ||
    0
  ) === 1;

  if (registrationNumberRemoved) {
    return 'Registration Number Removed';
  }

  return '';
}

function getDashboardWorkflowTagClass(tag) {
  const cleanTag = String(tag || '')
    .trim()
    .toLowerCase();

  if (cleanTag === 'reupload') {
    return 'workflow-tag-reupload';
  }

  if (
    cleanTag === 'not received' ||
    cleanTag === 'registration number removed'
  ) {
    return 'workflow-tag-danger';
  }

  return '';
}

