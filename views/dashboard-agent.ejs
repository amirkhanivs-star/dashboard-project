      const home = document.getElementById("schoolForwardHome");
      const workspace = document.getElementById("accountsAdmissionsWorkspace");

      if (home) home.classList.remove("d-none");
      if (workspace) workspace.classList.add("accounts-workspace-hidden");

      activeForwardMainFilter = "";
      activeForwardSubFilter = "";
      activeAccountsStageFilter = "";
      activeAccountsSourceFilter = "";

      document.querySelectorAll(".admission-card").forEach(card => {
        card.classList.add("forward-filter-hidden");
      });

      setActiveForwardFilter("");
      setActiveForwardSubFilter("");
      setActiveForwardStageFilter("");
      setActiveAccountsSourceFilter("");
      toggleForwardedSubfilters(false);
      toggleAccountsSourceFilters(false);
      updateForwardCounts();
    }

    window.showSchoolForwardHome = showSchoolForwardHome;

    function applySchoolForwardFilter(
      filter,
      subFilter = activeForwardSubFilter
    ) {
      const finalFilter = String(filter || "")
        .trim()
        .toLowerCase();

      const allowedSubFilters = new Set([
        "not_verified",
        "verified",
        "not_received",
      ]);

      const requestedSubFilter = String(
        subFilter || ""
      )
        .trim()
        .toLowerCase();

      const finalSubFilter =
        finalFilter === "forwarded"
          ? (
              allowedSubFilters.has(requestedSubFilter)
                ? requestedSubFilter
                : "not_verified"
            )
          : "";

      showSchoolForwardWorkspace();

      activeForwardMainFilter = finalFilter;
      activeForwardSubFilter = finalSubFilter;
      activeAccountsStageFilter = "";
      activeAccountsSourceFilter = "";

      document
        .querySelectorAll(".admission-card")
        .forEach(card => {
          const state = getCardForwardState(card);
          let show = true;

          if (finalFilter === "forwarded") {
            show =
              shouldShowSchoolForwardFilters &&
              state.isForwardedForThisUser &&
              state.forwardSubStatus === finalSubFilter;
          }

          if (finalFilter === "not_forwarded") {
            show =
              shouldShowSchoolForwardFilters &&
              state.isNotForwardedVisibleForThisUser;
          }

          card.classList.toggle(
            "forward-filter-hidden",
            !show
          );
        });

      setActiveForwardFilter(finalFilter);
      setActiveForwardSubFilter(finalSubFilter);
      setActiveForwardStageFilter("");
      setActiveAccountsSourceFilter("");

      toggleForwardedSubfilters(
        finalFilter === "forwarded"
      );

      toggleAccountsSourceFilters(false);
      updateForwardCounts();
    }

    function applySchoolAccountsWorkflowFilter(
      stageFilter,
      sourceFilter = ""
    ) {
      showAccountsWorkspace();

      const finalStage =
        normalizeAccountsWorkflowStageClient(
          stageFilter || "new_admissions"
        ) === "old_admissions"
          ? "old_admissions"
          : "new_admissions";

      const requestedSource = normalizeAccountsSourceTypeClient(
        sourceFilter || ""
      );

      const finalSource =
        finalStage === "new_admissions" &&
        requestedSource &&
        allowedAccountsSourceFilters.has(requestedSource)
          ? requestedSource
          : "";

      activeForwardMainFilter = "";
      activeForwardSubFilter = "";
      activeAccountsStageFilter = finalStage;
      activeAccountsSourceFilter = finalSource;

      document.querySelectorAll(".admission-card").forEach(card => {
        const state = getCardForwardState(card);

        let show =
          shouldShowSchoolAccountsWorkflow &&
          (
            finalStage === "old_admissions"
              ? state.isAccountsOldAdmission
              : state.isAccountsNewAdmission
          );

        if (show && finalStage === "new_admissions" && finalSource) {
          show = state.effectiveAccountsSource === finalSource;
        }

        card.classList.toggle("forward-filter-hidden", !show);
      });

      setActiveForwardFilter("");
      setActiveForwardSubFilter("");
      setActiveForwardStageFilter(finalStage);
      setActiveAccountsSourceFilter(finalSource);
      toggleForwardedSubfilters(false);
      toggleAccountsSourceFilters(finalStage === "new_admissions");
      updateForwardCounts();
