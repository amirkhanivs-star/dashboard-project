</div>

        <div class="agent-pagination-wrap d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 px-3 py-3 border-top">
          <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="small text-muted">Rows per page</span>

            <select
              class="form-select form-select-sm agent-pagination-limit"
              onchange="document.documentElement.classList.add('ivs-page-leaving'); document.documentElement.classList.add('ivs-loading'); setTimeout(() => { window.location.href=this.value; }, 1000);">
              <option value="<%= buildPageUrl(1, 50) %>" <%= pageLimit === 50 ? 'selected' : '' %>>50</option>
              <option value="<%= buildPageUrl(1, 100) %>" <%= pageLimit === 100 ? 'selected' : '' %>>100</option>
              <option value="<%= buildPageUrl(1, 200) %>" <%= pageLimit === 200 ? 'selected' : '' %>>200</option>
              <option value="<%= buildPageUrl(1, 500) %>" <%= pageLimit === 500 ? 'selected' : '' %>>500</option>
            </select>

            <span class="small text-muted">
              <%= startRecord %> - <%= endRecord %> of <%= totalRecords %>
            </span>
          </div>

          <% if (totalPages > 1) { %>
            <div class="d-flex align-items-center gap-2 flex-wrap justify-content-lg-end">
              <% if (currentPage > 1) { %>
                <a href="<%= buildPageUrl(currentPage - 1, pageLimit) %>" class="agent-page-btn agent-page-nav">
                  Previous
                </a>
              <% } else { %>
                <span class="agent-page-btn agent-page-nav disabled">Previous</span>
              <% } %>

              <% visiblePages.forEach(p => { %>
                <% if (p === 'dots-left' || p === 'dots-right') { %>
                  <span class="agent-page-dots">...</span>
                <% } else if (p === currentPage) { %>
                  <span class="agent-page-btn active"><%= p %></span>
                <% } else { %>
                  <a href="<%= buildPageUrl(p, pageLimit) %>" class="agent-page-btn"><%= p %></a>
                <% } %>
              <% }) %>

              <% if (currentPage < totalPages) { %>
                <a href="<%= buildPageUrl(currentPage + 1, pageLimit) %>" class="agent-page-btn agent-page-nav">
                  Next
                </a>
              <% } else { %>
                <span class="agent-page-btn agent-page-nav disabled">Next</span>
              <% } %>
            </div>
          <% } %>
        </div>
      </div>
    </div>

  <% } %>
</div>

