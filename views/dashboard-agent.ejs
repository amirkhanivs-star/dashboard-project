    let forwardUsersRequestToken = 0;

    function resetForwardTargetUsers({
      hide = true,
      message = "Select the user who should receive this admission.",
    } = {}) {
      forwardUsersRequestToken += 1;

      if (forwardTargetUserSelect) {
        forwardTargetUserSelect.disabled = true;
        forwardTargetUserSelect.innerHTML =
          '<option value="">Select pipeline first</option>';
      }

      if (forwardTargetUserHint) {
