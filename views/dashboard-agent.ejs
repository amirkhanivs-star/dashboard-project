<script>
  (function () {
    if (typeof io === "undefined") return;

    const socket = io();
    const pendingAdmissionIds = new Set();

    const updateBtn = document.getElementById("applyRealtimeUpdatesBtn");
    const updateCount = document.getElementById("realtimeUpdateCount");

    function isModalOpen() {
      return !!document.querySelector(".modal.show, .billing-status-overlay:not(.d-none)");
    }

    function isFlashOpen() {
      const flash = document.getElementById("upload-flash-overlay");
      return !!(flash && !flash.classList.contains("d-none"));
    }

    function isUserTyping() {
      const el = document.activeElement;
      if (!el) return false;

      return el.matches("input, textarea, select, [contenteditable='true']");
    }

    function isUserBusy() {
      const recentSubmit =
        sessionStorage.getItem("agent_dashboard_recent_submit") === "1";

      return isModalOpen() || isFlashOpen() || isUserTyping() || recentSubmit;
    }

    function showUpdatesButton() {
      if (!updateBtn || !updateCount) return;

      updateCount.textContent = String(pendingAdmissionIds.size || 0);

      if (pendingAdmissionIds.size > 0) {
        updateBtn.classList.remove("d-none");
      } else {
        updateBtn.classList.add("d-none");
      }
    }

    function getAdmissionIdFromPayload(payload) {
      const id =
        payload?.admissionId ||
        payload?.id ||
        "";

      return String(id || "").trim();
    }

    function getFieldValue(admission, key) {
      const a = admission || {};

      const map = {
        no: a.entryNumber || a.entry_number || a.id || "-",
        status: a.status || "-",
        feeStatus: a.feeStatus || "-",
        dept: a.dept || "-",
        student: a.student || a.studentName || "-",
        father: a.father || a.fatherName || "-",
        grade: a.grade || "-",
        tuitionGrade: a.tuitionGrade || "-",
        fatherEmail: a.fatherEmail || a.father_email || "-",
        phone: a.phone || a.contactNumber || "-",
        processedBy: a.processedBy || a.processed_by || "-",
        paymentStatus: a.accounts?.paymentStatus || "-",
        paidUpto: a.accounts?.paidUpto || "-",
        verificationNumber: a.latestBillingVerificationNumber || a.accounts?.verificationNumber || "-",
        registrationNumber: a.accounts?.registrationNumber || "-",
        familyNumber: a.accounts?.familyNumber || "-",
        registrationFee: a.admission?.registrationFee || "-",
        fees: a.admission?.fees || "-",
        currency: a.currency_code || a.currencyCode || a.admission?.currencyCode || a.admission?.currency_code || "-",
        month: a.admission?.month || "-",
        totalFees: a.admission?.totalFees || "-",
        pendingDues: a.admission?.pendingDues || "-",
        receivedPayment: a.admission?.receivedPayment || "0",
        invoiceStatus: a.admission?.invoiceStatus || "-",
        invoiceStatusTimestamp: a.admission?.invoiceStatusTimestamp || "-",
        paidInvoiceStatus: a.admission?.paidInvoiceStatus || "-",
        paidInvoiceStatusTimestamp: a.admission?.paidInvoiceStatusTimestamp || "-"
      };

      return map[key] ?? "-";
    }

    function updateField(card, key, value) {
      const field = card.querySelector(`.admission-field-link[data-field-key="${CSS.escape(String(key))}"] .field-value`);

      if (field) {
        field.textContent = value || "-";
        field.setAttribute("title", value || "-");
      }
    }

    function updateCardActions(card, admission) {
      const id = admission?.id || card.getAttribute("data-admission-id") || "";

      const student = admission?.student || admission?.studentName || "";
      const grade = admission?.grade || "";
      const phone = admission?.phone || admission?.contactNumber || "";
      const fees = admission?.admission?.fees || "";
      const currency =
        admission?.currency_code ||
        admission?.currencyCode ||
        admission?.admission?.currencyCode ||
        admission?.admission?.currency_code ||
        "";

      card.querySelectorAll("[data-admission-id]").forEach(el => {
        el.setAttribute("data-admission-id", id);
      });

      card.querySelectorAll("[data-student]").forEach(el => {
        el.setAttribute("data-student", student);
      });

      card.querySelectorAll("[data-grade]").forEach(el => {
        el.setAttribute("data-grade", grade);
      });

      card.querySelectorAll("[data-phone]").forEach(el => {
        el.setAttribute("data-phone", phone);
      });

      const billingBtn = card.querySelector(".btn-billing");
      if (billingBtn) {
        billingBtn.setAttribute("data-fees", fees);
        billingBtn.setAttribute("data-currency", currency);
      }

      const deleteBtn = card.querySelector(".btn-delete-admission");
      if (deleteBtn) {
        deleteBtn.setAttribute("data-student-name", student);
      }
    }

    function updateCardHeader(card, admission) {
      const student = admission?.student || admission?.studentName || "No Name";
      const father = admission?.father || admission?.fatherName || "-";
      const dept = admission?.dept || "Dept";

      const title = card.querySelector(".admission-title");
      const subtitle = card.querySelector(".admission-subtitle");
      const avatar = card.querySelector(".admission-avatar");
      const deptPill = card.querySelector(".admission-role-pill");

      if (title) title.textContent = student;
      if (subtitle) subtitle.textContent = father;
      if (avatar) avatar.textContent = String(student || "A").charAt(0).toUpperCase();
      if (deptPill) deptPill.textContent = dept;
    }

    async function refreshAdmissionCard(admissionId) {
      if (!admissionId) return false;

      const card = document.querySelector(`.admission-card[data-admission-id="${CSS.escape(String(admissionId))}"]`);

      if (!card) {
        pendingAdmissionIds.add(String(admissionId));
        showUpdatesButton();
        return false;
      }

      const res = await fetch(`/api/admissions/${encodeURIComponent(admissionId)}`, {
        method: "GET",
        credentials: "same-origin",
        headers: {
          "Accept": "application/json"
        }
      });

      const data = await res.json().catch(() => ({}));

      if (!res.ok || data.success === false || !data.admission) {
        throw new Error(data.message || "Admission refresh failed");
      }

      const admission = data.admission;

      updateCardHeader(card, admission);

      [
        "no",
        "status",
        "feeStatus",
        "dept",
        "student",
        "father",
        "grade",
        "tuitionGrade",
        "fatherEmail",
        "phone",
        "processedBy",
        "paymentStatus",
        "paidUpto",
        "verificationNumber",
        "registrationNumber",
        "familyNumber",
        "registrationFee",
        "fees",
        "currency",
        "month",
        "totalFees",
        "pendingDues",
        "receivedPayment",
        "invoiceStatus",
        "invoiceStatusTimestamp",
        "paidInvoiceStatus",
        "paidInvoiceStatusTimestamp"
      ].forEach(key => {
        updateField(card, key, getFieldValue(admission, key));
      });

      updateCardActions(card, admission);

      if (
        typeof window.updateAdmissionWorkflowCard ===
        "function"
      ) {
        window.updateAdmissionWorkflowCard(
          card,
          admission
        );
      }

      card.classList.remove("realtime-updated");
      void card.offsetWidth;
      card.classList.add("realtime-updated");

      return true;
    }

    async function applyPendingAdmissionUpdates() {
      const ids = Array.from(pendingAdmissionIds);
      pendingAdmissionIds.clear();
      showUpdatesButton();

      for (const id of ids) {
        try {
          await refreshAdmissionCard(id);
        } catch (err) {
          console.error("Real-time card update failed:", err);
        }
      }

      if (typeof window.rebuildAdmissionFilesDropdowns === "function") {
        window.rebuildAdmissionFilesDropdowns();
      }
    }

    if (updateBtn) {
      updateBtn.addEventListener("click", function () {
        document.documentElement.classList.add("ivs-loading");
        window.location.reload();
      });
    }

   socket.on("admission:changed", function (payload) {
  const singleId = getAdmissionIdFromPayload(payload);
  const insertedIds = Array.isArray(payload?.insertedIds) ? payload.insertedIds : [];
  const deletedIds = Array.isArray(payload?.deletedIds) ? payload.deletedIds : [];

  deletedIds.forEach(id => {
    const card = document.querySelector(`.admission-card[data-admission-id="${CSS.escape(String(id))}"]`);
    if (card) card.remove();
  });

  if (insertedIds.length) {
    insertedIds.forEach(id => pendingAdmissionIds.add(String(id)));
    showUpdatesButton();
    return;
  }

  if (singleId) {
    pendingAdmissionIds.add(String(singleId));
    showUpdatesButton();
    return;
  }

  if (typeof window.rebuildAdmissionFilesDropdowns === "function") {
    window.rebuildAdmissionFilesDropdowns();
  }
});

    socket.on("user:updated", function (payload) {
      const currentUserId = Number(window.CURRENT_USER?.id || 0);
      const targetUserId = Number(payload?.userId || 0);

      if (!currentUserId || !targetUserId) return;
      if (currentUserId !== targetUserId) return;

      if (isUserBusy()) {
        if (typeof window.showUploadFlash === "function") {
          window.showUploadFlash(
            "info",
            "Account Updated",
            "Your permissions were updated. Please refresh when you are free."
          );
        }
        return;
      }

      if (typeof window.smoothDashboardReload === "function") {
        window.smoothDashboardReload(1000);
      } else {
        window.location.reload();
      }
    });
  })();
</script>


<script>
  /* ✅ Agent card search/filter */
  (function () {
    document.addEventListener('DOMContentLoaded', function () {
      const modalEl = document.getElementById('agentSearchModal');
      const openBtn = document.getElementById('openAgentSearchModalBtn');
      const inputEl = document.getElementById('agentSearchToolbarInput');
      const clearBtn = document.getElementById('clearAgentSearchBtn');
      const triggerBadge = document.getElementById('agentSearchCriterionBadge');
      const optionButtons = document.querySelectorAll('.agent-search-option');

      if (!modalEl || !openBtn || !inputEl || typeof bootstrap === 'undefined') return;

      const searchModal = bootstrap.Modal.getOrCreateInstance(modalEl);

      let activeSearchKey = 'general';
      let activeSearchLabel = 'General';

      function normalizeText(value) {
        return String(value || '').toLowerCase().replace(/\s+/g, ' ').trim();
      }

      function getCards() {
        return Array.from(document.querySelectorAll('.admission-card'));
      }

      function getCardFieldValue(card, label) {
        const wanted = normalizeText(label).replace(':', '');

        const fields = Array.from(card.querySelectorAll('.admission-field-link'));

        for (const field of fields) {
          const labelEl = field.querySelector('.field-label');
          const valueEl = field.querySelector('.field-value');

          const currentLabel = normalizeText(labelEl ? labelEl.textContent : '').replace(':', '');

          if (currentLabel === wanted) {
            return normalizeText(valueEl ? valueEl.textContent : '');
          }
        }

        return '';
      }

      function getValueByKey(card, key) {
        const map = {
          registrationNumber: 'Reg #',
          student: 'Student',
          father: 'Father',
          familyNumber: 'Family #',
          phone: 'Phone Number',
          fatherEmail: 'Email Address',
          grade: 'Grade',
          tuitionGrade: 'Grade Section',
          dept: 'Dept',
          status: 'Current Status',
          feeStatus: 'Fee Status',
          processedBy: 'Processed By',
          paymentStatus: 'Payment Status',
          paidUpto: 'Paid Upto',
          verificationNumber: 'Verif #',
          registrationFee: 'Registration Fee',
          fees: 'Monthly Fees',
          currency: 'Currency',
          bank: 'Bank',
          month: 'Month/Year',
          totalFees: 'Total Fees',
          pendingDues: 'Pending Dues',
          receivedPayment: 'Received Payment',
          invoiceStatus: 'Invoice Status',
          invoiceStatusTimestamp: 'Invoice Status Timestamp',
          paidInvoiceStatus: 'Paid Invoice Status',
          paidInvoiceStatusTimestamp: 'Paid Invoice Status Timestamp'
        };

        const label = map[key];
        if (!label) return '';

        return getCardFieldValue(card, label);
      }

      function getGeneralCardText(card) {
        return normalizeText(card.textContent);
      }

      function applySearch() {
        const keyword = normalizeText(inputEl.value);
        const cards = getCards();

        cards.forEach(card => {
          if (!keyword) {
            card.style.display = '';
            return;
          }

          let matched = false;

          if (activeSearchKey === 'general') {
            matched = getGeneralCardText(card).includes(keyword);
          } else {
            matched = getValueByKey(card, activeSearchKey).includes(keyword);
          }

          card.style.display = matched ? '' : 'none';
        });
      }

      function updateCriterionUI(label) {
        activeSearchLabel = label || 'General';
        if (triggerBadge) triggerBadge.textContent = activeSearchLabel;
      }

      optionButtons.forEach(btn => {
        btn.addEventListener('click', function () {
          optionButtons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          activeSearchKey = btn.getAttribute('data-search-key') || 'general';
          const label = btn.getAttribute('data-search-label') || 'General';

          updateCriterionUI(label);
          applySearch();
          searchModal.hide();
          inputEl.focus();
        });
      });

      openBtn.addEventListener('click', function () {
        searchModal.show();
      });

      inputEl.addEventListener('input', function () {
        applySearch();
      });

      if (clearBtn) {
        clearBtn.addEventListener('click', function () {
          inputEl.value = '';
          activeSearchKey = 'general';
          activeSearchLabel = 'General';

          optionButtons.forEach(b => b.classList.remove('active'));

          updateCriterionUI('General');
          applySearch();
          searchModal.hide();
          inputEl.focus();
        });
      }

      updateCriterionUI('General');
      applySearch();
    });
  })();
</script>
<%- include('partials/bootstrap-footer') %>

<script>
  (function () {
    const canDeleteAdmissions = <%- JSON.stringify(!!canDeleteAdmissions) %>;
    if (!canDeleteAdmissions) return;

    const selectAllEl = document.getElementById('selectAllAdmissions');
    const bulkDeleteToolbar = document.getElementById('bulkDeleteToolbar');
    const bulkDeleteCount = document.getElementById('bulkDeleteCount');
    const bulkDeleteBtn = document.getElementById('bulkDeleteBtn');

    const confirmModalEl = document.getElementById('confirmModal');
    const confirmModalTitle = document.getElementById('confirmModalTitle');
    const confirmModalBody = document.getElementById('confirmModalBody');
    const confirmModalOk = document.getElementById('confirmModalOk');

    if (!confirmModalEl || !confirmModalOk) return;

    const confirmModal =
      typeof bootstrap !== 'undefined'
        ? bootstrap.Modal.getOrCreateInstance(confirmModalEl)
        : null;

    function getRowCheckboxes() {
      return Array.from(document.querySelectorAll('.admission-row-checkbox'));
    }

    function getSelectedCheckboxes() {
      return getRowCheckboxes().filter(cb => cb.checked);
    }

    function getSelectedIds() {
      return getSelectedCheckboxes().map(cb => Number(cb.value)).filter(Boolean);
    }

    function updateBulkToolbar() {
      const selected = getSelectedCheckboxes();
      const count = selected.length;

      if (bulkDeleteCount) bulkDeleteCount.textContent = String(count);
      if (bulkDeleteToolbar) bulkDeleteToolbar.classList.toggle('d-none', count === 0);

      if (selectAllEl) {
        const all = getRowCheckboxes();
        selectAllEl.checked = !!all.length && count === all.length;
        selectAllEl.indeterminate = count > 0 && count < all.length;
      }
    }

    function showPopup(type, title, message) {
      if (typeof window.showUploadFlash === 'function') {
        window.showUploadFlash(type, title, message);
      } else {
        alert(message || title || 'Notification');
      }
    }

    function openSingleDeleteModal(id, studentName) {
      confirmModalTitle.textContent = 'Delete Admission';
      confirmModalBody.textContent =
        `Are you sure you want to delete ${studentName || 'this admission'}? This action cannot be undone.`;

      confirmModalOk.dataset.mode = 'single';
      confirmModalOk.dataset.admissionId = String(id || '');

      if (confirmModal) confirmModal.show();
    }

    function openBulkDeleteModal(ids) {
      confirmModalTitle.textContent = 'Delete Selected Admissions';
      confirmModalBody.textContent =
        `You are about to delete ${ids.length} selected admission(s). This action cannot be undone.`;

      confirmModalOk.dataset.mode = 'bulk';
      confirmModalOk.dataset.admissionId = '';

      if (confirmModal) confirmModal.show();
    }

    async function deleteSingle(id) {
      const res = await fetch(`/api/admissions/${id}`, {
        method: 'DELETE',
        headers: { Accept: 'application/json' }
      });

      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.success) throw new Error(data.message || 'Delete failed');
      return data;
    }

    async function deleteBulk(ids) {
      const res = await fetch('/api/admissions/bulk-delete', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'application/json'
        },
        body: JSON.stringify({ ids })
      });

      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.success) throw new Error(data.message || 'Bulk delete failed');
      return data;
    }

    document.addEventListener('change', function (e) {
      if (e.target.matches('.admission-row-checkbox')) {
        updateBulkToolbar();
      }

      if (e.target === selectAllEl) {
        const checked = !!selectAllEl.checked;
        getRowCheckboxes().forEach(cb => {
          cb.checked = checked;
        });
        updateBulkToolbar();
      }
    });

    document.addEventListener('click', function (e) {
      const rowDeleteBtn = e.target.closest('.btn-delete-admission');
      if (rowDeleteBtn) {
        const id = Number(rowDeleteBtn.getAttribute('data-admission-id') || 0);
        const studentName = String(rowDeleteBtn.getAttribute('data-student-name') || '').trim();
        if (!id) return;

        openSingleDeleteModal(id, studentName);
        return;
      }

      const bulkDeleteTrigger = e.target.closest('#bulkDeleteBtn');
      if (bulkDeleteBtn && bulkDeleteTrigger) {
        const ids = getSelectedIds();
        if (!ids.length) {
          showPopup('error', 'No Selection', 'Please select at least one admission.');
          return;
        }

        openBulkDeleteModal(ids);
        return;
      }

      if (e.target === confirmModalOk) {
        const mode = String(confirmModalOk.dataset.mode || '').trim();

        (async function () {
          try {
            confirmModalOk.disabled = true;

            if (mode === 'single') {
              const id = Number(confirmModalOk.dataset.admissionId || 0);
              if (!id) throw new Error('Invalid admission id');

              await deleteSingle(id);
              if (confirmModal) confirmModal.hide();

              showPopup('success', 'Deleted', 'Admission deleted successfully.');

              if (typeof window.saveViewportState === 'function') {
                window.saveViewportState();
              }

              setTimeout(() => {
  if (typeof window.smoothDashboardReload === "function") {
    window.smoothDashboardReload(1000);
  } else {
    window.location.reload();
  }
}, 500);
              return;
            }

            if (mode === 'bulk') {
              const ids = getSelectedIds();
              if (!ids.length) throw new Error('No admissions selected');

              await deleteBulk(ids);
              if (confirmModal) confirmModal.hide();

              showPopup('success', 'Deleted', 'Selected admissions deleted successfully.');

              if (typeof window.saveViewportState === 'function') {
                window.saveViewportState();
              }

              setTimeout(() => {
  if (typeof window.smoothDashboardReload === "function") {
    window.smoothDashboardReload(1000);
  } else {
    window.location.reload();
  }
}, 500);
              return;
            }
          } catch (err) {
            showPopup('error', 'Delete Failed', err.message || 'Delete failed');
          } finally {
            confirmModalOk.disabled = false;
          }
        })();
      }
    });

    updateBulkToolbar();
  })();
</script>

<script>
  (function () {
    document.addEventListener('DOMContentLoaded', function () {
      const openBtn = document.getElementById('openBulkChallanBtn');
      const modalEl = document.getElementById('bulkChallanModal');
      if (!openBtn || !modalEl || typeof bootstrap === 'undefined') return;

      const bulkModal = bootstrap.Modal.getOrCreateInstance(modalEl);

      const monthEl = document.getElementById('bulkChallanMonth');
      const monthGrid = document.getElementById('bulkChallanMonthGrid');

      const feeTypeEl = document.getElementById('bulkChallanFeeType');

      const classEl = document.getElementById('bulkChallanClass');
      const classGrid = document.getElementById('bulkChallanClassGrid');

      const sectionEl = document.getElementById('bulkChallanSection');
      const yearEl = document.getElementById('bulkChallanYear');

      const createBtn = document.getElementById('bulkChallanCreateBtn');
      const sendBtn = document.getElementById('bulkChallanSendBtn');

      const summaryBox = document.getElementById('bulkChallanSummaryBox');
      const summaryText = document.getElementById('bulkChallanSummaryText');

      function showPopup(type, title, message) {
        if (typeof window.showUploadFlash === 'function') {
          window.showUploadFlash(type, title, message);
        } else {
          alert(message || title || 'Notification');
        }
      }

      function getPayload() {
        return {
          month: String(monthEl?.value || '').trim(),
          feeType: String(feeTypeEl?.value || '').trim(),
          className: String(classEl?.value || '').trim(),
          section: String(sectionEl?.value || 'All Sections').trim(),
          year: String(yearEl?.value || '').trim()
        };
      }

      function validatePayload(payload) {
        return !!(
          payload.month &&
          payload.feeType &&
          payload.className &&
          payload.section &&
          payload.year
        );
      }

      function setLoading(btn, state, loadingText, normalHtml) {
        if (!btn) return;
        btn.disabled = !!state;
        btn.innerHTML = state ? loadingText : normalHtml;
      }

      async function postJson(url, payload) {
        const res = await fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify(payload)
        });

        const data = await res.json().catch(() => ({}));
        return { ok: res.ok, data };
      }

      if (monthGrid && monthEl) {
        monthGrid.addEventListener('click', function (e) {
          const chip = e.target.closest('.bulk-month-chip');
          if (!chip) return;

          monthGrid.querySelectorAll('.bulk-month-chip').forEach(btn => btn.classList.remove('active'));
          chip.classList.add('active');
          monthEl.value = chip.getAttribute('data-month') || '';
        });
      }

      if (classGrid && classEl) {
        classGrid.addEventListener('click', function (e) {
          const chip = e.target.closest('.bulk-class-chip');
          if (!chip) return;

          classGrid.querySelectorAll('.bulk-class-chip').forEach(btn => btn.classList.remove('active'));
          chip.classList.add('active');
          classEl.value = chip.getAttribute('data-class') || '';
        });
      }

      openBtn.addEventListener('click', function () {
        summaryBox.classList.add('d-none');
        summaryText.textContent = '-';

        monthEl.value = '';
        classEl.value = '';

        if (monthGrid) {
          monthGrid.querySelectorAll('.bulk-month-chip').forEach(btn => btn.classList.remove('active'));
        }

        if (classGrid) {
          classGrid.querySelectorAll('.bulk-class-chip').forEach(btn => btn.classList.remove('active'));
        }

        bulkModal.show();
      });

      createBtn.addEventListener('click', async function () {
        const payload = getPayload();

        if (!validatePayload(payload)) {
          showPopup('error', 'Invalid Selection', 'Please select month, fee type, class, section and year.');
          return;
        }

        const normalHtml = 'Create Invoice';
        try {
          setLoading(createBtn, true, '<span class="spinner-border spinner-border-sm me-2"></span>Creating...', normalHtml);

          const result = await postJson('/api/bulk-challan/create', payload);

          if (!result.ok || !result.data?.success) {
            showPopup('error', 'Update Failed', result.data?.message || 'Invoice status update failed.');
            return;
          }

          const summary = result.data.summary || {};
          summaryText.textContent =
            `Matched: ${summary.totalMatched || 0} | Ready to Send: ${summary.readyToSend || 0} | Already Updated: ${summary.alreadyUpdated || 0}`;
          summaryBox.classList.remove('d-none');

          showPopup('success', 'Success', result.data?.message || 'Invoice status updated successfully.');

          if (typeof window.saveViewportState === 'function') {
            window.saveViewportState();
          }

          setTimeout(() => {
  if (typeof window.smoothDashboardReload === "function") {
    window.smoothDashboardReload(1000);
  } else {
    window.location.reload();
  }
}, 900);
        } catch (err) {
          console.error(err);
          showPopup('error', 'Update Failed', 'Invoice status update failed.');
        } finally {
          setLoading(createBtn, false, '', normalHtml);
        }
      });

      sendBtn.addEventListener('click', async function () {
        const payload = getPayload();

        if (!validatePayload(payload)) {
          showPopup('error', 'Invalid Selection', 'Please select month, fee type, class, section and year.');
          return;
        }

        const normalHtml = '<i class="bi bi-whatsapp me-1"></i> Send Invoice to WhatsApp';
        try {
          setLoading(sendBtn, true, '<span class="spinner-border spinner-border-sm me-2"></span>Sending...', normalHtml);

          const result = await postJson('/api/bulk-challan/send-whatsapp', payload);

          if (!result.ok || !result.data?.success) {
            showPopup('error', 'Send Failed', result.data?.message || 'Failed to send invoices to WhatsApp.');
            return;
          }

          showPopup(
            'success',
            'Sent Successfully',
            result.data?.message || 'Invoices sent to WhatsApp successfully.'
          );
        } catch (err) {
          console.error(err);
          showPopup('error', 'Send Failed', 'Failed to send invoices to WhatsApp.');
        } finally {
          setLoading(sendBtn, false, '', normalHtml);
        }
      });
    });
  })();
</script>
<script>
  (function () {
    document.addEventListener('DOMContentLoaded', function () {
      const table = document.getElementById('agentAccountsTable');
      const modalEl = document.getElementById('agentSearchModal');
      const openBtn = document.getElementById('openAgentSearchModalBtn');
      const inputEl = document.getElementById('agentSearchToolbarInput');
      const clearBtn = document.getElementById('clearAgentSearchBtn');
      const triggerBadge = document.getElementById('agentSearchCriterionBadge');

      if (!table || !modalEl || !openBtn || !inputEl || typeof bootstrap === 'undefined') return;

      const searchModal = bootstrap.Modal.getOrCreateInstance(modalEl);
      const optionButtons = Array.from(document.querySelectorAll('.agent-search-option'));

      let activeSearchKey = 'general';
      let activeSearchLabel = 'General';

      function getCellValue(row, colKey) {
        const cell = row.querySelector(`td[data-col="${colKey}"]`);
        if (!cell) return '';

        const field = cell.querySelector('input, select, textarea');
        if (field) return String(field.value || '').toLowerCase().trim();

        return String(cell.textContent || '').toLowerCase().trim();
      }

      function getGeneralRowText(row) {
        const cells = Array.from(row.querySelectorAll('td'));
        return cells.map(td => {
          const field = td.querySelector('input, select, textarea');
          return field ? String(field.value || '') : String(td.textContent || '');
        }).join(' ').toLowerCase().trim();
      }

      function applySearch() {
        const keyword = String(inputEl.value || '').toLowerCase().trim();
        const rows = table.querySelectorAll('tbody tr.agent-row');

        rows.forEach(row => {
          if (!keyword) {
            row.style.display = '';
            return;
          }

          let matched = false;

          if (activeSearchKey === 'general') {
            matched = getGeneralRowText(row).includes(keyword);
          } else {
            matched = getCellValue(row, activeSearchKey).includes(keyword);
          }

          row.style.display = matched ? '' : 'none';
        });
      }

      function updateCriterionUI(label) {
        activeSearchLabel = label || 'General';
        if (triggerBadge) triggerBadge.textContent = activeSearchLabel;
      }

      optionButtons.forEach(btn => {
        btn.addEventListener('click', function () {
          optionButtons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          activeSearchKey = btn.getAttribute('data-search-key') || 'general';
          const label = btn.getAttribute('data-search-label') || 'General';

          updateCriterionUI(label);
          applySearch();
          searchModal.hide();
          inputEl.focus();
        });
      });

      openBtn.addEventListener('click', function () {
        searchModal.show();
      });

      inputEl.addEventListener('input', function () {
        applySearch();
      });

      if (clearBtn) {
        clearBtn.addEventListener('click', function () {
          inputEl.value = '';
          activeSearchKey = 'general';
          activeSearchLabel = 'General';

          optionButtons.forEach(b => b.classList.remove('active'));
          updateCriterionUI('General');
          applySearch();
          searchModal.hide();
          inputEl.focus();
        });
      }

      updateCriterionUI('General');
      applySearch();
    });
  })();
</script>