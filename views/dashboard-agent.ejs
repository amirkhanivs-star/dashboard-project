      const feeStatusVal = (a.feeStatus || a.fee_status || a.feeStatusText || '').trim();

      const registrationDateRaw =
        a.registrationDate ||
        a.registration_date ||
        '';

      const assignedRegistrationDateRaw =
        a.registrationNumberAssignedAt ||
        a.accounts_registration_number_assigned_at ||
        (a.accounts && a.accounts.registrationNumberAssignedAt) ||
        '';

      const registrationDateOnly =
        toDashboardDateOnly(registrationDateRaw);

      const assignedRegistrationDateOnly =
        toDashboardDateOnly(assignedRegistrationDateRaw);

      const workflowTag =
        getDashboardWorkflowTag(a);

      const workflowTagClass =
        getDashboardWorkflowTagClass(workflowTag);

      const cardSchoolReturnStatus = String(
        a.schoolReturnStatus ||
        a.school_return_status ||
        (a.forward && a.forward.schoolReturnStatus) ||
        ''
      )
        .trim()
        .toLowerCase();

      const cardReuploadTagActive =
        Number(
          a.reuploadTagActive ||
          a.reupload_tag_active ||
          0
        ) === 1;

      const cardForwardSubStatus = String(
        a.forwardSubStatus ||
        (a.forward && a.forward.subStatus) ||
        ''
      )
        .trim()
        .toLowerCase();

      const cardForwardStatus = String(
        a.forwardStatus ||
        (a.forward && a.forward.status) ||
        'not_forwarded'
      ).trim().toLowerCase();

      const cardForwardedTo = String(
        a.forwardedToDepartment ||
        (a.forward && a.forward.toDepartment) ||
        ''
      ).trim();

      const cardForwardedToType = normalizeAccountsAgentTypeForView(
        a.forwardedToType ||
        a.forwarded_to_type ||
        (a.forward && a.forward.toType) ||
        ''
      );

      const cardForwardedFromDepartment = String(
        a.forwardedFromDepartment ||
        a.forwarded_from_department ||
        (a.forward && a.forward.fromDepartment) ||
        ''
      ).trim();

      const cardForwardedFromType = String(
        a.forwardedFromType ||
        a.forwarded_from_type ||
        (a.forward && a.forward.fromType) ||
        'school'
      ).trim().toLowerCase();

      const cardAccountsWorkflowStage = String(
        a.accountsWorkflowStage ||
        a.accounts_workflow_stage ||
        (a.forward && a.forward.workflowStage) ||
        'new_admissions'
      ).trim().toLowerCase();

      const cardAccountsIssueMessage = String(
        a.accountsIssueMessage ||
        a.accounts_issue_message ||
        (a.forward && a.forward.issueMessage) ||
        ''
      ).trim();

      const cardAccountsIssueFields = parseDashboardJsonArray(
        a.accountsIssueFields ||
        a.accounts_issue_fields ||
        (a.forward && a.forward.issueFields) ||
        []
      );

      const cardForwardedOwnerName = String(
        a.forwardedOwnerUserName ||
        a.forwarded_owner_user_name ||
        (a.forward && a.forward.forwardedOwnerUserName) ||
        ''
      ).trim();

      const cardForwardTimer =
        getDashboardForwardTimer(a);

      const cardForwardTimerStartedAt =
        getDashboardForwardTimerStartedAt(cardForwardTimer);

      const cardForwardTimerName =
        getDashboardForwardTimerName(cardForwardTimer) ||
        cardForwardedOwnerName;

      const cardForwardTimerDept =
        getDashboardForwardTimerDept(cardForwardTimer) ||
        cardForwardedTo ||
        '';

      const cardForwardTimerType =
        getDashboardForwardTimerType(cardForwardTimer) ||
        getAccountsPipelineLabel(cardForwardedToType) ||
        cardForwardedToType ||
        '';

      const cardForwardTimerDurationLabel =
        getDashboardForwardTimerDurationLabel(cardForwardTimer);

      const cardForwardTimerContext = [
        cardForwardTimerDept,
        cardForwardTimerType
      ].filter(Boolean).join(' | ');

      const cardForwardTimerTitle = [
        cardForwardTimerName ? `With ${cardForwardTimerName}` : 'With selected user',
        cardForwardTimerDept,
        cardForwardTimerType,
        cardForwardTimerDurationLabel
      ].filter(Boolean).join(' | ');

      const cardForwardTimerLogs =
        Array.isArray(a.forwardTimeLogs)
          ? a.forwardTimeLogs
          : (
              Array.isArray(a.forward_time_logs)
                ? a.forward_time_logs
                : (
                    Array.isArray(a.timeLogs)
                      ? a.timeLogs
                      : []
                  )
            );

      const shouldShowCardForwardTimer =
        cardForwardStatus === 'forwarded' &&
        cardAccountsWorkflowStage !== 'old_admissions' &&
        !!cardForwardTimerStartedAt;

      const studentVal = a.studentName || a.student || '';
      const fatherVal = a.fatherName || a.father || '';
      const fatherEmailVal = a.fatherEmail || a.father_email || '';
      const processedByVal = a.processedBy || a.processed_by || '';

      const gradeVal = a.grade || '';
      const tuitionVal = a.tuitionGrade || '';
      const phoneVal = a.phone || a.contactNumber || '';

      const payVal = (a.accounts && a.accounts.paymentStatus) || '';
      const paidUptoVal = (a.accounts && a.accounts.paidUpto) || '';
      const verifVal = a.latestBillingVerificationNumber || '';
      const regVal = (a.accounts && a.accounts.registrationNumber) || '';
      const familyVal = (a.accounts && a.accounts.familyNumber) || '';

      const registrationFeeVal = (a.admission && a.admission.registrationFee) || '';
      const feesVal = (a.admission && a.admission.fees) || '';

            const currencyVal = String(
        (a.admission && (a.admission.currency || a.admission.currencyCode || a.admission.currency_code)) ||
        (a.accounts && (a.accounts.currency || a.accounts.currencyCode || a.accounts.currency_code)) ||
        a.currency ||
        a.currencyCode ||
        a.currency_code ||
        ''
      ).trim().toUpperCase();

      const bankVal = String(
        (a.admission && (a.admission.bankName || a.admission.bank_name || a.admission.bank)) ||
        (a.accounts && (a.accounts.bankName || a.accounts.bank_name || a.accounts.bank)) ||
        a.bankName ||
        a.bank_name ||
        a.bank ||
        ''
      ).trim();

      const monthVal = (a.admission && a.admission.month) || '';
      const totalFeesVal = (a.admission && a.admission.totalFees) || '';
      const pendingDuesVal = (a.admission && a.admission.pendingDues) || '';
      const receivedPaymentVal = (a.admission && a.admission.receivedPayment) || '0';

      const invoiceStatusVal = (a.admission && a.admission.invoiceStatus) || '';
      const invoiceStatusTimestampVal = (a.admission && a.admission.invoiceStatusTimestamp) || '';
      const paidInvoiceStatusVal = (a.admission && a.admission.paidInvoiceStatus) || '';
      const paidInvoiceStatusTimestampVal = (a.admission && a.admission.paidInvoiceStatusTimestamp) || '';

      const cardFields = [
        { key: 'no', show: true, label: 'No.', value: a.entryNumber || a.entry_number || a.id || '-' },
{ key: 'registrationNumber', show: P.col.reg, label: 'Reg #', value: regVal || '-' },
{ key: 'familyNumber', show: P.col.family, label: 'Family #', value: familyVal || '-' },
{ key: 'verificationNumber', show: P.col.verif, label: 'Verif #', value: verifVal || '-' },
{ key: 'status', show: P.col.status, label: 'Current Status', value: currentStatusVal || '-' },
{ key: 'feeStatus', show: P.col.feeStatus, label: 'Fee Status', value: feeStatusVal || '-' },
        { key: 'dept', show: P.col.dept, label: 'Dept', value: deptVal || '-' },
        { key: 'student', show: P.col.student, label: 'Student', value: studentVal || '-' },
        { key: 'father', show: P.col.father, label: 'Father', value: fatherVal || '-' },
        { key: 'grade', show: P.col.grade, label: 'Grade', value: gradeVal || '-' },
        { key: 'tuitionGrade', show: P.col.tuitionGrade, label: 'Grade Section', value: tuitionVal || '-' },
        { key: 'fatherEmail', show: P.col.fatherEmail, label: 'Email Address', value: fatherEmailVal || '-' },
        { key: 'phone', show: P.col.phone, label: 'Phone Number', value: phoneVal || '-' },
        { key: 'processedBy', show: P.col.processedBy, label: 'Processed By', value: processedByVal || '-' },
        { key: 'paymentStatus', show: P.col.paymentStatus, label: 'Payment Status', value: payVal || '-' },
        { key: 'paidUpto', show: P.col.paidUpto, label: 'Paid Upto', value: paidUptoVal || '-' },
        { key: 'registrationFee', show: P.col.registrationFee, label: 'Registration Fee', value: registrationFeeVal || '-' },
        { key: 'fees', show: P.col.fees, label: 'Monthly Fees', value: feesVal || '-' },
        { key: 'currency', show: P.col.currency, label: 'Currency', value: currencyVal || '-' },
        { key: 'bank', show: P.col.bank, label: 'Bank', value: bankVal || '-' },
        { key: 'month', show: P.col.month, label: 'Month/Year', value: monthVal || '-' },
        { key: 'totalFees', show: P.col.totalFees, label: 'Total Fees', value: totalFeesVal || '-' },
        { key: 'pendingDues', show: P.col.pendingDues, label: 'Pending Dues', value: pendingDuesVal || '-' },
        { key: 'receivedPayment', show: P.col.receivedPayment, label: 'Received Payment', value: receivedPaymentVal || '0' },
        { key: 'invoiceStatus', show: P.col.invoiceStatus, label: 'Invoice Status', value: invoiceStatusVal || '-' },
        { key: 'invoiceStatusTimestamp', show: P.col.invoiceStatusTimestamp, label: 'Invoice Status Timestamp', value: invoiceStatusTimestampVal || '-' },
        { key: 'paidInvoiceStatus', show: P.col.paidInvoiceStatus, label: 'Paid Invoice Status', value: paidInvoiceStatusVal || '-' },
        { key: 'paidInvoiceStatusTimestamp', show: P.col.paidInvoiceStatusTimestamp, label: 'Paid Invoice Status Timestamp', value: paidInvoiceStatusTimestampVal || '-' }
      ];
    %>

      <form id="<%= fid %>" action="/pipeline/update/<%= a.id %>" method="POST" class="d-none"></form>

      <div
