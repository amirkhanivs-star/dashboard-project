    window.showAccountsPipelineHome = showAccountsPipelineHome;
       function showSchoolForwardWorkspace() {
      if (!shouldShowSchoolForwardFilters || shouldShowSchoolAccountsWorkflow) return;

      const home = document.getElementById("schoolForwardHome");
      const workspace = document.getElementById("accountsAdmissionsWorkspace");

      if (home) home.classList.add("d-none");
