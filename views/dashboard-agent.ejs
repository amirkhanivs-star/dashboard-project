<script>
  (function () {
    const canShowNote = window.SHOW_ACCOUNTS_NUMBER_NOTE === true;
    const widget = document.getElementById("accountsNumberNoteWidget");
    const openBtn = document.getElementById("accountsNumberNoteOpenBtn");
    const hideBtn = document.getElementById("accountsNumberNoteHideBtn");
    const listEl = document.getElementById("accountsNumberNoteList");
    const emptyEl = document.getElementById("accountsNumberNoteEmpty");
    const totalEl = document.getElementById("accountsNumberNoteTotal");

    if (!canShowNote || !widget || !listEl) {
      return;
    }

    const storageKey =
      widget.getAttribute("data-hidden-storage-key") ||
      "ivs_accounts_number_note_hidden_agent";

    let currentRecords = [];

    function escapeHtml(value) {
      return String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function normalizeRecord(record = {}) {
      const verificationNumber =
        String(record.verificationNumber || record.rawVerificationNumber || "").trim() || "?";

      const registrationNumber =
        String(record.registrationNumber || record.rawRegistrationNumber || "").trim() || "?";

      const missingVerificationNumber =
        record.missingVerificationNumber === true ||
        verificationNumber === "?";

      const missingRegistrationNumber =
        record.missingRegistrationNumber === true ||
        registrationNumber === "?";

      return {
        admissionId: record.admissionId || record.id || "",
        entryNumber: record.entryNumber || record.entry_number || record.admissionId || record.id || "-",
        studentName: record.studentName || record.student_name || "No Name",
        fatherName: record.fatherName || record.father_name || "",
        grade: record.grade || "",
        verificationNumber,
        registrationNumber,
        missingVerificationNumber,
        missingRegistrationNumber,
        updatedAt: record.updatedAt || record.updated_at || "",
        updatedByName: record.updatedByName || record.updated_by_name || "",
        copyText:
          record.copyText ||
          [
            `Entry: ${record.entryNumber || record.admissionId || record.id || "-"}`,
            `Student: ${record.studentName || record.student_name || "No Name"}`,
            `VERIF: ${verificationNumber}`,
            `REG: ${registrationNumber}`
          ].join(" | ")
      };
    }

    function formatDate(value) {
      const raw = String(value || "").trim();

      if (!raw) return "";

      const parsed = new Date(raw);

      if (Number.isNaN(parsed.getTime())) {
        return raw;
      }

      const dd = String(parsed.getDate()).padStart(2, "0");
      const mm = String(parsed.getMonth() + 1).padStart(2, "0");
      const yyyy = parsed.getFullYear();

      return `${dd}-${mm}-${yyyy}`;
    }

    function makeChip(label, value, missing) {
      return `
        <span class="accounts-number-note-chip ${missing ? "missing" : ""}" title="${escapeHtml(value)}">
          <span class="accounts-number-note-chip-label">${escapeHtml(label)}</span>
          <span class="accounts-number-note-chip-value">${escapeHtml(value)}</span>
        </span>
      `;
    }

    function renderAccountsNumberNote(data = {}) {
      const records = Array.isArray(data.records)
        ? data.records.map(normalizeRecord)
        : [];

      currentRecords = records;

      if (totalEl) {
        totalEl.textContent = String(data.total || records.length || 0);
      }

      if (!records.length) {
        listEl.innerHTML = "";

        if (emptyEl) {
          emptyEl.classList.remove("d-none");
        }

        return;
      }

      if (emptyEl) {
        emptyEl.classList.add("d-none");
      }

      listEl.innerHTML = records.map((record, index) => {
        const metaParts = [
          record.fatherName ? `Father: ${record.fatherName}` : "",
          record.grade ? `Grade: ${record.grade}` : "",
          record.updatedAt ? `Updated: ${formatDate(record.updatedAt)}` : "",
          record.updatedByName ? `By: ${record.updatedByName}` : ""
        ].filter(Boolean);

        return `
          <div class="accounts-number-note-row">
            <div class="accounts-number-note-row-head">
              <div class="accounts-number-note-student">
                ${escapeHtml(record.studentName)}
              </div>

              <div class="accounts-number-note-entry">
                #${escapeHtml(record.entryNumber)}
              </div>
            </div>

            <div class="accounts-number-note-meta">
              ${escapeHtml(metaParts.join(" | ") || "Admission number update")}
            </div>

            <div class="accounts-number-note-numbers">
              ${makeChip("VERIF", record.verificationNumber, record.missingVerificationNumber)}
              ${makeChip("REG", record.registrationNumber, record.missingRegistrationNumber)}
            </div>

            <button
              type="button"
              class="accounts-number-note-copy"
              data-copy-index="${index}">
              <i class="bi bi-copy me-1"></i>
              Copy
            </button>
          </div>
        `;
      }).join("");
    }

    async function copyText(text) {
      const finalText = String(text || "").trim();

      if (!finalText) return;

      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(finalText);
        } else {
          const textarea = document.createElement("textarea");
          textarea.value = finalText;
          textarea.setAttribute("readonly", "readonly");
          textarea.style.position = "fixed";
          textarea.style.left = "-9999px";
          document.body.appendChild(textarea);
          textarea.select();
          document.execCommand("copy");
          textarea.remove();
        }

        if (typeof window.showUploadFlash === "function") {
          window.showUploadFlash("success", "Copied", "Verification and registration number copied.");
        }
      } catch (err) {
        console.error("Copy failed:", err);

        if (typeof window.showUploadFlash === "function") {
          window.showUploadFlash("error", "Copy Failed", "Could not copy number.");
        }
      }
    }

    function setNoteHidden(hidden) {
      const shouldHide = !!hidden;

      widget.classList.toggle("d-none", shouldHide);

      if (openBtn) {
        openBtn.classList.toggle("d-none", !shouldHide);
      }

      localStorage.setItem(storageKey, shouldHide ? "1" : "0");
    }

    async function refreshAccountsNumberNote() {
      try {
        const res = await fetch("/api/accounts-number-note", {
          method: "GET",
          credentials: "same-origin",
          headers: {
            "Accept": "application/json"
          }
        });

        const data = await res.json().catch(() => ({}));

        if (!res.ok || data.success === false) {
          return;
        }

        const noteData = data.accountsNumberNote || {
          enabled: false,
          latestHighest: null,
          records: [],
          total: 0
        };

        window.ACCOUNTS_NUMBER_NOTE = noteData;

        if (noteData.enabled) {
          renderAccountsNumberNote(noteData);
        }
      } catch (err) {
        console.error("Accounts number note refresh failed:", err);
      }
    }

    listEl.addEventListener("click", function (event) {
      const btn = event.target.closest("[data-copy-index]");
      if (!btn) return;

      const index = Number(btn.getAttribute("data-copy-index") || -1);
      const record = currentRecords[index];

      if (!record) return;

      copyText(record.copyText);
    });

    if (hideBtn) {
      hideBtn.addEventListener("click", function () {
        setNoteHidden(true);
      });
    }

    if (openBtn) {
      openBtn.addEventListener("click", function () {
        setNoteHidden(false);
      });
    }

    renderAccountsNumberNote(window.ACCOUNTS_NUMBER_NOTE || {});

    const isHidden =
      localStorage.getItem(storageKey) === "1";

    setNoteHidden(isHidden);

    window.refreshAccountsNumberNote = refreshAccountsNumberNote;

    document.addEventListener("DOMContentLoaded", function () {
      refreshAccountsNumberNote();
    });

    setInterval(refreshAccountsNumberNote, 60000);

    if (typeof io !== "undefined") {
      try {
        const noteSocket = io();

        noteSocket.on("admission:changed", function () {
          setTimeout(refreshAccountsNumberNote, 700);
        });
      } catch (err) {
        console.error("Accounts number note socket failed:", err);
      }
    }
  })();
</script>

<script>
  (function () {
    const canUseFiles = <%= P.btn.files ? 'true' : 'false' %>;

    if (!canUseFiles) {
      return;
    }

    let latestAdmissionFilesCache = [];
    let currentAdmissionFileFilter = 'none';

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function normalizeFileItem(item) {
      const forward =
        item.forward || {};

      const currentForwardTimer =
        item.currentForwardTimer ||
        item.forwardTimer ||
        forward.currentTimer ||
        forward.timer ||
        null;

      const forwardTimeLogs = Array.isArray(item.forwardTimeLogs)
        ? item.forwardTimeLogs
        : (
            Array.isArray(item.timeLogs)
              ? item.timeLogs
              : []
          );

      return {
        uploadId: item.uploadId || item.id || '',
        admissionId: item.admissionId || '',
        fileUrl: item.fileUrl || '#',
        seen: item.seen === true || item.seenByCurrentUser === true,
        student: item.student || item.studentName || 'No Name',
        father: item.father || item.fatherName || '-',
        addedBy: item.addedBy || item.uploadedByName || 'System / Old Record',
        addedByRole: item.addedByRole || item.uploadedByRole || '',
        fileName: item.fileName || item.originalName || 'File',
        uploadedAt: item.uploadedAt || '',
        dept: item.dept || '',
        grade: item.grade || '',
        registrationNumber: item.registrationNumber || '',
        familyNumber: item.familyNumber || '',
        currentForwardTimer,
        forwardTimeLogs
      };
    }

    function getFileTimerLogName(log = {}) {
      return String(
        log.name ||
        log.holderUserName ||
        log.holder_user_name ||
        log.userName ||
        log.user_name ||
        ''
      ).trim();
    }

    function getFileTimerLogDept(log = {}) {
      return String(
        log.department ||
        log.holderDepartment ||
        log.holder_department ||
        log.dept ||
        ''
      ).trim();
    }

    function getFileTimerLogType(log = {}) {
      return String(
        log.type ||
        log.holderType ||
        log.holder_type ||
        ''
      ).trim();
    }

    function getFileTimerLogDuration(log = {}) {
      const savedLabel = String(
        log.durationLabel ||
        log.duration_label ||
        ''
      ).trim();

      if (savedLabel) return savedLabel;

      const seconds = Number(
        log.durationSeconds ||
        log.duration_seconds ||
        0
      );

      const totalMinutes = Math.floor(Math.max(0, seconds) / 60);
      const days = Math.floor(totalMinutes / 1440);
      const hours = Math.floor((totalMinutes % 1440) / 60);
      const minutes = totalMinutes % 60;

      return `${days}d ${hours}h ${minutes}m`;
    }

    function renderForwardTimerLogsForFile(item = {}) {
      const logs = Array.isArray(item.forwardTimeLogs)
        ? item.forwardTimeLogs
        : [];

      if (!logs.length) {
        return '';
      }

      const rows = logs.map(log => {
        const name = getFileTimerLogName(log) || 'Selected user';
        const dept = getFileTimerLogDept(log) || '-';
        const type = getFileTimerLogType(log) || '-';
        const duration = getFileTimerLogDuration(log);

        return `
          <div class="file-forward-timer-row">
            <span><b>Name:</b> ${escapeHtml(name)}</span>
            <span><b>Dept:</b> ${escapeHtml(dept)}</span>
            <span><b>Type:</b> ${escapeHtml(type)}</span>
            <span><b>Time:</b> ${escapeHtml(duration)}</span>
          </div>
        `;
      }).join('');

      return `
        <div class="file-forward-timer-history">
          <div class="file-forward-timer-title">
            <i class="bi bi-clock-history"></i>
            Forward Time History
          </div>
          ${rows}
        </div>
      `;
    }
    function getAdmissionCardUploadState(card) {
  if (!card) return 'none';

  const icon = card.querySelector('.admission-file-bill-icon');

  if (!icon) return 'none';

  if (icon.classList.contains('seen-file-icon')) return 'seen';
  if (icon.classList.contains('new-file-icon')) return 'unseen';

  return 'none';
}

function setActiveFileFilterButton(filter) {
  document.querySelectorAll('[data-admission-file-filter]').forEach(btn => {
    const btnFilter = btn.getAttribute('data-admission-file-filter') || '';
    btn.classList.toggle('active-file-filter', filter !== 'none' && btnFilter === filter);
  });
}

function applyAdmissionPipelineFileFilter(filter) {
  const finalFilter = String(filter || 'none').trim().toLowerCase();
  const cards = document.querySelectorAll('.admission-card');

  cards.forEach(card => {
    const state = getAdmissionCardUploadState(card);

    let showCard = true;

    if (finalFilter === 'all') {
      showCard = state === 'seen' || state === 'unseen';
    } else if (finalFilter === 'seen') {
      showCard = state === 'seen';
    } else if (finalFilter === 'unseen') {
      showCard = state === 'unseen';
    } else {
      showCard = true;
    }

    card.classList.toggle('file-filter-hidden', !showCard);
  });

  setActiveFileFilterButton(finalFilter);
}
    function updateSingleIconToSeen(uploadId) {
      if (!uploadId) return;

      const icons = document.querySelectorAll(
        `.admission-file-bill-icon[data-upload-id="${CSS.escape(String(uploadId))}"]`
      );

      icons.forEach(fileIcon => {
        fileIcon.classList.remove('new-file-icon');
        fileIcon.classList.add('seen-file-icon');

        const tooltip = fileIcon.querySelector('.admission-file-tooltip');
        if (tooltip) {
          tooltip.classList.remove('new-file-tooltip');
          tooltip.classList.add('seen-file-tooltip');

          const title = tooltip.querySelector('.file-tooltip-title');
          if (title) title.textContent = 'File Seen';
        }
      });
    }

    async function markUploadSeen(uploadId) {
      if (!uploadId) return false;

      try {
        const res = await fetch(`/api/uploads/${encodeURIComponent(uploadId)}/seen`, {
          method: 'POST',
          credentials: 'same-origin',
          headers: {
            'Accept': 'application/json'
          }
        });

        const data = await res.json().catch(() => ({}));

        if (!res.ok || data.success === false) {
          console.error('Mark upload seen failed:', data.message || 'Unknown error');
          return false;
        }

        return true;
      } catch (err) {
        console.error('Mark upload seen failed:', err);
        return false;
      }
    }

    async function fetchAdmissionFiles(filter) {
      const finalFilter = filter || 'all';

      const res = await fetch(`/api/admission-files?filter=${encodeURIComponent(finalFilter)}`, {
        method: 'GET',
        credentials: 'same-origin',
        headers: {
          'Accept': 'application/json'
        }
      });

      const data = await res.json().catch(() => ({}));

      if (!res.ok || data.success === false) {
        throw new Error(data.message || 'Files load failed');
      }

      return data;
    }

    function renderList(targetId, items) {
      const wrap = document.getElementById(targetId);
      if (!wrap) return;

      const finalItems = (items || []).map(normalizeFileItem);

      if (!finalItems.length) {
        wrap.innerHTML = '<div class="file-dropdown-empty">No files found.</div>';
        return;
      }

      wrap.innerHTML = finalItems.map(item => {
        const statusClass = item.seen ? 'seen' : 'unseen';
        const statusText = item.seen ? 'Seen' : 'Unseen';

        return `
          <button
            type="button"
            class="file-dropdown-item ${statusClass}"
            data-upload-id="${escapeHtml(item.uploadId)}"
            data-file-url="${escapeHtml(item.fileUrl)}">
            <div class="file-dropdown-head">
              <div class="file-dropdown-student">${escapeHtml(item.student)}</div>
              <span class="file-dropdown-status ${statusClass}">${statusText}</span>
            </div>

            <div class="file-dropdown-meta">
              <div><b>Father:</b> ${escapeHtml(item.father)}</div>
              ${item.grade ? `<div><b>Grade:</b> ${escapeHtml(item.grade)}</div>` : ''}
              ${item.dept ? `<div><b>Dept:</b> ${escapeHtml(item.dept)}</div>` : ''}
              ${item.registrationNumber ? `<div><b>Reg #:</b> ${escapeHtml(item.registrationNumber)}</div>` : ''}
              ${item.familyNumber ? `<div><b>Family #:</b> ${escapeHtml(item.familyNumber)}</div>` : ''}
              <div><b>Added by:</b> ${escapeHtml(item.addedBy)}${item.addedByRole ? ' (' + escapeHtml(item.addedByRole).replace(/_/g, ' ') + ')' : ''}</div>
              <div><b>File:</b> ${escapeHtml(item.fileName)}</div>
              ${item.uploadedAt ? `<div><b>Date:</b> ${escapeHtml(item.uploadedAt)}</div>` : ''}
              ${renderForwardTimerLogsForFile(item)}
            </div>
          </button>
        `;
      }).join('');
    }

    function setCounts(counts, fallbackFiles) {
      const files = Array.isArray(fallbackFiles) ? fallbackFiles.map(normalizeFileItem) : [];

      const allCount = document.getElementById('allFilesCount');
      const unseenCount = document.getElementById('unseenFilesCount');
      const seenCount = document.getElementById('seenFilesCount');

      const finalCounts = counts || {
        all: files.length,
        unseen: files.filter(f => !f.seen).length,
        seen: files.filter(f => f.seen).length
      };

      if (allCount) allCount.textContent = String(finalCounts.all || 0);
      if (unseenCount) unseenCount.textContent = String(finalCounts.unseen || 0);
      if (seenCount) seenCount.textContent = String(finalCounts.seen || 0);
    }

    window.rebuildAdmissionFilesDropdowns = async function () {
      try {
        const data = await fetchAdmissionFiles('all');

        latestAdmissionFilesCache = Array.isArray(data.files)
          ? data.files.map(normalizeFileItem)
          : [];

        const allFiles = latestAdmissionFilesCache;
        const unseenFiles = allFiles.filter(f => !f.seen);
        const seenFiles = allFiles.filter(f => f.seen);

        setCounts(data.counts, allFiles);

        renderList('allFilesDropdownList', allFiles);
        renderList('unseenFilesDropdownList', unseenFiles);
        renderList('seenFilesDropdownList', seenFiles);
        applyAdmissionPipelineFileFilter(currentAdmissionFileFilter);
      } catch (err) {
        console.error('Admission files dropdown load failed:', err);

        renderList('allFilesDropdownList', []);
        renderList('unseenFilesDropdownList', []);
        renderList('seenFilesDropdownList', []);
        setCounts({ all: 0, unseen: 0, seen: 0 }, []);
      }
    };

    async function openFileAndMarkSeen(uploadId, fileUrl) {
      if (!uploadId) return;

      await markUploadSeen(uploadId);

      latestAdmissionFilesCache = latestAdmissionFilesCache.map(item => {
        if (String(item.uploadId) === String(uploadId)) {
          return { ...item, seen: true, seenByCurrentUser: true };
        }
        return item;
      });

      updateSingleIconToSeen(uploadId);

      if (typeof window.rebuildAdmissionFilesDropdowns === 'function') {
        await window.rebuildAdmissionFilesDropdowns();
      }

      if (fileUrl && fileUrl !== '#') {
        window.open(fileUrl, '_blank');
      }
    }
document.addEventListener('click', function (e) {
