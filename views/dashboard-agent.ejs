<script>
(function () {
  window.STATUS_OPTION_CACHE = {
    current: [],
    fee: [],
    billing: []
  };

  function setSelectVisual(sel, color) {
    if (!sel) return;
    const c = color || '#64748b';
    sel.style.setProperty('--dot', c);
    sel.style.setProperty('--bd', c + '26');
sel.style.setProperty('--tx', '#000000');
sel.style.setProperty('--bg', c + '12');
  }

  function getCachedOptions(type) {
    return Array.isArray(window.STATUS_OPTION_CACHE?.[type])
      ? window.STATUS_OPTION_CACHE[type]
      : [];
  }

  function findColor(items, value) {
    const v = String(value || '').trim().toLowerCase();
    const found = (items || []).find(x => String(x.value || '').trim().toLowerCase() === v);
    return found ? found.color : '#64748b';
  }

    function applyDynamicColors() {
    const currentItems = getCachedOptions('current');
    const feeItems = getCachedOptions('fee');

    document.querySelectorAll('.js-status-select').forEach(sel => {
      if ((sel.value || '') === '__add_new_status__') return;
      setSelectVisual(sel, findColor(currentItems, sel.value));
    });

    document.querySelectorAll('.js-fee-select').forEach(sel => {
      if ((sel.value || '') === '__add_new_fee_status__') return;
      setSelectVisual(sel, findColor(feeItems, sel.value));
    });
  }

  window.applyDynamicDropdownColors = applyDynamicColors;

  function applyDynamicBillingColors() {
  const billingItems = getCachedOptions('billing');

  document.querySelectorAll('.bill-status').forEach(sel => {
    const val = String(sel.value || '').trim();
    const clean = val.toLowerCase();

    sel.classList.remove(
      'status-notadmitted',
      'status-nopayment',
      'status-partial',
      'status-full',
      'status-unpaid'
    );

    if (clean === 'not admitted') sel.classList.add('status-notadmitted');
    if (clean === 'no payment') sel.classList.add('status-nopayment');
    if (clean === 'partial payment') sel.classList.add('status-partial');
    if (clean === 'full payment') sel.classList.add('status-full');
    if (clean === 'unpaid') sel.classList.add('status-unpaid');

    if (!val || val === '__add_new_billing_status__') {
      setSelectVisual(sel, '#64748b');
      return;
    }

    setSelectVisual(sel, findColor(billingItems, val));
  });
}

window.applyDynamicBillingColors = applyDynamicBillingColors;

    function openBillingStatusManager() {
  const billingModalEl = document.getElementById('billingStatusOptionModal');
  if (!billingModalEl) return;

  billingModalEl.classList.remove('d-none');
  billingModalEl.setAttribute('aria-hidden', 'false');
}

function init() {
  document.addEventListener('change', function (e) {
    if (e.target.matches('.js-status-select, .js-fee-select')) {
      applyDynamicColors();
    }

    if (e.target.matches('.bill-status')) {
      const sel = e.target;

      if (sel.value === '__add_new_billing_status__') {
        const prev = sel.getAttribute('data-prev-value') || '';

        sel.value = prev;
        openBillingStatusManager();

        if (window.applyDynamicBillingColors) {
          window.applyDynamicBillingColors();
        }

        return;
      }

      sel.setAttribute('data-prev-value', sel.value || '');

      if (window.applyDynamicBillingColors) {
        window.applyDynamicBillingColors();
      }
    }
