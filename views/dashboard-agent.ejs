  const inputEl = document.getElementById('statusOptionInput');
  const colorEl = document.getElementById('statusOptionColor');
  const saveBtn = document.getElementById('statusOptionSaveBtn');
  const listEl = document.getElementById('statusOptionList');
  const listTitleEl = document.getElementById('statusOptionListTitle');

  function optionLabel(type) {
    return type === 'current' ? 'Current Status' : 'Fee Status';
  }

  function apiBase(type) {
    return type === 'current'
      ? '/api/options/status'
      : '/api/options/fee-status';
  }

 function normalizeRows(type, rows) {
  return (rows || []).map(row => ({
    id: row.id,
    value: row.value || row.label || row.opt_key || '',
    color: row.color || '#64748b',
    is_custom: Number(row.is_custom || 0)
  }));
}

  async function fetchOptions(type) {
    const res = await fetch(apiBase(type), {
      headers: { 'Accept': 'application/json' }
    });
    const data = await res.json();
    if (!res.ok || !data.success) throw new Error(data.message || 'Failed to load options');
    const items = normalizeRows(type, data.data || []);
    window.STATUS_OPTION_CACHE[type] = items;
    return items;
  }

  async function updateColor(type, id, color) {
    const res = await fetch(`${apiBase(type)}/${id}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ color })
    });
    const data = await res.json();
    if (!res.ok || !data.success) throw new Error(data.message || 'Failed to update color');
    return data;
  }

  async function createOption(type, value, color) {
    const res = await fetch(apiBase(type), {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ label: value, color })
    });
    const data = await res.json();
    if (!res.ok || !data.success) throw new Error(data.message || 'Failed to save option');
    return data.data;
  }

  async function deleteOption(type, id) {
    const res = await fetch(`${apiBase(type)}/${id}`, {
      method: 'DELETE',
      headers: { 'Accept': 'application/json' }
    });
    const data = await res.json();
    if (!res.ok || !data.success) throw new Error(data.message || 'Failed to delete option');
    return true;
  }

  function rebuildSelect(selectEl, items, selectedValue, includeAll, addValue) {
    if (!selectEl) return;
    let html = includeAll ? '<option value="">All</option>' : '';
    html += items.map(item => {
      const selected = String(selectedValue || '') === String(item.value) ? 'selected' : '';
      return `<option value="${item.value}" ${selected}>${item.value}</option>`;
    }).join('');
    if (addValue) html += `<option value="${addValue}">+ Add Option</option>`;
    selectEl.innerHTML = html;
  }

  function normalizeRows2(type, rows) {
    return (rows || []).map(row => ({
      id: row.id,
      value: row.value || row.label || row.opt_key || '',
      color: row.color || '#64748b'
    }));
  }

  function renderList() {
    const items = Array.isArray(window.STATUS_OPTION_CACHE?.[activeType])
      ? window.STATUS_OPTION_CACHE[activeType]
      : [];

    if (titleEl) titleEl.textContent = `Manage ${optionLabel(activeType)} Options`;
    if (listTitleEl) listTitleEl.textContent = `${optionLabel(activeType)} Options`;

    if (!items.length) {
      listEl.innerHTML = '<div class="status-option-empty">No options available.</div>';
      return;
    }

    listEl.innerHTML = items.map((item, index) => `
      <div class="status-option-item">
        <div class="status-option-left">
          <span class="status-option-dot" style="background:${item.color || '#64748b'}"></span>
          <div class="status-option-name">${item.value}</div>
        </div>
        <div class="status-option-actions">
          <input type="color" class="form-control form-control-color status-option-color-input"
            value="${item.color || '#64748b'}" data-index="${index}" data-id="${item.id}"
            style="width:48px;min-width:48px;">
          ${item.is_custom ? `
  <button type="button" class="btn btn-sm btn-outline-danger rounded-pill status-option-delete-btn"
    data-index="${index}" data-id="${item.id}">Delete</button>
` : ''}
        </div>
      </div>
    `).join('');
  }

    function refreshDropdowns() {
    const currentItems = window.STATUS_OPTION_CACHE.current || [];
    const feeItems = window.STATUS_OPTION_CACHE.fee || [];

    document.querySelectorAll('.js-status-select').forEach(sel => {
      const selected = sel.getAttribute('data-prev-value') || sel.value || 'New Admission';
      rebuildSelect(sel, currentItems, selected, false, '__add_new_status__');
      sel.value = selected;
    });

    document.querySelectorAll('.js-fee-select').forEach(sel => {
      const selected = sel.getAttribute('data-prev-value') || sel.value || 'New Admission';
      rebuildSelect(sel, feeItems, selected, false, '__add_new_fee_status__');
      sel.value = selected;
    });

    if (window.applyDynamicDropdownColors) window.applyDynamicDropdownColors();
  }

  async function loadAllOptions() {
    await Promise.all([fetchOptions('current'), fetchOptions('fee')]);
    refreshDropdowns();
    renderList();
  }

  function openModal(type, selectEl) {
    activeType = type;
    pendingSelect = selectEl || null;
    inputEl.value = '';
    colorEl.value = '#64748b';
    renderList();
    modalEl.classList.remove('d-none');
    modalEl.setAttribute('aria-hidden', 'false');
  }

  document.addEventListener('change', function (e) {
    const el = e.target;

    if (el.matches('.js-status-select')) {
      if (el.value === '__add_new_status__') {
        const prev = el.getAttribute('data-prev-value') || 'New Admission';
        el.value = prev;
        openModal('current', el);
        return;
      }
      el.setAttribute('data-prev-value', el.value || '');
    }

    if (el.matches('.js-fee-select')) {
      if (el.value === '__add_new_fee_status__') {
        const prev = el.getAttribute('data-prev-value') || 'New Admission';
        el.value = prev;
        openModal('fee', el);
        return;
      }
      el.setAttribute('data-prev-value', el.value || '');
    }
  });

  if (saveBtn) {
    saveBtn.addEventListener('click', async function () {
      try {
        const val = String(inputEl.value || '').trim();
        const color = colorEl.value || '#64748b';
        if (!val) { alert('Option name required'); return; }

        const items = window.STATUS_OPTION_CACHE[activeType] || [];
        const exists = items.some(x => String(x.value || '').trim().toLowerCase() === val.toLowerCase());
        if (exists) { alert('Ye option pehle se mojood hai'); return; }

        const created = await createOption(activeType, val, color);
        await fetchOptions(activeType);
        refreshDropdowns();
        renderList();

        if (pendingSelect) {
          pendingSelect.value = created.value || created.label || val;
          pendingSelect.setAttribute('data-prev-value', created.value || created.label || val);
          if (window.applyDynamicDropdownColors) window.applyDynamicDropdownColors();
        }

        inputEl.value = '';
        colorEl.value = '#64748b';
      } catch (err) { alert(err.message || 'Save failed'); }
    });
  }

  listEl.addEventListener('change', async function (e) {
    const input = e.target.closest('.status-option-color-input');
    if (!input) return;
    try {
      const id = Number(input.getAttribute('data-id'));
      if (!id) return;
      await updateColor(activeType, id, input.value || '#64748b');
      await fetchOptions(activeType);
      refreshDropdowns();
      renderList();
    } catch (err) { alert(err.message || 'Color update failed'); }
  });

 listEl.addEventListener('click', async function (e) {
  const btn = e.target.closest('.status-option-delete-btn');
  if (!btn) return;
  try {
    const id = Number(btn.getAttribute('data-id'));
    if (!id) return;

    const items = window.STATUS_OPTION_CACHE[activeType] || [];
    const item = items.find(x => Number(x.id) === id);

    if (!item) return;
    if (Number(item.is_custom || 0) !== 1) {
      alert('Sirf user-added option delete ho sakta hai');
