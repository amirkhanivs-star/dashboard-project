        <i class="bi bi-receipt-cutoff"></i>

        <span class="admission-file-tooltip <%= a.latestUpload.seenByCurrentUser ? 'seen-file-tooltip' : 'new-file-tooltip' %>">

          <span class="file-tooltip-title">
            <%= a.latestUpload.seenByCurrentUser ? 'File Seen' : 'New File Added' %>
