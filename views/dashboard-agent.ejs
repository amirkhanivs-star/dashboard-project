    async function loadForwardTargetUsers(toType) {
      const cleanType =
        normalizeAccountsPipelineType(toType);

      if (
        !cleanType ||
        cleanType === "school_return"
      ) {
        resetForwardTargetUsers({
          hide: true,
        });
        return;
      }

      const requestToken =
        ++forwardUsersRequestToken;

      if (forwardTargetUserWrap) {
        forwardTargetUserWrap.classList.remove(
          "d-none"
        );
      }

      if (forwardTargetUserSelect) {
        forwardTargetUserSelect.disabled = true;
        forwardTargetUserSelect.innerHTML =
          '<option value="">Loading users...</option>';
      }

      if (forwardTargetUserHint) {
        forwardTargetUserHint.textContent =
          "Loading matching Accounts Agents and Sub-Agents...";
      }

      try {
        const response = await fetch(
          `/api/accounts/forward-users?toType=${encodeURIComponent(
            cleanType
          )}`,
          {
            credentials: "same-origin",
            headers: {
              "Accept": "application/json",
            },
          }
        );

        const data = await response
          .json()
          .catch(() => ({}));

        if (
          requestToken !== forwardUsersRequestToken
        ) {
          return;
        }

        if (
          !response.ok ||
          data.success === false
        ) {
          throw new Error(
            data.message ||
            "Could not load forwarding users."
          );
        }

        const users = Array.isArray(data.users)
          ? data.users
          : [];

        if (!forwardTargetUserSelect) return;

        if (!users.length) {
          forwardTargetUserSelect.disabled = true;
          forwardTargetUserSelect.innerHTML =
            '<option value="">No matching user available</option>';

          if (forwardTargetUserHint) {
            forwardTargetUserHint.textContent =
              "Create or assign an Agent/Sub-Agent to this Accounts pipeline first.";
          }

          return;
        }

        forwardTargetUserSelect.innerHTML = [
          '<option value="">Select Agent / Sub-Agent</option>',
          ...users.map(item => {
            const id = Number(item?.id || 0);
            const name = String(
              item?.name ||
              item?.email ||
              "User"
            ).trim();

            const role = String(
              item?.role || ""
            )
              .replace(/_/g, " ")
              .replace(/\b\w/g, char =>
                char.toUpperCase()
              );

            return `
              <option value="${id}">
                ${escapeHtml(name)}${role ? ` (${escapeHtml(role)})` : ""}
              </option>
            `;
          }),
        ].join("");

        forwardTargetUserSelect.disabled = false;

        if (forwardTargetUserHint) {
          forwardTargetUserHint.textContent =
            `${users.length} matching user${users.length === 1 ? "" : "s"} available.`;
        }
      } catch (error) {
        if (
          requestToken !== forwardUsersRequestToken
        ) {
          return;
        }

        if (forwardTargetUserSelect) {
          forwardTargetUserSelect.disabled = true;
          forwardTargetUserSelect.innerHTML =
            '<option value="">Users could not be loaded</option>';
        }

        if (forwardTargetUserHint) {
          forwardTargetUserHint.textContent =
            error.message ||
            "Could not load forwarding users.";
        }

        showPopup(
          "danger",
          "Users Not Loaded",
          error.message ||
          "Could not load forwarding users."
        );
      }
    }

