<script>
  /* ✅ Agent Billing Modal Opener - same as Admin */
  (function () {
    const months = [
      'january', 'february', 'march', 'april', 'may', 'june',
      'july', 'august', 'september', 'october', 'november', 'december'
    ];

    function clean(value) {
      return String(value || '').trim();
    }

    function normalizeBillingStatusValue(value) {
      const raw = clean(value);
      const v = raw.toLowerCase().replace(/[_-]+/g, ' ').replace(/\s+/g, ' ');

      if (!v) return '';
      if (v === 'not admitted' || v === 'notadmitted') return 'Not admitted';
      if (v === 'no payment' || v === 'nopayment') return 'No payment';
      if (v === 'partial payment' || v === 'partial') return 'Partial payment';
      if (v === 'full payment' || v === 'full') return 'Full payment';
      if (v === 'unpaid') return 'Unpaid';

      return raw;
    }

    function ensureSelectOption(selectEl, value) {
      if (!selectEl || !value) return;

      const exists = Array.from(selectEl.options).some(opt =>
        clean(opt.value).toLowerCase() === clean(value).toLowerCase()
      );

      if (exists) return;

      const addOption = Array.from(selectEl.options).find(opt =>
        opt.value === '__add_new_billing_status__'
      );

      const option = document.createElement('option');
      option.value = value;
      option.textContent = value;

      if (addOption) {
        selectEl.insertBefore(option, addOption);
      } else {
        selectEl.appendChild(option);
      }
    }

    function setSelectValueSafe(selectEl, value) {
      if (!selectEl) return;

      const finalValue = normalizeBillingStatusValue(value);

      if (!finalValue) {
        selectEl.value = '';
        return;
      }

      ensureSelectOption(selectEl, finalValue);
      selectEl.value = finalValue;
      selectEl.setAttribute('data-prev-value', finalValue);
    }

    function setBankValueSafe(selectEl, value) {
      if (!selectEl) return;

      const finalValue = clean(value);

      if (!finalValue) {
        selectEl.value = '';
        return;
      }

      const exists = Array.from(selectEl.options).some(opt =>
        clean(opt.value).toLowerCase() === finalValue.toLowerCase()
      );

      if (!exists) {
        const addOption = Array.from(selectEl.options).find(opt => opt.value === '__add_new_bank__');

        const option = document.createElement('option');
        option.value = finalValue;
        option.textContent = finalValue;

        if (addOption) {
          selectEl.insertBefore(option, addOption);
        } else {
          selectEl.appendChild(option);
        }
      }

      selectEl.value = finalValue;
      selectEl.setAttribute('data-prev-value', finalValue);
    }

    function syncAgentBillingYearText() {
      const yearSelect = document.getElementById('billingYearSelect');
      const yearText = document.getElementById('billingYearText');

      if (!yearSelect || !yearText) return;

      const y = clean(yearSelect.value);
      yearText.textContent = y ? `Selected: ${y}` : 'Current Year';
    }

    function resetBillingFields(defaultFee) {
      months.forEach(month => {
        const statusEl = document.querySelector(`.bill-status[data-month="${month}"]`);
        const amountEl = document.getElementById('bill_' + month);
        const feeEl = document.getElementById('bill_fee_' + month);
        const feeLabel = document.getElementById('bill_fee_label_' + month);
        const verifEl = document.getElementById('bill_verif_' + month);
        const bankEl = document.getElementById('bill_bank_' + month);

        if (statusEl) statusEl.value = '';
        if (amountEl) amountEl.value = '';
        if (feeEl) feeEl.value = '';
        if (verifEl) verifEl.value = '';
        if (bankEl) bankEl.value = '';

        if (feeLabel) {
          feeLabel.textContent = 'Fee: ' + (defaultFee || '-');
        }
      });

      if (window.applyDynamicBillingColors) {
        window.applyDynamicBillingColors();
      }
      setTimeout(function () {
  if (window.applyDynamicBillingColors) {
    window.applyDynamicBillingColors();
  }
}, 100);

setTimeout(function () {
  if (window.applyDynamicBillingColors) {
    window.applyDynamicBillingColors();
  }
}, 500);
    }

    async function loadBillingData(admissionId, defaultFee) {
      if (!admissionId) return;

      const yearSelect = document.getElementById('billingYearSelect');
      const year = clean(yearSelect?.value || new Date().getFullYear());

      const res = await fetch(`/api/billing/${admissionId}?year=${encodeURIComponent(year)}`, {
        headers: { Accept: 'application/json' }
      });

      const data = await res.json().catch(() => ({}));

      if (!res.ok || !data.success) {
        throw new Error(data.message || 'Billing data load failed');
      }

      const billing = data.billing || {};

      months.forEach(month => {
        const row = billing[month] || {};

        const statusEl = document.querySelector(`.bill-status[data-month="${month}"]`);
        const amountEl = document.getElementById('bill_' + month);
        const feeEl = document.getElementById('bill_fee_' + month);
        const feeLabel = document.getElementById('bill_fee_label_' + month);
        const verifEl = document.getElementById('bill_verif_' + month);
        const bankEl = document.getElementById('bill_bank_' + month);

        setSelectValueSafe(statusEl, row.status || '');

        if (amountEl) amountEl.value = row.amount || '';
        if (feeEl) feeEl.value = row.feeOverride || '';
        if (verifEl) verifEl.value = row.verification || '';
        setBankValueSafe(bankEl, row.bank || '');

        const statusText = clean(row.status).toLowerCase();
        const finalFee = row.feeOverride || defaultFee || data.calc?.baseFee || '-';

        if (feeLabel) {
          if (statusText === 'not admitted') {
            feeLabel.textContent = 'Fee: -';
          } else {
            const modalEl = document.getElementById('billingModal');
            const currency = modalEl?.getAttribute('data-current-currency') || '';
            feeLabel.textContent = 'Fee: ' + finalFee + (currency ? ' ' + currency : '');
          }
        }
      });

      if (window.applyDynamicBillingColors) {
        window.applyDynamicBillingColors();
      }
      setTimeout(function () {
  if (window.applyDynamicBillingColors) {
    window.applyDynamicBillingColors();
  }
}, 100);

setTimeout(function () {
  if (window.applyDynamicBillingColors) {
    window.applyDynamicBillingColors();
  }
}, 500);
    }

    document.addEventListener('click', async function (e) {
      const btn = e.target.closest('.btn-billing');
      if (!btn) return;

      e.preventDefault();
      e.stopPropagation();

      const modalEl = document.getElementById('billingModal');

      if (!modalEl || typeof bootstrap === 'undefined') {
        console.error('Billing modal or Bootstrap not found');
        alert('Billing modal or Bootstrap not found');
        return;
      }

      const admissionId = btn.getAttribute('data-admission-id') || '';
      const student = btn.getAttribute('data-student') || '-';
      const grade = btn.getAttribute('data-grade') || '-';
      const phone = btn.getAttribute('data-phone') || '-';
      const fees = btn.getAttribute('data-fees') || '-';
      const currency = btn.getAttribute('data-currency') || '-';

      modalEl.setAttribute('data-current-admission-id', admissionId);
      modalEl.setAttribute('data-current-fees', fees);
      modalEl.setAttribute('data-current-currency', currency);

      const billId = document.getElementById('billId');
      const billStudent = document.getElementById('billStudent');
      const billGrade = document.getElementById('billGrade');
      const billPhone = document.getElementById('billPhone');
      const billCurrency = document.getElementById('billCurrency');

      if (billId) billId.textContent = admissionId;
      if (billStudent) billStudent.textContent = student;
      if (billGrade) billGrade.textContent = grade;
      if (billPhone) billPhone.textContent = phone;
      if (billCurrency) billCurrency.textContent = currency || '-';

      resetBillingFields(fees);
      syncAgentBillingYearText();

      bootstrap.Modal.getOrCreateInstance(modalEl).show();

      setTimeout(async function () {
        try {
          await loadBillingData(admissionId, fees);
        } catch (err) {
          console.error(err);
          alert(err.message || 'Billing data load failed');
        }
      }, 150);
    }, true);

    document.addEventListener('change', async function (e) {
      if (!e.target || e.target.id !== 'billingYearSelect') return;

      syncAgentBillingYearText();

      const modalEl = document.getElementById('billingModal');
      if (!modalEl || !modalEl.classList.contains('show')) return;

      const admissionId = modalEl.getAttribute('data-current-admission-id') || '';
      const fees = modalEl.getAttribute('data-current-fees') || '-';

      resetBillingFields(fees);

      try {
        await loadBillingData(admissionId, fees);
      } catch (err) {
        console.error(err);
        alert(err.message || 'Billing data load failed');
      }
    });

    document.addEventListener('DOMContentLoaded', syncAgentBillingYearText);

    window.syncAgentBillingYearText = syncAgentBillingYearText;
  })();
</script>

<script>
  /* ✅ Agent Billing Save: same behavior as Super/Admin */
  (function () {
    const months = [
      'january', 'february', 'march', 'april', 'may', 'june',
      'july', 'august', 'september', 'october', 'november', 'december'
    ];

    function clean(value) {
      return String(value || '').trim();
    }

    function showBillingMessage(type, title, message) {
      if (typeof window.showUploadFlash === 'function') {
        window.showUploadFlash(type, title, message);
      } else {
        alert(message || title || 'Notification');
      }
    }

    function getBillingPayload() {
      const modalEl = document.getElementById('billingModal');
      const yearSelect = document.getElementById('billingYearSelect');

      const admissionId = clean(modalEl?.getAttribute('data-current-admission-id'));
      const year = clean(yearSelect?.value || new Date().getFullYear());

      const billing = {};

      months.forEach(month => {
        const statusEl = document.querySelector(`.bill-status[data-month="${month}"]`);
        const amountEl = document.getElementById('bill_' + month);
        const feeEl = document.getElementById('bill_fee_' + month);
        const verifEl = document.getElementById('bill_verif_' + month);
        const bankEl = document.getElementById('bill_bank_' + month);

        billing[month] = {
          status: clean(statusEl?.value),
          amount: clean(amountEl?.value),
          feeOverride: clean(feeEl?.value),
          verification: clean(verifEl?.value),
          bank: clean(bankEl?.value)
        };
      });

      return { admissionId, year, billing };
    }

    async function saveBillingData(payload) {
      const res = await fetch(`/api/billing/${payload.admissionId}`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({
          year: payload.year,
          billing: payload.billing
        })
      });

      const data = await res.json().catch(() => ({}));

      if (!res.ok || !data.success) {
        throw new Error(data.message || 'Billing save failed');
      }

      return data;
    }

    document.addEventListener('click', async function (e) {
      const btn = e.target.closest('#billSaveBtn');
      if (!btn) return;

      e.preventDefault();

      const payload = getBillingPayload();

      if (!payload.admissionId) {
        showBillingMessage('error', 'Missing Admission', 'Admission ID missing. Please close billing and open again.');
        return;
      }

      try {
  btn.disabled = true;

  await saveBillingData(payload);

        const modalEl = document.getElementById('billingModal');
        if (modalEl && typeof bootstrap !== 'undefined') {
          const modal = bootstrap.Modal.getInstance(modalEl);
          if (modal) modal.hide();
        }

        setTimeout(function () {
          showBillingMessage('success', 'Saved', 'Data has been saved.');

          if (typeof window.rebuildAdmissionFilesDropdowns === "function") {
            window.rebuildAdmissionFilesDropdowns();
          }
        }, 250);

      } catch (err) {
        console.error(err);
        showBillingMessage('error', 'Save Failed', err.message || 'Billing save failed.');
      } finally {
  btn.disabled = false;
}
    });
  })();
</script>



