<div class="container-fluid py-4 agent-page">

  <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
      <h4 class="mb-1 d-flex align-items-center">
        <span class="badge rounded-pill bg-light text-muted border me-2">
          <i class="bi bi-diagram-3-fill me-1" style="color:#7c3aed;"></i>
          Team Access
        </span>
        <span>My Sub Agents</span>
      </h4>
      <p class="text-muted small mb-0">
        This page shows only the sub agents created under your account.
      </p>
    </div>

    <div class="d-flex gap-2 align-items-center flex-wrap">
      <div class="input-group input-group-sm" style="max-width:360px;">
        <span class="input-group-text bg-white border-end-0">
          <i class="bi bi-search" style="color:#7c3aed;"></i>
        </span>
        <input
          id="subAgentSearch"
          type="text"
          class="form-control border-start-0"
          placeholder="Search name, email, id, assigned admin..."
          autocomplete="off">
        <button class="btn btn-outline-secondary" type="button" id="subAgentSearchClear">
          Clear
        </button>
      </div>

      <% if (canCreateUsers) { %>
        <a href="/dashboard/agent/agents/new" class="btn btn-sm btn-agent rounded-pill px-3 shadow-sm">
          <i class="bi bi-person-plus me-1"></i>
          Create Sub Agent
        </a>
      <% } else { %>
        <button class="btn btn-sm btn-agent rounded-pill px-3" disabled>
          <i class="bi bi-person-plus me-1"></i>
          Create Sub Agent
        </button>
      <% } %>
    </div>
  </div>

  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body">
      <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
        <div class="d-flex flex-wrap gap-2">
          <span class="btn btn-sm rounded-pill px-3 agent-purple-active">
            <i class="bi bi-people me-1"></i> My Sub Agents
          </span>
        </div>

        <div class="small text-muted">
          Manager: <strong><%= managerName %></strong>
        </div>
      </div>

      <div class="row g-3 small">
        <div class="col-md-4">
          <div class="card border-0 shadow-sm h-100 rounded-3">
            <div class="card-body py-2 d-flex align-items-center justify-content-between">
              <div>
                <div class="text-muted">Total sub agents</div>
                <div class="h5 mb-0"><%= total %></div>
              </div>
              <span class="badge rounded-pill agent-total-badge">
  <i class="bi bi-people me-1"></i>Total
</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <% if (total === 0) { %>
    <div class="empty-box">
      <i class="bi bi-inboxes-fill"></i>
      <div class="fw-semibold mb-1">No sub agents found</div>
      <div class="small">You have not created any sub agents yet.</div>
    </div>
  <% } else { %>

    <div class="cards-wrap">
      <div class="row g-3" id="subAgentCards">
        <% myList.forEach((sa, index) => {
          let p = sa.permissions || {};
          try { if (typeof p === 'string') p = JSON.parse(p); } catch (e) { p = {}; }

          const isColOn = (key, legacy) => {
            if (typeof p[key] !== 'undefined') return !!p[key];
            if (legacy && typeof p[legacy] !== 'undefined') return !!p[legacy];
            return false;
          };

          const isBtnOn = (key) => !!p[key];
          const canDeleteAdmissions = !!p.canDeleteAdmissions;

          const assignedAdminDisplay =
            sa.assignedAdminName ||
            sa.assigned_admin_name ||
            sa.assignedAdmin ||
            sa.assigned_admin ||
            (Number(sa.assigned_admin_id || 0) === Number(user.assigned_admin_id || 0) ? 'Assigned Admin' : '') ||
            (sa.assigned_admin_id ? ('Admin ID #' + sa.assigned_admin_id) : 'Your Admin Team');

          const createdByDisplay =
            sa.createdByName ||
            sa.created_by_name ||
            sa.createdBy ||
            sa.created_by_user ||
            (Number(sa.created_by || 0) === Number(user.id || 0) ? 'You' : '') ||
            (sa.created_by ? ('User ID #' + sa.created_by) : '—');

          const accessScopeLabel =
            String(sa.access_scope || '').trim() === 'all' ? 'All Admissions' :
            String(sa.access_scope || '').trim() === 'team' ? 'Team Admissions' :
            String(sa.access_scope || '').trim() === 'department' ? 'Department Admissions' :
            String(sa.access_scope || '').trim() === 'own' ? 'Own Admissions' :
            'Own Admissions';

          const enabledCols = ALL_COLS.reduce((acc, c) => acc + (isColOn(c.key, c.legacy) ? 1 : 0), 0);
          const totalCols = ALL_COLS.length;
          const typeValue = String(sa.agentType || '').toLowerCase() || 'unknown';
          const firstLetter = (sa.name && String(sa.name).trim()) ? String(sa.name).trim().charAt(0).toUpperCase() : '#';
        %>

          <div
            class="col-lg-4 col-md-6 user-item"
            data-type="<%= typeValue %>"
            data-search="<%= [
              sa.name || '',
              sa.email || '',
              sa.dept || '',
              sa.role || '',
              sa.agentType || '',
              sa.id || '',
              sa.lastUpdatedBy || '',
              sa.assignedAdminName || '',
              sa.assigned_admin_name || '',
              sa.assigned_admin_id || '',
              sa.access_scope || '',
              sa.createdByName || '',
              sa.created_by_name || '',
              sa.created_by || ''
            ].join(' ').toLowerCase() %>">

            <div class="card border-0 shadow-sm h-100 rounded-4 position-relative agent-user-card" style="overflow:hidden;">
              <div class="position-absolute top-0 start-0 w-100"
                   style="height:4px; background:linear-gradient(90deg,#7c3aed,#a855f7,#7c3aed); opacity:0.85;"></div>

              <div class="card-body d-flex flex-column pt-3">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <div class="d-flex align-items-center gap-2">
                    <div class="rounded-circle d-flex align-items-center justify-content-center fw-semibold agent-avatar"
                         style="width:36px;height:36px;">
                      <%= firstLetter %>
                    </div>

                    <div>
                      <div class="fw-semibold d-flex align-items-center gap-2">
                        <span><%= sa.name || 'Unnamed User' %></span>
                      </div>
                      <div class="small text-muted"><%= sa.email || '-' %></div>
                    </div>
                  </div>

                  <span class="badge rounded-pill px-3 agent-role-badge">
                    <i class="bi bi-shield-check me-1"></i>
                    Sub Agent
                  </span>
                </div>

                <div class="small mb-2">
                  <div class="mb-1">
                    <span class="text-muted">Dept:</span>
                    <span class="badge rounded-pill bg-light text-dark border text-capitalize ms-1">
                      <%= formatDeptLabel(sa.dept) %>
                    </span>
                  </div>

                  <div class="mb-1">
                    <span class="text-muted">Type:</span>
                    <span class="badge rounded-pill bg-light text-dark border text-capitalize ms-1">
                      <%= sa.agentType || '-' %>
                    </span>
                  </div>

                                    <div class="d-flex flex-wrap gap-2 align-items-center">
                    <span class="text-muted">ID:</span>
                    <span class="badge rounded-pill bg-light text-dark border">#<%= sa.id %></span>

                    <span class="badge rounded-pill bg-light text-dark border">
                      <i class="bi bi-diagram-3 me-1" style="color:#7c3aed;"></i>
                      Assigned: <strong><%= assignedAdminDisplay %></strong>
                    </span>

                    <span class="badge rounded-pill bg-light text-dark border">
                      <i class="bi bi-shield-check me-1" style="color:#2563eb;"></i>
                      Scope: <strong><%= accessScopeLabel %></strong>
                    </span>

                    <span class="badge rounded-pill bg-light text-dark border">
                      <i class="bi bi-person-plus me-1" style="color:#7c3aed;"></i>
                      Created By: <strong><%= createdByDisplay %></strong>
                    </span>
                  </div>
                </div>

                <div class="small mb-3">
                  <div class="text-muted mb-1">Access summary</div>

                  <div class="d-flex flex-wrap gap-1">
                    <span class="badge rounded-pill bg-light text-dark border">
                      <i class="bi bi-table me-1"></i>
                      Columns: <strong><%= enabledCols %>/<%= totalCols %></strong>
                    </span>

                    <span class="badge rounded-pill <%= isBtnOn('btnDetails') ? 'bg-primary-subtle text-primary' : 'bg-light text-muted border' %>">
                      <i class="bi bi-eye me-1"></i>Details
                    </span>

                    <span class="badge rounded-pill <%= isBtnOn('btnUpdateRow') ? 'bg-primary-subtle text-primary' : 'bg-light text-muted border' %>">
                      <i class="bi bi-check2-circle me-1"></i>Update
                    </span>

                    <span class="badge rounded-pill <%= isBtnOn('btnPdf') ? 'bg-primary-subtle text-primary' : 'bg-light text-muted border' %>">
                      <i class="bi bi-filetype-pdf me-1"></i>PDF
                    </span>

                    <span class="badge rounded-pill <%= isBtnOn('btnBilling') ? 'bg-primary-subtle text-primary' : 'bg-light text-muted border' %>">
                      <i class="bi bi-receipt me-1"></i>Billing
                    </span>

                    <span class="badge rounded-pill <%= isBtnOn('btnWhatsApp') ? 'bg-primary-subtle text-primary' : 'bg-light text-muted border' %>">
                      <i class="bi bi-whatsapp me-1"></i>WhatsApp
                    </span>

                    <span class="badge rounded-pill <%= isBtnOn('btnUpload') ? 'bg-primary-subtle text-primary' : 'bg-light text-muted border' %>">
                      <i class="bi bi-cloud-upload me-1"></i>Upload
                    </span>

                    <span class="badge rounded-pill <%= isBtnOn('btnFiles') ? 'bg-primary-subtle text-primary' : 'bg-light text-muted border' %>">
                      <i class="bi bi-folder2-open me-1"></i>Files
                    </span>

                    <span class="badge rounded-pill <%= canDeleteAdmissions ? 'bg-danger-subtle text-danger' : 'bg-light text-muted border' %>">
                      <i class="bi bi-trash3 me-1"></i>Delete Admissions
                    </span>
                  </div>

                  <% if (sa.lastUpdatedBy) { %>
                    <div class="text-muted mt-2" style="font-size:.78rem;">
                      Last updated by: <strong class="text-dark"><%= sa.lastUpdatedBy %></strong>
                      <% if (sa.lastUpdatedByRole) { %>
                        <span class="text-muted">(<%= String(sa.lastUpdatedByRole).replace(/_/g, ' ') %>)</span>
                      <% } %>
                    </div>
                  <% } %>
                </div>

                <% if (showActions) { %>
                  <div class="mt-auto d-flex justify-content-between align-items-center pt-2 border-top">
                    <% if (showEdit) { %>
                      <a href="/dashboard/agent/users/<%= sa.id %>/edit"
                         class="btn btn-sm btn-agent-outline rounded-pill px-3">
                        <i class="bi bi-pencil-square me-1"></i>
                        Edit
                      </a>
                    <% } else { %>
                      <span class="small text-muted">No edit permission</span>
                    <% } %>

                    <% if (showDelete) { %>
                      <form method="POST"
                            action="/dashboard/agent/users/<%= sa.id %>/delete"
                            class="js-delete-user-form">
                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                          <i class="bi bi-trash3 me-1"></i>
                          Delete
                        </button>
                      </form>
                    <% } %>
                  </div>
                <% } %>

              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

    <div class="empty-box d-none" id="noSearchResults">
      <i class="bi bi-search"></i>
      <div class="fw-semibold mb-1">No matching users found</div>
      <div class="small">Try another name, email, or id.</div>
    </div>

  <% } %>
</div>
<script>
  (function () {
    const searchInput = document.getElementById('subAgentSearch');
    const clearBtn = document.getElementById('subAgentSearchClear');
    const cards = document.querySelectorAll('.user-item');
    const emptyState = document.getElementById('noSearchResults');

    if (!searchInput || !cards.length) return;

    function runSearch() {
      const query = (searchInput.value || '').trim().toLowerCase();
      let visibleCount = 0;

      cards.forEach((card) => {
        const haystack = (card.getAttribute('data-search') || '').toLowerCase();
        const match = !query || haystack.includes(query);

        card.classList.toggle('d-none', !match);
        if (match) visibleCount += 1;
      });

      if (emptyState) {
        emptyState.classList.toggle('d-none', visibleCount !== 0);
      }
    }

    searchInput.addEventListener('input', runSearch);

    if (clearBtn) {
      clearBtn.addEventListener('click', function () {
        searchInput.value = '';
        runSearch();
        searchInput.focus();
      });
    }
  })();
</script>
<%- include('partials/bootstrap-footer') %>

<div id="deleteConfirmOverlay"
     class="position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center d-none"
     style="background:rgba(15,23,42,0.35); z-index:1080;">

  <div class="card border-0 shadow-lg rounded-4"
       style="width:min(92vw, 430px); animation:flashScaleIn 220ms ease-out;">
    <div class="card-body p-4 text-center">

      <div class="mb-3">
        <div class="mx-auto d-flex align-items-center justify-content-center rounded-circle"
             style="width:56px;height:56px;background:#fee2e2;color:#dc2626;">
          <i class="bi bi-trash3-fill fs-4"></i>
        </div>
      </div>

      <h4 class="mb-2 fw-semibold">Confirm Delete</h4>
      <p class="text-muted mb-4 small" id="deleteConfirmText">
        Delete this sub agent? This action cannot be undone.
      </p>

      <div class="d-flex justify-content-center gap-2">
        <button type="button"
                class="btn btn-light rounded-pill px-4"
                id="deleteConfirmCancelBtn">
          Cancel
        </button>

        <button type="button"
                class="btn btn-danger rounded-pill px-4"
                id="deleteConfirmOkBtn">
          Delete
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const overlay = document.getElementById("deleteConfirmOverlay");
    const okBtn = document.getElementById("deleteConfirmOkBtn");
    const cancelBtn = document.getElementById("deleteConfirmCancelBtn");
    const textEl = document.getElementById("deleteConfirmText");

    if (!overlay || !okBtn || !cancelBtn) return;

    let pendingForm = null;

    function openDeletePopup(form) {
      pendingForm = form;
      if (textEl) {
        textEl.textContent = "Delete this sub agent? This action cannot be undone.";
      }
      overlay.classList.remove("d-none");
      overlay.setAttribute("aria-hidden", "false");
    }

    function closeDeletePopup() {
      overlay.classList.add("d-none");
      overlay.setAttribute("aria-hidden", "true");
      pendingForm = null;
    }

    document.addEventListener("submit", function (e) {
      const form = e.target.closest(".js-delete-user-form");
      if (!form) return;

      e.preventDefault();
      openDeletePopup(form);
    });

    okBtn.addEventListener("click", function () {
      if (!pendingForm) return;
      const form = pendingForm;
      closeDeletePopup();
      form.submit();
    });

    cancelBtn.addEventListener("click", closeDeletePopup);

    overlay.addEventListener("click", function (e) {
      if (e.target === overlay) {
        closeDeletePopup();
      }
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && !overlay.classList.contains("d-none")) {
        closeDeletePopup();
      }
    });
  })();
</script>