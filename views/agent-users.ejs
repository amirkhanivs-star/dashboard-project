        </div>

        <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end hero-actions">
          <span class="soft-badge">
            <i class="bi bi-buildings"></i>
            Dept: <span class="text-capitalize"><%= user.dept || 'N/A' %></span>
          </span>


          <% if (canCreateUsers) { %>
            <a href="/dashboard/agent/agents/new" class="btn btn-sm btn-agent rounded-pill px-3 shadow-sm">
              <i class="bi bi-person-plus me-1"></i>
              Create Sub Agent
            </a>
          <% } else { %>
            <button class="btn btn-sm btn-agent rounded-pill px-3" disabled>
              <i class="bi bi-person-plus me-1"></i>
              Create Sub Agent
            </button>
          <% } %>
        </div>
      </div>
    </div>

    <div class="search-toolbar">
  <div class="search-box">
    <i class="bi bi-search"></i>
    <input
      type="text"
      id="subAgentSearch"
      placeholder="Search name, email, or id..."
      autocomplete="off"
    >
    <button type="button" class="search-clear-btn" id="subAgentSearchClear">Clear</button>
  </div>
</div>

    <div class="stats-card mb-3" style="max-width: 260px; padding: .85rem 1rem;">
  <div class="d-flex justify-content-between align-items-center gap-2">
    <div>
      <div class="stats-label mb-1">Total sub agents</div>
      <p class="stats-value mb-0" style="font-size: 1.6rem;"><%= total %></p>
    </div>

    <span class="soft-badge">
      <i class="bi bi-people"></i>
      Total
    </span>
  </div>
</div>
    

    
    <div>
      <% if (total === 0) { %>
        <div class="empty-box">
          <i class="bi bi-inboxes-fill"></i>
          <div class="fw-semibold mb-1">No sub agents found</div>
          <div class="small">You have not created any sub agents yet.</div>
        </div>
      <% } else { %>
         <div class="cards-wrap">
  <div class="row g-3" id="subAgentCards">
    <% myList.forEach((sa, index) => { 
      let p = sa.permissions || {};
      try { if (typeof p === 'string') p = JSON.parse(p); } catch (e) { p = {}; }

      const isColOn = (key, legacy) => {
        if (typeof p[key] !== 'undefined') return !!p[key];
        if (legacy && typeof p[legacy] !== 'undefined') return !!p[legacy];
        return false;
      };

            const isBtnOn = (key) => !!p[key];
      const canDeleteAdmissions = !!p.canDeleteAdmissions;

      const enabledCols = ALL_COLS.reduce((acc, c) => acc + (isColOn(c.key, c.legacy) ? 1 : 0), 0);
      const totalCols = ALL_COLS.length;
      const typeValue = String(sa.agentType || '').toLowerCase() || 'unknown';
      const firstLetter = (sa.name && String(sa.name).trim()) ? String(sa.name).trim().charAt(0).toUpperCase() : '#';
    %>
      <div
        class="col-12 col-md-6 col-lg-4 user-item"
        data-type="<%= typeValue %>"
        data-search="<%= [
          sa.name || '',
          sa.email || '',
          sa.dept || '',
          sa.role || '',
          sa.agentType || '',
          sa.id || '',
          sa.lastUpdatedBy || ''
        ].join(' ').toLowerCase() %>"
      >
        <div class="user-card">
          <div class="user-card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <div class="d-flex align-items-center gap-2">
                <div class="avatar-circle"><%= firstLetter %></div>
                <div>
                  <p class="user-name"><%= sa.name || 'Unnamed User' %></p>
                  <div class="user-email"><%= sa.email || '-' %></div>
                </div>
              </div>

              <span class="agent-role-badge">
                <i class="bi bi-shield-check me-1"></i>
                Sub Agent
              </span>
            </div>

            <div class="meta-grid">
              <div class="meta-row">
                <span class="meta-label">Dept:</span>
                <span class="soft-tag text-capitalize"><%= sa.dept || '-' %></span>
              </div>

              <div class="meta-row">
                <span class="meta-label">Type:</span>
                <span class="soft-tag text-capitalize"><%= sa.agentType || '-' %></span>
              </div>

              <div class="meta-row">
                <span class="meta-label">ID:</span>
                <span class="perm-chip">#<%= sa.id %></span>
              </div>
            </div>

            <div class="access-strip">
              <div class="access-title">Access summary</div>

              <div class="d-flex flex-wrap gap-1">
                <span class="badge rounded-pill bg-light text-dark border">
                  <i class="bi bi-table me-1"></i>
                  Columns: <strong><%= enabledCols %>/<%= totalCols %></strong>
                </span>

                <span class="badge rounded-pill <%= isBtnOn('btnDetails') ? 'bg-primary-subtle text-primary' : 'bg-light text-muted border' %>">
                  <i class="bi bi-eye me-1"></i>Details
                </span>

                <span class="badge rounded-pill <%= isBtnOn('btnUpdateRow') ? 'bg-primary-subtle text-primary' : 'bg-light text-muted border' %>">
                  <i class="bi bi-check2-circle me-1"></i>Update
                </span>

                <span class="badge rounded-pill <%= isBtnOn('btnPdf') ? 'bg-primary-subtle text-primary' : 'bg-light text-muted border' %>">
                  <i class="bi bi-filetype-pdf me-1"></i>PDF
                </span>

                <span class="badge rounded-pill <%= isBtnOn('btnBilling') ? 'bg-primary-subtle text-primary' : 'bg-light text-muted border' %>">
                  <i class="bi bi-receipt me-1"></i>Billing
                </span>

                <span class="badge rounded-pill <%= isBtnOn('btnWhatsApp') ? 'bg-primary-subtle text-primary' : 'bg-light text-muted border' %>">
                  <i class="bi bi-whatsapp me-1"></i>WhatsApp
                </span>

                <span class="badge rounded-pill <%= isBtnOn('btnUpload') ? 'bg-primary-subtle text-primary' : 'bg-light text-muted border' %>">
                  <i class="bi bi-cloud-upload me-1"></i>Upload
                </span>

                <span class="badge rounded-pill <%= isBtnOn('btnFiles') ? 'bg-primary-subtle text-primary' : 'bg-light text-muted border' %>">
                  <i class="bi bi-folder2-open me-1"></i>Files
                </span>

                                <span class="badge rounded-pill <%= canDeleteAdmissions ? 'bg-danger-subtle text-danger' : 'bg-light text-muted border' %>">
                  <i class="bi bi-trash3 me-1"></i>Delete Admissions
                </span>
              </div>

              <% if (sa.lastUpdatedBy) { %>
                <div class="text-muted mt-2" style="font-size:.78rem;">
                  Last updated by: <strong class="text-dark"><%= sa.lastUpdatedBy %></strong>
                  <% if (sa.lastUpdatedByRole) { %>
                    <span class="text-muted">(<%= String(sa.lastUpdatedByRole).replace(/_/g, ' ') %>)</span>
                  <% } %>
                </div>
              <% } %>
            </div>

            <div class="action-row">
              <% if (showEdit) { %>
                <a href="/dashboard/agent/users/<%= sa.id %>/edit"
                   class="btn btn-sm btn-agent-outline rounded-pill px-3">
                  <i class="bi bi-pencil-square me-1"></i>
                  Edit
                </a>
              <% } else { %>
                <span></span>
              <% } %>

             <% if (showDelete) { %>
  <form method="POST"
        action="/dashboard/agent/users/<%= sa.id %>/delete"
        class="js-delete-user-form"
        style="display:inline;">
    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
      <i class="bi bi-trash3 me-1"></i>
      Delete
    </button>
  </form>
<% } %>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <div class="empty-box d-none" id="noSearchResults">
    <i class="bi bi-search"></i>
    <div class="fw-semibold mb-1">No matching users found</div>
    <div class="small">Try another name, email, or id.</div>
  </div>
</div>
<% } %>
</div>
</div>
</div>
<script>
  (function () {
    const searchInput = document.getElementById('subAgentSearch');
    const clearBtn = document.getElementById('subAgentSearchClear');
    const cards = document.querySelectorAll('.user-item');
    const emptyState = document.getElementById('noSearchResults');

    if (!searchInput || !cards.length) return;

    function runSearch() {
      const query = (searchInput.value || '').trim().toLowerCase();
      let visibleCount = 0;

      cards.forEach((card) => {
        const haystack = (card.getAttribute('data-search') || '').toLowerCase();
        const match = !query || haystack.includes(query);

        card.classList.toggle('d-none', !match);
        if (match) visibleCount += 1;
      });

      if (emptyState) {
        emptyState.classList.toggle('d-none', visibleCount !== 0);
      }
    }

    searchInput.addEventListener('input', runSearch);

    if (clearBtn) {
      clearBtn.addEventListener('click', function () {
        searchInput.value = '';
        runSearch();
        searchInput.focus();
      });
    }
  })();
</script>
<%- include('partials/bootstrap-footer') %>

<div id="deleteConfirmOverlay"
     class="position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center d-none"
     style="background:rgba(15,23,42,0.35); z-index:1080;">

  <div class="card border-0 shadow-lg rounded-4"
       style="width:min(92vw, 430px); animation:flashScaleIn 220ms ease-out;">
    <div class="card-body p-4 text-center">

      <div class="mb-3">
        <div class="mx-auto d-flex align-items-center justify-content-center rounded-circle"
             style="width:56px;height:56px;background:#fee2e2;color:#dc2626;">
          <i class="bi bi-trash3-fill fs-4"></i>
        </div>
      </div>

      <h4 class="mb-2 fw-semibold">Confirm Delete</h4>
      <p class="text-muted mb-4 small" id="deleteConfirmText">
        Delete this sub agent? This action cannot be undone.
      </p>

      <div class="d-flex justify-content-center gap-2">
        <button type="button"
                class="btn btn-light rounded-pill px-4"
                id="deleteConfirmCancelBtn">
          Cancel
        </button>

        <button type="button"
                class="btn btn-danger rounded-pill px-4"
                id="deleteConfirmOkBtn">
          Delete
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const overlay = document.getElementById("deleteConfirmOverlay");
    const okBtn = document.getElementById("deleteConfirmOkBtn");
    const cancelBtn = document.getElementById("deleteConfirmCancelBtn");
    const textEl = document.getElementById("deleteConfirmText");

    if (!overlay || !okBtn || !cancelBtn) return;

    let pendingForm = null;

    function openDeletePopup(form) {
      pendingForm = form;
      if (textEl) {
        textEl.textContent = "Delete this sub agent? This action cannot be undone.";
      }
      overlay.classList.remove("d-none");
      overlay.setAttribute("aria-hidden", "false");
    }

    function closeDeletePopup() {
      overlay.classList.add("d-none");
      overlay.setAttribute("aria-hidden", "true");
      pendingForm = null;
    }

    document.addEventListener("submit", function (e) {
      const form = e.target.closest(".js-delete-user-form");
      if (!form) return;

      e.preventDefault();
      openDeletePopup(form);
    });

    okBtn.addEventListener("click", function () {
      if (!pendingForm) return;
      const form = pendingForm;
      closeDeletePopup();
      form.submit();
    });

    cancelBtn.addEventListener("click", closeDeletePopup);

    overlay.addEventListener("click", function (e) {
      if (e.target === overlay) {
        closeDeletePopup();
      }
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && !overlay.classList.contains("d-none")) {
        closeDeletePopup();
      }
    });
  })();
</script>