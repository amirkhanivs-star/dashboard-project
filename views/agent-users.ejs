}

.agent-page .search-clear-btn {
  border: 0;
  border-left: 1px solid rgba(15, 23, 42, 0.12);
  background: #f8fafc;
  color: #475569;
  padding: .7rem .9rem;
  font-size: .88rem;
}

.agent-page .search-clear-btn:hover {
