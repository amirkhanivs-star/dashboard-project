<div class="container-fluid py-4 agent-page">
  <div class="page-shell">

    <div class="hero-card">
      <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
          <div class="d-inline-flex align-items-center gap-2 mb-2">
