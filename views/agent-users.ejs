}

@media (max-width: 767.98px) {
  .agent-page .search-toolbar {
    justify-content: stretch;
  }

  .agent-page .search-box {
    min-width: 100%;
    max-width: 100%;
  }
}

  .agent-page .cards-wrap {
  padding: 0;
}

.agent-page .user-card {
  height: 100%;
  padding: 0;
  overflow: hidden;
  transition: transform .15s ease, box-shadow .15s ease;
  border-top: 4px solid var(--agent-primary);
}

  .agent-page .user-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--agent-card-shadow-hover);
  }

 .agent-page .user-card-body {
  padding: 1rem;
  padding-top: 1rem;
}

.agent-page .avatar-circle {
  width: 36px;
  height: 36px;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 1rem;
  color: #ffffff;
  background: linear-gradient(135deg, #60a5fa 0%, #2563eb 100%);
  box-shadow: inset 0 0 0 1px rgba(15, 23, 42, 0.06);
  flex-shrink: 0;
}

  .agent-page .user-name {
    font-weight: 800;
    font-size: 1.03rem;
    margin: 0;
    line-height: 1.2;
  }

  .agent-page .user-email {
    color: var(--agent-text-muted);
    font-size: .9rem;
  }

.agent-page .agent-role-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: .22rem;
  border-radius: 999px;
  padding: .35em .9em;
  font-size: .75rem;
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
  border: 1px solid rgba(59, 130, 246, 0.26);
  background: rgba(59, 130, 246, 0.10);
  color: #2563eb;
  box-shadow: 0 4px 12px rgba(59, 130, 246, 0.08);
}
.agent-page .agent-role-badge i{
  font-size: .72rem;
  line-height: 1;
  color: #2563eb;
}

 .agent-page .meta-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: .55rem;
  margin-top: 1rem;
  margin-bottom: 1rem;
}

  .agent-page .meta-row {
    display: flex;
    gap: .45rem;
    flex-wrap: wrap;
    align-items: center;
    font-size: .88rem;
  }

  .agent-page .meta-label {
    color: var(--agent-text-muted);
    min-width: 64px;
  }

  .agent-page .soft-tag {
    border-radius: 999px;
    background: #f8fafc;
    border: 1px solid rgba(15, 23, 42, 0.08);
    padding: .18rem .48rem;
    font-size: .72rem;
    font-weight: 700;
    color: #0f172a;
    display: inline-flex;
    align-items: center;
    gap: .25rem;
  }

 .agent-page .perm-chip {
  border-radius: 999px;
  padding: .22rem .58rem;
  font-size: .72rem;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  gap: .25rem;
  border: 1px solid transparent;
  line-height: 1.1;
}

.agent-page .perm-columns {
  background: #f3f4f6;
  border-color: #e5e7eb;
  color: #111827;
}

.agent-page .perm-details,
.agent-page .perm-update,
.agent-page .perm-pdf,
.agent-page .perm-billing,
.agent-page .perm-whatsapp,
.agent-page .perm-upload,
.agent-page .perm-files {
  background: #dbeafe;
  border-color: #bfdbfe;
  color: #2563eb;
}

  .agent-page .access-strip {
    margin-top: .9rem;
  }

  .agent-page .access-title {
    font-size: .86rem;
    color: var(--agent-text-muted);
    margin-bottom: .35rem;
  }

.agent-page .action-row {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
  align-items: center;
  padding-top: 1rem;
  border-top: 1px solid rgba(15, 23, 42, 0.08);
  margin-top: 1rem;
}


  .agent-page .empty-box {
    padding: 2.5rem 1rem;
    text-align: center;
    color: var(--agent-text-muted);
  }

  .agent-page .empty-box i {
    font-size: 2rem;
    color: var(--agent-primary);
    display: inline-block;
    margin-bottom: .6rem;
  }

  @media (max-width: 767.98px) {
    .agent-page .hero-actions {
      width: 100%;
    }

    .agent-page .hero-actions .btn,
    .agent-page .hero-actions .soft-badge {
      width: 100%;
      justify-content: center;
    }

    .agent-page .action-row {
      flex-direction: column;
      align-items: stretch;
    }

    .agent-page .action-row > * {
      width: 100%;
    }

    .agent-page .action-row .btn,
    .agent-page .action-row form button {
      width: 100%;
    }
  }

  @keyframes flashScaleIn {
  from {
    opacity: 0;
    transform: scale(.94);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}
