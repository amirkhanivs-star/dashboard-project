<%- include('partials/bootstrap-header', { user, pageTitle: 'My Sub Agents' }) %>
<%- include('partials/flash') %>

<%
  const myList = mySubAgents || [];
  const total = myList.length;

  const cap = (txt) => (txt ? txt.charAt(0).toUpperCase() + txt.slice(1) : '-');
  const deptLabel =
  String(user.dept || '').trim().toLowerCase() === 'accounts'
    ? 'School Accounts'
    : cap(user.dept || 'Department');

const formatDeptLabel = (dept) => {
  return String(dept || '').trim().toLowerCase() === 'accounts'
    ? 'School Accounts'
    : (dept || '-');
};
  const managerName = user.name || 'Manager';
  const ALL_COLS = [
  { key: 'colStatus' },
  { key: 'colFeeStatus' },
  { key: 'colDept' },
  { key: 'colStudentName' },
  { key: 'colFatherName' },
  { key: 'colFatherEmail' },
  { key: 'colGrade' },
  { key: 'colTuitionGrade' },
  { key: 'colPhone' },
  { key: 'colProcessedBy' },
  { key: 'colPaymentStatus' },
  { key: 'colPaidUpto' },
  { key: 'colVerificationNumber' },
  { key: 'colRegistrationNumber' },
  { key: 'colFamilyNumber' },
  { key: 'colRegistrationFee' },
  { key: 'colFees' },
  { key: 'colCurrency' },
  { key: 'colMonth' },
  { key: 'colTotalFees' },
  { key: 'colPendingDues' },
{ key: 'colReceivedPayment' },
{ key: 'colInvoiceStatus' },
{ key: 'colInvoiceStatusTimestamp' },
{ key: 'colPaidInvoiceStatus' },
{ key: 'colPaidInvoiceStatusTimestamp' },
];

  let permRaw = user && (user.permissions || user.perms || user.permissionMap)
    ? (user.permissions || user.perms || user.permissionMap)
    : {};
  try { if (typeof permRaw === 'string') permRaw = JSON.parse(permRaw); } catch(e) { permRaw = {}; }

  const isSuper =
    !!(user && (
      user.role === 'superadmin' ||
      user.role === 'super_admin' ||
      user.agentType === 'superadmin' ||
      user.agentType === 'super_admin' ||
      user.isSuperAdmin === true ||
      user.is_super_admin === true
    ));

  function hasPerm(key, fallback = false){
    if (isSuper) return true;
    if (!permRaw) return fallback;

    if (permRaw === true) return true;

    if (Array.isArray(permRaw)) {
      return permRaw.includes(key) || permRaw.includes('*') || permRaw.includes('all');
    }

    if (typeof permRaw === 'object') {
      if (key in permRaw) return !!permRaw[key];
      return fallback;
    }

    return fallback;
  }

  const canCreateUsers = hasPerm('btnCreateUser', true) || hasPerm('canCreateUsers', true);
  const canManageUsers = hasPerm('canManageUsers', true);

  const canEditUsers   = hasPerm('btnEditUser', true)   || hasPerm('canEditUsers', true);
  const canDeleteUsers = hasPerm('btnDeleteUser', true) || hasPerm('canDeleteUsers', true);

  const showEdit = canManageUsers && canEditUsers;
  const showDelete = canManageUsers && canDeleteUsers;
  const showActions = showEdit || showDelete;

%>

<style>
  .agent-page {
    --agent-primary: #7c3aed;
    --agent-primary-dark: #5b21b6;
    --agent-soft: #f3e8ff;
    --agent-soft-2: #faf5ff;
    --agent-border: rgba(15, 23, 42, 0.08);
    --agent-text-muted: #64748b;
    --agent-card-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
    --agent-card-shadow-hover: 0 16px 38px rgba(15, 23, 42, 0.10);
  }

  .agent-page .page-shell {
    display: flex;
    flex-direction: column;
    gap: .8rem;
  }

  .agent-page .hero-card,
  .agent-page .stats-card,
  .agent-page .directory-card,
  .agent-page .user-card,
  .agent-page .toolbar-card {
    border: 0;
    border-radius: 22px;
    background: #fff;
    box-shadow: var(--agent-card-shadow);
  }

  .agent-page .hero-card {
    background:
     radial-gradient(1000px 280px at 0% 0%, rgba(124, 58, 237, 0.16) 0%, rgba(255,255,255,0) 55%),
      linear-gradient(135deg, #ffffff 0%, #faf5ff 45%, #f8fafc 100%);
    border: 1px solid var(--agent-border);
    padding: 1rem 1.15rem;
  }

  .agent-page .hero-badge,
  .agent-page .soft-badge {
    border-radius: 999px;
    border: 1px solid var(--agent-border);
    background: #fff;
    padding: .38rem .72rem;
    font-size: .78rem;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: .35rem;
  }

  .agent-page .hero-mini {
    color: var(--agent-text-muted);
    font-size: .87rem;
  }

  .agent-page .hero-title {
    margin: 0;
    font-weight: 800;
    letter-spacing: -.2px;
  }

  .agent-page .hero-subtitle {
    color: var(--agent-text-muted);
    font-size: .92rem;
    margin-top: .2rem;
  }

  .agent-page .btn-agent {
    background: linear-gradient(135deg, #7c3aed, #5b21b6);
    border-color: #5b21b6;
    color: #ffffff;
    font-weight: 700;
  }

  .agent-page .btn-agent:hover,
  .agent-page .btn-agent:focus {
    background: linear-gradient(135deg, #6d28d9, #4c1d95);
    border-color: #4c1d95;
    color: #ffffff;
  }

  .agent-page .btn-agent-outline {
    border-color: rgba(124, 58, 237, 0.45);
    color: #5b21b6;
    background: #fff;
  }

  .agent-page .btn-agent-outline:hover {
    background: var(--agent-soft);
    border-color: rgba(124, 58, 237, 0.65);
    color: #4c1d95;
  }

  .agent-page .stats-card {
    padding: 1rem 1.1rem;
  }

  .agent-page .stats-label {
    color: var(--agent-text-muted);
    font-size: .9rem;
    margin-bottom: .25rem;
  }

  .agent-page .stats-value {
    font-size: 1.9rem;
    line-height: 1;
    font-weight: 800;
    margin: 0;
  }

  .agent-page .search-toolbar {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: .6rem;
  flex-wrap: wrap;
}

.agent-page .search-box {
  display: flex;
  align-items: center;
  min-width: 320px;
  max-width: 420px;
  width: 100%;
  background: #fff;
  border: 1px solid rgba(15, 23, 42, 0.14);
  border-radius: 14px;
  overflow: hidden;
  box-shadow: var(--agent-card-shadow);
}

.agent-page .search-box i {
  padding: 0 .8rem;
  color: #7c3aed;
}

.agent-page .search-box input {
  border: 0;
  outline: 0;
  box-shadow: none;
  width: 100%;
  padding: .7rem .2rem;
