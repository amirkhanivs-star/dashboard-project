<%- include('partials/bootstrap-header', { user, pageTitle: 'System Activity History' }) %>

<%
  const f = (typeof filters !== 'undefined' && filters) ? filters : {};
  const meta = (typeof filterMeta !== 'undefined' && filterMeta) ? filterMeta : { depts: [], roles: [], events: [] };

  const logsSafe = Array.isArray(logs) ? logs : [];

  // Quick stats
  const totalCount = logsSafe.length;
  const createCount = logsSafe.filter(l => String(l.eventType || '').toLowerCase().includes('create') || String(l.eventType || '').toLowerCase().includes('created')).length;
  const updateCount = logsSafe.filter(l => String(l.eventType || '').toLowerCase().includes('update') || String(l.eventType || '').toLowerCase().includes('updated')).length;
  const deleteCount = logsSafe.filter(l => String(l.eventType || '').toLowerCase().includes('delete') || String(l.eventType || '').toLowerCase().includes('deleted')).length;

  function niceDate(rawDate) {
    if (!rawDate) return '-';
    try {
      return new Date(rawDate).toLocaleString('en-GB', {
        year: 'numeric',
        month: 'short',
        day: '2-digit',
        hour: '2-digit',
        minute: '2-digit'
      });
    } catch (e) {
      return rawDate;
    }
  }

  // ✅ Role colors (as you asked)
  // Super Admin = RED (dashboard red)
  // Admin = GREEN
  // Agent = YELLOW
  // Sub Agent = BLUE
  function roleBadgeClass(roleRaw) {
    const r = String(roleRaw || '').toLowerCase();
    if (r === 'super_admin' || r === 'superadmin') return 'role-super';
    if (r === 'admin') return 'role-admin';
    if (r === 'agent') return 'role-agent';
    if (r === 'sub_agent' || r === 'subagent') return 'role-sub';
    return 'role-neutral';
  }

  function roleLabel(roleRaw) {
    const v = String(roleRaw || '-');
    return v.replace(/_/g, ' ');
  }

  // Event badge colors
  function eventBadgeClass(eventRaw) {
    const e = String(eventRaw || '').toLowerCase();
    if (!e) return 'evt-neutral';
    if (e.includes('create') || e.includes('created')) return 'evt-create';
    if (e.includes('delete') || e.includes('deleted')) return 'evt-delete';
    if (e.includes('update') || e.includes('updated')) return 'evt-update';
    if (e.includes('upload')) return 'evt-upload';
    if (e.includes('billing') || e.includes('payment') || e.includes('invoice')) return 'evt-billing';
    if (e.includes('whatsapp') || e.includes('message')) return 'evt-wa';
    return 'evt-neutral';
  }

  function eventLabel(eventRaw) {
    return String(eventRaw || '-').replace(/_/g, ' ');
  }

  function parseDetails(detailsStr) {
    let parsed = null;
    try { parsed = JSON.parse(detailsStr); } catch (e) {}
    return parsed;
  }

  function buildSummaryFromDetails(parsed) {
    const root = parsed && (parsed.details || parsed);
    const before = root && root.before ? root.before : null;
    const after = root && root.after ? root.after : null;
    const admissionId = root && (root.admissionId || root.admission_id || root.admission) ? (root.admissionId || root.admission_id || root.admission) : null;

    let changedFields = [];
    if (before && after) {
      try {
        Object.keys(before).forEach(function(k) {
          const b = before[k];
          const a = after[k];
          if (JSON.stringify(b) !== JSON.stringify(a)) changedFields.push(k);
        });
        Object.keys(after).forEach(function(k) {
          if (typeof before[k] === 'undefined' && changedFields.indexOf(k) === -1) changedFields.push(k);
        });
      } catch (e) {}
    }

    return { before, after, admissionId, changedFields };
  }
%>

<style>
  html, body { overflow-x: hidden; }
  .hist-shell{ padding: 14px 14px 22px; }

  /* HERO */
  .hist-hero{
    border-radius: 18px;
    border: 1px solid rgba(148,163,184,.35);
    background:
      radial-gradient(1100px 340px at 12% 12%, rgba(56,189,248,.16), transparent 55%),
      radial-gradient(900px 300px at 88% 20%, rgba(99,102,241,.14), transparent 55%),
      linear-gradient(135deg, rgba(255,255,255,0.98), rgba(248,250,252,0.96));
    padding: 16px;
    box-shadow: 0 10px 28px rgba(2,8,23,.06);
  }

  .hist-chip{
    border-radius: 999px;
    border: 1px solid rgba(15,23,42,.10);
    background: rgba(248,250,252,.95);
    color: rgba(15,23,42,.72);
    font-weight: 700;
    padding: 6px 10px;
    display:inline-flex;
    align-items:center;
    gap:6px;
    font-size: 12px;
  }

  .hist-chip strong{ color: rgba(15,23,42,.88); }

  /* FILTER CARD */
  .hist-filters{
    border-radius: 18px;
    border: 1px solid rgba(148,163,184,.35);
    background:
      radial-gradient(900px 240px at 10% 0%, rgba(34,197,94,.10), transparent 55%),
      radial-gradient(900px 240px at 90% 0%, rgba(59,130,246,.10), transparent 55%),
      #ffffff;
    box-shadow: 0 10px 20px rgba(2,8,23,.06);
  }

  .hist-input, .hist-select{
    border-radius: 12px !important;
    border: 1px solid rgba(15,23,42,.14) !important;
    background: rgba(248,250,252,.92) !important;
  }
  .hist-input:focus, .hist-select:focus{
    border-color: rgba(59,130,246,.75) !important;
    box-shadow: 0 0 0 4px rgba(59,130,246,.16) !important;
    background: #fff !important;
  }

  /* Apply/Reset (fixed look & behavior) */
  .btn-pill{ border-radius: 999px !important; padding: 8px 14px !important; }
  .btn-apply{
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    border: 0 !important;
    color: #fff !important;
  }
  .btn-apply:hover{ filter: brightness(.97); }
  .btn-reset{
    border: 1px solid rgba(15,23,42,.18) !important;
    background: #fff !important;
  }

  /* TABLE CARD */
  .hist-card{
    border-radius: 18px;
    border: 1px solid rgba(15,23,42,.08);
    box-shadow: 0 10px 18px rgba(2,8,23,.06);
    overflow: hidden;
    background:#fff;
  }
  .hist-card .card-header{
    background:#fff;
    border-bottom: 1px solid rgba(15,23,42,.08);
  }

  .xsmall{ font-size: 12px; }
  .nowrap{ white-space: nowrap; }

  /* Role badges (your colors) */
  .role-badge{
    border-radius: 999px;
    padding: 6px 10px;
    font-size: 12px;
    font-weight: 800;
    display:inline-flex;
    align-items:center;
    gap:6px;
    border: 1px solid rgba(15,23,42,.10);
  }
  .role-super{ background: rgba(220,38,38,.12); color: #b91c1c; border-color: rgba(220,38,38,.25); } /* RED */
  .role-admin{ background: rgba(34,197,94,.12); color: #15803d; border-color: rgba(34,197,94,.25); }   /* GREEN */
  .role-agent{ background: rgba(245,158,11,.16); color: #92400e; border-color: rgba(245,158,11,.30); }  /* YELLOW */
  .role-sub{ background: rgba(59,130,246,.12); color: #1d4ed8; border-color: rgba(59,130,246,.25); }    /* BLUE */
  .role-neutral{ background: rgba(107,114,128,.12); color: #374151; border-color: rgba(107,114,128,.22); }

  /* Event badges */
  .evt-badge{
    border-radius: 999px;
    padding: 6px 10px;
    font-size: 12px;
    font-weight: 800;
    display:inline-flex;
    align-items:center;
    gap:6px;
    border: 1px solid rgba(15,23,42,.10);
  }
  .evt-create{ background: rgba(34,197,94,.12); color: #15803d; border-color: rgba(34,197,94,.25); }
  .evt-update{ background: rgba(245,158,11,.16); color: #92400e; border-color: rgba(245,158,11,.30); }
  .evt-delete{ background: rgba(220,38,38,.12); color: #b91c1c; border-color: rgba(220,38,38,.25); }
  .evt-upload{ background: rgba(59,130,246,.12); color: #1d4ed8; border-color: rgba(59,130,246,.25); }
  .evt-billing{ background: rgba(124,58,237,.12); color: #6d28d9; border-color: rgba(124,58,237,.25); }
  .evt-wa{ background: rgba(14,165,233,.12); color: #0369a1; border-color: rgba(14,165,233,.25); }
  .evt-neutral{ background: rgba(107,114,128,.12); color: #374151; border-color: rgba(107,114,128,.22); }

  /* Summary pills */
  .field-pill{
    border: 1px solid rgba(15,23,42,.10);
    background: rgba(248,250,252,.95);
    color: rgba(15,23,42,.78);
    border-radius: 999px;
    font-size: 12px;
    padding: 4px 10px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-right: 6px;
    margin-top: 6px;
  }

  /* Sticky header */
  .table thead th{
    position: sticky;
    top: 0;
    z-index: 2;
    background: #f8fafc !important;
  }

  .row-soft{ background: rgba(248,250,252,.55); }

  /* Details button */
  .details-btn{
    border-radius: 999px !important;
    padding: 7px 12px !important;
    border: 1px solid rgba(37,99,235,.30) !important;
    background: rgba(37,99,235,.06) !important;
    color: #1d4ed8 !important;
    font-weight: 700;
  }
  .details-btn:hover{ background: rgba(37,99,235,.10) !important; }

  /* Modal JSON */
