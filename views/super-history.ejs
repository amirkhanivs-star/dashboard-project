<%
  const f = (typeof filters !== 'undefined' && filters) ? filters : {};
  const meta = (typeof filterMeta !== 'undefined' && filterMeta) ? filterMeta : { depts: [], roles: [], events: [] };

  const logsSafe = Array.isArray(logs) ? logs : [];

  // Quick stats
  const totalCount = logsSafe.length;
    const createCount = logsSafe.filter(l => String(l.eventType || '').toLowerCase().includes('create') || String(l.eventType || '').toLowerCase().includes('created')).length;
  const updateCount = logsSafe.filter(l => String(l.eventType || '').toLowerCase().includes('update') || String(l.eventType || '').toLowerCase().includes('updated')).length;
  const deleteCount = logsSafe.filter(l => String(l.eventType || '').toLowerCase().includes('delete') || String(l.eventType || '').toLowerCase().includes('deleted')).length;
  const forwardCount = logsSafe.filter(l => String(l.eventType || '').toLowerCase().includes('forward')).length;

  function niceDate(rawDate) {
    if (!rawDate) return '-';
    try {
      return new Date(rawDate).toLocaleString('en-GB', {
        year: 'numeric',
        month: 'short',
        day: '2-digit',
        hour: '2-digit',
        minute: '2-digit'
      });
    } catch (e) {
      return rawDate;
    }
  }

  // ✅ Role colors (as you asked)
  // Super Admin = RED (dashboard red)
  // Admin = GREEN
  // Agent = PURPLE
  // Sub Agent = BLUE
  function roleBadgeClass(roleRaw) {
    const r = String(roleRaw || '').toLowerCase();
    if (r === 'super_admin' || r === 'superadmin') return 'role-super';
    if (r === 'admin') return 'role-admin';
    if (r === 'agent') return 'role-agent';
    if (r === 'sub_agent' || r === 'subagent') return 'role-sub';
    return 'role-neutral';
  }

  function roleLabel(roleRaw) {
    const v = String(roleRaw || '-');
    return v.replace(/_/g, ' ');
  }

  // Event badge colors
  function eventBadgeClass(eventRaw) {
    const e = String(eventRaw || '').toLowerCase();
    if (!e) return 'evt-neutral';
    if (e.includes('create') || e.includes('created')) return 'evt-create';
    if (e.includes('delete') || e.includes('deleted')) return 'evt-delete';
    if (e.includes('update') || e.includes('updated')) return 'evt-update';
    if (e.includes('upload')) return 'evt-upload';
    if (e.includes('forward')) return 'evt-forward';
    if (e.includes('billing') || e.includes('payment') || e.includes('invoice')) return 'evt-billing';
    if (e.includes('whatsapp') || e.includes('message')) return 'evt-wa';
    return 'evt-neutral';
  }

  function eventLabel(eventRaw) {
    return String(eventRaw || '-').replace(/_/g, ' ');
  }

  function parseDetails(detailsStr) {
    if (!detailsStr) return null;

    if (typeof detailsStr === 'object') {
      return detailsStr;
    }

    try {
      return JSON.parse(detailsStr);
    } catch (e) {
      return null;
    }
  }

  function humanizeHistoryKey(value) {
    return String(value || '')
      .replace(/([a-z0-9])([A-Z])/g, '$1 $2')
      .replace(/[_-]+/g, ' ')
      .replace(/\s+/g, ' ')
      .trim()
      .replace(/\b\w/g, function(letter) {
        return letter.toUpperCase();
      })
      .replace(/\bId\b/g, 'ID')
      .replace(/\bPdf\b/g, 'PDF')
      .replace(/\bWhatsapp\b/g, 'WhatsApp');
  }

  function historyPermissionLabel(key) {
    const cleanKey = String(key || '')
      .replace(/^permissions\./, '')
      .trim();

    if (cleanKey.indexOf('col') === 0) {
      return humanizeHistoryKey(cleanKey.slice(3)) + ' Column';
    }

    if (cleanKey.indexOf('btn') === 0) {
      return humanizeHistoryKey(cleanKey.slice(3)) + ' Button';
    }

    if (cleanKey.indexOf('can') === 0) {
      return humanizeHistoryKey(cleanKey.slice(3)) + ' Button';
    }

    return humanizeHistoryKey(cleanKey);
  }

    function historyPathLabel(pathValue) {
    const path = String(pathValue || '').trim();

    if (
      path === 'entryNumber' ||
      path === 'entry_number' ||
      path === 'admissionNumber' ||
      path === 'admission_number'
    ) {
      return 'Admission Number';
    }

    if (
      path === 'databaseAdmissionId' ||
      path === 'database_admission_id'
    ) {
      return 'Database Admission ID';
    }

    if (path.indexOf('permissions.') === 0) {
      return historyPermissionLabel(path);
    }

    const parts = path.split('.').filter(Boolean);
    const lastPart = parts.length
      ? parts[parts.length - 1]
      : path;

    const prefixMap = {
      accounts: 'Accounts',
      admissionPanel: 'Admission',
      admission: 'Admission',
      billing: 'Billing'
    };

    const prefix =
      parts.length > 1
        ? prefixMap[parts[0]]
        : '';

    const label = humanizeHistoryKey(lastPart);

    return prefix
      ? prefix + ' - ' + label
      : label;
  }

  function historyValue(value) {
    if (value === null || typeof value === 'undefined') {
      return 'Not set';
    }

    if (typeof value === 'boolean') {
      return value ? 'On' : 'Off';
    }

    if (Array.isArray(value)) {
      if (!value.length) return 'None';

      return value.map(function(item) {
        if (item && typeof item === 'object') {
          return (
            item.label ||
            item.name ||
            item.studentName ||
            item.monthLabel ||
            item.monthKey ||
            item.status ||
            'Recorded item'
          );
        }

        return String(item);
      }).join(', ');
    }

    if (typeof value === 'object') {
      const simpleParts = Object.keys(value)
        .filter(function(key) {
          const oneValue = value[key];
          return (
            oneValue === null ||
            typeof oneValue === 'undefined' ||
            typeof oneValue === 'string' ||
            typeof oneValue === 'number' ||
            typeof oneValue === 'boolean'
          );
        })
        .slice(0, 6)
        .map(function(key) {
          return humanizeHistoryKey(key) + ': ' + historyValue(value[key]);
        });

      return simpleParts.length ? simpleParts.join(' · ') : 'Recorded';
    }

    const finalValue = String(value).trim();
    return finalValue || 'Not set';
  }

  function shortHistoryValue(value, maxLength) {
    const text = historyValue(value);
    const limit = Number(maxLength || 90);

    return text.length > limit
      ? text.slice(0, limit - 1) + '…'
      : text;
  }

  function flattenHistoryObject(value, prefix, output) {
    const result = output || {};
    const cleanPrefix = prefix || '';

    if (
      value &&
      typeof value === 'object' &&
      !Array.isArray(value)
    ) {
      Object.keys(value).forEach(function(key) {
        const nextPath = cleanPrefix ? cleanPrefix + '.' + key : key;
        flattenHistoryObject(value[key], nextPath, result);
      });

      return result;
    }

    result[cleanPrefix] = value;
    return result;
  }

  function buildLegacyChanges(before, after) {
    if (!before || !after) return [];

    const beforeFlat = flattenHistoryObject(before);
    const afterFlat = flattenHistoryObject(after);
    const allKeys = Array.from(
      new Set(
        Object.keys(beforeFlat).concat(Object.keys(afterFlat))
      )
    );

    const ignoredKeys = new Set([
      'id',
      'entryNumber',
      'entry_number',
      'lastActivityAt',
      'last_activity_at',
      'statusMeta.key',
      'statusMeta.label',
      'statusMeta.color',
      'feeStatusMeta.key',
      'feeStatusMeta.label',
      'feeStatusMeta.color'
    ]);

    return allKeys
      .filter(function(key) {
        if (!key || ignoredKeys.has(key)) return false;

        return (
          JSON.stringify(beforeFlat[key] ?? '') !==
          JSON.stringify(afterFlat[key] ?? '')
        );
      })
      .map(function(key) {
        return {
          key,
          label: historyPathLabel(key),
          category: 'legacy',
          before: historyValue(beforeFlat[key]),
          after: historyValue(afterFlat[key])
        };
      });
  }

  function buildDetailRows(root) {
    if (!root || typeof root !== 'object') return [];

    const hasPermanentAdmissionNumber = !!(
      root.entryNumber ||
      root.entry_number ||
      root.admissionNumber ||
      root.admission_number
    );

    const hiddenKeys = new Set([
      'changes',
      'before',
      'after',
      'permissions',
      'billing',
      'calc',
      'pipeline',
      'admission',

      // Internal database ID Super Admin ko display nahi karni.
      'databaseAdmissionId',
      'database_admission_id'
    ]);

    const priorityKeys = [
      'action',

      // Permanent card number sab se pehle show hoga.
      'entryNumber',
      'entry_number',
      'admissionNumber',
      'admission_number',

      'studentName',
      'userName',
      'role',
      'dept',
      'agentType',
      'billingYear',
      'monthKey',
      'status',
      'displayText',
      'processedBy',
      'forwardedToDepartment',
      'forwardedByName',
      'forwardedOwnerUserName',
      'collectionAccount',
      'receivingDate',
      'receiveAmount',
      'appliedAmount',
      'remainingAmount',
      'note',

      // Sirf old records ke fallback ke liye.
      'admissionId',
      'admission_id'
    ];

    const keys = Object.keys(root)
      .filter(function(key) {
        if (hiddenKeys.has(key)) {
          return false;
        }

        // New record mein permanent number available ho to
        // old/internal admissionId display nahi karni.
        if (
          hasPermanentAdmissionNumber &&
          (
            key === 'admissionId' ||
            key === 'admission_id'
          )
        ) {
          return false;
        }

        return true;
      })
      .sort(function(a, b) {
        const ai = priorityKeys.indexOf(a);
        const bi = priorityKeys.indexOf(b);

        if (ai === -1 && bi === -1) {
          return a.localeCompare(b);
        }

        if (ai === -1) return 1;
        if (bi === -1) return -1;

        return ai - bi;
      });

    return keys
      .map(function(key) {
        return {
          key,
          label: historyPathLabel(key),
          value: historyValue(root[key])
        };
      })
      .filter(function(item) {
        return item.value !== 'Not set';
      });
  }

  function buildSummaryFromDetails(parsed) {
    const root =
      parsed && typeof parsed === 'object'
        ? (parsed.details || parsed)
        : {};

    const before =
      root && root.before
        ? root.before
        : null;

    const after =
      root && root.after
        ? root.after
        : null;

    const directChanges = Array.isArray(root.changes)
      ? root.changes
      : [];

    const changes = (
      directChanges.length
        ? directChanges
        : buildLegacyChanges(before, after)
    ).map(function(change) {
      return {
        key: change.key || '',

        label:
          change.label ||
          historyPathLabel(
            change.key || 'Changed field'
          ),

        category: change.category || 'data',
        before: historyValue(change.before),
        after: historyValue(change.after)
      };
    });

    // Dashboard card wala permanent NO.
    const admissionNumber =
      root && (
        root.entryNumber ||
        root.entry_number ||
        root.admissionNumber ||
        root.admission_number
      )
        ? (
            root.entryNumber ||
            root.entry_number ||
            root.admissionNumber ||
            root.admission_number
          )
        : null;

    // Internal DB ID sirf technical fallback ke liye rakhen.
    // Isko page par display nahi karenge.
    const databaseAdmissionId =
      root && (
        root.databaseAdmissionId ||
        root.database_admission_id ||
        root.admissionId ||
        root.admission_id
      )
        ? (
            root.databaseAdmissionId ||
            root.database_admission_id ||
            root.admissionId ||
            root.admission_id
          )
        : null;

    return {
      admissionNumber,
      databaseAdmissionId,
      changes,

      detailRows: buildDetailRows(root),

      displayText:
        root && root.displayText
          ? String(root.displayText || '').trim()
          : '',

      studentName:
        root && root.studentName
          ? String(root.studentName || '').trim()
          : '',

      processedBy:
        root && root.processedBy
          ? String(root.processedBy || '').trim()
          : '',

      forwardedToDepartment:
        root && root.forwardedToDepartment
          ? String(
              root.forwardedToDepartment || ''
            ).trim()
          : '',

      forwardedByName:
        root && root.forwardedByName
          ? String(root.forwardedByName || '').trim()
          : '',

      forwardedOwnerUserName:
        root && root.forwardedOwnerUserName
          ? String(
              root.forwardedOwnerUserName || ''
            ).trim()
          : ''
    };
  }

