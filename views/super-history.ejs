    background:#fff;
  }

  .history-info-row{
    display:grid;
    grid-template-columns:minmax(150px,.8fr) minmax(180px,1.5fr);
    gap:12px;
    padding:10px 12px;
    border-bottom:1px solid #f1f5f9;
  }

  .history-info-row:last-child{
    border-bottom:0;
  }

  .history-info-label{
    color:#64748b;
    font-size:12px;
    font-weight:800;
  }

  .history-info-value{
    color:#0f172a;
    font-size:13px;
    font-weight:700;
    white-space:pre-wrap;
    word-break:break-word;
  }

  .history-empty{
    border:1px dashed #cbd5e1;
    border-radius:12px;
    background:#f8fafc;
    color:#64748b;
    padding:18px;
    text-align:center;
    font-size:13px;
  }

  @media (max-width: 767px){
    .history-change-values{
      grid-template-columns:1fr;
    }

    .history-change-arrow{
      min-height:30px;
      transform:rotate(90deg);
      border:0;
      border-top:1px solid #f1f5f9;
      border-bottom:1px solid #f1f5f9;
    }

    .history-info-row{
      grid-template-columns:1fr;
      gap:4px;
    }
  }

  /* Make filters super easy */
  .help-line{
    color: rgba(15,23,42,.55);
    font-size: 12px;
    margin-top: 10px;
  }
</style>

<div class="container-fluid hist-shell">

  <!-- HERO -->
  <div class="hist-hero mb-3">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
      <div>
        <div class="d-flex align-items-center gap-2 flex-wrap mb-2">
          <span class="hist-chip">
            <i class="bi bi-clock-history"></i> System Activity History
          </span>

          <span class="hist-chip">
            <i class="bi bi-list-ul"></i> Results: <strong><%= totalCount %></strong>
          </span>

          <span class="hist-chip">
            <i class="bi bi-plus-circle"></i> Create: <strong><%= createCount %></strong>
          </span>

          <span class="hist-chip">
            <i class="bi bi-pencil-square"></i> Update: <strong><%= updateCount %></strong>
          </span>

          <span class="hist-chip">
            <i class="bi bi-trash3"></i> Delete: <strong><%= deleteCount %></strong>
          </span>

          <span class="hist-chip">
            <i class="bi bi-send-check"></i> Forward: <strong><%= forwardCount %></strong>
          </span>

          <span class="hist-chip">
            <i class="bi bi-info-circle"></i> Max: <strong>200</strong>
          </span>
        </div>

        <h4 class="mb-1 fw-bold">System Activity History</h4>
        <div class="text-muted small">
          Simple view: <strong>Who</strong> did <strong>what</strong>, <strong>when</strong>, and <strong>on which record</strong>.
        </div>
      </div>

      <div class="d-flex gap-2 flex-wrap">
        <a href="/dashboard" class="btn btn-sm btn-outline-secondary btn-pill">
          <i class="bi bi-grid-1x2 me-1"></i> Back to Dashboard
        </a>
      </div>
    </div>
  </div>

  <!-- FILTERS -->
  <form method="get" class="card hist-filters mb-3">
    <div class="card-body py-3">
      <div class="row g-2 align-items-end">
        <div class="col-6 col-md-2">
          <label class="form-label small mb-1">Department</label>
          <select name="dept" class="form-select form-select-sm hist-select">
            <option value="">All</option>
            <% (meta.depts || []).forEach(function (d) { %>
              <option value="<%= d %>" <%= (f.dept === d ? 'selected' : '') %>>
                <%= d.charAt(0).toUpperCase() + d.slice(1) %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="col-6 col-md-2">
          <label class="form-label small mb-1">Actor Role</label>
          <select name="role" class="form-select form-select-sm hist-select">
            <option value="">All</option>
            <% (meta.roles || []).forEach(function (r) { %>
              <option value="<%= r %>" <%= (f.role === r ? 'selected' : '') %>>
                <%= r.replace(/_/g, ' ') %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="col-6 col-md-2">
          <label class="form-label small mb-1">Event Type</label>
          <select name="eventType" class="form-select form-select-sm hist-select">
            <option value="">All</option>
            <% (meta.events || []).forEach(function (e) { %>
              <option value="<%= e %>" <%= (f.eventType === e ? 'selected' : '') %>>
                <%= e %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="col-6 col-md-4">
          <label class="form-label small mb-1">Search</label>
          <input
            type="text"
            name="q"
            value="<%= f.q || '' %>"
            class="form-control form-control-sm hist-input"
            placeholder="Type: admission id, student, actor, event..."
          />
        </div>

        <div class="col-6 col-md-1">
          <label class="form-label small mb-1">From</label>
          <input type="date" name="from" value="<%= f.from || '' %>" class="form-control form-control-sm hist-input" />
        </div>

        <div class="col-6 col-md-1">
          <label class="form-label small mb-1">To</label>
          <input type="date" name="to" value="<%= f.to || '' %>" class="form-control form-control-sm hist-input" />
        </div>

        <div class="col-12 d-flex justify-content-end gap-2 mt-2">
          <button type="submit" class="btn btn-sm btn-apply btn-pill">
            <i class="bi bi-funnel me-1"></i> Apply
          </button>

          <a href="/dashboard/super/history" class="btn btn-sm btn-reset btn-pill">
            <i class="bi bi-arrow-counterclockwise me-1"></i> Reset
          </a>
        </div>

        <div class="col-12 help-line">
          Tip: Filters optional hain. Sirf search me “Aamir”, “Admission 47”, “billing”, “file”, etc likhen aur Apply.
        </div>
      </div>
    </div>
  </form>

  <!-- TABLE -->
  <div class="card hist-card">
    <div class="card-header d-flex justify-content-between align-items-center">
      <div class="fw-semibold">Activity Timeline</div>
      <span class="text-muted small">Most recent on top</span>
    </div>

    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-sm table-hover mb-0 align-middle">
          <thead class="table-light">
            <tr>
              <th style="min-width:170px;">Date &amp; Time</th>
              <th style="min-width:200px;">Who</th>
              <th style="min-width:120px;">Dept</th>
              <th style="min-width:190px;">What</th>
              <th style="min-width:220px;">Target</th>
              <th style="min-width:420px;">Quick Summary</th>
              <th class="text-end" style="min-width:120px;">Details</th>
            </tr>
          </thead>

          <tbody>
            <% if (!logsSafe || logsSafe.length === 0) { %>
              <tr>
                <td colspan="7" class="text-center text-muted small py-4">
                  No activity recorded yet.
                </td>
              </tr>
            <% } %>

            <% logsSafe.forEach(function(log, idx) { %>
              <%
                const rawDate = log.createdAt || log.created_at;
                const dt = niceDate(rawDate);

                const actorName = log.actorName || '-';
                const actorRoleRaw = log.actorRole || '-';
                const dept = log.dept || log.actorDept || '-';
                const eventRaw = log.eventType || '';
                const targetName = log.targetUserName || log.targetAdmissionName || log.target || '-';
                const targetId = log.targetUserId || log.targetAdmissionId || log.targetId || '';

                const parsed = log.details
                  ? parseDetails(log.details)
                  : null;

                const sum = parsed
                  ? buildSummaryFromDetails(parsed)
                  : {
                      admissionNumber: null,
                      databaseAdmissionId: null,
                      changes: [],
                      detailRows: [],
                      displayText: '',
                      studentName: '',
                      processedBy: ''
                    };

                const previewChanges =
                  (sum.changes || []).slice(0, 3);

                const previewDetails =
                  (sum.detailRows || []).slice(0, 4);

                // Admission update mein permanent card NO use hoga.
                // User update mein normal user ID use hogi.
                const targetDisplayId =
                  sum.admissionNumber ||
                  targetId;

                const targetIdLabel =
                  sum.admissionNumber
                    ? 'NO'
                    : 'ID';

                const modalId = 'histDetailsModal';

                const modalPayload = encodeURIComponent(
                  JSON.stringify({
                    changes: sum.changes || [],
                    detailRows: sum.detailRows || []
                  })
                );

              %>

              <tr class="<%= (idx % 2 === 0) ? 'row-soft' : '' %>">
                <td class="nowrap">
                  <div class="fw-semibold small"><%= dt %></div>
                  <div class="text-muted xsmall">Log ID: <%= log.id %></div>
                </td>

                <td>
                  <div class="fw-semibold small"><%= actorName %></div>
                  <span class="role-badge <%= roleBadgeClass(actorRoleRaw) %> text-capitalize mt-1">
                    <i class="bi bi-person-badge"></i> <%= roleLabel(actorRoleRaw) %>
                  </span>
                </td>

                <td>
                  <span class="badge bg-light text-muted border text-capitalize">
                    <%= dept %>
                  </span>
                </td>

                <td>
                  <span class="evt-badge <%= eventBadgeClass(eventRaw) %> text-capitalize">
                    <i class="bi bi-activity"></i> <%= eventLabel(eventRaw) %>
                  </span>
                </td>

                <td>
                  <div class="small fw-semibold">
                    <%= targetName %>
                  </div>

                  <% if (targetDisplayId) { %>
                    <div class="text-muted xsmall">
                      <%= targetIdLabel %>:
                      <%= targetDisplayId %>
                    </div>
                  <% } %>
                </td>

                <td style="max-width:620px;">
                  <% if (sum.admissionNumber) { %>
                    <div class="admission-ref">
                      <i class="bi bi-hash"></i>
                      Admission No.
                      <%= sum.admissionNumber %>
                    </div>
                  <% } %>

                  <% if (String(eventRaw || '').toLowerCase().includes('forward') && sum.displayText) { %>
                    <div class="forward-summary-line">
                      <i class="bi bi-send-check"></i>
                      <span><%= sum.displayText %></span>
                    </div>

                    <div class="summary-mini-line">
                      <% if (sum.studentName) { %>
                        Student: <strong><%= sum.studentName %></strong>
                      <% } %>
                      <% if (sum.processedBy) { %>
                        · Processed By: <strong><%= sum.processedBy %></strong>
                      <% } %>
                    </div>

                  <% } else if (previewChanges.length > 0) { %>
                    <div class="change-summary-box">
                      <div class="change-summary-head">
                        <span>
                          <i class="bi bi-pencil-square me-1"></i>
                          <%= (sum.changes || []).length %>
                          field<%= (sum.changes || []).length === 1 ? '' : 's' %> changed
                        </span>
                        <span class="text-muted">Before → After</span>
                      </div>

                      <% previewChanges.forEach(function(change) { %>
                        <div class="change-preview-row">
                          <div class="change-preview-label">
                            <%= change.label || 'Changed field' %>
                          </div>

                          <div class="change-preview-value change-preview-before">
                            <%= shortHistoryValue(change.before, 80) %>
                          </div>

                          <div class="change-preview-arrow">
                            <i class="bi bi-arrow-right"></i>
                          </div>

                          <div class="change-preview-value change-preview-after">
                            <%= shortHistoryValue(change.after, 80) %>
                          </div>
                        </div>
                      <% }) %>

                      <% if ((sum.changes || []).length > previewChanges.length) { %>
                        <div class="more-line">
                          +<%= (sum.changes || []).length - previewChanges.length %>
                          more change<%= ((sum.changes || []).length - previewChanges.length) === 1 ? '' : 's' %>.
                          Open View for complete details.
                        </div>
                      <% } %>
                    </div>

                  <% } else if (previewDetails.length > 0) { %>
                    <div class="simple-summary-list">
                      <% previewDetails.forEach(function(item) { %>
                        <div class="simple-summary-row">
                          <div class="simple-summary-label">
                            <%= item.label %>
                          </div>
                          <div class="simple-summary-value">
                            <%= shortHistoryValue(item.value, 120) %>
                          </div>
                        </div>
                      <% }) %>

                      <% if ((sum.detailRows || []).length > previewDetails.length) { %>
                        <div class="more-line">
                          +<%= (sum.detailRows || []).length - previewDetails.length %>
                          more detail<%= ((sum.detailRows || []).length - previewDetails.length) === 1 ? '' : 's' %>.
                        </div>
                      <% } %>
                    </div>

                  <% } else { %>
                    <span class="text-muted xsmall">
                      Activity recorded. Open View for details.
                    </span>
                  <% } %>
                </td>

                <td class="text-end">
                  <% if (log.details) { %>
                    <button
                      type="button"
                      class="btn btn-sm details-btn"
                      data-bs-toggle="modal"
                      data-bs-target="#<%= modalId %>"
                      data-logid="<%= log.id %>"
                      data-actor="<%= String(actorName).replace(/"/g,'&quot;') %>"
                      data-event="<%= String(eventLabel(eventRaw)).replace(/"/g,'&quot;') %>"
                      data-date="<%= String(dt).replace(/"/g,'&quot;') %>"
                      data-details="<%= modalPayload %>"
                    >
                      <i class="bi bi-eye me-1"></i> View
                    </button>
                  <% } else { %>
                    <span class="text-muted xsmall">—</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</div>

<!-- MODAL -->
<div class="modal fade" id="histDetailsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content" style="border-radius:16px; overflow:hidden; border:1px solid #e2e8f0;">
      <div class="modal-header bg-white">
        <div>
          <div class="fw-bold text-dark">Activity Details</div>
          <div class="xsmall text-muted mt-1" id="histModalMeta">—</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body" style="background:#f8fafc;">
        <div id="histModalChangesSection" class="d-none mb-3">
          <div class="history-section-title">
            <i class="bi bi-arrow-left-right me-1"></i>
            Changed Information
          </div>
          <div class="history-change-list" id="histModalChanges"></div>
        </div>

        <div id="histModalInfoSection" class="d-none">
          <div class="history-section-title">
            <i class="bi bi-info-circle me-1"></i>
            Recorded Information
          </div>
          <div class="history-info-list" id="histModalInfo"></div>
        </div>

        <div class="history-empty d-none" id="histModalEmpty">
          No additional details are available for this activity.
        </div>
      </div>

      <div class="modal-footer bg-white">
        <button type="button" class="btn btn-outline-secondary btn-pill px-3" data-bs-dismiss="modal">
          Close
        </button>
      </div>
    </div>
  </div>
</div>


<script>
  (function () {
    const modal = document.getElementById('histDetailsModal');
    if (!modal) return;

    const metaEl = document.getElementById('histModalMeta');

    const changesSection = document.getElementById('histModalChangesSection');
    const changesEl = document.getElementById('histModalChanges');

    const infoSection = document.getElementById('histModalInfoSection');
    const infoEl = document.getElementById('histModalInfo');

    const emptyEl = document.getElementById('histModalEmpty');

    modal.addEventListener('show.bs.modal', function (event) {
      const btn = event.relatedTarget;
      if (!btn) return;

      const id = btn.getAttribute('data-logid') || '';
      const actor = btn.getAttribute('data-actor') || '';
      const ev = btn.getAttribute('data-event') || '';
      const dt = btn.getAttribute('data-date') || '';
      const rawDetails = btn.getAttribute('data-details') || '';

      let payload = {
        changes: [],
        detailRows: []
      };

      try {
        payload = JSON.parse(decodeURIComponent(rawDetails));
      } catch (e) {
        payload = {
          changes: [],
          detailRows: []
        };
      }

      if (metaEl) {
        metaEl.textContent =
          `Log ID: ${id}  |  ${dt}  |  ${actor}  |  ${ev}`;
      }

      renderChanges(
        Array.isArray(payload.changes)
          ? payload.changes
          : []
      );

      renderInformation(
        Array.isArray(payload.detailRows)
          ? payload.detailRows
          : []
      );

      const hasChanges =
        Array.isArray(payload.changes) &&
        payload.changes.length > 0;

      const hasInformation =
        Array.isArray(payload.detailRows) &&
        payload.detailRows.length > 0;

      if (emptyEl) {
        emptyEl.classList.toggle(
          'd-none',
          hasChanges || hasInformation
        );
      }
    });

    function renderChanges(changes) {
      if (!changesSection || !changesEl) return;

      if (!changes.length) {
        changesSection.classList.add('d-none');
        changesEl.innerHTML = '';
        return;
      }

      changesSection.classList.remove('d-none');

      changesEl.innerHTML = changes.map(function (change) {
        const label = escapeHtml(
          change.label || 'Changed field'
        );

        const before = escapeHtml(
          displayValue(change.before)
        );

        const after = escapeHtml(
          displayValue(change.after)
        );

        return `
          <div class="history-change-card">
            <div class="history-change-title">
              ${label}
            </div>

            <div class="history-change-values">
              <div class="history-value-box before">
                <div class="history-value-caption">Before</div>
                <div class="history-value-text">${before}</div>
              </div>

              <div class="history-change-arrow">
                <i class="bi bi-arrow-right"></i>
              </div>

              <div class="history-value-box after">
                <div class="history-value-caption">After</div>
                <div class="history-value-text">${after}</div>
              </div>
            </div>
          </div>
        `;
      }).join('');
    }

    function renderInformation(rows) {
      if (!infoSection || !infoEl) return;

      if (!rows.length) {
        infoSection.classList.add('d-none');
        infoEl.innerHTML = '';
        return;
      }

      infoSection.classList.remove('d-none');

      infoEl.innerHTML = rows.map(function (item) {
        const label = escapeHtml(item.label || 'Detail');
        const value = escapeHtml(
          displayValue(item.value)
        );

        return `
          <div class="history-info-row">
            <div class="history-info-label">${label}</div>
            <div class="history-info-value">${value}</div>
          </div>
        `;
      }).join('');
    }

    function displayValue(value) {
      if (value === null || typeof value === 'undefined') {
        return 'Not set';
      }

      const text = String(value).trim();
      return text || 'Not set';
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }
  })();
</script>

<%- include('partials/bootstrap-footer') %>
