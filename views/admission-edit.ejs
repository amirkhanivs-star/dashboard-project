<%- include('partials/bootstrap-header', { user, pageTitle: 'Edit Admission' }) %>
<%- include('partials/flash') %>

<%
  const A = admission || {};
  const acc = A.accounts || {};
  const adm = A.admission || A.admissionPanel || {};
  const roleKey = String(user?.role || user?.agentType || '').toLowerCase();

let themeClass = 'theme-super';

if (roleKey === 'admin') {
  themeClass = 'theme-admin';
} else if (roleKey === 'agent') {
  themeClass = 'theme-agent';
} else if (
  roleKey === 'sub_agent' ||
  roleKey === 'subagent' ||
  roleKey === 'sub-agent'
) {
  themeClass = 'theme-subagent';
}

  const isSuper = !!(user && (
    user.role === 'super_admin' ||
    user.role === 'superadmin' ||
    user.agentType === 'super_admin' ||
    user.agentType === 'superadmin' ||
    user.isSuperAdmin === true ||
    user.is_super_admin === true
  ));

  const rawPerms = perms || (user && (user.permissions || user.perms || user.permission || user.permissionMap)) || {};

  function hasPerm(keys) {
    if (isSuper) return true;
    if (!rawPerms) return false;
    if (rawPerms === true) return true;
    if (Array.isArray(rawPerms)) return keys.some(k => rawPerms.includes(k) || rawPerms.includes('*') || rawPerms.includes('all'));
    if (typeof rawPerms === 'object') {
      return keys.some(k => {
        if (rawPerms[k] === true) return true;
        const alt = k.replace(/\./g, '_');
        if (rawPerms[alt] === true) return true;
        return false;
      });
    }
    return false;
  }

  function canCol(key, normalizedKey) {
    if (isSuper) return true;
    if (normalizedKey && rawPerms && rawPerms[normalizedKey] === true) return true;
    return hasPerm([
      `super.col.${key}`,
      `super.column.${key}`,
      `dashboard_super.col.${key}`,
      `dashboard-super.col.${key}`,
      `perm.super.col.${key}`,
      normalizedKey || ''
    ]);
  }

  function canBtn(key, normalizedKey) {
    if (isSuper) return true;
    if (normalizedKey && rawPerms && rawPerms[normalizedKey] === true) return true;
    return hasPerm([
      `super.btn.${key}`,
      `super.button.${key}`,
      `dashboard_super.btn.${key}`,
      `dashboard-super.btn.${key}`,
      `perm.super.btn.${key}`,
      normalizedKey || ''
    ]);
  }

  const P = {
    col: {
      status: canCol('status', 'colStatus'),
      feeStatus: canCol('feeStatus', 'colFeeStatus'),
      dept: canCol('dept', 'colDept'),
      student: canCol('student', 'colStudentName'),
      father: canCol('father', 'colFatherName'),
      fatherEmail: canCol('fatherEmail', 'colFatherEmail'),
      grade: canCol('grade', 'colGrade'),
      tuitionGrade: canCol('tuitionGrade', 'colTuitionGrade'),
      phone: canCol('phone', 'colPhone'),
      processedBy: canCol('processedBy', 'colProcessedBy'),
      paymentStatus: canCol('paymentStatus', 'colPaymentStatus'),
      paidUpto: canCol('paidUpto', 'colPaidUpto'),
      verif: canCol('verificationNumber', 'colVerificationNumber'),
      reg: canCol('registrationNumber', 'colRegistrationNumber'),
      family: canCol('familyNumber', 'colFamilyNumber'),
      registrationFee: canCol('registrationFee', 'colRegistrationFee'),
      fees: canCol('fees', 'colFees'),
      currency: canCol('currency', 'colCurrency'),
      month: canCol('month', 'colMonth'),
      totalFees: canCol('totalFees', 'colTotalFees'),
      pendingDues: canCol('pendingDues', 'colPendingDues'),
      receivedPayment: canCol('receivedPayment', 'colReceivedPayment'),
      invoiceStatus: canCol('invoiceStatus', 'colInvoiceStatus'),
      invoiceStatusTimestamp: canCol('invoiceStatusTimestamp', 'colInvoiceStatusTimestamp'),
      paidInvoiceStatus: canCol('paidInvoiceStatus', 'colPaidInvoiceStatus'),
      paidInvoiceStatusTimestamp: canCol('paidInvoiceStatusTimestamp', 'colPaidInvoiceStatusTimestamp')
    },
    btn: {
      update: canBtn('update', 'btnUpdateRow'),
      details: canBtn('details', 'btnDetails')
    }
  };

  const DEFAULT_CURRENT_STATUS_OPTIONS =
    (typeof statusOptionsCurrent !== 'undefined' && Array.isArray(statusOptionsCurrent) && statusOptionsCurrent.length)
      ? statusOptionsCurrent
      : [
          { value: 'New Admission', color: '#64748b' },
          { value: 'Running', color: '#22c55e' },
          { value: 'Leave', color: '#f59e0b' },
          { value: 'Stop', color: '#ef4444' },
          { value: 'Left', color: '#2563eb' },
          { value: 'Freez', color: '#94a3b8' }
        ];

  const DEFAULT_FEE_STATUS_OPTIONS =
    (typeof statusOptionsFee !== 'undefined' && Array.isArray(statusOptionsFee) && statusOptionsFee.length)
      ? statusOptionsFee
      : [
          { value: 'New Admission', color: '#64748b' },
          { value: 'Present + Dues', color: '#ef4444' },
          { value: 'Present + No Dues', color: '#22c55e' }
        ];

  const DEFAULT_CURRENCY_OPTIONS =
    (typeof currencyOptions !== 'undefined' && Array.isArray(currencyOptions) && currencyOptions.length)
      ? currencyOptions.map(opt => ({
          value: opt.value || opt.label || opt.opt_key || '',
          label: opt.label || opt.value || opt.opt_key || ''
        })).filter(opt => opt.value)
      : [
          { value: 'AED', label: 'AED' },
          { value: 'SAR', label: 'SAR' },
          { value: 'PKR', label: 'PKR' },
          { value: 'USD', label: 'USD' },
          { value: 'GBP', label: 'GBP' }
        ];

  const editAction = isSuper ? `/dashboard/super/update/${A.id}` : `/admin/update/${A.id}`;
  const detailsUrl = isSuper ? `/dashboard/super/admission/${A.id}` : `/admin/admission/${A.id}`;
  const backUrl = detailsUrl;

  const currentStatusVal = String(A.status || A.currentStatus || A.current_status || 'New Admission').trim();
  const feeStatusVal = String(A.feeStatus || A.fee_status || A.feeStatusText || 'New Admission').trim();
  const currencyVal = String(A.currency_code || A.currencyCode || adm.currencyCode || adm.currency_code || '').trim().toUpperCase();
  const monthVal = String(adm.month || A.admission_month || '').trim();
  const currentYearOnly = new Date().getFullYear();
  const months = [
    { full: 'January', short: 'Jan' },
    { full: 'February', short: 'Feb' },
    { full: 'March', short: 'Mar' },
    { full: 'April', short: 'Apr' },
    { full: 'May', short: 'May' },
    { full: 'June', short: 'Jun' },
    { full: 'July', short: 'Jul' },
    { full: 'August', short: 'Aug' },
    { full: 'September', short: 'Sep' },
    { full: 'October', short: 'Oct' },
    { full: 'November', short: 'Nov' },
    { full: 'December', short: 'Dec' }
  ];
%>

<%
  const activeAdmissionId = Number(A.id || 0);

const rawEditAdmissions =
  (typeof admissions !== 'undefined' && Array.isArray(admissions) && admissions.length)
    ? admissions
    : [A];

const editAdmissions = rawEditAdmissions.slice().sort((x, y) => {
  const xActive = Number(x && x.id || 0) === activeAdmissionId ? 0 : 1;
  const yActive = Number(y && y.id || 0) === activeAdmissionId ? 0 : 1;
  return xActive - yActive;
});
%>

<div class="compact-edit-page <%= themeClass %>">

  <% if (familyNumber && editAdmissions.length > 1) { %>
    <div class="family-edit-banner">
      <div>
        <div class="family-title">
          <i class="bi bi-people-fill me-1"></i>
          Family Admissions
        </div>
        <div class="family-subtitle">
          Family # <strong><%= familyNumber %></strong> | <%= editAdmissions.length %> admissions found
        </div>
      </div>
    </div>
  <% } %>

  <% editAdmissions.forEach((item, idx) => {
    const E = item || {};
    const eAcc = E.accounts || {};
    const eAdm = E.admission || E.admissionPanel || {};

    const eEditAction = isSuper ? `/dashboard/super/update/${E.id}` : `/admin/update/${E.id}`;
    const eDetailsUrl = isSuper ? `/dashboard/super/admission/${E.id}` : `/admin/admission/${E.id}`;

    const eCurrentStatusVal = String(E.status || E.currentStatus || E.current_status || 'New Admission').trim();
    const eFeeStatusVal = String(E.feeStatus || E.fee_status || E.feeStatusText || 'New Admission').trim();
    const eCurrencyVal = String(E.currency_code || E.currencyCode || eAdm.currencyCode || eAdm.currency_code || '').trim().toUpperCase();
    const eMonthVal = String(eAdm.month || E.admission_month || '').trim();

    const isActiveCard = Number(E.id || 0) === activeAdmissionId;
  %>

  <form class="admission-edit-form" action="<%= eEditAction %>" method="POST">
    <div class="compact-card <%= isActiveCard ? 'active-edit-card' : '' %>">
      <div class="compact-head">
        <div class="student-mini">
          <div class="student-avatar">
            <%= String(E.student || E.studentName || 'S').trim().charAt(0).toUpperCase() || 'S' %>
          </div>

          <div>
            <div class="chip-row">
              <span class="mini-chip danger">
                <i class="bi bi-pencil-square me-1"></i>Edit Admission
              </span>

              <span class="mini-chip text-capitalize">
                <%= E.dept || 'Admission' %>
              </span>

              <% if (E.id) { %>
                <span class="mini-chip">ID #<%= E.id %></span>
              <% } %>

              <% if (eAcc.familyNumber) { %>
                <span class="mini-chip">Family #<%= eAcc.familyNumber %></span>
              <% } %>

              <% if (isActiveCard) { %>
                <span class="mini-chip active-chip">Selected</span>
              <% } %>
            </div>

            <h3><%= E.student || E.studentName || 'Student Admission' %></h3>
          </div>
        </div>
      </div>

      <div class="section-title">Student & Admission</div>

      <div class="compact-grid">
        <% if (P.col.status) { %>
          <div class="field-box">
            <label>Current Status</label>
            <select
  name="status"
  class="form-select form-select-sm compact-input status-select js-status-select"
  data-prev-value="<%= eCurrentStatusVal %>">
              <% DEFAULT_CURRENT_STATUS_OPTIONS.forEach(opt => { %>
                <option value="<%= opt.value %>" <%= eCurrentStatusVal === opt.value ? 'selected' : '' %>>
                  <%= opt.value %>
                </option>
                <% }) %>
                <option value="__add_new_status__">+ Add Option</option>
             </select>
          </div>
        <% } %>

        <% if (P.col.feeStatus) { %>
          <div class="field-box">
            <label>Fee Status</label>
            <select
  name="feeStatus"
  class="form-select form-select-sm compact-input fee-select js-fee-select"
  data-prev-value="<%= eFeeStatusVal %>">
              <% DEFAULT_FEE_STATUS_OPTIONS.forEach(opt => { %>
                <option value="<%= opt.value %>" <%= eFeeStatusVal === opt.value ? 'selected' : '' %>>
                  <%= opt.value %>
                </option>
              <% }) %>
              <option value="__add_new_fee_status__">+ Add Option</option>
            </select>
          </div>
        <% } %>

        <% if (P.col.dept) { %>
          <div class="field-box">
            <label>Department</label>
            <select name="dept" class="form-select form-select-sm compact-input text-capitalize">
              <option value="quran" <%= E.dept === 'quran' ? 'selected' : '' %>>Quran</option>
              <option value="tuition" <%= E.dept === 'tuition' ? 'selected' : '' %>>Tuition</option>
              <option value="school" <%= E.dept === 'school' ? 'selected' : '' %>>School</option>
            </select>
          </div>
        <% } %>

        <% if (P.col.student) { %>
          <div class="field-box">
            <label>Student Name</label>
            <input type="text" name="student" class="form-control form-control-sm compact-input" value="<%= E.student || E.studentName || '' %>">
          </div>
        <% } %>

        <% if (P.col.father) { %>
          <div class="field-box">
            <label>Father Name</label>
            <input type="text" name="father" class="form-control form-control-sm compact-input" value="<%= E.father || E.fatherName || '' %>">
          </div>
        <% } %>

        <% if (P.col.fatherEmail) { %>
          <div class="field-box">
            <label>Email Address</label>
            <input type="email" name="father_email" class="form-control form-control-sm compact-input" value="<%= E.fatherEmail || E.father_email || '' %>">
          </div>
        <% } %>

        <% if (P.col.phone) { %>
          <div class="field-box">
            <label>Phone Number</label>
            <input type="text" name="phone" class="form-control form-control-sm compact-input" value="<%= E.phone || E.contactNumber || '' %>">
          </div>
        <% } %>

        <% if (P.col.grade) { %>
          <div class="field-box">
            <label>Grade</label>
            <input type="text" name="grade" class="form-control form-control-sm compact-input" value="<%= E.grade || '' %>">
          </div>
        <% } %>

        <% if (P.col.tuitionGrade) { %>
          <div class="field-box">
            <label>Grade Section</label>
            <input type="text" name="tuitionGrade" class="form-control form-control-sm compact-input" value="<%= E.tuitionGrade || '' %>">
          </div>
        <% } %>

        <% if (P.col.processedBy) { %>
          <div class="field-box">
            <label>Processed By</label>
            <input type="text" class="form-control form-control-sm compact-input readonly-field" value="<%= E.processedBy || E.processed_by || '' %>" readonly tabindex="-1">
          </div>
        <% } %>
      </div>

      <div class="section-title">Accounts & Fee</div>

      <div class="compact-grid">
        <% if (P.col.paymentStatus) { %>
          <div class="field-box">
            <label>Payment Status</label>
            <select name="paymentStatus" class="form-select form-select-sm compact-input">
              <option value="">Select</option>
              <option value="Paid" <%= eAcc.paymentStatus === 'Paid' ? 'selected' : '' %>>Paid</option>
              <option value="Partial" <%= eAcc.paymentStatus === 'Partial' ? 'selected' : '' %>>Partial</option>
              <option value="Unpaid" <%= eAcc.paymentStatus === 'Unpaid' ? 'selected' : '' %>>Unpaid</option>
            </select>
          </div>
        <% } %>

        <% if (P.col.paidUpto) { %>
          <div class="field-box">
            <label>Paid Upto</label>
            <input type="text" name="paidUpto" class="form-control form-control-sm compact-input" value="<%= eAcc.paidUpto || '' %>">
          </div>
        <% } %>

        <% if (P.col.verif) { %>
          <div class="field-box">
            <label>Verification #</label>
            <input type="text" class="form-control form-control-sm compact-input readonly-field" value="<%= E.latestBillingVerificationNumber || eAcc.verificationNumber || '' %>" readonly tabindex="-1">
          </div>
        <% } %>

        <% if (P.col.reg) { %>
          <div class="field-box">
            <label>Registration #</label>
            <input type="text" name="registrationNumber" class="form-control form-control-sm compact-input" value="<%= eAcc.registrationNumber || '' %>">
          </div>
        <% } %>

        <% if (P.col.family) { %>
          <div class="field-box">
            <label>Family #</label>
            <input type="text" name="familyNumber" class="form-control form-control-sm compact-input" value="<%= eAcc.familyNumber || '' %>">
          </div>
        <% } %>

        <% if (P.col.registrationFee) { %>
          <div class="field-box">
            <label>Registration Fee</label>
            <input type="text" name="registrationFee" class="form-control form-control-sm compact-input" value="<%= eAdm.registrationFee || '' %>">
          </div>
        <% } %>

        <% if (P.col.fees) { %>
          <div class="field-box">
            <label>Monthly Fees</label>
            <input type="text" name="fees" class="form-control form-control-sm compact-input" value="<%= eAdm.fees || '' %>">
          </div>
        <% } %>

        <% if (P.col.currency) { %>
          <div class="field-box">
            <label>Currency</label>
            <select
  name="currency_code"
  class="form-select form-select-sm compact-input js-currency-select"
  data-prev-value="<%= eCurrencyVal %>">
              <option value="" <%= !eCurrencyVal ? 'selected' : '' %>>Select</option>
             <% DEFAULT_CURRENCY_OPTIONS.forEach(opt => { %>
  <option value="<%= opt.value %>" <%= eCurrencyVal === String(opt.value).toUpperCase() ? 'selected' : '' %>>
    <%= opt.label || opt.value %>
  </option>
<% }) %>

<option value="__add_new_currency__">+ Add Option</option>
</select>
          </div>
        <% } %>

        <% if (P.col.month) { %>
          <div class="field-box">
            <label>Month/Year</label>
            <select name="month" class="form-select form-select-sm compact-input">
              <option value="" <%= !eMonthVal ? 'selected' : '' %>>Select</option>
              <% months.forEach(m => {
                const fullValue = `${m.full} ${currentYearOnly}`;
                const shortValue = `${m.short} ${currentYearOnly}`;
                const isSelected = eMonthVal === fullValue || eMonthVal === shortValue;
              %>
                <option value="<%= shortValue %>" <%= isSelected ? 'selected' : '' %>>
                  <%= shortValue %>
                </option>
              <% }) %>
            </select>
          </div>
        <% } %>

        <% if (P.col.totalFees) { %>
          <div class="field-box">
            <label>Total Fees</label>
            <input type="text" name="totalFees" class="form-control form-control-sm compact-input readonly-field" value="<%= eAdm.totalFees || '' %>" readonly tabindex="-1">
          </div>
        <% } %>

        <% if (P.col.pendingDues) { %>
          <div class="field-box">
            <label>Pending Dues</label>
            <input type="text" name="pendingDues" class="form-control form-control-sm compact-input readonly-field" value="<%= eAdm.pendingDues || '' %>" readonly tabindex="-1">
          </div>
        <% } %>

        <% if (P.col.receivedPayment) { %>
          <div class="field-box">
            <label>Received Payment</label>
            <input type="text" name="receivedPayment" class="form-control form-control-sm compact-input readonly-field" value="<%= eAdm.receivedPayment || '0' %>" readonly tabindex="-1">
          </div>
        <% } %>
      </div>

      <div class="section-title">Invoice Fields</div>

      <div class="compact-grid invoice-grid">
        <% if (P.col.invoiceStatus) { %>
          <div class="field-box">
            <label>Invoice Status</label>
            <input type="text" class="form-control form-control-sm compact-input readonly-field" value="<%= eAdm.invoiceStatus || '' %>" readonly tabindex="-1">
          </div>
        <% } %>

        <% if (P.col.invoiceStatusTimestamp) { %>
          <div class="field-box">
            <label>Invoice Status Timestamp</label>
            <input type="text" class="form-control form-control-sm compact-input readonly-field" value="<%= eAdm.invoiceStatusTimestamp || '' %>" readonly tabindex="-1">
          </div>
        <% } %>

        <% if (P.col.paidInvoiceStatus) { %>
          <div class="field-box">
            <label>Paid Invoice Status</label>
            <input type="text" class="form-control form-control-sm compact-input readonly-field" value="<%= eAdm.paidInvoiceStatus || '' %>" readonly tabindex="-1">
          </div>
        <% } %>

        <% if (P.col.paidInvoiceStatusTimestamp) { %>
          <div class="field-box">
            <label>Paid Invoice Status Timestamp</label>
            <input type="text" class="form-control form-control-sm compact-input readonly-field" value="<%= eAdm.paidInvoiceStatusTimestamp || '' %>" readonly tabindex="-1">
          </div>
        <% } %>
      </div>

      <div class="compact-footer">
        <div></div>

        <div class="footer-actions">
          <a href="<%= eDetailsUrl %>" class="btn btn-light rounded-pill px-4">
            Cancel
          </a>

          <% if (P.btn.update) { %>
            <button type="submit" class="btn btn-danger rounded-pill px-5 save-btn">
              <i class="bi bi-check2-circle me-1"></i> Update Admission
            </button>
          <% } else { %>
            <span class="text-muted small align-self-center">No update permission</span>
          <% } %>
        </div>
      </div>
    </div>
  </form>

  <% }) %>
</div>

<style>
  body{ background:#f8fafc; }
   .theme-super{
  --theme-main:#ef4444;
  --theme-dark:#b91c1c;
  --theme-soft:#fff7f7;
  --theme-glow:rgba(239,68,68,.18);
  --theme-focus:rgba(239,68,68,.12);
}

.theme-admin{
  --theme-main:#22c55e;
  --theme-dark:#15803d;
  --theme-soft:#f0fdf4;
  --theme-glow:rgba(34,197,94,.18);
  --theme-focus:rgba(34,197,94,.12);
}

.theme-agent{
  --theme-main:#7c3aed;
  --theme-dark:#5b21b6;
  --theme-soft:#faf5ff;
  --theme-glow:rgba(124,58,237,.18);
  --theme-focus:rgba(124,58,237,.12);
}

.theme-subagent{
  --theme-main:#2563eb;
  --theme-dark:#1d4ed8;
  --theme-soft:#eff6ff;
  --theme-glow:rgba(37,99,235,.18);
  --theme-focus:rgba(37,99,235,.12);
}
  .compact-edit-page{
    min-height: calc(100vh - 85px);
    padding: 14px;
    background:
  radial-gradient(circle at top left, var(--theme-focus), transparent 34%),
  linear-gradient(180deg, var(--theme-soft), #f8fafc);
  }
.family-edit-banner{
  max-width:1500px;
  margin:0 auto 12px;
  background:#fff;
  border:1px solid rgba(148,163,184,.24);
  border-radius:16px;
  padding:12px 16px;
  box-shadow:0 10px 24px rgba(15,23,42,.06);
}

.family-title{
  font-size:15px;
  font-weight:900;
  color:#0f172a;
}

.family-subtitle{
  margin-top:2px;
  font-size:12px;
  color:#64748b;
}

.admission-edit-form{
  margin-bottom:14px;
}

.active-edit-card{
  border-color:rgba(239,68,68,.35) !important;
  box-shadow:
    0 16px 38px rgba(239,68,68,.10),
    0 14px 35px rgba(15,23,42,.08) !important;
}

.active-chip{
  color:#166534 !important;
  background:#dcfce7 !important;
  border-color:#bbf7d0 !important;
}
  .compact-card{
    max-width: 1500px;
    margin: 0 auto;
    background:#fff;
    border:1px solid rgba(148,163,184,.24);
    border-radius:18px;
    box-shadow:0 14px 35px rgba(15,23,42,.08);
    padding:14px 16px 12px;
  }

  .compact-head{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:14px;
    padding-bottom:10px;
    border-bottom:1px solid rgba(148,163,184,.20);
    margin-bottom:10px;
  }

  .student-mini{
    display:flex;
    align-items:center;
    gap:12px;
    min-width:0;
  }

  .student-avatar{
    width:58px;
    height:58px;
    border-radius:18px;
    background:linear-gradient(135deg,#111827,var(--theme-main));
    color:#fff;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:24px;
    font-weight:900;
    box-shadow:0 12px 24px var(--theme-glow);
    flex:0 0 auto;
  }

  .compact-head h3{
    margin:4px 0 0;
    font-size:24px;
    line-height:1;
    font-weight:900;
    color:#0f172a;
  }

  .compact-head p{
    margin:4px 0 0;
    color:#64748b;
    font-size:12px;
  }

  .chip-row{
    display:flex;
    gap:6px;
    flex-wrap:wrap;
  }

  .mini-chip{
    display:inline-flex;
    align-items:center;
    border-radius:999px;
    padding:3px 9px;
    background:#fff;
    color:#475569;
    border:1px solid rgba(148,163,184,.35);
    font-size:11px;
    font-weight:800;
