<script>
  (function () {
    document.addEventListener('DOMContentLoaded', function () {
      const params = new URLSearchParams(window.location.search);
      const focusKey = params.get('focus');

      if (!focusKey) return;

      const fieldMap = {
        status: ['[name="status"]'],
        feeStatus: ['[name="feeStatus"]'],
        dept: ['[name="dept"]'],
        student: ['[name="student"]'],
        father: ['[name="father"]'],
        fatherEmail: ['[name="father_email"]'],
        phone: ['[name="phone"]'],
        grade: ['[name="grade"]'],
        tuitionGrade: ['[name="tuitionGrade"]'],
        paymentStatus: ['[name="paymentStatus"]'],
        paidUpto: ['[name="paidUpto"]'],
        registrationNumber: ['[name="registrationNumber"]'],
        familyNumber: ['[name="familyNumber"]'],
        registrationFee: ['[name="registrationFee"]'],
        fees: ['[name="fees"]'],
        currency: ['[name="currency_code"]'],
        month: ['[name="month"]'],
        totalFees: ['[name="totalFees"]'],
        pendingDues: ['[name="pendingDues"]'],
        receivedPayment: ['[name="receivedPayment"]']
      };

      const labelMap = {
        no: '',
        processedBy: 'Processed By',
        verificationNumber: 'Verification #',
        invoiceStatus: 'Invoice Status',
        invoiceStatusTimestamp: 'Invoice Status Timestamp',
        paidInvoiceStatus: 'Paid Invoice Status',
        paidInvoiceStatusTimestamp: 'Paid Invoice Status Timestamp'
      };

      function getActiveScope() {
  const activeCard = document.querySelector('.active-edit-card');
  if (activeCard) return activeCard;

  return document;
}

function findBySelectors(selectors) {
  const scope = getActiveScope();

  for (const selector of selectors || []) {
    const el = scope.querySelector(selector);
    if (el) return el;
  }

  return null;
}

      function findByLabel(labelText) {
        if (!labelText) return null;

        const wanted = String(labelText).toLowerCase().trim();

        const scope = getActiveScope();
const boxes = Array.from(scope.querySelectorAll('.field-box'));
        for (const box of boxes) {
          const label = box.querySelector('label');
          if (!label) continue;

          const current = String(label.textContent || '').toLowerCase().trim();
          if (current === wanted) {
            return box.querySelector('input, select, textarea') || box;
          }
        }

        return null;
      }

      let target = findBySelectors(fieldMap[focusKey]);

      if (!target) {
        target = findByLabel(labelMap[focusKey]);
      }

      if (!target) return;

      setTimeout(function () {
        target.scrollIntoView({
          behavior: 'smooth',
          block: 'center'
        });

        if (!target.readOnly && !target.disabled && typeof target.focus === 'function') {
          target.focus();
        }

        target.classList.add('chip-focus-highlight');

        const box = target.closest('.field-box');
        if (box) box.classList.add('chip-focus-box');

        setTimeout(function () {
          target.classList.remove('chip-focus-highlight');
          if (box) box.classList.remove('chip-focus-box');
        }, 3500);
      }, 250);
    });
  })();
</script>

<style>
  .chip-focus-highlight {
    border-color: var(--theme-main) !important;
    box-shadow: 0 0 0 4px var(--theme-focus) !important;
    background: #fffafa !important;
  }

  .chip-focus-box label {
    color: var(--theme-main) !important;
  }
</style>
<script>
(function () {
  window.STATUS_OPTION_CACHE = {
    current: [],
    fee: []
  };

  function setSelectVisual(sel, color) {
    if (!sel) return;
    const c = color || '#64748b';
    sel.style.setProperty('--dot', c);
    sel.style.setProperty('--bd', c + '55');
    sel.style.setProperty('--tx', '#0f172a');
    sel.style.setProperty('--bg', c + '18');
  }

  function findColor(items, value) {
    const v = String(value || '').trim().toLowerCase();
    const found = (items || []).find(x => String(x.value || '').trim().toLowerCase() === v);
    return found ? found.color : '#64748b';
  }

  function applyDynamicColors() {
    const currentItems = window.STATUS_OPTION_CACHE.current || [];
    const feeItems = window.STATUS_OPTION_CACHE.fee || [];

    document.querySelectorAll('.js-status-select').forEach(sel => {
      if ((sel.value || '') === '__add_new_status__') return;
      setSelectVisual(sel, findColor(currentItems, sel.value));
    });

    document.querySelectorAll('.js-fee-select').forEach(sel => {
      if ((sel.value || '') === '__add_new_fee_status__') return;
      setSelectVisual(sel, findColor(feeItems, sel.value));
    });
  }

  function apiBase(type) {
    return type === 'current'
      ? '/api/options/status'
      : '/api/options/fee-status';
  }

  function normalizeRows(rows) {
    return (rows || []).map(row => ({
      id: row.id,
      value: row.value || row.label || row.opt_key || '',
      color: row.color || '#64748b',
      is_custom: Number(row.is_custom || 0)
    })).filter(x => x.value);
  }

  async function fetchOptions(type) {
    const res = await fetch(apiBase(type), {
      headers: { 'Accept': 'application/json' }
    });

    const data = await res.json();
    if (!res.ok || !data.success) {
      throw new Error(data.message || 'Failed to load options');
    }

    const items = normalizeRows(data.data || []);
    window.STATUS_OPTION_CACHE[type] = items;
    return items;
  }

  async function createOption(type, value, color) {
    const res = await fetch(apiBase(type), {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify({ label: value, color })
    });

    const data = await res.json();
    if (!res.ok || !data.success) {
      throw new Error(data.message || 'Failed to save option');
    }

    return data.data;
  }

  async function updateColor(type, id, color) {
    const res = await fetch(`${apiBase(type)}/${id}`, {
      method: 'PATCH',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify({ color })
    });

    const data = await res.json();
    if (!res.ok || !data.success) {
      throw new Error(data.message || 'Failed to update color');
    }

    return data;
  }

  async function deleteOption(type, id) {
    const res = await fetch(`${apiBase(type)}/${id}`, {
      method: 'DELETE',
      headers: { 'Accept': 'application/json' }
    });

    const data = await res.json();
    if (!res.ok || !data.success) {
      throw new Error(data.message || 'Failed to delete option');
    }

    return true;
  }

  function rebuildSelect(selectEl, items, selectedValue, addValue) {
    if (!selectEl) return;

    let html = '';

    html += items.map(item => {
      const selected = String(selectedValue || '') === String(item.value) ? 'selected' : '';
      return `<option value="${item.value}" ${selected}>${item.value}</option>`;
    }).join('');

    html += `<option value="${addValue}">+ Add Option</option>`;

    selectEl.innerHTML = html;
    selectEl.value = selectedValue || 'New Admission';
  }

  function refreshDropdowns() {
    const currentItems = window.STATUS_OPTION_CACHE.current || [];
    const feeItems = window.STATUS_OPTION_CACHE.fee || [];

    document.querySelectorAll('.js-status-select').forEach(sel => {
      const selected = sel.getAttribute('data-prev-value') || sel.value || 'New Admission';
      rebuildSelect(sel, currentItems, selected, '__add_new_status__');
      sel.value = selected;
    });

    document.querySelectorAll('.js-fee-select').forEach(sel => {
      const selected = sel.getAttribute('data-prev-value') || sel.value || 'New Admission';
      rebuildSelect(sel, feeItems, selected, '__add_new_fee_status__');
      sel.value = selected;
    });

    applyDynamicColors();
  }

  let activeType = 'current';
  let pendingSelect = null;

  const modalEl = document.getElementById('statusOptionModal');
  const titleEl = document.getElementById('statusOptionModalTitle');
  const inputEl = document.getElementById('statusOptionInput');
  const colorEl = document.getElementById('statusOptionColor');
  const saveBtn = document.getElementById('statusOptionSaveBtn');
  const listEl = document.getElementById('statusOptionList');
  const listTitleEl = document.getElementById('statusOptionListTitle');

  function optionLabel(type) {
    return type === 'current' ? 'Current Status' : 'Fee Status';
  }

  function renderList() {
    const items = window.STATUS_OPTION_CACHE[activeType] || [];

    titleEl.textContent = `Manage ${optionLabel(activeType)} Options`;
    listTitleEl.textContent = `${optionLabel(activeType)} Options`;

    if (!items.length) {
      listEl.innerHTML = '<div class="status-option-empty">No options available.</div>';
      return;
    }

    listEl.innerHTML = items.map(item => `
      <div class="status-option-item">
        <div class="status-option-left">
          <span class="status-option-dot" style="background:${item.color || '#64748b'}"></span>
          <div class="status-option-name">${item.value}</div>
        </div>
        <div class="status-option-actions">
          <input
            type="color"
            class="form-control form-control-color status-option-color-input"
            value="${item.color || '#64748b'}"
            data-id="${item.id}"
            style="width:48px;min-width:48px;">
          ${item.is_custom ? `
            <button
              type="button"
              class="btn btn-sm btn-outline-danger rounded-pill status-option-delete-btn"
              data-id="${item.id}">
              Delete
            </button>
          ` : ''}
        </div>
      </div>
    `).join('');
  }

  function openModal(type, selectEl) {
    activeType = type;
    pendingSelect = selectEl || null;
    inputEl.value = '';
    colorEl.value = '#64748b';
    renderList();

    modalEl.classList.remove('d-none');
    modalEl.setAttribute('aria-hidden', 'false');
  }

  document.addEventListener('change', function (e) {
    const el = e.target;

    if (el.matches('.js-status-select')) {
      if (el.value === '__add_new_status__') {
        const prev = el.getAttribute('data-prev-value') || 'New Admission';
        el.value = prev;
        openModal('current', el);
        return;
      }

      el.setAttribute('data-prev-value', el.value || '');
      applyDynamicColors();
    }

    if (el.matches('.js-fee-select')) {
      if (el.value === '__add_new_fee_status__') {
        const prev = el.getAttribute('data-prev-value') || 'New Admission';
        el.value = prev;
        openModal('fee', el);
        return;
      }

      el.setAttribute('data-prev-value', el.value || '');
      applyDynamicColors();
    }
  });

  if (saveBtn) {
    saveBtn.addEventListener('click', async function () {
      try {
        const val = String(inputEl.value || '').trim();
        const color = colorEl.value || '#64748b';

        if (!val) {
          alert('Option name required');
          return;
        }

        const items = window.STATUS_OPTION_CACHE[activeType] || [];
        const exists = items.some(x => String(x.value || '').trim().toLowerCase() === val.toLowerCase());

        if (exists) {
          alert('Ye option pehle se mojood hai');
          return;
        }

        const created = await createOption(activeType, val, color);
        await fetchOptions(activeType);
        refreshDropdowns();
        renderList();

        if (pendingSelect) {
          const newVal = created.value || created.label || val;
          pendingSelect.value = newVal;
          pendingSelect.setAttribute('data-prev-value', newVal);
          applyDynamicColors();
        }

        inputEl.value = '';
        colorEl.value = '#64748b';
      } catch (err) {
        alert(err.message || 'Save failed');
      }
    });
  }

  if (listEl) {
    listEl.addEventListener('change', async function (e) {
      const input = e.target.closest('.status-option-color-input');
      if (!input) return;

      try {
        const id = Number(input.getAttribute('data-id'));
        if (!id) return;

        await updateColor(activeType, id, input.value || '#64748b');
        await fetchOptions(activeType);
        refreshDropdowns();
        renderList();
      } catch (err) {
        alert(err.message || 'Color update failed');
      }
    });

    listEl.addEventListener('click', async function (e) {
      const btn = e.target.closest('.status-option-delete-btn');
      if (!btn) return;

      try {
        const id = Number(btn.getAttribute('data-id'));
        if (!id) return;

        await deleteOption(activeType, id);
        await fetchOptions(activeType);
        refreshDropdowns();
        renderList();
      } catch (err) {
        alert(err.message || 'Delete failed');
      }
    });
  }

  document.addEventListener('click', function (e) {
    if (e.target.closest('.status-option-close-btn') || e.target === modalEl) {
      modalEl.classList.add('d-none');
      modalEl.setAttribute('aria-hidden', 'true');
    }
  });

  Promise.all([
    fetchOptions('current'),
    fetchOptions('fee')
  ])
    .then(function () {
      refreshDropdowns();
      renderList();
    })
    .catch(function (err) {
      console.error('Options load error:', err);
      applyDynamicColors();
    });
})();
</script>
<script>
(function () {
  const currencyModalEl = document.getElementById('currencyOptionModal');
  if (!currencyModalEl) return;

  const inputEl = document.getElementById('currencyOptionInput');
  const saveBtn = document.getElementById('currencyOptionSaveBtn');
  const listEl = document.getElementById('currencyOptionList');

  let pendingSelect = null;

  function normalizeCurrencyRows(rows) {
    return (rows || []).map(row => ({
      id: row.id,
      value: row.value || row.label || row.opt_key || '',
      label: row.label || row.value || row.opt_key || '',
      is_custom: Number(row.is_custom || 0)
    })).filter(x => x.value);
  }

  async function fetchCurrencyOptions() {
    const res = await fetch('/api/options/currency', {
      headers: { Accept: 'application/json' }
    });

    const data = await res.json();

    if (!res.ok || !data.success) {
      throw new Error(data.message || 'Failed to load currency options');
    }

    window.CURRENCY_OPTION_CACHE = normalizeCurrencyRows(data.data || []);
    return window.CURRENCY_OPTION_CACHE;
  }

  async function createCurrencyOption(value) {
    const res = await fetch('/api/options/currency', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        Accept: 'application/json'
      },
      body: JSON.stringify({ label: value })
    });

    const data = await res.json();

    if (!res.ok || !data.success) {
      throw new Error(data.message || 'Failed to save currency option');
    }

    return data.data;
  }

  async function deleteCurrencyOption(id) {
    const res = await fetch(`/api/options/currency/${id}`, {
      method: 'DELETE',
      headers: { Accept: 'application/json' }
    });

    const data = await res.json();

    if (!res.ok || !data.success) {
      throw new Error(data.message || 'Failed to delete currency option');
    }

    return true;
  }

  function renderCurrencyList() {
    const items = Array.isArray(window.CURRENCY_OPTION_CACHE)
      ? window.CURRENCY_OPTION_CACHE
      : [];

    if (!items.length) {
      listEl.innerHTML = '<div class="status-option-empty">No currency options available.</div>';
      return;
    }

    listEl.innerHTML = items.map(item => `
      <div class="status-option-item">
        <div class="status-option-left">
          <div class="status-option-name">${item.label}</div>
        </div>

        <div class="status-option-actions">
          ${item.is_custom ? `
            <button
              type="button"
              class="btn btn-sm btn-outline-danger rounded-pill currency-option-delete-btn"
              data-id="${item.id}">
              Delete
            </button>
          ` : ''}
        </div>
      </div>
    `).join('');
  }

  function rebuildCurrencySelect(selectEl, items, selectedValue, includeAdd) {
    if (!selectEl) return;

    let html = '<option value="">Select</option>';

    html += items.map(item => {
      const selected = String(selectedValue || '') === String(item.value) ? 'selected' : '';
      return `<option value="${item.value}" ${selected}>${item.label}</option>`;
    }).join('');

    if (includeAdd) {
      html += '<option value="__add_new_currency__">+ Add Option</option>';
    }

    selectEl.innerHTML = html;
    selectEl.value = selectedValue || '';
  }

  function refreshCurrencyDropdowns() {
    const items = Array.isArray(window.CURRENCY_OPTION_CACHE)
      ? window.CURRENCY_OPTION_CACHE
      : [];

    document.querySelectorAll('.js-currency-select').forEach(sel => {
      const selected = sel.getAttribute('data-prev-value') || sel.value || '';
      rebuildCurrencySelect(sel, items, selected, true);
      sel.value = selected || '';
    });
  }

  async function loadCurrencyOptionsAndRefresh() {
    await fetchCurrencyOptions();
    renderCurrencyList();
    refreshCurrencyDropdowns();
  }

  function openCurrencyModal(selectEl) {
    pendingSelect = selectEl || null;
    currencyModalEl.classList.remove('d-none');
    currencyModalEl.setAttribute('aria-hidden', 'false');
  }

  document.addEventListener('change', function (e) {
    const el = e.target;
    if (!el) return;

    if (el.matches('.js-currency-select')) {
      if (el.value === '__add_new_currency__') {
        const prev = el.getAttribute('data-prev-value') || '';
        el.value = prev;
        openCurrencyModal(el);
        return;
      }

      el.setAttribute('data-prev-value', el.value || '');
    }
  });

  if (saveBtn) {
    saveBtn.addEventListener('click', async function () {
      try {
        const val = String(inputEl.value || '').trim().toUpperCase();

        if (!val) {
          alert('Currency name required');
          return;
        }

        const existing = window.CURRENCY_OPTION_CACHE || [];
        const duplicate = existing.some(x =>
          String(x.value || '').trim().toLowerCase() === val.toLowerCase()
        );

        if (duplicate) {
          alert('Ye currency pehle se mojood hai');
          return;
        }

        const created = await createCurrencyOption(val);
        await loadCurrencyOptionsAndRefresh();

        if (pendingSelect) {
          const newVal = created.value || created.label || created.opt_key || val;
          pendingSelect.value = newVal;
          pendingSelect.setAttribute('data-prev-value', newVal);
        }

        inputEl.value = '';
      } catch (err) {
        alert(err.message || 'Currency save failed');
      }
    });
  }

  if (listEl) {
    listEl.addEventListener('click', async function (e) {
      const btn = e.target.closest('.currency-option-delete-btn');
      if (!btn) return;

      try {
        const id = Number(btn.getAttribute('data-id'));
        if (!id) return;

        await deleteCurrencyOption(id);
        await loadCurrencyOptionsAndRefresh();
      } catch (err) {
        alert(err.message || 'Delete failed');
      }
    });
  }

  document.addEventListener('click', function (e) {
    if (e.target.closest('.currency-option-close-btn') || e.target === currencyModalEl) {
      currencyModalEl.classList.add('d-none');
      currencyModalEl.setAttribute('aria-hidden', 'true');
    }
  });

  loadCurrencyOptionsAndRefresh().catch(function (err) {
    console.error('Currency options load error:', err);
  });
})();
</script>
<%- include('partials/bootstrap-footer') %>
