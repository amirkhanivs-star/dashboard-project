          <div class="bulk-month-box">
            <div class="bulk-month-grid" id="bulkChallanMonthGrid">
              <button type="button" class="bulk-month-chip" data-month="January">Jan</button>
              <button type="button" class="bulk-month-chip" data-month="February">Feb</button>
              <button type="button" class="bulk-month-chip" data-month="March">Mar</button>
              <button type="button" class="bulk-month-chip" data-month="April">Apr</button>
              <button type="button" class="bulk-month-chip" data-month="May">May</button>
              <button type="button" class="bulk-month-chip" data-month="June">Jun</button>
              <button type="button" class="bulk-month-chip" data-month="July">Jul</button>
              <button type="button" class="bulk-month-chip" data-month="August">Aug</button>
              <button type="button" class="bulk-month-chip" data-month="September">Sep</button>
              <button type="button" class="bulk-month-chip" data-month="October">Oct</button>
              <button type="button" class="bulk-month-chip" data-month="November">Nov</button>
              <button type="button" class="bulk-month-chip" data-month="December">Dec</button>
            </div>
          </div>
          <input type="hidden" id="bulkChallanMonth" value="">
        </div>

        <div class="bulk-challan-section mb-4">
          <label class="form-label bulk-challan-label">Select Fee Type</label>
          <div class="bulk-fee-box">
            <button type="button" class="bulk-fee-chip active" data-fee-type="Monthly Fee" id="bulkFeeTypeChip">
              Monthly Fee
            </button>
          </div>
          <input type="hidden" id="bulkChallanFeeType" value="Monthly Fee">
        </div>

        <div class="bulk-challan-section mb-4">
          <label class="form-label bulk-challan-label">Select Class</label>
          <div class="bulk-class-box">
            <div class="bulk-class-grid" id="bulkChallanClassGrid">
              <% DEFAULT_CLASS_OPTIONS.forEach(cls => { %>
                <button type="button" class="bulk-class-chip" data-class="<%= cls %>"><%= cls %></button>
              <% }) %>
            </div>
          </div>
          <input type="hidden" id="bulkChallanClass" value="">
        </div>

        <div class="row g-3">
          <div class="col-md-6">
            <label for="bulkChallanSection" class="form-label bulk-challan-label">Select Section</label>
            <select id="bulkChallanSection" class="form-select bulk-challan-select">
              <option value="All Sections" selected>All Sections</option>
            </select>
          </div>

          <div class="col-md-6">
            <label for="bulkChallanYear" class="form-label bulk-challan-label">Select year</label>
            <%
              const bulkCurrentYear = new Date().getFullYear();
              const bulkYears = [];
              for (let y = bulkCurrentYear + 2; y >= bulkCurrentYear - 5; y--) {
                bulkYears.push(String(y));
              }
            %>
            <select id="bulkChallanYear" class="form-select bulk-challan-select">
              <% bulkYears.forEach(y => { %>
                <option value="<%= y %>" <%= String(bulkCurrentYear) === String(y) ? 'selected' : '' %>><%= y %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div id="bulkChallanSummaryBox" class="d-none mt-4 p-3 rounded-4 bg-light border">
          <div class="fw-semibold mb-1">Summary</div>
          <div class="small text-muted" id="bulkChallanSummaryText">-</div>
        </div>
      </div>

      <div class="modal-footer border-0 pt-3">
        <button type="button" class="btn bulk-create-btn rounded-3 px-4" id="bulkChallanCreateBtn">
          Create Invoice
        </button>
        <button type="button" class="btn bulk-whatsapp-btn rounded-3 px-4" id="bulkChallanSendBtn">
          <i class="bi bi-whatsapp me-1"></i> Send Invoice to WhatsApp
        </button>
      </div>
    </div>
  </div>
</div>
