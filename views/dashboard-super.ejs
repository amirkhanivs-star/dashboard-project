        <span class="badge text-bg-primary text-capitalize">
          Filter: <%= deptFilter %>
        </span>
      <% } else { %>
        <span class="badge text-bg-secondary">All Departments</span>
      <% } %>
    </div>

       <div class="px-3 pt-3 pb-2 border-top bulk-challan-toolbar-wrap">
  <div class="d-flex flex-wrap align-items-center gap-2">
    <% if (showBulkDeleteBar) { %>
      <div id="bulkDeleteToolbar" class="d-none d-flex align-items-center gap-2">
