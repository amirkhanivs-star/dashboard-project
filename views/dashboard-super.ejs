            <tr>
              <% if (canDeleteAdmissions) { %>
                <th class="text-center col-select" data-col="select">
                  <input
                    type="checkbox"
                    id="selectAllAdmissions"
                    class="form-check-input bulk-select-all"
                    title="Select All">
                </th>
              <% } %>

              <% if (P.col.status) { %><th data-col="status">Current Status</th><% } %>
              <% if (P.col.feeStatus) { %><th data-col="feeStatus">Fee Status</th><% } %>

              <% if (P.col.dept) { %><th data-col="dept">Dept</th><% } %>
              <% if (P.col.student) { %><th data-col="student">Student</th><% } %>
              <% if (P.col.father) { %><th data-col="father">Father</th><% } %>
              <% if (P.col.grade) { %><th data-col="grade">Grade</th><% } %>
              <% if (P.col.tuitionGrade) { %><th data-col="tuitionGrade">Grade Section</th><% } %>
              <% if (P.col.fatherEmail) { %><th data-col="fatherEmail">Email Address</th><% } %>
              <% if (P.col.phone) { %><th data-col="phone">Phone Number</th><% } %>
              <% if (P.col.processedBy) { %><th data-col="processedBy">Processed By</th><% } %>
              <% if (P.col.paymentStatus) { %><th data-col="paymentStatus">Payment Status</th><% } %>
              <% if (P.col.paidUpto) { %><th data-col="paidUpto">Paid Upto</th><% } %>
              <% if (P.col.verif) { %><th data-col="verificationNumber">Verif #</th><% } %>
              <% if (P.col.reg) { %><th data-col="registrationNumber">Reg #</th><% } %>
              <% if (P.col.family) { %><th data-col="familyNumber">Family #</th><% } %>
              <% if (P.col.registrationFee) { %><th data-col="registrationFee">Registration Fee</th><% } %>
              <% if (P.col.fees) { %><th data-col="fees">Monthly Fees</th><% } %>
              <% if (P.col.currency) { %><th data-col="currency">Currency</th><% } %>
              <% if (P.col.month) { %><th data-col="month">Month/Year</th><% } %>
              <% if (P.col.totalFees) { %><th data-col="totalFees">Total Fees</th><% } %>
              <% if (P.col.pendingDues) { %><th data-col="pendingDues">Pending Dues</th><% } %>
              <% if (P.col.receivedPayment) { %><th data-col="receivedPayment">Received Payment</th><% } %>
              <% if (P.col.invoiceStatus) { %><th data-col="invoiceStatus">Invoice Status</th><% } %>
              <% if (P.col.invoiceStatusTimestamp) { %><th data-col="invoiceStatusTimestamp">Invoice Status Timestamp</th><% } %>
              <% if (P.col.paidInvoiceStatus) { %><th data-col="paidInvoiceStatus">Paid Invoice Status</th><% } %>
              <% if (P.col.paidInvoiceStatusTimestamp) { %><th data-col="paidInvoiceStatusTimestamp">Paid Invoice Status Timestamp</th><% } %>

              <% if (showActions) { %>
                <th class="text-center col-actions" data-col="actions">Action Buttons</th>
              <% } %>
            </tr>

            <!-- Filter row -->
