<script>
  (function () {
    async function copyTextToClipboard(text) {
      if (!text) return false;

      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(text);
          return true;
        }

        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.left = '-9999px';
        textarea.style.top = '-9999px';
        document.body.appendChild(textarea);
        textarea.focus();
        textarea.select();

        const ok = document.execCommand('copy');
        document.body.removeChild(textarea);

        return ok;
      } catch (err) {
        console.error('Copy failed:', err);
        return false;
      }
    }

    function showPopup(type, title, message) {
      if (typeof window.showUploadFlash === 'function') {
        window.showUploadFlash(type, title, message);
      } else {
        alert(message || title || 'Notification');
      }
    }

    document.addEventListener('click', async function (e) {
      const btn = e.target.closest('.btn-external-upload-link');
      if (!btn) return;

      e.preventDefault();

      const admissionId = btn.getAttribute('data-admission-id') || '';
      const student = btn.getAttribute('data-student') || 'Student';

      if (!admissionId) {
        showPopup('danger', 'Invalid Admission', 'Admission ID not found.');
        return;
      }

      const oldHtml = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Creating...';

      try {
        const res = await fetch(`/api/admissions/${encodeURIComponent(admissionId)}/external-upload-link`, {
          method: 'POST',
          credentials: 'same-origin',
          headers: {
            'Accept': 'application/json'
          }
        });

        const data = await res.json().catch(() => ({}));

        if (!res.ok || data.success === false || !data.uploadUrl) {
          throw new Error(data.message || 'External upload link create failed');
        }

        const copied = await copyTextToClipboard(data.uploadUrl);

        if (copied) {
          showPopup(
            'success',
            'Upload Link Copied',
            `External upload link copied for ${student}. You can now send it on WhatsApp.`
          );
        } else {
          prompt('Copy this external upload link:', data.uploadUrl);
        }
      } catch (err) {
        console.error(err);
        showPopup(
          'danger',
          'Upload Link Failed',
          err.message || 'Could not create external upload link.'
        );
      } finally {
        btn.disabled = false;
        btn.innerHTML = oldHtml;
      }
    });
  })();
</script>
<script>
  (function () {
    let latestAdmissionFilesCache = [];
