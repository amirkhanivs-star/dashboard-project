<%- include('partials/bootstrap-header', { user, pageTitle: 'Super Admin Dashboard' }) %>
<%- include('partials/flash') %>

<%
  const deptLabel =
    deptFilter === 'quran'
      ? 'Quran Dept'
      : deptFilter === 'tuition'
      ? 'Tuition Dept'
      : deptFilter === 'school'
      ? 'School Dept'
      : 'All Departments';
    
    const paginationData = pagination || {};
  const currentPage = Number(paginationData.page || 1);
  const totalPages = Number(paginationData.totalPages || 1);
  const pageLimit = Number(paginationData.limit || 200);
  const totalRecords = Number(paginationData.totalRecords || 0);
  const startRecord = Number(paginationData.startRecord || 0);
  const endRecord = Number(paginationData.endRecord || 0);

  function buildPageUrl(pageNumber, limitNumber) {
    const params = new URLSearchParams();

    params.set('page', String(pageNumber));
    params.set('limit', String(limitNumber));

    return deptFilter
      ? `/dashboard/super/${encodeURIComponent(deptFilter)}?${params.toString()}`
      : `/dashboard?${params.toString()}`;
  }

  function getVisiblePages(current, total) {
    const pages = [];
    const start = Math.max(1, current - 2);
    const end = Math.min(total, current + 2);

    if (start > 1) {
      pages.push(1);
      if (start > 2) pages.push('dots-left');
    }

    for (let i = start; i <= end; i++) {
      pages.push(i);
    }

    if (end < total) {
      if (end < total - 1) pages.push('dots-right');
      pages.push(total);
    }

    return pages;
  }

  const visiblePages = getVisiblePages(currentPage, totalPages);
  // =========================
  // ✅ PERMISSIONS HELPERS
  // =========================
  const _perms =
    (user && (user.permissions || user.perms || user.permission || user.permissionMap)) || null;

  const _isSuper =
    !!(user && (
      user.role === 'superadmin' ||
      user.role === 'super_admin' ||
      user.agentType === 'superadmin' ||
      user.agentType === 'super_admin' ||
      user.isSuperAdmin === true ||
      user.is_super_admin === true
    ));

  function _getNested(obj, path) {
    try {
      const parts = String(path || '').split('.');
      let cur = obj;
      for (const p of parts) {
        if (!cur || typeof cur !== 'object' || !(p in cur)) return undefined;
        cur = cur[p];
      }
      return cur;
    } catch (e) {
      return undefined;
    }
  }

  function _hasKey(key) {
    if (_isSuper) return true;
    if (!_perms) return false;

    // If permissions are "true" or wildcard
    if (_perms === true) return true;

    // Array format
    if (Array.isArray(_perms)) {
      return _perms.includes(key) || _perms.includes('*') || _perms.includes('all');
    }

    // Object format (flat or nested)
    if (typeof _perms === 'object') {
      if (key in _perms) return !!_perms[key];

      const nested = _getNested(_perms, key);
      if (typeof nested !== 'undefined') return !!nested;

      const alt = key.replace(/\./g, '_');
      if (alt in _perms) return !!_perms[alt];

      return false;
    }

    return false;
  }

  function canAny(keys) {
    return (keys || []).some(k => _hasKey(k));
  }

  function canCol(name) {
    if (_isSuper) return true;
    const k = String(name || '').trim();
    return canAny([
      `super.col.${k}`,
      `super.column.${k}`,
      `dashboard_super.col.${k}`,
      `dashboard-super.col.${k}`,
      `perm.super.col.${k}`,
    ]);
  }

  function canBtn(name) {
    if (_isSuper) return true;
    const k = String(name || '').trim();
    return canAny([
      `super.btn.${k}`,
      `super.button.${k}`,
      `dashboard_super.btn.${k}`,
      `dashboard-super.btn.${k}`,
      `perm.super.btn.${k}`,
    ]);
  }

  const P = {
    col: {
      // ✅ NEW (Current Status + Fee Status)
      status: canCol('status'),
      feeStatus: canCol('feeStatus'),

      dept: canCol('dept'),
      student: canCol('student'),
      father: canCol('father'),
      fatherEmail: canCol('father'),
      grade: canCol('grade'),
      tuitionGrade: canCol('tuitionGrade'),
      phone: canCol('phone'),
      processedBy: canCol('processedBy'),
      paymentStatus: canCol('paymentStatus'),
      paidUpto: canCol('paidUpto'),
      verif: canCol('verificationNumber'),
      reg: canCol('registrationNumber'),
      family: canCol('familyNumber'),
      registrationFee: canCol('registrationFee'),
      fees: canCol('fees'),
      currency: canCol('currency'),
      month: canCol('month'),
      totalFees: canCol('totalFees'),
      pendingDues: canCol('pendingDues'),
      receivedPayment: canCol('receivedPayment'),
      invoiceStatus: canCol('invoiceStatus'),
      invoiceStatusTimestamp: canCol('invoiceStatusTimestamp'),
      paidInvoiceStatus: canCol('paidInvoiceStatus'),
      paidInvoiceStatusTimestamp: canCol('paidInvoiceStatusTimestamp'),
    },
        btn: {
      details: canBtn('details'),
      pdf: canBtn('pdf'),
      update: canBtn('update'),
      whatsapp: canBtn('whatsapp'),
      billing: canBtn('billing'),
      upload: canBtn('upload'),
      files: canBtn('files'),
     deleteAdmission: _hasKey('canDeleteAdmissions'),
    }
  };

    const canDeleteAdmissions = !!P.btn.deleteAdmission;

  const showActions =
    P.btn.details ||
    P.btn.pdf ||
    P.btn.update ||
    P.btn.whatsapp ||
    P.btn.billing ||
    P.btn.upload ||
    P.btn.files ||
    canDeleteAdmissions;

  const showBulkDeleteBar = canDeleteAdmissions;
  // =========================
  // Dynamic dropdown options
  // UI first, backend later
  // =========================
 const DEFAULT_CURRENT_STATUS_OPTIONS =
  (typeof statusOptionsCurrent !== 'undefined' && Array.isArray(statusOptionsCurrent) && statusOptionsCurrent.length)
    ? statusOptionsCurrent
    : [
          { value: 'New Admission', color: '#64748b' },
          { value: 'Running', color: '#22c55e' },
          { value: 'Leave', color: '#f59e0b' },
          { value: 'Stop', color: '#ef4444' },
          { value: 'Left', color: '#2563eb' },
          { value: 'Freez', color: '#94a3b8' }
        ];

 const DEFAULT_FEE_STATUS_OPTIONS =
  (typeof statusOptionsFee !== 'undefined' && Array.isArray(statusOptionsFee) && statusOptionsFee.length)
    ? statusOptionsFee
    : [
          { value: 'New Admission', color: '#64748b' },
          { value: 'Present + Dues', color: '#ef4444' },
          { value: 'Present + No Dues', color: '#22c55e' }
        ];
    const visibleColCount =
    Object.values(P.col).filter(Boolean).length +
    (showActions ? 1 : 0) +
    (canDeleteAdmissions ? 1 : 0);

    const DEFAULT_CURRENCY_OPTIONS =
  (typeof currencyOptions !== 'undefined' && Array.isArray(currencyOptions) && currencyOptions.length)
    ? currencyOptions.map(opt => ({
        id: opt.id,
        value: opt.value || opt.label || opt.opt_key || '',
        label: opt.label || opt.value || opt.opt_key || '',
        is_custom: Number(opt.is_custom || 0)
      })).filter(opt => opt.value)
    : [
        { value: 'AED', label: 'AED', is_custom: 0 },
        { value: 'SAR', label: 'SAR', is_custom: 0 },
        { value: 'PKR', label: 'PKR', is_custom: 0 },
        { value: 'USD', label: 'USD', is_custom: 0 },
        { value: 'GBP', label: 'GBP', is_custom: 0 }
      ];
      const DEFAULT_BANK_OPTIONS =
  (typeof bankOptions !== 'undefined' && Array.isArray(bankOptions) && bankOptions.length)
    ? bankOptions.map(opt => ({
        id: opt.id,
        value: opt.value || opt.label || opt.opt_key || '',
        label: opt.label || opt.value || opt.opt_key || '',
        is_custom: Number(opt.is_custom || 0)
      })).filter(opt => opt.value)
    : [
        { value: 'Meezan Bank', label: 'Meezan Bank', is_custom: 0 },
        { value: 'Bank Al Habib', label: 'Bank Al Habib', is_custom: 0 },
        { value: 'HBL', label: 'HBL', is_custom: 0 },
        { value: 'UBL', label: 'UBL', is_custom: 0 },
        { value: 'JazzCash', label: 'JazzCash', is_custom: 0 },
        { value: 'EasyPaisa', label: 'EasyPaisa', is_custom: 0 }
      ];
         
    const DEFAULT_CLASS_OPTIONS =
  (typeof classOptions !== 'undefined' && Array.isArray(classOptions) && classOptions.length)
    ? classOptions
    : [
        'FS 1',
        'FS 2',
        'FS 3',
        'Grade 1',
        'Grade 2',
        'Grade 3',
        'Grade 4',
        'Grade 5',
        'Grade 6',
        'Grade 7',
        'Grade 8 (FBISE)',
        "Grade 8 (IGCSE / O'Level)",
        'Grade 9 (FBISE)',
        "Grade 9 (IGCSE / O'Level)",
        'Grade 10 (FBISE)',
        "Grade 10 (IGCSE / O'Level)",
        'Grade 11 (FBISE)',
        "Grade 11 (IGCSE, O / A'Level)",
        'Grade 12 (FBISE)'
      ];
%>

<div class="super-shell">

