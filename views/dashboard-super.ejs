          <span id="bulkDeleteCount">0</span> selected
        </span>

        <button
          type="button"
          class="btn btn-outline-danger rounded-pill px-3"
          id="bulkDeleteBtn">
          <i class="bi bi-trash3 me-1"></i> Delete Selected
        </button>
      </div>
    <% } %>

    <div class="ms-auto d-flex justify-content-end">
      <button
        type="button"
        class="btn rounded-pill px-4 bulk-challan-open-btn"
        id="openBulkChallanBtn">
        <i class="bi bi-whatsapp me-2"></i>Send Bulk Challan
      </button>
    </div>
  </div>
</div>

    <div class="card-body p-0">
      <!-- ✅ ONLY PIPELINE SCROLL -->
