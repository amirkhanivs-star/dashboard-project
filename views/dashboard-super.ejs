        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card super-stat-card stat-danger">
        <div class="card-body">
          <div class="stat-label mb-1">Tuition + School</div>
          <div class="stat-value-sm">
            <%= (deptFilter === 'tuition' || deptFilter === 'school') ? totalRecords : admissions.filter(a => a.dept !== 'quran').length %> students
