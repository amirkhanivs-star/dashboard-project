  function normalizeBankRows(rows) {
    return (rows || []).map(row => ({
      id: row.id,
      value: row.value || row.label || row.opt_key || '',
      label: row.label || row.value || row.opt_key || '',
      is_custom: Number(row.is_custom || 0)
    })).filter(x => x.value);
  }

  async function fetchBankOptions() {
    const res = await fetch('/api/options/bank', {
      headers: { Accept: 'application/json' }
    });

    const data = await res.json();
    if (!res.ok || !data.success) {
      throw new Error(data.message || 'Failed to load bank options');
    }

    window.BANK_OPTION_CACHE = normalizeBankRows(data.data || []);
    return window.BANK_OPTION_CACHE;
  }

  async function createBankOption(value) {
    const res = await fetch('/api/options/bank', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        Accept: 'application/json'
      },
      body: JSON.stringify({ label: value })
    });

    const data = await res.json();
    if (!res.ok || !data.success) {
      throw new Error(data.message || 'Failed to save bank option');
    }

    return data.data;
  }

  async function deleteBankOption(id) {
    const res = await fetch(`/api/options/bank/${id}`, {
      method: 'DELETE',
      headers: { Accept: 'application/json' }
    });

    const data = await res.json();
    if (!res.ok || !data.success) {
      throw new Error(data.message || 'Failed to delete bank option');
    }

    return true;
  }

  function renderBankList() {
    const items = Array.isArray(window.BANK_OPTION_CACHE)
      ? window.BANK_OPTION_CACHE
      : [];

    if (!items.length) {
      listEl.innerHTML = '<div class="status-option-empty">No bank options available.</div>';
      return;
    }

    listEl.innerHTML = items.map(item => `
      <div class="currency-option-item">
        <div class="currency-option-name">${item.label}</div>
        <div class="currency-option-actions">
          ${item.is_custom ? `
  <button
    type="button"
    class="btn btn-sm btn-outline-danger rounded-pill bank-option-delete-btn"
    data-id="${item.id}"
  >
    Delete
  </button>
` : ''}
        </div>
      </div>
    `).join('');
  }

  function rebuildBankSelect(selectEl, items, selectedValue, includeAdd) {
    if (!selectEl) return;

    let html = '<option value="">Select bank</option>';

    html += items.map(item => {
      const selected = String(selectedValue || '') === String(item.value) ? 'selected' : '';
      return `<option value="${item.value}" ${selected}>${item.label}</option>`;
    }).join('');

    if (includeAdd) {
      html += '<option value="__add_new_bank__">+ Add Option</option>';
    }

    selectEl.innerHTML = html;
  }

  function refreshBankDropdowns() {
    const items = Array.isArray(window.BANK_OPTION_CACHE)
      ? window.BANK_OPTION_CACHE
      : [];

    document.querySelectorAll('.js-bank-select').forEach(sel => {
      const selected = sel.getAttribute('data-prev-value') || sel.value || '';
      rebuildBankSelect(sel, items, selected, true);
      sel.value = selected || '';
    });
  }

  async function loadBankOptionsAndRefresh() {
    await fetchBankOptions();
    renderBankList();
    refreshBankDropdowns();
  }

 function openBankModal(selectEl) {
  pendingSelect = selectEl || null;

  bankModalEl.classList.remove("d-none");
  bankModalEl.setAttribute("aria-hidden", "false");
}

  document.addEventListener('change', function (e) {
    const el = e.target;
    if (!el) return;

    if (el.matches('.js-bank-select')) {
      if (el.value === '__add_new_bank__') {
        const prev = el.getAttribute('data-prev-value') || '';
        el.value = prev;
        openBankModal(el);
        return;
      }
      el.setAttribute('data-prev-value', el.value || '');
    }
  });

  if (saveBtn) {
    saveBtn.addEventListener('click', async function () {
      try {
        const val = String(inputEl.value || '').trim();

        if (!val) {
          alert('Bank name required');
          return;
        }

        const existing = window.BANK_OPTION_CACHE || [];
        const dup = existing.some(x => String(x.value || '').trim().toLowerCase() === val.toLowerCase());

        if (dup) {
          alert('Ye bank pehle se mojood hai');
          return;
        }

        const created = await createBankOption(val);
        await loadBankOptionsAndRefresh();

        if (pendingSelect) {
          const newVal = created.value || created.label || created.opt_key || val;
          pendingSelect.value = newVal;
          pendingSelect.setAttribute('data-prev-value', newVal);
        }

        inputEl.value = '';
      } catch (err) {
        alert(err.message || 'Bank save failed');
      }
    });
  }

  listEl.addEventListener('click', async function (e) {
    const btn = e.target.closest('.bank-option-delete-btn');
    if (!btn) return;

    try {
      const id = Number(btn.getAttribute('data-id'));
      if (!id) return;

      const items = window.BANK_OPTION_CACHE || [];
const item = items.find(x => Number(x.id) === id);

if (!item) return;

if (Number(item.is_custom || 0) !== 1) {
  alert('Sirf user-added option delete ho sakta hai');
  return;
}

      await deleteBankOption(id);
      await loadBankOptionsAndRefresh();
    } catch (err) {
      alert(err.message || 'Delete failed');
    }
  });
document.addEventListener("click", function (e) {
  if (e.target.closest(".bank-option-close-btn")) {
    bankModalEl.classList.add("d-none");
    bankModalEl.setAttribute("aria-hidden", "true");
    return;
  }

  if (e.target === bankModalEl) {
    bankModalEl.classList.add("d-none");
    bankModalEl.setAttribute("aria-hidden", "true");
  }
});
  loadBankOptionsAndRefresh().catch(err => {
    console.error('Bank options load error:', err);
  });
})();

</script>

<script>
  (function () {
    const STORAGE_KEY = "super_dashboard_viewport";
    const RECENT_KEY = "super_dashboard_recent_submit";

    function getPipelineScroll() {
      return document.querySelector(".pipeline-scroll");
    }

    function getMainScrollTop() {
      return (
        window.pageYOffset ||
        document.documentElement.scrollTop ||
        document.body.scrollTop ||
        0
      );
    }

    function setMainScrollTop(value) {
      window.scrollTo(0, Number(value || 0));
      document.documentElement.scrollTop = Number(value || 0);
      document.body.scrollTop = Number(value || 0);
    }

    window.saveViewportState = function () {
      const wrap = getPipelineScroll();

      const state = {
        pageY: getMainScrollTop(),
        tableLeft: wrap ? wrap.scrollLeft : 0,
        tableTop: wrap ? wrap.scrollTop : 0
      };

      sessionStorage.setItem(STORAGE_KEY, JSON.stringify(state));
    };

    function restoreViewportState() {
      const raw = sessionStorage.getItem(STORAGE_KEY);
      if (!raw) return;

      try {
        const state = JSON.parse(raw);
        const wrap = getPipelineScroll();

        const applyRestore = function () {
          setMainScrollTop(state.pageY || 0);

          if (wrap) {
            wrap.scrollLeft = Number(state.tableLeft || 0);
            wrap.scrollTop = Number(state.tableTop || 0);
          }
        };

        applyRestore();

        requestAnimationFrame(() => {
          applyRestore();

          requestAnimationFrame(() => {
            applyRestore();

            setTimeout(() => {
              applyRestore();
            }, 120);
          });
        });
      } catch (err) {
        console.error("Viewport restore failed:", err);
      }

      sessionStorage.removeItem(STORAGE_KEY);
    }

    function bindSaveEvents() {
      document.querySelectorAll('form[id^="rowForm_"]').forEach(form => {
        if (form.dataset.viewportBound === "1") return;
        form.dataset.viewportBound = "1";

        form.addEventListener("submit", function () {
          window.saveViewportState();
          sessionStorage.setItem(RECENT_KEY, "1");
        });
      });

      document.querySelectorAll(".action-update").forEach(btn => {
        if (btn.dataset.viewportBound === "1") return;
        btn.dataset.viewportBound = "1";

        btn.addEventListener("click", function () {
          window.saveViewportState();
          sessionStorage.setItem(RECENT_KEY, "1");
        });
      });
    }

    document.addEventListener("DOMContentLoaded", function () {
      bindSaveEvents();
    });

    window.addEventListener("load", function () {
      restoreViewportState();

      setTimeout(function () {
        sessionStorage.removeItem(RECENT_KEY);
      }, 8000);
    });
  })();
</script>

<%- include('partials/bootstrap-footer') %>
<script>
  (function () {
    const canDeleteAdmissions = <%- JSON.stringify(!!canDeleteAdmissions) %>;
    if (!canDeleteAdmissions) return;

    const selectAllEl = document.getElementById('selectAllAdmissions');
    const bulkDeleteToolbar = document.getElementById('bulkDeleteToolbar');
    const bulkDeleteCount = document.getElementById('bulkDeleteCount');
    const bulkDeleteBtn = document.getElementById('bulkDeleteBtn');

    const confirmModalEl = document.getElementById('confirmModal');
    const confirmModalTitle = document.getElementById('confirmModalTitle');
    const confirmModalBody = document.getElementById('confirmModalBody');
    const confirmModalOk = document.getElementById('confirmModalOk');

    if (!confirmModalEl || !confirmModalOk) return;

    const confirmModal =
      typeof bootstrap !== 'undefined'
        ? bootstrap.Modal.getOrCreateInstance(confirmModalEl)
        : null;

    function getRowCheckboxes() {
      return Array.from(document.querySelectorAll('.admission-row-checkbox'));
    }

    function getSelectedCheckboxes() {
      return getRowCheckboxes().filter(cb => cb.checked);
    }

    function getSelectedIds() {
      return getSelectedCheckboxes().map(cb => Number(cb.value)).filter(Boolean);
    }

    function updateBulkToolbar() {
      const selected = getSelectedCheckboxes();
      const count = selected.length;

      if (bulkDeleteCount) {
        bulkDeleteCount.textContent = String(count);
      }

      if (bulkDeleteToolbar) {
        bulkDeleteToolbar.classList.toggle('d-none', count === 0);
      }

      if (selectAllEl) {
        const all = getRowCheckboxes();
        selectAllEl.checked = !!all.length && count === all.length;
        selectAllEl.indeterminate = count > 0 && count < all.length;
      }
    }

    function showPopup(type, title, message) {
      if (typeof window.showUploadFlash === 'function') {
        window.showUploadFlash(type, title, message);
      } else {
        alert(message || title || 'Notification');
      }
    }

    function openSingleDeleteModal(id, studentName) {
      confirmModalTitle.textContent = 'Delete Admission';
      confirmModalBody.textContent =
        `Are you sure you want to delete ${studentName || 'this admission'}? This action cannot be undone.`;

      confirmModalOk.dataset.mode = 'single';
      confirmModalOk.dataset.admissionId = String(id || '');

      if (confirmModal) confirmModal.show();
    }

    function openBulkDeleteModal(ids) {
      confirmModalTitle.textContent = 'Delete Selected Admissions';
      confirmModalBody.textContent =
        `You are about to delete ${ids.length} selected admission(s). This action cannot be undone.`;

      confirmModalOk.dataset.mode = 'bulk';
      confirmModalOk.dataset.admissionId = '';

      if (confirmModal) confirmModal.show();
    }

    async function deleteSingle(id) {
      const res = await fetch(`/api/admissions/${id}`, {
        method: 'DELETE',
        headers: { Accept: 'application/json' }
      });

      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.success) {
        throw new Error(data.message || 'Delete failed');
      }

      return data;
    }

    async function deleteBulk(ids) {
      const res = await fetch('/api/admissions/bulk-delete', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'application/json'
        },
        body: JSON.stringify({ ids })
      });

      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.success) {
        throw new Error(data.message || 'Bulk delete failed');
      }

      return data;
    }

    document.addEventListener('change', function (e) {
      if (e.target.matches('.admission-row-checkbox')) {
        updateBulkToolbar();
      }

      if (e.target === selectAllEl) {
        const checked = !!selectAllEl.checked;
        getRowCheckboxes().forEach(cb => {
          cb.checked = checked;
        });
        updateBulkToolbar();
      }
    });

    document.addEventListener('click', function (e) {
      const rowDeleteBtn = e.target.closest('.btn-delete-admission');
      if (rowDeleteBtn) {
        const id = Number(rowDeleteBtn.getAttribute('data-admission-id') || 0);
        const studentName = String(rowDeleteBtn.getAttribute('data-student-name') || '').trim();
        if (!id) return;

        openSingleDeleteModal(id, studentName);
        return;
      }

            const bulkDeleteTrigger = e.target.closest('#bulkDeleteBtn');
      if (bulkDeleteBtn && bulkDeleteTrigger) {
        const ids = getSelectedIds();
        if (!ids.length) {
          showPopup('error', 'No Selection', 'Please select at least one admission.');
          return;
        }

        openBulkDeleteModal(ids);
        return;
      }

      if (e.target === confirmModalOk) {
        const mode = String(confirmModalOk.dataset.mode || '').trim();

        (async function () {
          try {
            confirmModalOk.disabled = true;

            if (mode === 'single') {
              const id = Number(confirmModalOk.dataset.admissionId || 0);
              if (!id) throw new Error('Invalid admission id');

              await deleteSingle(id);
              if (confirmModal) confirmModal.hide();

              showPopup('success', 'Deleted', 'Admission deleted successfully.');

              if (typeof window.saveViewportState === 'function') {
                window.saveViewportState();
              }

              setTimeout(() => window.location.reload(), 500);
              return;
            }

            if (mode === 'bulk') {
              const ids = getSelectedIds();
              if (!ids.length) throw new Error('No admissions selected');

              await deleteBulk(ids);
              if (confirmModal) confirmModal.hide();

              showPopup('success', 'Deleted', 'Selected admissions deleted successfully.');

              if (typeof window.saveViewportState === 'function') {
                window.saveViewportState();
              }

              setTimeout(() => window.location.reload(), 500);
              return;
            }
          } catch (err) {
            showPopup('error', 'Delete Failed', err.message || 'Delete failed');
          } finally {
            confirmModalOk.disabled = false;
          }
        })();
      }
    });

    updateBulkToolbar();
  })();
</script>
<script>
  (function () {
    document.addEventListener('DOMContentLoaded', function () {
    const openBtn = document.getElementById('openBulkChallanBtn');
    const modalEl = document.getElementById('bulkChallanModal');
    if (!openBtn || !modalEl || typeof bootstrap === 'undefined') return;

    const bulkModal = bootstrap.Modal.getOrCreateInstance(modalEl);

    const monthEl = document.getElementById('bulkChallanMonth');
    const monthGrid = document.getElementById('bulkChallanMonthGrid');
    const feeTypeEl = document.getElementById('bulkChallanFeeType');
    const classEl = document.getElementById('bulkChallanClass');
    const classGrid = document.getElementById('bulkChallanClassGrid');
    const sectionEl = document.getElementById('bulkChallanSection');
    const yearEl = document.getElementById('bulkChallanYear');

    const createBtn = document.getElementById('bulkChallanCreateBtn');
    const sendBtn = document.getElementById('bulkChallanSendBtn');

    const summaryBox = document.getElementById('bulkChallanSummaryBox');
    const summaryText = document.getElementById('bulkChallanSummaryText');

        if (monthGrid && monthEl) {
      monthGrid.addEventListener('click', function (e) {
        const chip = e.target.closest('.bulk-month-chip');
        if (!chip) return;

        monthGrid.querySelectorAll('.bulk-month-chip').forEach(btn => btn.classList.remove('active'));
        chip.classList.add('active');
        monthEl.value = chip.getAttribute('data-month') || '';
      });
    }

    if (classGrid && classEl) {
  classGrid.addEventListener('click', function (e) {
    const chip = e.target.closest('.bulk-class-chip');
    if (!chip) return;

    classGrid.querySelectorAll('.bulk-class-chip').forEach(btn => btn.classList.remove('active'));
    chip.classList.add('active');
    classEl.value = chip.getAttribute('data-class') || '';
  });
}

    function showPopup(type, title, message) {
      if (typeof window.showUploadFlash === 'function') {
        window.showUploadFlash(type, title, message);
      } else {
        alert(message || title || 'Notification');
      }
    }

    function getPayload() {
      return {
        month: String(monthEl?.value || '').trim(),
        feeType: String(feeTypeEl?.value || '').trim(),
        className: String(classEl?.value || '').trim(),
        section: String(sectionEl?.value || 'All Sections').trim(),
        year: String(yearEl?.value || '').trim()
      };
    }

    function validatePayload(payload) {
      return !!(
        payload.month &&
        payload.feeType &&
        payload.className &&
        payload.section &&
        payload.year
      );
    }

    function setLoading(btn, state, loadingText, normalHtml) {
      if (!btn) return;
      btn.disabled = !!state;
      btn.innerHTML = state ? loadingText : normalHtml;
    }

    async function postJson(url, payload) {
      const res = await fetch(url, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify(payload)
      });

      const data = await res.json().catch(() => ({}));
      return { ok: res.ok, data };
    }

  openBtn.addEventListener('click', function () {
  summaryBox.classList.add('d-none');
  summaryText.textContent = '-';

  monthEl.value = '';
  classEl.value = '';

  if (monthGrid) {
    monthGrid.querySelectorAll('.bulk-month-chip').forEach(btn => btn.classList.remove('active'));
  }

  if (classGrid) {
    classGrid.querySelectorAll('.bulk-class-chip').forEach(btn => btn.classList.remove('active'));
  }

  bulkModal.show();
});

    createBtn.addEventListener('click', async function () {
      const payload = getPayload();

      if (!validatePayload(payload)) {
        showPopup('error', 'Invalid Selection', 'Please select month, fee type, class, section and year.');
        return;
      }

      const normalHtml = '<i class="bi bi-receipt-cutoff me-1"></i> Create Invoice';
      try {
        setLoading(createBtn, true, '<span class="spinner-border spinner-border-sm me-2"></span>Creating...', normalHtml);

        const result = await postJson('/api/bulk-challan/create', payload);

        if (!result.ok || !result.data?.success) {
          showPopup('error', 'Update Failed', result.data?.message || 'Invoice status update failed.');
          return;
        }

        const summary = result.data.summary || {};
        summaryText.textContent =
          `Matched: ${summary.totalMatched || 0} | Ready to Send: ${summary.readyToSend || 0} | Already Updated: ${summary.alreadyUpdated || 0}`;
        summaryBox.classList.remove('d-none');

        showPopup('success', 'Success', result.data?.message || 'Invoice status updated successfully.');

        if (typeof window.saveViewportState === 'function') {
          window.saveViewportState();
        }

        setTimeout(() => window.location.reload(), 900);
      } catch (err) {
        console.error(err);
        showPopup('error', 'Update Failed', 'Invoice status update failed.');
      } finally {
        setLoading(createBtn, false, '', normalHtml);
      }
    });

    sendBtn.addEventListener('click', async function () {
      const payload = getPayload();

      if (!validatePayload(payload)) {
        showPopup('error', 'Invalid Selection', 'Please select month, fee type, class, section and year.');
        return;
      }

      const normalHtml = '<i class="bi bi-whatsapp me-1"></i> Send Invoice to WhatsApp';
      try {
        setLoading(sendBtn, true, '<span class="spinner-border spinner-border-sm me-2"></span>Sending...', normalHtml);

        const result = await postJson('/api/bulk-challan/send-whatsapp', payload);

        if (!result.ok || !result.data?.success) {
          showPopup('error', 'Send Failed', result.data?.message || 'Failed to send invoices to WhatsApp.');
          return;
        }

        showPopup(
          'success',
          'Sent Successfully',
          result.data?.message || 'Invoices sent to WhatsApp successfully.'
        );
      } catch (err) {
        console.error(err);
        showPopup('error', 'Send Failed', 'Failed to send invoices to WhatsApp.');
      } finally {
        setLoading(sendBtn, false, '', normalHtml);
      }
    });
   });
  })();
</script>