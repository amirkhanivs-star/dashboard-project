  <div>
    <strong>Admissions Pipeline</strong>
  </div>

  <div class="d-flex align-items-center gap-2 flex-wrap">
    <button
      type="button"
      id="applyRealtimeUpdatesBtn"
      class="btn btn-sm btn-warning rounded-pill px-3 d-none">
