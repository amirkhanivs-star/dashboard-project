</div>
  </div>
</div>

    <div class="card-body p-0">
      <!-- ✅ ONLY PIPELINE SCROLL -->
     <div class="pipeline-scroll admission-card-scroll">
  <div class="admission-card-grid">

    <% if (!admissions || admissions.length === 0) { %>
      <div class="text-center small text-muted py-4 w-100">
        No admissions found for this view.
      </div>
    <% } %>

    <% admissions.forEach((a, index) => { 
      const currentStatusVal = (a.status || a.currentStatus || a.current_status || '').trim();
      const feeStatusVal = (a.feeStatus || a.fee_status || a.feeStatusText || '').trim();

      const cardFields = [
  { key: 'no', show: true, label: 'No.', value: (startRecord || 1) + index },
  { key: 'status', show: P.col.status, label: 'Current Status', value: currentStatusVal || '-' },
  { key: 'feeStatus', show: P.col.feeStatus, label: 'Fee Status', value: feeStatusVal || '-' },
  { key: 'dept', show: P.col.dept, label: 'Dept', value: a.dept || '-' },
  { key: 'student', show: P.col.student, label: 'Student', value: a.student || a.studentName || '-' },
  { key: 'father', show: P.col.father, label: 'Father', value: a.father || a.fatherName || '-' },
  { key: 'grade', show: P.col.grade, label: 'Grade', value: a.grade || '-' },
  { key: 'tuitionGrade', show: P.col.tuitionGrade, label: 'Grade Section', value: a.tuitionGrade || '-' },
  { key: 'fatherEmail', show: P.col.fatherEmail, label: 'Email Address', value: a.fatherEmail || a.father_email || '-' },
  { key: 'phone', show: P.col.phone, label: 'Phone Number', value: a.phone || a.contactNumber || '-' },
  { key: 'processedBy', show: P.col.processedBy, label: 'Processed By', value: a.processedBy || a.processed_by || '-' },
  { key: 'paymentStatus', show: P.col.paymentStatus, label: 'Payment Status', value: (a.accounts && a.accounts.paymentStatus) || '-' },
  { key: 'paidUpto', show: P.col.paidUpto, label: 'Paid Upto', value: (a.accounts && a.accounts.paidUpto) || '-' },
  { key: 'verificationNumber', show: P.col.verif, label: 'Verif #', value: a.latestBillingVerificationNumber || '-' },
  { key: 'registrationNumber', show: P.col.reg, label: 'Reg #', value: (a.accounts && a.accounts.registrationNumber) || '-' },
  { key: 'familyNumber', show: P.col.family, label: 'Family #', value: (a.accounts && a.accounts.familyNumber) || '-' },
  { key: 'registrationFee', show: P.col.registrationFee, label: 'Registration Fee', value: (a.admission && a.admission.registrationFee) || '-' },
  { key: 'fees', show: P.col.fees, label: 'Monthly Fees', value: (a.admission && a.admission.fees) || '-' },
  { key: 'currency', show: P.col.currency, label: 'Currency', value: (a.currency_code || a.currencyCode || (a.admission && (a.admission.currencyCode || a.admission.currency_code))) || '-' },
  { key: 'month', show: P.col.month, label: 'Month/Year', value: (a.admission && a.admission.month) || '-' },
  { key: 'totalFees', show: P.col.totalFees, label: 'Total Fees', value: (a.admission && a.admission.totalFees) || '-' },
  { key: 'pendingDues', show: P.col.pendingDues, label: 'Pending Dues', value: (a.admission && a.admission.pendingDues) || '-' },
  { key: 'receivedPayment', show: P.col.receivedPayment, label: 'Received Payment', value: (a.admission && a.admission.receivedPayment) || '0' },
  { key: 'invoiceStatus', show: P.col.invoiceStatus, label: 'Invoice Status', value: (a.admission && a.admission.invoiceStatus) || '-' },
  { key: 'invoiceStatusTimestamp', show: P.col.invoiceStatusTimestamp, label: 'Invoice Status Timestamp', value: (a.admission && a.admission.invoiceStatusTimestamp) || '-' },
  { key: 'paidInvoiceStatus', show: P.col.paidInvoiceStatus, label: 'Paid Invoice Status', value: (a.admission && a.admission.paidInvoiceStatus) || '-' },
  { key: 'paidInvoiceStatusTimestamp', show: P.col.paidInvoiceStatusTimestamp, label: 'Paid Invoice Status Timestamp', value: (a.admission && a.admission.paidInvoiceStatusTimestamp) || '-' }
];
    %>

      <div
