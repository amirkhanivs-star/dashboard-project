          <div class="quick-icon q-quran">
            <i class="bi bi-moon-stars"></i>
          </div>
          <div class="flex-grow-1">
            <div class="fw-semibold">Quran</div>
            <small class="text-muted">Quran Admissions · Accounts · Management</small>
          </div>
          <a href="/dashboard/super/quran" class="btn btn-sm btn-outline-primary rounded-pill px-3">
            Open
          </a>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card border-0 shadow-sm super-quick-link">
