            <div class="admission-avatar">
              <%= String(a.student || a.studentName || 'A').charAt(0).toUpperCase() %>
            </div>

            <div>
              <div class="admission-title">
                <%= a.student || a.studentName || 'No Name' %>
              </div>
              <div class="admission-subtitle">
                <%= a.father || a.fatherName || '-' %>
              </div>
            </div>
          </div>

          <div class="admission-card-top-right">
  <% if (a.hasLatestUpload && a.latestUpload) { %>
  <a
    href="<%= a.latestUpload.fileUrl || '#' %>"
    target="_blank"
    class="admission-file-bill-icon <%= a.latestUpload.seenByCurrentUser ? 'seen-file-icon' : 'new-file-icon' %>"
    data-upload-id="<%= a.latestUpload.id %>"
    data-admission-id="<%= a.id %>"
    data-student="<%= a.student || a.studentName || 'No Name' %>"
    data-father="<%= a.father || a.fatherName || '-' %>"
    data-added-by="<%= a.latestUpload.addedBy || 'System / Old Record' %>"
    data-added-by-role="<%= a.latestUpload.addedByRole || '' %>"
    data-file-name="<%= a.latestUpload.fileName || 'File' %>"
    data-uploaded-at="<%= a.latestUpload.uploadedAt || '' %>"
    title="Open file">
    <i class="bi bi-receipt-cutoff"></i>

    <span class="admission-file-tooltip <%= a.latestUpload.seenByCurrentUser ? 'seen-file-tooltip' : 'new-file-tooltip' %>">
      <span class="file-tooltip-title">
        <%= a.latestUpload.seenByCurrentUser ? 'File Seen' : 'New File Added' %>
      </span>

      <span class="file-tooltip-row">
        <b>Added by:</b>
        <%= a.latestUpload.addedBy || 'System / Old Record' %>
      </span>

      <% if (a.latestUpload.addedByRole) { %>
        <span class="file-tooltip-row">
          <b>Role:</b>
          <%= String(a.latestUpload.addedByRole || '').replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) %>
        </span>
      <% } %>

      <span class="file-tooltip-row">
        <b>File:</b>
        <%= a.latestUpload.fileName || 'File' %>
      </span>

      <% if (a.latestUpload.uploadedAt) { %>
        <span class="file-tooltip-row">
          <b>Date:</b>
          <%= a.latestUpload.uploadedAt %>
        </span>
      <% } %>
    </span>
  </a>
<% } %>

  <span class="admission-role-pill">
    <%= a.dept || 'Dept' %>
  </span>
</div>
        </div>

        <div class="admission-card-fields">
          <% cardFields.forEach(field => { %>
            <% if (field.show) { %>

    <% if (P.btn.edit) { %>
    <a
      href="/dashboard/super/admission/<%= a.id %>/edit?focus=<%= encodeURIComponent(field.key || '') %>"
      class="admission-field-link <%= getCardFieldClass(field) %>"
      data-field-key="<%= field.key || '' %>"
      style="<%= getCardFieldStyle(field) %>">
      <span class="field-label"><%= field.label %></span>
      <span class="field-value"><%= field.value %></span>
    </a>
  <% } else { %>
    <span
      class="admission-field-link <%= getCardFieldClass(field) %> no-edit-field"
      data-field-key="<%= field.key || '' %>"
      style="<%= getCardFieldStyle(field) %>">
      <span class="field-label"><%= field.label %></span>
      <span class="field-value"><%= field.value %></span>
    </span>
  <% } %>
            <% } %>
          <% }) %>
        </div>

        <% if (showActions) { %>
          <div class="admission-card-actions">

            <% if (P.btn.details) { %>
              <a href="/dashboard/super/admission/<%= a.id %>" class="mini-action-btn mini-dark">
                <i class="bi bi-eye"></i> Details
              </a>
            <% } %>

                       <% if (P.btn.edit) { %>
              <a href="/dashboard/super/admission/<%= a.id %>/edit" class="mini-action-btn mini-red">
                <i class="bi bi-pencil-square"></i> Edit
              </a>
            <% } %>

            <% if (P.btn.pdf) { %>
              <a href="/admissions/<%= a.id %>/pdf" target="_blank" class="mini-action-btn mini-pdf">
                <i class="bi bi-file-earmark-pdf-fill"></i> PDF
              </a>
            <% } %>

            <% if (P.btn.billing) { %>
              <button
  type="button"
  class="mini-action-btn mini-purple btn-billing"
  data-admission-id="<%= a.id %>"
  data-student="<%= a.student || a.studentName || '' %>"
  data-grade="<%= a.grade || '' %>"
  data-phone="<%= a.phone || a.contactNumber || '' %>"
  data-fees="<%= (a.admission && a.admission.fees) || '' %>"
  data-currency="<%= (a.currency_code || a.currencyCode || (a.admission && (a.admission.currencyCode || a.admission.currency_code))) || '' %>">
  <i class="bi bi-receipt"></i> Billing
</button>
            <% } %>

            <% if (P.btn.whatsapp) { %>
              <button
  type="button"
  class="mini-action-btn mini-whatsapp btn-whatsapp"
  data-admission-id="<%= a.id %>"
  data-student="<%= a.student || a.studentName || '' %>"
  data-grade="<%= a.grade || '' %>"
  data-phone="<%= a.phone || a.contactNumber || '' %>">
  <i class="bi bi-whatsapp"></i> WhatsApp
</button>
            <% } %>

            <% if (P.btn.upload) { %>
  <input
    type="file"
    id="file_card_<%= a.id %>"
    class="d-none"
    data-admission-id="<%= a.id %>"
    accept=".png,.jpg,.jpeg,.webp,.pdf,.doc,.docx,.xls,.xlsx,.txt" />

  <button
    type="button"
    class="mini-action-btn mini-blue"
    onclick="document.getElementById('file_card_<%= a.id %>').click()">
    <i class="bi bi-upload"></i> Upload
  </button>

  <button
    type="button"
    class="mini-action-btn mini-external-upload btn-external-upload-link"
    data-admission-id="<%= a.id %>"
    data-student="<%= a.student || a.studentName || '' %>">
    <i class="bi bi-link-45deg"></i> Upload Link
  </button>
<% } %>

            <% if (P.btn.files) { %>
              <a
                href="<%= _isSuper ? '/dashboard/super/files?admission_id=' + a.id : '/admin/files?admission_id=' + a.id %>"
                class="mini-action-btn mini-blue">
                <i class="bi bi-folder2-open"></i> Files
              </a>
            <% } %>

            <% if (canDeleteAdmissions) { %>
              <button
                type="button"
                class="mini-action-btn mini-danger btn-delete-admission"
                data-admission-id="<%= a.id %>"
                data-student-name="<%= a.student || a.studentName || '' %>">
                <i class="bi bi-trash3"></i> Delete
              </button>
            <% } %>

          </div>
        <% } %>

      </div>

    <% }) %>

  </div>
</div>

            <div class="super-pagination-wrap d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 px-3 py-3 border-top">
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <span class="small text-muted">Rows per page</span>

          <select
  class="form-select form-select-sm super-pagination-limit"
  onchange="document.documentElement.classList.add('ivs-page-leaving'); document.documentElement.classList.add('ivs-loading'); setTimeout(() => { window.location.href=this.value; }, 1000);">
  <option value="<%= buildPageUrl(1, 50) %>" <%= pageLimit === 50 ? 'selected' : '' %>>50</option>
  <option value="<%= buildPageUrl(1, 100) %>" <%= pageLimit === 100 ? 'selected' : '' %>>100</option>
  <option value="<%= buildPageUrl(1, 200) %>" <%= pageLimit === 200 ? 'selected' : '' %>>200</option>
  <option value="<%= buildPageUrl(1, 500) %>" <%= pageLimit === 500 ? 'selected' : '' %>>500</option>
</select>

          <span class="small text-muted">
            <%= startRecord %> - <%= endRecord %> of <%= totalRecords %>
          </span>
        </div>

        <% if (totalPages > 1) { %>
          <div class="d-flex align-items-center gap-2 flex-wrap justify-content-lg-end">
            <% if (currentPage > 1) { %>
              <a href="<%= buildPageUrl(currentPage - 1, pageLimit) %>" class="super-page-btn super-page-nav">
                Previous
              </a>
            <% } else { %>
              <span class="super-page-btn super-page-nav disabled">Previous</span>
            <% } %>

            <% visiblePages.forEach(p => { %>
              <% if (p === 'dots-left' || p === 'dots-right') { %>
                <span class="super-page-dots">...</span>
              <% } else if (p === currentPage) { %>
                <span class="super-page-btn active"><%= p %></span>
              <% } else { %>
                <a href="<%= buildPageUrl(p, pageLimit) %>" class="super-page-btn"><%= p %></a>
              <% } %>
            <% }) %>

            <% if (currentPage < totalPages) { %>
              <a href="<%= buildPageUrl(currentPage + 1, pageLimit) %>" class="super-page-btn super-page-nav">
                Next
              </a>
            <% } else { %>
              <span class="super-page-btn super-page-nav disabled">Next</span>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
