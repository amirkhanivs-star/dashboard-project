    function normalizeFileItem(item) {
      return {
        uploadId: item.uploadId || item.id || '',
        admissionId: item.admissionId || '',
        fileUrl: item.fileUrl || '#',
        seen: item.seen === true || item.seenByCurrentUser === true,
        student: item.student || item.studentName || 'No Name',
        father: item.father || item.fatherName || '-',
        addedBy: item.addedBy || item.uploadedByName || 'System / Old Record',
        addedByRole: item.addedByRole || item.uploadedByRole || '',
        fileName: item.fileName || item.originalName || 'File',
        uploadedAt: item.uploadedAt || '',
        dept: item.dept || '',
        grade: item.grade || '',
        registrationNumber: item.registrationNumber || '',
        familyNumber: item.familyNumber || ''
      };
    }
function getAdmissionCardUploadState(card) {
  if (!card) return 'none';

  const icon = card.querySelector('.admission-file-bill-icon');

  if (!icon) return 'none';

  if (icon.classList.contains('seen-file-icon')) return 'seen';
  if (icon.classList.contains('new-file-icon')) return 'unseen';

  return 'none';
}

function setActiveFileFilterButton(filter) {
  document.querySelectorAll('[data-admission-file-filter]').forEach(btn => {
    const btnFilter = btn.getAttribute('data-admission-file-filter') || '';
    btn.classList.toggle('active-file-filter', filter !== 'none' && btnFilter === filter);
  });
}

function applyAdmissionPipelineFileFilter(filter) {
  const finalFilter = String(filter || 'none').trim().toLowerCase();
  const cards = document.querySelectorAll('.admission-card');

  cards.forEach(card => {
    const state = getAdmissionCardUploadState(card);

    let showCard = true;

    if (finalFilter === 'all') {
      showCard = state === 'seen' || state === 'unseen';
    } else if (finalFilter === 'seen') {
      showCard = state === 'seen';
    } else if (finalFilter === 'unseen') {
      showCard = state === 'unseen';
    } else {
      showCard = true;
    }

    card.classList.toggle('file-filter-hidden', !showCard);
  });

  setActiveFileFilterButton(finalFilter);
}
    function updateSingleIconToSeen(uploadId) {
