                </th>
              <% } %>

             <% if (P.col.registrationFee) { %>
                 <th data-col="registrationFee">
                  <input id="filter-registration-fee" type="text" class="form-control form-control-sm" placeholder="Registration fee" data-filter-col="registrationFee">
                     </th>
                  <% } %>

              <% if (P.col.fees) { %>
