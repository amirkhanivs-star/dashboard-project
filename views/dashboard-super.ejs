  (function () {
  const overlay = document.getElementById('billingStatusOptionModal');
  if (!overlay) return;

  const inputEl = document.getElementById('billingStatusOptionInput');
  const colorEl = document.getElementById('billingStatusOptionColor');
  const saveBtn = document.getElementById('billingStatusOptionSaveBtn');
  const listEl = document.getElementById('billingStatusOptionList');

  function billingApiBase() {
    return '/api/options/billing-status';
  }

  function normalizeBillingRows(rows) {
    return (rows || []).map(row => ({
      id: row.id,
      value: row.value || row.label || row.opt_key || '',
      color: row.color || '#64748b',
      is_custom: Number(row.is_custom || 0)
    }));
  }

  async function fetchBillingOptions() {
    const res = await fetch(billingApiBase(), {
      headers: { 'Accept': 'application/json' }
    });

    const data = await res.json();
    if (!res.ok || !data.success) {
      throw new Error(data.message || 'Failed to load billing status options');
    }

    const items = normalizeBillingRows(data.data || []);
    window.STATUS_OPTION_CACHE.billing = items;
    return items;
  }

  async function createBillingOption(value, color) {
    const res = await fetch(billingApiBase(), {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify({ label: value, color })
    });

    const data = await res.json();
    if (!res.ok || !data.success) {
      throw new Error(data.message || 'Failed to save billing option');
    }

    return data.data;
  }

  async function updateBillingOption(id, payload) {
    const res = await fetch(`${billingApiBase()}/${id}`, {
      method: 'PATCH',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify(payload || {})
    });

    const data = await res.json();
    if (!res.ok || !data.success) {
      throw new Error(data.message || 'Failed to update billing option');
    }

    return data;
  }

  async function deleteBillingOption(id) {
    const res = await fetch(`${billingApiBase()}/${id}`, {
      method: 'DELETE',
      headers: { 'Accept': 'application/json' }
    });

    const data = await res.json();
    if (!res.ok || !data.success) {
      throw new Error(data.message || 'Failed to delete billing option');
    }

    return true;
  }

  function renderBillingOptionList() {
    const items = Array.isArray(window.STATUS_OPTION_CACHE?.billing)
      ? window.STATUS_OPTION_CACHE.billing
      : [];

    if (!items.length) {
      listEl.innerHTML = '<div class="status-option-empty">No billing status options available.</div>';
      return;
    }

    listEl.innerHTML = items.map(item => `
      <div class="status-option-item">
        <div class="status-option-left">
          <span class="status-option-dot" style="background:${item.color || '#64748b'}"></span>
          <div class="status-option-name">${item.value}</div>
        </div>

        <div class="status-option-actions">
          <input
            type="color"
            class="form-control form-control-color billing-status-color-input"
            value="${item.color || '#64748b'}"
            data-id="${item.id}"
            style="width:48px;min-width:48px;"
          >
          ${item.is_custom ? `
  <button
    type="button"
    class="btn btn-sm btn-outline-danger rounded-pill billing-status-delete-btn"
    data-id="${item.id}"
  >
    Delete
  </button>
` : ''}
        </div>
      </div>
    `).join('');
  }

  function rebuildBillingDropdowns() {
    const items = window.STATUS_OPTION_CACHE.billing || [];

    document.querySelectorAll('.bill-status').forEach(sel => {
      const selected = String(sel.value || '').trim();

      let html = '<option value="">Select status</option>';

      html += items.map(item => {
        const isSelected = selected === String(item.value || '') ? 'selected' : '';
        return `<option value="${item.value}" ${isSelected}>${item.value}</option>`;
      }).join('');

      html += '<option value="__add_new_billing_status__">+ Add Option</option>';
      sel.innerHTML = html;

      if (selected && selected !== '__add_new_billing_status__') {
        sel.value = selected;
      }
    });

    if (window.applyDynamicBillingColors) {
      window.applyDynamicBillingColors();
    }
  }

  async function loadBillingOptionsAndRefresh() {
    await fetchBillingOptions();
    renderBillingOptionList();
    rebuildBillingDropdowns();
  }

  if (saveBtn) {
    saveBtn.addEventListener('click', async function () {
      try {
        const val = String(inputEl.value || '').trim();
        const color = colorEl.value || '#64748b';

        if (!val) {
          alert('Option name required');
          return;
        }

        const existing = window.STATUS_OPTION_CACHE.billing || [];
        const dup = existing.some(x => String(x.value || '').trim().toLowerCase() === val.toLowerCase());

        if (dup) {
          alert('Ye billing status pehle se mojood hai');
          return;
        }

        await createBillingOption(val, color);
        await loadBillingOptionsAndRefresh();

        inputEl.value = '';
        colorEl.value = '#64748b';
      } catch (err) {
        alert(err.message || 'Billing status save failed');
      }
    });
  }

  listEl.addEventListener('change', async function (e) {
    const input = e.target.closest('.billing-status-color-input');
    if (!input) return;

    try {
      const id = Number(input.getAttribute('data-id'));
      if (!id) return;

      await updateBillingOption(id, { color: input.value || '#64748b' });
      await loadBillingOptionsAndRefresh();
    } catch (err) {
      alert(err.message || 'Color update failed');
    }
  });

const editBillingStatusModalEl = document.getElementById('editBillingStatusModal');
const editBillingStatusInput = document.getElementById('editBillingStatusInput');
const editBillingStatusSaveBtn = document.getElementById('editBillingStatusSaveBtn');

let editingBillingStatusId = null;
let editingBillingStatusOldValue = '';

listEl.addEventListener('click', function (e) {
  if (e.target.closest('.billing-status-delete-btn')) return;
  if (e.target.closest('.billing-status-color-input')) return;

  const nameEl = e.target.closest('.status-option-name');
  if (!nameEl) return;

  const wrap = nameEl.closest('.status-option-item');
  if (!wrap) return;

  const colorInput = wrap.querySelector('.billing-status-color-input');
  const id = Number(colorInput?.getAttribute('data-id') || 0);
  if (!id) return;

  editingBillingStatusId = id;
  editingBillingStatusOldValue = String(nameEl.textContent || '').trim();

  if (editBillingStatusInput) {
    editBillingStatusInput.value = editingBillingStatusOldValue;
  }

  if (editBillingStatusModalEl && typeof bootstrap !== 'undefined') {
    bootstrap.Modal.getOrCreateInstance(editBillingStatusModalEl).show();
  }
});

if (editBillingStatusSaveBtn) {
  editBillingStatusSaveBtn.addEventListener('click', async function () {
    try {
      if (!editingBillingStatusId) return;

      const clean = String(editBillingStatusInput?.value || '').trim();
      if (!clean || clean === editingBillingStatusOldValue) {
        const modal = bootstrap.Modal.getInstance(editBillingStatusModalEl);
        if (modal) modal.hide();
        return;
      }

      await updateBillingOption(editingBillingStatusId, { label: clean });
      await loadBillingOptionsAndRefresh();

      const modal = bootstrap.Modal.getInstance(editBillingStatusModalEl);
      if (modal) modal.hide();

      editingBillingStatusId = null;
      editingBillingStatusOldValue = '';
    } catch (err) {
      alert(err.message || 'Name update failed');
    }
  });
}
