        status: a.status || "-",
        feeStatus: a.feeStatus || "-",
        dept: a.dept || "-",
        student: a.student || a.studentName || "-",
        father: a.father || a.fatherName || "-",
        grade: a.grade || "-",
        tuitionGrade: a.tuitionGrade || "-",
        fatherEmail: a.fatherEmail || a.father_email || "-",
        phone: a.phone || a.contactNumber || "-",
        processedBy: a.processedBy || a.processed_by || "-",
        paymentStatus: a.accounts?.paymentStatus || "-",
        paidUpto: a.accounts?.paidUpto || "-",
        verificationNumber: a.latestBillingVerificationNumber || a.accounts?.verificationNumber || "-",
        registrationNumber: a.accounts?.registrationNumber || "-",
        familyNumber: a.accounts?.familyNumber || "-",
        registrationFee: a.admission?.registrationFee || "-",
        fees: a.admission?.fees || "-",
        currency: a.currency_code || a.currencyCode || a.admission?.currencyCode || a.admission?.currency_code || "-",
        month: a.admission?.month || "-",
        totalFees: a.admission?.totalFees || "-",
        pendingDues: a.admission?.pendingDues || "-",
        receivedPayment: a.admission?.receivedPayment || "0",
        invoiceStatus: a.admission?.invoiceStatus || "-",
        invoiceStatusTimestamp: a.admission?.invoiceStatusTimestamp || "-",
        paidInvoiceStatus: a.admission?.paidInvoiceStatus || "-",
        paidInvoiceStatusTimestamp: a.admission?.paidInvoiceStatusTimestamp || "-"
      };

      return map[key] ?? "-";
    }

    function updateField(card, key, value) {
      const field = card.querySelector(`.admission-field-link[data-field-key="${CSS.escape(String(key))}"] .field-value`);
      if (field) {
        field.textContent = value || "-";
        field.setAttribute("title", value || "-");
      }
    }

    function updateCardActions(card, admission) {
      const id = admission?.id || card.getAttribute("data-admission-id") || "";

      const student = admission?.student || admission?.studentName || "";
      const grade = admission?.grade || "";
      const phone = admission?.phone || admission?.contactNumber || "";
      const fees = admission?.admission?.fees || "";
      const currency =
        admission?.currency_code ||
        admission?.currencyCode ||
        admission?.admission?.currencyCode ||
        admission?.admission?.currency_code ||
        "";

      card.querySelectorAll("[data-admission-id]").forEach(el => {
        el.setAttribute("data-admission-id", id);
      });

      card.querySelectorAll("[data-student]").forEach(el => {
        el.setAttribute("data-student", student);
      });

      card.querySelectorAll("[data-grade]").forEach(el => {
        el.setAttribute("data-grade", grade);
      });

      card.querySelectorAll("[data-phone]").forEach(el => {
        el.setAttribute("data-phone", phone);
      });

      const billingBtn = card.querySelector(".btn-billing");
      if (billingBtn) {
        billingBtn.setAttribute("data-fees", fees);
        billingBtn.setAttribute("data-currency", currency);
      }

      const deleteBtn = card.querySelector(".btn-delete-admission");
      if (deleteBtn) {
        deleteBtn.setAttribute("data-student-name", student);
      }
    }

    function updateCardHeader(card, admission) {
      const student = admission?.student || admission?.studentName || "No Name";
      const father = admission?.father || admission?.fatherName || "-";
      const dept = admission?.dept || "Dept";

      const title = card.querySelector(".admission-title");
      const subtitle = card.querySelector(".admission-subtitle");
      const avatar = card.querySelector(".admission-avatar");
      const deptPill = card.querySelector(".admission-role-pill");

      if (title) title.textContent = student;
      if (subtitle) subtitle.textContent = father;
      if (avatar) avatar.textContent = String(student || "A").charAt(0).toUpperCase();
      if (deptPill) deptPill.textContent = dept;
    }

    async function refreshAdmissionCard(admissionId) {
      if (!admissionId) return false;

      const card = document.querySelector(`.admission-card[data-admission-id="${CSS.escape(String(admissionId))}"]`);

      if (!card) {
        pendingAdmissionIds.add(String(admissionId));
        showUpdatesButton();
        return false;
      }

      const res = await fetch(`/api/admissions/${encodeURIComponent(admissionId)}`, {
        method: "GET",
        credentials: "same-origin",
        headers: {
          "Accept": "application/json"
        }
      });

      const data = await res.json().catch(() => ({}));

      if (!res.ok || data.success === false || !data.admission) {
        throw new Error(data.message || "Admission refresh failed");
      }

      const admission = data.admission;

      updateCardHeader(card, admission);

      [
        "status",
        "feeStatus",
        "dept",
        "student",
        "father",
        "grade",
        "tuitionGrade",
        "fatherEmail",
        "phone",
        "processedBy",
        "paymentStatus",
        "paidUpto",
        "verificationNumber",
        "registrationNumber",
        "familyNumber",
        "registrationFee",
        "fees",
        "currency",
        "month",
        "totalFees",
        "pendingDues",
        "receivedPayment",
        "invoiceStatus",
        "invoiceStatusTimestamp",
        "paidInvoiceStatus",
        "paidInvoiceStatusTimestamp"
      ].forEach(key => {
        updateField(card, key, getFieldValue(admission, key));
      });

      updateCardActions(card, admission);

      card.classList.remove("realtime-updated");
      void card.offsetWidth;
      card.classList.add("realtime-updated");

      return true;
    }

    async function applyPendingAdmissionUpdates() {
      const ids = Array.from(pendingAdmissionIds);
      pendingAdmissionIds.clear();
      showUpdatesButton();

      for (const id of ids) {
        try {
          await refreshAdmissionCard(id);
        } catch (err) {
          console.error("Real-time card update failed:", err);
        }
      }

      if (typeof window.rebuildAdmissionFilesDropdowns === "function") {
        window.rebuildAdmissionFilesDropdowns();
      }
    }

    if (updateBtn) {
      updateBtn.addEventListener("click", function () {
        applyPendingAdmissionUpdates();
      });
    }

    socket.on("admission:changed", async function (payload) {
      const singleId = getAdmissionIdFromPayload(payload);
      const insertedIds = Array.isArray(payload?.insertedIds) ? payload.insertedIds : [];
      const deletedIds = Array.isArray(payload?.deletedIds) ? payload.deletedIds : [];

      deletedIds.forEach(id => {
        const card = document.querySelector(`.admission-card[data-admission-id="${CSS.escape(String(id))}"]`);
        if (card) card.remove();
      });

      if (insertedIds.length) {
        insertedIds.forEach(id => pendingAdmissionIds.add(String(id)));
        showUpdatesButton();
        return;
      }

      if (!singleId) {
        if (typeof window.rebuildAdmissionFilesDropdowns === "function") {
          window.rebuildAdmissionFilesDropdowns();
        }
        return;
      }

      if (isUserBusy()) {
        pendingAdmissionIds.add(String(singleId));
        showUpdatesButton();
        return;
      }

      try {
        await refreshAdmissionCard(singleId);

        if (typeof window.rebuildAdmissionFilesDropdowns === "function") {
          window.rebuildAdmissionFilesDropdowns();
        }
      } catch (err) {
        console.error("Real-time admission update failed:", err);
        pendingAdmissionIds.add(String(singleId));
        showUpdatesButton();
      }
    });

    socket.on("user:updated", function (payload) {
      const currentUserId = Number(window.CURRENT_USER?.id || 0);
      const targetUserId = Number(payload?.userId || 0);

      if (!currentUserId || !targetUserId) return;
      if (currentUserId !== targetUserId) return;

      if (isUserBusy()) {
        if (typeof window.showUploadFlash === "function") {
          window.showUploadFlash(
            "info",
            "Account Updated",
            "Your permissions were updated. Please refresh when you are free."
          );
        }
        return;
      }

      if (typeof window.smoothDashboardReload === "function") {
        window.smoothDashboardReload(1000);
      } else {
        window.location.reload();
      }
    });
  })();

