          </div>
          <a href="/dashboard/super/school" class="btn btn-sm btn-outline-warning rounded-pill px-3">
            Open
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ADMISSIONS TABLE -->
  <div class="card shadow-sm super-table-card">
    <div class="card-header d-flex justify-content-between align-items-center">
      <div>
        <strong>Admissions Pipeline</strong>
        <small class="text-muted ms-2">Quran · Tuition · School (demo data)</small>
