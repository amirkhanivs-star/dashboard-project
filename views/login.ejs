<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>IVS Login</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<link rel="icon" type="image/png" sizes="32x32" href="/img/tabLogo.png" />

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

:root{
  --super:#ef4444;
  --super-dark:#b91c1c;
  --super-soft:#fee2e2;

  --admin:#22c55e;
  --admin-dark:#15803d;
  --admin-soft:#dcfce7;

  --agent:#7c3aed;
  --agent-dark:#5b21b6;
  --agent-soft:#ede9fe;

  --sub:#3b82f6;
  --sub-dark:#1d4ed8;
  --sub-soft:#dbeafe;

  --active:#ef4444;
  --active-dark:#b91c1c;
  --active-soft:#fee2e2;

  --text:#0f172a;
  --muted:#64748b;
  --card:#ffffff;
  --card-border:rgba(15,23,42,.10);
  --input-bg:#ffffff;
  --input-text:#111827;
}

html,body{
  width:100%;
  min-height:100%;
}

body{
  font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
  min-height:100vh;
  overflow:hidden;
  color:var(--text);
  position:relative;
  background:
    radial-gradient(circle at 80% 75%, var(--active-soft), transparent 22%),
    radial-gradient(circle at 14% 18%, rgba(255,255,255,.95), transparent 25%),
    linear-gradient(135deg,#ffffff 0%, #f8fafc 45%, #eef2f7 100%);
}

/* ROLE THEMES */
body.theme-super{
  --active:var(--super);
  --active-dark:var(--super-dark);
  --active-soft:rgba(239,68,68,.18);
}

body.theme-admin{
  --active:var(--admin);
  --active-dark:var(--admin-dark);
  --active-soft:rgba(34,197,94,.18);
}

body.theme-agent{
  --active:var(--agent);
  --active-dark:var(--agent-dark);
  --active-soft:rgba(124,58,237,.18);
}

body.theme-sub{
  --active:var(--sub);
  --active-dark:var(--sub-dark);
  --active-soft:rgba(59,130,246,.18);
}

/* PREMIUM BACKGROUND */
body::before{
  content:"";
  position:fixed;
  inset:0;
  background-image:
    linear-gradient(rgba(15,23,42,.035) 1px, transparent 1px),
    linear-gradient(90deg, rgba(15,23,42,.035) 1px, transparent 1px);
  background-size:42px 42px;
  opacity:.8;
  pointer-events:none;
  z-index:0;
}

body::after{
  content:"";
  position:fixed;
  inset:0;
  background:
    radial-gradient(circle at 78% 72%, var(--active-soft), transparent 25%),
    radial-gradient(circle at 88% 20%, rgba(255,255,255,.85), transparent 18%),
    radial-gradient(circle at 16% 76%, rgba(148,163,184,.16), transparent 22%);
  pointer-events:none;
  z-index:0;
}

.bg-bubbles{
  position:fixed;
  inset:0;
  overflow:hidden;
  z-index:1;
  pointer-events:none;
}

.bubble{
  position:absolute;
  width:220px;
  height:220px;
  border-radius:999px;
  background:var(--active);
  opacity:.12;
  filter:blur(2px);
  animation:floatBubble 10s ease-in-out infinite;
}

.bubble.one{
  right:7%;
  bottom:10%;
  width:260px;
  height:260px;
}

.bubble.two{
  right:21%;
  top:12%;
  width:120px;
  height:120px;
  opacity:.10;
  animation-delay:1.3s;
}

.bubble.three{
  left:5%;
  bottom:13%;
  width:170px;
  height:170px;
  opacity:.08;
  animation-delay:2.2s;
}

.bubble.four{
  left:46%;
  top:18%;
  width:95px;
  height:95px;
  opacity:.09;
  animation-delay:3s;
}

@keyframes floatBubble{
  0%,100%{ transform:translate3d(0,0,0) scale(1); }
  50%{ transform:translate3d(0,-18px,0) scale(1.04); }
}

.wrapper{
  position:relative;
  z-index:3;
  width:100%;
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:40px;
  padding:36px 52px;
}

/* LEFT SIDE */
.left{
  flex:1;
  min-width:0;
  min-height:100vh;
  display:flex;
  flex-direction:column;
  justify-content:flex-start;
  align-items:flex-start;
  padding:28px 0;
}

.logo{
  display:inline-flex;
  align-items:center;
  gap:14px;
  padding:10px 18px 10px 10px;
  border-radius:999px;
  background:rgba(255,255,255,.92);
  border:1px solid rgba(15,23,42,.10);
  backdrop-filter:blur(18px);
  -webkit-backdrop-filter:blur(18px);
  box-shadow:
    0 14px 36px rgba(15,23,42,.10),
    inset 0 1px 0 rgba(255,255,255,.9);
  width:max-content;
}

.logo-box{
  width:42px;
  height:42px;
  border-radius:14px;
  background:linear-gradient(135deg,#ef4444 0%, #f59e0b 35%, #22c55e 65%, #38bdf8 100%);
  display:flex;
  align-items:center;
  justify-content:center;
  font-weight:900;
  color:#fff;
  font-size:17px;
  letter-spacing:.03em;
  box-shadow:0 10px 24px rgba(15,23,42,.16);
  flex-shrink:0;
}

.logo-text{
  display:flex;
  flex-direction:column;
  justify-content:center;
  line-height:1.15;
}

.logo-title{
  font-size:17px;
  font-weight:900;
  color:#0f172a;
}

.logo-sub{
  font-size:9px;
  color:#64748b;
  letter-spacing:.18em;
  text-transform:uppercase;
  margin-top:4px;
  font-weight:800;
}

.hero-copy{
  max-width:760px;
  width:100%;
  min-height:66vh;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:flex-start;
  padding-left:0;
  margin-left:0;
  margin-top:-35px;
  padding-bottom:0;
}

.heading{
  font-size:clamp(56px, 5.6vw, 92px);
  font-weight:950;
  line-height:.98;
  margin-bottom:24px;
  letter-spacing:-2.7px;
  color:#0f172a;
  text-wrap:balance;
  max-width:760px;
}

.heading span{
  color:var(--active);
}

.sub{
  color:#475569;
  font-size:clamp(17px, 1.2vw, 22px);
  line-height:1.75;
  max-width:680px;
}

.trust-row{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
  margin-top:28px;
}

.trust-pill{
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding:9px 13px;
  border-radius:999px;
  background:#fff;
  border:1px solid rgba(15,23,42,.08);
  color:#334155;
  font-size:13px;
  font-weight:800;
  box-shadow:0 10px 26px rgba(15,23,42,.06);
}

.trust-pill i{
  color:var(--active);
}

/* RIGHT LOGIN CARD */
.right{
  width:100%;
  max-width:520px;
  display:flex;
  justify-content:flex-end;
}

.login-card{
  width:100%;
  max-width:450px;
  padding:34px;
  border-radius:30px;
  background:rgba(255,255,255,.86);
  border:1px solid rgba(15,23,42,.10);
  backdrop-filter:blur(24px);
  -webkit-backdrop-filter:blur(24px);
  box-shadow:
    0 28px 90px rgba(15,23,42,.16),
    inset 0 1px 0 rgba(255,255,255,.95);
  position:relative;
  overflow:hidden;
}

.login-card::before{
  content:"";
  position:absolute;
  inset:0;
  border-radius:30px;
  background:
    radial-gradient(circle at 100% 0%, var(--active-soft), transparent 34%),
    linear-gradient(180deg, rgba(255,255,255,.88), rgba(255,255,255,.70));
  pointer-events:none;
}

.login-card::after{
  content:"";
  position:absolute;
  top:0;
  left:34px;
  right:34px;
  height:4px;
  border-radius:999px;
  background:linear-gradient(90deg, transparent, var(--active), transparent);
  opacity:.75;
}

.login-card > *{
  position:relative;
  z-index:2;
}

.login-icon{
  width:54px;
  height:54px;
  border-radius:18px;
  margin:0 auto 16px;
  display:flex;
  align-items:center;
  justify-content:center;
  color:#fff;
  background:linear-gradient(135deg,var(--active),var(--active-dark));
  box-shadow:0 16px 30px color-mix(in srgb, var(--active) 24%, transparent);
  font-size:24px;
}

.login-title{
  font-size:clamp(36px, 3vw, 46px);
  font-weight:950;
  margin-bottom:8px;
  line-height:1;
  letter-spacing:-1.3px;
  color:#0f172a;
  text-align:center;
}

.login-desc{
  color:#64748b;
  font-size:15px;
  margin-bottom:22px;
  text-align:center;
  font-weight:600;
}

/* ROLE BUTTONS */
.role-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:12px;
  margin-bottom:18px;
}

.role{
  position:relative;
  padding:13px 12px;
  border-radius:14px;
  background:#fff;
  border:1px solid rgba(15,23,42,.10);
  text-align:center;
  text-decoration:none;
  font-size:15px;
  font-weight:900;
  color:#334155;
  transition:.22s ease;
  overflow:hidden;
  box-shadow:0 8px 20px rgba(15,23,42,.05);
}

.role:hover{
  transform:translateY(-1px);
  color:#0f172a;
  background:#f8fafc;
}

.role.active{
  color:#fff;
}

.role-super.active{
  border:1px solid var(--super);
  background:linear-gradient(135deg,#ff5757 0%, #ef4444 45%, #dc2626 100%);
  box-shadow:0 12px 28px rgba(239,68,68,.22);
}

.role-admin.active{
  border:1px solid var(--admin);
  background:linear-gradient(135deg,#34d399 0%, #22c55e 45%, #16a34a 100%);
  box-shadow:0 12px 28px rgba(34,197,94,.22);
}

.role-agent.active{
  border:1px solid var(--agent);
  background:linear-gradient(135deg,#a855f7 0%, #7c3aed 45%, #5b21b6 100%);
  box-shadow:0 12px 28px rgba(124,58,237,.24);
}

.role-sub.active{
  border:1px solid var(--sub);
  background:linear-gradient(135deg,#60a5fa 0%, #3b82f6 45%, #2563eb 100%);
  box-shadow:0 12px 28px rgba(59,130,246,.22);
}

/* FORM */
.form-control{
  background:var(--input-bg);
  border:1px solid rgba(15,23,42,.12);
  border-radius:14px;
  padding:14px 15px;
  font-size:15px;
  color:var(--input-text);
  box-shadow:none;
  height:52px;
}

.form-control::placeholder{
  color:#94a3b8;
}

.form-control:focus{
  border-color:var(--active);
  box-shadow:0 0 0 4px var(--active-soft);
  background:#fff;
}

.field-wrap{
  position:relative;
  margin-bottom:12px;
}

.field-wrap .form-control{
  padding-left:44px;
  margin-bottom:0;
}

.field-icon{
  position:absolute;
  left:15px;
  top:50%;
  transform:translateY(-50%);
  color:#94a3b8;
  z-index:3;
}

.password-wrap .form-control{
  padding-right:48px;
}

.eye-btn{
  position:absolute;
  right:10px;
  top:50%;
  transform:translateY(-50%);
  border:0;
  background:transparent;
  color:#64748b;
  width:36px;
  height:36px;
  border-radius:10px;
  display:flex;
  align-items:center;
  justify-content:center;
  z-index:4;
}

.eye-btn:hover{
  background:#f1f5f9;
  color:var(--active);
}

/* LOGIN BUTTON */
.btn-login{
  width:100%;
  border:none;
  padding:14px;
  border-radius:14px;
  font-weight:900;
  font-size:16px;
  transition:.22s ease;
  box-shadow:
    0 14px 28px rgba(15,23,42,.12),
    inset 0 1px 0 rgba(255,255,255,.30);
}

.btn-login:hover{
  transform:translateY(-1px);
  filter:brightness(1.03);
}

.btn-super{
  background:linear-gradient(135deg,#ff5757 0%, #ef4444 45%, #dc2626 100%);
  color:#fff;
}

.btn-admin{
  background:linear-gradient(135deg,#34d399 0%, #22c55e 45%, #16a34a 100%);
  color:#fff;
}

.btn-agent{
  background:linear-gradient(135deg,#a855f7 0%, #7c3aed 45%, #5b21b6 100%);
  color:#fff;
}

.btn-sub{
  background:linear-gradient(135deg,#60a5fa 0%, #3b82f6 45%, #2563eb 100%);
  color:#fff;
}

/* ERROR POPUP */
.login-toast{
  position:fixed;
  right:28px;
  top:92px;
  z-index:50;
  width:min(92vw, 390px);
  border-radius:18px;
  background:#fff;
  border:1px solid rgba(220,38,38,.18);
  box-shadow:0 22px 60px rgba(15,23,42,.18);
  overflow:hidden;
  animation:toastIn .35s ease-out;
}

.login-toast::before{
  content:"";
  position:absolute;
  left:0;
  top:0;
  bottom:0;
  width:5px;
  background:linear-gradient(180deg,#ef4444,#b91c1c);
}

.toast-inner{
  display:flex;
  gap:12px;
  padding:16px 16px 16px 18px;
  align-items:flex-start;
}

.toast-icon{
  width:38px;
  height:38px;
  border-radius:12px;
  background:#fee2e2;
  color:#dc2626;
  display:flex;
  align-items:center;
  justify-content:center;
  flex-shrink:0;
  font-size:19px;
}

.toast-title{
  font-weight:900;
  color:#991b1b;
  margin-bottom:2px;
}

.toast-text{
  color:#64748b;
  font-size:13px;
  line-height:1.45;
}

.toast-close{
  border:0;
  background:#f8fafc;
  color:#64748b;
  width:30px;
  height:30px;
  border-radius:10px;
  margin-left:auto;
}

.toast-close:hover{
  background:#fee2e2;
  color:#dc2626;
}

@keyframes toastIn{
  from{ opacity:0; transform:translateX(24px) translateY(-8px); }
  to{ opacity:1; transform:translateX(0) translateY(0); }
}

.mak-footer{
  position:fixed;
  left:50%;
  bottom:26px;
  transform:translateX(-50%);
  z-index:9999;
  color:#111827 !important;
  font-size:11px;
  font-weight:900;
  letter-spacing:.16em;
  text-transform:uppercase;
  white-space:nowrap;
  opacity:1 !important;
  text-shadow:none !important;
  pointer-events:auto;
  user-select:none;
}

.mak-key{
  display:inline;
  cursor:default;
  padding:0;
  border-radius:0;
  transition:none;
  color:inherit;
  background:transparent;
}

.mak-key:hover{
  background:transparent;
  color:inherit;
}
/* HIDDEN DEVELOPER LOGIN */
.developer-modal-overlay{
  position:fixed;
  inset:0;
  z-index:10000;
  background:rgba(0,0,0,.54);
  backdrop-filter:blur(8px);
  -webkit-backdrop-filter:blur(8px);
  display:none;
  align-items:center;
  justify-content:center;
  padding:18px;
}

.developer-modal-overlay.show{
  display:flex;
}

.developer-modal{
  width:min(94vw, 390px);
  background:#fff;
  color:#111827;
  border-radius:24px;
  border:1px solid rgba(255,255,255,.20);
  box-shadow:0 30px 90px rgba(0,0,0,.35);
  overflow:hidden;
  animation:developerModalIn .22s ease-out;
}

.developer-modal-top{
  background:#050505;
  color:#fff;
  padding:22px 22px 18px;
  position:relative;
}

.developer-modal-icon{
  width:46px;
  height:46px;
  border-radius:16px;
  background:#fff;
  color:#000;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:22px;
  margin-bottom:14px;
}

.developer-modal-title{
  font-size:28px;
  font-weight:950;
  line-height:1;
  letter-spacing:-.8px;
  margin-bottom:6px;
}

.developer-modal-sub{
  color:#d1d5db;
  font-size:13px;
  font-weight:600;
  line-height:1.5;
}

.developer-close{
  position:absolute;
  right:14px;
  top:14px;
  width:34px;
  height:34px;
  border:1px solid rgba(255,255,255,.16);
  background:rgba(255,255,255,.08);
  color:#fff;
  border-radius:12px;
  display:flex;
  align-items:center;
  justify-content:center;
}

.developer-close:hover{
  background:#fff;
  color:#000;
}

.developer-modal-body{
  padding:22px;
  background:#fff;
}

.developer-field{
  position:relative;
  margin-bottom:12px;
}

.developer-field .form-control{
  height:50px;
  border-radius:14px;
  border:1px solid rgba(17,24,39,.16);
  background:#fff;
  color:#111827;
  padding-left:43px;
}

.developer-field .form-control:focus{
  border-color:#111827;
  box-shadow:0 0 0 4px rgba(17,24,39,.10);
}

.developer-field-icon{
  position:absolute;
  left:15px;
  top:50%;
  transform:translateY(-50%);
  color:#6b7280;
  z-index:3;
}

.developer-password-field .form-control{
  padding-right:48px;
}

.developer-eye-btn{
  position:absolute;
  right:10px;
  top:50%;
  transform:translateY(-50%);
  border:0;
  background:transparent;
  color:#6b7280;
  width:34px;
  height:34px;
  border-radius:10px;
  display:flex;
  align-items:center;
  justify-content:center;
  z-index:4;
}

.developer-eye-btn:hover{
  background:#f3f4f6;
  color:#000;
}

.developer-login-btn{
  width:100%;
  height:50px;
  border:0;
  border-radius:14px;
  background:#050505;
  color:#fff;
  font-weight:900;
  font-size:15px;
  margin-top:4px;
  transition:.2s ease;
}

.developer-login-btn:hover{
  background:#111827;
  transform:translateY(-1px);
}

.developer-hint{
  margin-top:12px;
  color:#6b7280;
  font-size:12px;
  text-align:center;
  font-weight:600;
}

.developer-error{
  display:flex;
  align-items:flex-start;
  gap:9px;
  padding:10px 12px;
  border-radius:14px;
  background:#fef2f2;
  color:#991b1b;
  border:1px solid rgba(220,38,38,.18);
  font-size:13px;
  font-weight:700;
  line-height:1.4;
  margin-bottom:12px;
}

@keyframes developerModalIn{
  from{ opacity:0; transform:translateY(16px) scale(.96); }
  to{ opacity:1; transform:translateY(0) scale(1); }
}
/* RESPONSIVE */
@media (max-width: 1200px){
  .wrapper{
    padding:30px 30px 70px;
    gap:28px;
  }

  .heading{
    font-size:64px;
  }

  .login-card{
    max-width:430px;
  }
}

@media (max-width: 992px){
  body{
    overflow:auto;
  }

  .wrapper{
    min-height:100vh;
    flex-direction:column;
    align-items:flex-start;
    justify-content:center;
    padding:28px 20px 80px;
  }

  .left{
    min-height:auto;
    width:100%;
    padding:0;
    gap:40px;
  }

  .hero-copy{
    min-height:auto;
    padding-top:40px;
    padding-bottom:10px;
  }

  .heading{
    font-size:48px;
    letter-spacing:-1.5px;
  }

  .sub{
    font-size:16px;
  }

  .right{
    max-width:100%;
    width:100%;
    justify-content:center;
  }

  .login-card{
    max-width:480px;
  }

  .mak-footer{
    bottom:14px;
    width:100%;
    text-align:center;
    padding:0 12px;
    white-space:normal;
  }

  .login-toast{
    top:18px;
    right:18px;
    left:18px;
    width:auto;
  }
}

@media (max-width: 576px){
  .wrapper{
    padding:20px 14px 78px;
  }

  .logo{
    transform:scale(.95);
    transform-origin:left center;
  }

  .heading{
    font-size:38px;
  }

  .login-card{
    padding:24px 18px;
    border-radius:24px;
  }

  .login-title{
    font-size:32px;
  }

  .role{
    font-size:14px;
    padding:12px 10px;
  }

  .btn-login{
    padding:13px;
  }
}
</style>
</head>

<%
  let themeClass = 'theme-super';
  if(type === 'admin') themeClass = 'theme-admin';
  if(type === 'agent') themeClass = 'theme-agent';
  if(type === 'sub_agent') themeClass = 'theme-sub';

  let btnClass = 'btn-super';
  if(type === 'admin') btnClass = 'btn-admin';
  if(type === 'agent') btnClass = 'btn-agent';
  if(type === 'sub_agent') btnClass = 'btn-sub';

  const loginError =
    (typeof error !== 'undefined' && error)
      ? error
      : ((typeof message !== 'undefined' && message) ? message : '');

  const developerError =
    (typeof devError !== 'undefined' && devError)
      ? devError
      : '';
%>

<body class="<%= themeClass %>">

<div class="bg-bubbles">
  <span class="bubble one"></span>
  <span class="bubble two"></span>
  <span class="bubble three"></span>
  <span class="bubble four"></span>
</div>

<% if (loginError) { %>
  <div class="login-toast" id="loginToast">
    <div class="toast-inner">
      <div class="toast-icon">
        <i class="bi bi-exclamation-triangle-fill"></i>
      </div>
      <div>
        <div class="toast-title">Login failed</div>
        <div class="toast-text"><%= loginError %></div>
      </div>
      <button type="button" class="toast-close" id="toastCloseBtn" aria-label="Close">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>
  </div>
<% } %>

<div class="wrapper">

  <div class="left">
    <div class="logo">
      <div class="logo-box">IVS</div>
      <div class="logo-text">
        <div class="logo-title">IQRA Virtual School</div>
        <div class="logo-sub">Internal Dashboard Access</div>
      </div>
    </div>

    <div class="hero-copy">
      <div class="heading">
        Smart login for<br><span>School teams.</span>
      </div>

      <div class="sub">
        A clean internal dashboard for admissions, departments, accounts, and team management.
        Select your role and access the tools assigned to your account.
      </div>

      <div class="trust-row">
        <span class="trust-pill">
          <i class="bi bi-shield-check"></i>
          Secure access
        </span>
        <span class="trust-pill">
          <i class="bi bi-kanban"></i>
          Pipeline control
        </span>
        <span class="trust-pill">
          <i class="bi bi-people"></i>
          Team permissions
        </span>
      </div>
    </div>
  </div>

  <div class="right">
    <div class="login-card">
      <div class="login-icon">
        <i class="bi bi-fingerprint"></i>
      </div>

      <div class="login-title">Welcome back</div>
      <div class="login-desc">Select your role and login securely</div>

      <div class="role-grid">
        <a href="/login?type=super" class="role role-super <%= type==='super'?'active':'' %>">Super</a>
        <a href="/login?type=admin" class="role role-admin <%= type==='admin'?'active':'' %>">Admin</a>
        <a href="/login?type=agent" class="role role-agent <%= type==='agent'?'active':'' %>">Agent</a>
        <a href="/login?type=sub_agent" class="role role-sub <%= type==='sub_agent'?'active':'' %>">Sub</a>
      </div>

      <% if(type){ %>
      <form method="POST" action="/login">
        <input type="hidden" name="loginType" value="<%= type %>">

        <div class="field-wrap">
          <i class="bi bi-envelope field-icon"></i>
          <input type="email" name="email" class="form-control" placeholder="Email" required>
        </div>

        <div class="field-wrap password-wrap">
          <i class="bi bi-lock field-icon"></i>
          <input type="password" name="password" id="passwordInput" class="form-control" placeholder="Password" required>
          <button type="button" class="eye-btn" id="togglePassword" aria-label="Show password">
            <i class="bi bi-eye"></i>
          </button>
        </div>

        <button class="btn-login <%= btnClass %>">
          <i class="bi bi-box-arrow-in-right me-1"></i>
          Login
        </button>
      </form>
      <% } %>
    </div>
  </div>

</div>

<div class="mak-footer">
  POWERED AND DESIGNED BY <span class="mak-key" id="developerTrigger">MAK</span>
</div>

<div class="developer-modal-overlay" id="developerModal" aria-hidden="true">
  <div class="developer-modal" role="dialog" aria-modal="true" aria-labelledby="developerModalTitle">
    <div class="developer-modal-top">
      <button type="button" class="developer-close" id="developerCloseBtn" aria-label="Close developer login">
        <i class="bi bi-x-lg"></i>
      </button>

      <div class="developer-modal-icon">
        <i class="bi bi-code-slash"></i>
      </div>

      <div class="developer-modal-title" id="developerModalTitle">Developer access</div>
      <div class="developer-modal-sub">
        Private dashboard login for authorized developer only.
      </div>
    </div>

    <div class="developer-modal-body">
      <% if (developerError) { %>
        <div class="developer-error">
          <i class="bi bi-exclamation-triangle-fill"></i>
          <span><%= developerError %></span>
        </div>
      <% } %>

      <form method="POST" action="/developer/login" autocomplete="off">
        <div class="developer-field">
  <i class="bi bi-person-badge developer-field-icon"></i>
  <input
    type="text"
    name="username"
    class="form-control"
    placeholder="Developer username or email"
    autocomplete="username"
    required
  >
</div>

        <div class="developer-field developer-password-field">
          <i class="bi bi-lock developer-field-icon"></i>
          <input type="password" name="password" id="developerPasswordInput" class="form-control" placeholder="Developer password" required>
          <button type="button" class="developer-eye-btn" id="toggleDeveloperPassword" aria-label="Show developer password">
            <i class="bi bi-eye"></i>
          </button>
        </div>

        <button type="submit" class="developer-login-btn">
          <i class="bi bi-shield-lock me-1"></i>
          Login as Developer
        </button>

        <div class="developer-hint">
          This panel is not connected with Super, Admin, Agent, or Sub login.
        </div>
      </form>
    </div>
  </div>
</div>
<script>
  (function () {
    const passwordInput = document.getElementById('passwordInput');
    const togglePassword = document.getElementById('togglePassword');

    if (passwordInput && togglePassword) {
      togglePassword.addEventListener('click', function () {
        const isPassword = passwordInput.type === 'password';
        passwordInput.type = isPassword ? 'text' : 'password';

        const icon = togglePassword.querySelector('i');
        if (icon) {
          icon.className = isPassword ? 'bi bi-eye-slash' : 'bi bi-eye';
        }
      });
    }

    const developerTrigger = document.getElementById('developerTrigger');
    const developerModal = document.getElementById('developerModal');
    const developerCloseBtn = document.getElementById('developerCloseBtn');
    const developerPasswordInput = document.getElementById('developerPasswordInput');
    const toggleDeveloperPassword = document.getElementById('toggleDeveloperPassword');

    function openDeveloperModal() {
      if (!developerModal) return;

      developerModal.classList.add('show');
      developerModal.setAttribute('aria-hidden', 'false');

      const firstInput = developerModal.querySelector('input[name="username"]');
      if (firstInput) {
        setTimeout(function () {
          firstInput.focus();
        }, 120);
      }
    }

    function closeDeveloperModal() {
      if (!developerModal) return;

      developerModal.classList.remove('show');
      developerModal.setAttribute('aria-hidden', 'true');

      if (developerPasswordInput) {
        developerPasswordInput.type = 'password';
      }

      if (toggleDeveloperPassword) {
        const icon = toggleDeveloperPassword.querySelector('i');
        if (icon) {
          icon.className = 'bi bi-eye';
        }
      }
    }

    if (developerTrigger) {
      developerTrigger.addEventListener('dblclick', function (event) {
        event.preventDefault();
        event.stopPropagation();
        openDeveloperModal();
      });
    }

    if (developerCloseBtn) {
      developerCloseBtn.addEventListener('click', closeDeveloperModal);
    }

    if (developerModal) {
      developerModal.addEventListener('click', function (event) {
        if (event.target === developerModal) {
          closeDeveloperModal();
        }
      });
    }

    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape' && developerModal && developerModal.classList.contains('show')) {
        closeDeveloperModal();
      }
    });

    if (developerPasswordInput && toggleDeveloperPassword) {
      toggleDeveloperPassword.addEventListener('click', function () {
        const isPassword = developerPasswordInput.type === 'password';
        developerPasswordInput.type = isPassword ? 'text' : 'password';

        const icon = toggleDeveloperPassword.querySelector('i');
        if (icon) {
          icon.className = isPassword ? 'bi bi-eye-slash' : 'bi bi-eye';
        }
      });
    }

    <% if (developerError) { %>
      openDeveloperModal();
    <% } %>

    const toast = document.getElementById('loginToast');
    const toastCloseBtn = document.getElementById('toastCloseBtn');

    if (toast && toastCloseBtn) {
      toastCloseBtn.addEventListener('click', function () {
        toast.style.display = 'none';
      });

      setTimeout(function () {
        if (toast) {
          toast.style.opacity = '0';
          toast.style.transform = 'translateX(24px) translateY(-8px)';
          setTimeout(function () {
            toast.style.display = 'none';
          }, 250);
        }
      }, 6000);
    }
  })();
</script>

</body>
</html>