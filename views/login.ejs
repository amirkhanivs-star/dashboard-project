    </div>
  </div>
</div>

<div class="mak-footer">
  POWERED AND DESIGNED BY <span class="mak-key" id="developerTrigger">MAK</span>
</div>

<div class="developer-modal-overlay" id="developerModal" aria-hidden="true">
  <div class="developer-modal" role="dialog" aria-modal="true" aria-labelledby="developerModalTitle">
    <div class="developer-modal-top">
      <button type="button" class="developer-close" id="developerCloseBtn" aria-label="Close developer login">
        <i class="bi bi-x-lg"></i>
      </button>

      <div class="developer-modal-icon">
        <i class="bi bi-code-slash"></i>
      </div>

      <div class="developer-modal-title" id="developerModalTitle">Developer access</div>
      <div class="developer-modal-sub">
        Private dashboard login for authorized developer only.
      </div>
    </div>

    <div class="developer-modal-body">
      <% if (developerError) { %>
        <div class="developer-error">
          <i class="bi bi-exclamation-triangle-fill"></i>
          <span><%= developerError %></span>
        </div>
      <% } %>

      <form method="POST" action="/developer/login" autocomplete="off">
        <div class="developer-field">
  <i class="bi bi-person-badge developer-field-icon"></i>
  <input
    type="text"
    name="username"
    class="form-control"
    placeholder="Developer username or email"
    autocomplete="username"
    required
  >
</div>

        <div class="developer-field developer-password-field">
          <i class="bi bi-lock developer-field-icon"></i>
          <input type="password" name="password" id="developerPasswordInput" class="form-control" placeholder="Developer password" required>
          <button type="button" class="developer-eye-btn" id="toggleDeveloperPassword" aria-label="Show developer password">
            <i class="bi bi-eye"></i>
          </button>
        </div>

        <button type="submit" class="developer-login-btn">
          <i class="bi bi-shield-lock me-1"></i>
          Login as Developer
        </button>

        <div class="developer-hint">
          This panel is not connected with Super, Admin, Agent, or Sub login.
        </div>
      </form>
    </div>
  </div>
</div>
<script>
  (function () {
    const passwordInput = document.getElementById('passwordInput');
    const togglePassword = document.getElementById('togglePassword');

    if (passwordInput && togglePassword) {
      togglePassword.addEventListener('click', function () {
        const isPassword = passwordInput.type === 'password';
        passwordInput.type = isPassword ? 'text' : 'password';

        const icon = togglePassword.querySelector('i');
        if (icon) {
          icon.className = isPassword ? 'bi bi-eye-slash' : 'bi bi-eye';
        }
      });
    }

    const developerTrigger = document.getElementById('developerTrigger');
    const robotDeveloperTrigger = document.getElementById('robotDeveloperTrigger');
    const developerModal = document.getElementById('developerModal');
    const developerCloseBtn = document.getElementById('developerCloseBtn');
    const developerPasswordInput = document.getElementById('developerPasswordInput');
    const toggleDeveloperPassword = document.getElementById('toggleDeveloperPassword');

    function openDeveloperModal() {
      if (!developerModal) return;

      developerModal.classList.add('show');
      developerModal.setAttribute('aria-hidden', 'false');

      const firstInput = developerModal.querySelector('input[name="username"]');
      if (firstInput) {
        setTimeout(function () {
          firstInput.focus();
        }, 120);
      }
    }

    function closeDeveloperModal() {
      if (!developerModal) return;

      developerModal.classList.remove('show');
      developerModal.setAttribute('aria-hidden', 'true');

      if (developerPasswordInput) {
        developerPasswordInput.type = 'password';
      }

      if (toggleDeveloperPassword) {
        const icon = toggleDeveloperPassword.querySelector('i');
        if (icon) {
          icon.className = 'bi bi-eye';
        }
      }
    }

    if (developerTrigger) {
      developerTrigger.addEventListener('dblclick', function (event) {
        event.preventDefault();
        event.stopPropagation();
        openDeveloperModal();
      });
    }
           const devProfileModal = document.getElementById('devProfileModal');
    const devProfileCloseBtn = document.getElementById('devProfileCloseBtn');
    const devProfileFooterCloseBtn = document.getElementById('devProfileFooterCloseBtn');
    const devProfileUploadLoginBtn = document.getElementById('devProfileUploadLoginBtn');
    const loginProfileCameraBtn = document.getElementById('loginProfileCameraBtn');

    const devProfileFallbackImage = '/img/ivs-robot.png';
    let devProfileLoading = false;

    function cleanDevText(value) {
      return String(value || '').trim();
    }

    function setDevProfileText(selector, value) {
      const el = document.querySelector(selector);
      if (el) {
        el.textContent = value || '-';
      }
    }

    function getDeveloperInitials(name) {
      const cleanName = cleanDevText(name);

      if (!cleanName) {
        return 'DV';
      }

      const parts = cleanName
        .split(/\s+/)
        .filter(Boolean)
        .slice(0, 2);

      return parts
        .map((part) => part.charAt(0).toUpperCase())
        .join('') || 'DV';
    }

    function formatDeveloperDate(value) {
      if (!value) return '-';

      const date = new Date(value);

      if (Number.isNaN(date.getTime())) {
        return String(value);
      }

      return date.toLocaleString('en-GB', {
        day: '2-digit',
        month: '2-digit',
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit',
        hour12: false,
      });
    }

    function renderDeveloperAvatar(imageSelector, fallbackSelector, imageUrl, name) {
      const image = document.querySelector(imageSelector);
      const fallback = document.querySelector(fallbackSelector);

      if (!image || !fallback) return;

      const initials = getDeveloperInitials(name);
      const cleanImageUrl = cleanDevText(imageUrl);

      fallback.textContent = initials;

      const showFallback = function () {
        image.classList.add('d-none');
        image.removeAttribute('src');
        fallback.classList.remove('d-none');
      };

      if (!cleanImageUrl) {
        showFallback();
        return;
      }

      image.onerror = showFallback;
      image.src = cleanImageUrl;
      image.classList.remove('d-none');
      fallback.classList.add('d-none');
    }

    function renderDeveloperProfilePreview(profile) {
      const safeProfile = profile || {};

      const developerId = Number(safeProfile.id || 0);

      const displayDeveloperId = developerId
        ? 'DEV-' + String(developerId).padStart(3, '0')
        : 'DEV';

      const name =
        cleanDevText(safeProfile.name) ||
        cleanDevText(safeProfile.username) ||
        'Developer';

      const username =
        cleanDevText(safeProfile.username) ||
        '-';

      const email =
        cleanDevText(safeProfile.email) ||
        '-';

      const role =
        cleanDevText(safeProfile.role) ||
        'Developer';

      const imageUrl =
        cleanDevText(safeProfile.profileImageUrl) ||
        devProfileFallbackImage;

      renderDeveloperAvatar(
        '#developerProfileModalAvatarImage',
        '#developerProfileModalAvatarFallback',
        imageUrl,
        name
      );

      setDevProfileText('#profileCardTopId', displayDeveloperId);
      setDevProfileText('#profileCardName', name);
      setDevProfileText('#profileCardNameId', developerId ? '#' + developerId : '');
      setDevProfileText('#profileCardEmailLine', email);
      setDevProfileText('#profileCardRoleLine', role);

      setDevProfileText('#profileCardDeveloperId', displayDeveloperId);
      setDevProfileText('#profileCardUsername', username);
      setDevProfileText('#profileCardEmail', email);
      setDevProfileText('#profileCardRole', role);
      setDevProfileText(
        '#profileCardStatus',
        safeProfile.isActive === false ? 'Inactive' : 'Active'
      );
      setDevProfileText('#profileCardLastLogin', formatDeveloperDate(safeProfile.lastLoginAt));
      setDevProfileText('#profileCardCreatedAt', formatDeveloperDate(safeProfile.createdAt));
      setDevProfileText('#profileCardUpdatedAt', formatDeveloperDate(safeProfile.updatedAt));
    }

    async function loadDeveloperProfilePreview() {
      if (devProfileLoading) return;

      devProfileLoading = true;

      try {
        const res = await fetch('/api/public/developer-profile', {
          headers: {
            Accept: 'application/json',
          },
          cache: 'no-store',
        });

        const data = await res.json();

        if (!res.ok || !data?.success || !data?.profile) {
          throw new Error(data?.message || 'Developer profile not found.');
        }

        renderDeveloperProfilePreview(data.profile);
      } catch (err) {
        console.error('Developer profile preview error:', err);

        renderDeveloperProfilePreview({
          id: 1,
          name: 'Developer',
          username: 'Developer',
          email: '',
          role: 'Developer',
          profileImageUrl: devProfileFallbackImage,
          isActive: true,
          createdAt: '',
          updatedAt: '',
          lastLoginAt: '',
        });
      } finally {
        devProfileLoading = false;
      }
    }

    function openDevProfileModal() {
      if (!devProfileModal) return;

      devProfileModal.classList.add('show');
      devProfileModal.setAttribute('aria-hidden', 'false');

      loadDeveloperProfilePreview();
    }

    function closeDevProfileModal() {
      if (!devProfileModal) return;

      devProfileModal.classList.remove('show');
      devProfileModal.setAttribute('aria-hidden', 'true');
    }

    function openDeveloperLoginFromProfile() {
      closeDevProfileModal();
      openDeveloperModal();
    }

    if (robotDeveloperTrigger) {
      robotDeveloperTrigger.addEventListener('click', function (event) {
        event.preventDefault();
        event.stopPropagation();
        openDevProfileModal();
      });

      robotDeveloperTrigger.addEventListener('keydown', function (event) {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          openDevProfileModal();
        }
      });
    }

    if (devProfileCloseBtn) {
      devProfileCloseBtn.addEventListener('click', closeDevProfileModal);
    }

    if (devProfileFooterCloseBtn) {
      devProfileFooterCloseBtn.addEventListener('click', closeDevProfileModal);
    }

    if (devProfileUploadLoginBtn) {
      devProfileUploadLoginBtn.addEventListener('click', openDeveloperLoginFromProfile);
    }

    if (loginProfileCameraBtn) {
      loginProfileCameraBtn.addEventListener('click', openDeveloperLoginFromProfile);
    }

    if (devProfileModal) {
      devProfileModal.addEventListener('click', function (event) {
        if (event.target === devProfileModal) {
          closeDevProfileModal();
        }
      });
    }
    if (developerCloseBtn) {
      developerCloseBtn.addEventListener('click', closeDeveloperModal);
    }

    if (developerModal) {
      developerModal.addEventListener('click', function (event) {
        if (event.target === developerModal) {
          closeDeveloperModal();
        }
      });
    }
document.addEventListener('keydown', function (event) {
  if (event.key === 'Escape' && developerModal && developerModal.classList.contains('show')) {
    closeDeveloperModal();
  }

  if (event.key === 'Escape' && devProfileModal && devProfileModal.classList.contains('show')) {
    closeDevProfileModal();
  }
});
    if (developerPasswordInput && toggleDeveloperPassword) {
      toggleDeveloperPassword.addEventListener('click', function () {
        const isPassword = developerPasswordInput.type === 'password';
        developerPasswordInput.type = isPassword ? 'text' : 'password';

        const icon = toggleDeveloperPassword.querySelector('i');
        if (icon) {
          icon.className = isPassword ? 'bi bi-eye-slash' : 'bi bi-eye';
        }
      });
    }

    <% if (developerError) { %>
      openDeveloperModal();
    <% } %>

    const toast = document.getElementById('loginToast');
    const toastCloseBtn = document.getElementById('toastCloseBtn');

    if (toast && toastCloseBtn) {
      toastCloseBtn.addEventListener('click', function () {
        toast.style.display = 'none';
      });

      setTimeout(function () {
        if (toast) {
          toast.style.opacity = '0';
          toast.style.transform = 'translateX(24px) translateY(-8px)';
          setTimeout(function () {
            toast.style.display = 'none';
          }, 250);
        }
      }, 6000);
    }
  })();
</script>

</body>
</html>