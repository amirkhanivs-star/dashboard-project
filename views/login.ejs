        <div class="developer-info-card">
          <div class="developer-info-head">
            <span class="developer-info-icon">
              <i class="bi bi-person-badge"></i>
            </span>
            Username
          </div>

          <div
            class="developer-info-value"
            id="profileCardUsername"
          >-</div>
        </div>

        <div class="developer-info-card">
          <div class="developer-info-head">
            <span class="developer-info-icon">
              <i class="bi bi-envelope-check"></i>
            </span>
            Email
          </div>

          <div
            class="developer-info-value"
            id="profileCardEmail"
          >-</div>
        </div>

        <div class="developer-info-card">
          <div class="developer-info-head">
            <span class="developer-info-icon">
              <i class="bi bi-code-square"></i>
            </span>
            Role
          </div>

          <div
            class="developer-info-value"
            id="profileCardRole"
