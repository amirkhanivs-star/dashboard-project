    </div>

    <div class="developer-profile-body">

      <div class="developer-card-info-grid">

        <div class="developer-info-card">
          <div class="developer-info-head">
            <span class="developer-info-icon">
              <i class="bi bi-person-vcard"></i>
            </span>
            Developer ID
          </div>

          <div
            class="developer-info-value"
