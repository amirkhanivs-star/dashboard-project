        </div>

        <div class="developer-info-card">
          <div class="developer-info-head">
            <span class="developer-info-icon">
              <i class="bi bi-shield-check"></i>
            </span>
            Account Status
          </div>

          <div
            class="developer-info-value"
            id="profileCardStatus"
          >Active</div>
        </div>

        <div class="developer-info-card">
          <div class="developer-info-head">
            <span class="developer-info-icon">
              <i class="bi bi-clock-history"></i>
            </span>
            Last Login
          </div>

          <div
            class="developer-info-value"
            id="profileCardLastLogin"
          >-</div>
        </div>

      </div>

      <div class="developer-profile-divider"></div>

      <div class="developer-profile-footer">
