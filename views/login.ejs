/* DEVELOPER PROFILE PREVIEW - SAME AS DEVELOPER DASHBOARD CARD */
.dev-profile-overlay{
  position:fixed;
  inset:0;
  z-index:10001;
  background:rgba(15,23,42,.52);
  backdrop-filter:blur(12px);
  -webkit-backdrop-filter:blur(12px);
  display:none;
  align-items:center;
  justify-content:center;
  padding:18px;
}

.dev-profile-overlay.show{
  display:flex;
}

.dev-profile-overlay .developer-profile-card{
  width:min(94vw, 980px);
}

.developer-profile-card{
  position:relative;
  overflow:hidden;
  border-radius:30px;
  border:1px solid rgba(255,255,255,.78);
  background:linear-gradient(
    135deg,
    rgba(237,233,254,.99) 0%,
    rgba(243,232,255,.99) 48%,
    rgba(252,231,243,.99) 100%
  );
  box-shadow:
    0 35px 100px rgba(23,16,54,.34),
    0 12px 35px rgba(124,58,237,.17);
  animation:developerModalIn .24s ease-out;
}

.developer-profile-cover{
  position:relative;
  min-height:250px;
  padding:22px 28px 30px;
  overflow:hidden;
  background:
    linear-gradient(
      180deg,
      rgba(255,255,255,0) 0%,
      rgba(255,255,255,0) 53%,
      rgba(255,255,255,.45) 53%,
      rgba(255,255,255,.45) 100%
    ),
    radial-gradient(
      circle at 18% 18%,
      rgba(255,255,255,.20) 0 2px,
      transparent 2px 100%
    ),
    linear-gradient(
      115deg,
      #8174fa 0%,
      #ae72ee 48%,
      #eb75bc 100%
    );
  background-size:auto, 22px 22px, auto;
}

.developer-profile-cover::after{
  content:"";
  position:absolute;
  width:280px;
  height:280px;
  right:-100px;
  top:-145px;
  border-radius:50%;
  background:rgba(255,255,255,.12);
  pointer-events:none;
}

.developer-profile-top-row{
  position:relative;
  z-index:2;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
}

.developer-profile-top-chip{
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding:9px 13px;
  border-radius:16px;
  background:rgba(255,255,255,.93);
  color:#302d49;
  font-size:11px;
  font-weight:950;
  letter-spacing:.03em;
  box-shadow:0 10px 28px rgba(41,29,90,.16);
  text-transform:uppercase;
}

.developer-profile-chip-number{
  min-width:32px;
  height:30px;
  padding:0 8px;
  border-radius:999px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  color:#ffffff;
  background:#635bff;
  font-size:10px;
  font-weight:950;
}

.developer-profile-close{
  width:36px;
  height:36px;
  border:1px solid rgba(255,255,255,.7);
  border-radius:12px;
  background:rgba(17,24,39,.88);
  color:#ffffff;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  transition:.16s ease;
}

.developer-profile-close:hover{
  background:#ffffff;
  color:#111827;
  transform:rotate(4deg);
}

.developer-profile-identity{
  position:relative;
  z-index:2;
  display:flex;
  align-items:flex-end;
  gap:25px;
  margin-top:45px;
}

.developer-card-avatar-shell{
  position:relative;
  width:170px;
  height:170px;
  border-radius:30px;
  flex-shrink:0;
  border:6px solid rgba(255,255,255,.96);
  background:#111827;
  box-shadow:
    0 22px 38px rgba(37,26,82,.28),
    0 4px 12px rgba(0,0,0,.12);
}

.developer-card-avatar-image,
.developer-card-avatar-fallback{
  width:100%;
  height:100%;
  border-radius:22px;
}

.developer-card-avatar-image{
  display:block;
  object-fit:cover;
  object-position:center top;
  background:#ffffff;
  image-rendering:auto;
  filter:none !important;
}

.developer-card-avatar-fallback{
  display:flex;
  align-items:center;
  justify-content:center;
  color:#ffffff;
  font-size:38px;
  font-weight:950;
  letter-spacing:-.04em;
  background:linear-gradient(
    135deg,
    #111827 0%,
    #5b21b6 48%,
    #db2777 100%
  );
}

.developer-card-camera-button{
  position:absolute;
  right:-10px;
  bottom:-10px;
  width:42px;
  height:42px;
  border:4px solid #ffffff;
  border-radius:50%;
  background:#111827;
  color:#ffffff;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  font-size:15px;
  box-shadow:0 9px 22px rgba(0,0,0,.24);
  transition:.16s ease;
}

.developer-card-camera-button:hover{
  background:#635bff;
  transform:scale(1.06);
}

.developer-profile-main-info{
  min-width:0;
  padding-bottom:7px;
}

.developer-profile-eyebrow{
  display:flex;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
  margin-bottom:7px;
}

.developer-profile-role-badge{
  display:inline-flex;
  align-items:center;
  gap:6px;
  padding:6px 10px;
  border-radius:999px;
  background:rgba(255,255,255,.87);
  color:#5b4fe8;
  font-size:10px;
  font-weight:950;
  letter-spacing:.05em;
  text-transform:uppercase;
}

.developer-profile-online{
  display:inline-flex;
  align-items:center;
  gap:7px;
  color:#059669;
  font-size:11px;
  font-weight:950;
}

.developer-profile-online-dot{
  width:8px;
  height:8px;
  border-radius:50%;
  background:#10b981;
  box-shadow:0 0 0 4px rgba(16,185,129,.14);
}

.developer-profile-name{
  margin:0;
  color:#17152d;
  font-size:38px;
  line-height:1.05;
  font-weight:950;
  letter-spacing:-1.3px;
  word-break:break-word;
}

.developer-profile-name-id{
  color:#6558f5;
}

.developer-profile-meta-line{
  display:flex;
  align-items:center;
  gap:16px;
  flex-wrap:wrap;
  margin-top:11px;
  color:#706e8c;
  font-size:13px;
  font-weight:800;
}

.developer-profile-meta-line span{
  display:inline-flex;
  align-items:center;
  gap:7px;
}

.developer-profile-body{
  padding:26px 28px 24px;
}

.developer-card-info-grid{
  display:grid;
  grid-template-columns:repeat(3, minmax(0, 1fr));
  gap:15px;
}

.developer-info-card{
  min-height:102px;
  border:1px solid rgba(255,255,255,.80);
  border-radius:19px;
  padding:16px;
  background:rgba(255,255,255,.58);
  box-shadow:inset 0 1px 0 rgba(255,255,255,.88);
  backdrop-filter:blur(13px);
  -webkit-backdrop-filter:blur(13px);
}

.developer-info-head{
  display:flex;
  align-items:center;
  gap:10px;
  margin-bottom:12px;
  color:#9290b0;
  font-size:10px;
  line-height:1;
  font-weight:950;
  letter-spacing:.08em;
  text-transform:uppercase;
}

.developer-info-icon{
  width:32px;
  height:32px;
  border-radius:10px;
  background:#ffffff;
  color:#6558f5;
  display:flex;
  align-items:center;
  justify-content:center;
  flex-shrink:0;
  font-size:14px;
  box-shadow:0 5px 13px rgba(79,70,229,.10);
}

.developer-info-value{
  color:#34324a;
  font-size:14px;
  line-height:1.4;
  font-weight:900;
  overflow-wrap:anywhere;
}

.developer-profile-divider{
  height:1px;
  margin:23px 0 18px;
  background:rgba(113,99,178,.16);
}

.developer-profile-footer{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:16px;
  flex-wrap:wrap;
}

.developer-profile-dates{
  display:flex;
  align-items:center;
  gap:18px;
  flex-wrap:wrap;
  color:#77758e;
  font-size:10px;
  font-weight:800;
}

.developer-profile-dates strong{
  display:block;
  margin-top:3px;
  color:#34324a;
  font-size:11px;
  font-weight:950;
}

.developer-profile-actions{
  display:flex;
  align-items:center;
  gap:9px;
  flex-wrap:wrap;
}

.developer-profile-upload-btn{
  border:0;
  border-radius:13px;
  min-height:40px;
  padding:9px 15px;
  background:linear-gradient(
    135deg,
    #6558f5,
    #8b5cf6
  );
  color:#ffffff;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:8px;
  font-size:11px;
  font-weight:950;
  cursor:pointer;
  box-shadow:0 10px 22px rgba(99,88,245,.25);
  transition:.16s ease;
}

.developer-profile-upload-btn:hover{
  transform:translateY(-1px);
  box-shadow:0 13px 26px rgba(99,88,245,.32);
}

.developer-profile-close-btn{
  min-height:40px;
  padding:9px 15px;
  border:1px solid rgba(98,87,180,.18);
  border-radius:13px;
  background:rgba(255,255,255,.72);
  color:#34324a;
  font-size:11px;
  font-weight:950;
  cursor:pointer;
}

.developer-profile-close-btn:hover{
  background:#ffffff;
}

.developer-profile-upload-note{
  margin-top:8px;
  color:#85829d;
  font-size:9px;
  font-weight:750;
}

@media (max-width:760px){
  .dev-profile-overlay{
    align-items:flex-start;
    overflow:auto;
  }

  .dev-profile-overlay .developer-profile-card{
    width:min(96vw, 520px);
  }

  .developer-profile-cover{
    min-height:auto;
