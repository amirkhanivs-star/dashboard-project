<script>
(function () {
  const widget = document.getElementById("accountsNumberNoteWidget");
  const openBtn = document.getElementById("accountsNumberNoteOpenBtn");

  if (!widget) return;

  const listEl = document.getElementById("accountsNumberNoteList");
  const emptyEl = document.getElementById("accountsNumberNoteEmpty");
  const hideBtn = document.getElementById("accountsNumberNoteHideBtn");

  const storageKey =
    widget.getAttribute("data-hidden-storage-key") ||
    "ivs_accounts_number_note_hidden_details";

  const positionStorageKey = `${storageKey}_position_v2`;
  let currentNote = null;
  let openBtnDragMoved = false;

  window.ACCOUNTS_NUMBER_NOTE = <%- JSON.stringify(
    shouldRenderAccountsNumberNote
      ? accountsNumberNoteData
      : {
          enabled: false,
          highestNumbers: null,
          sidebarHighest: null,
          latestNumbers: null,
          notepadLatest: null,
          latestHighest: null,
          records: [],
          total: 0
        }
  ) %>;

  function isAccountsNumberNoteMobile() {
    return window.matchMedia("(max-width: 767.98px)").matches;
  }

  function clearAccountsNumberNoteInlinePosition(element) {
    if (!element) return;

    element.style.left = "";
    element.style.top = "";
    element.style.right = "";
    element.style.bottom = "";
  }

  function clampAccountsNumberNotePosition(left, top, element) {
    const rect = element.getBoundingClientRect();
    const margin = 10;
    const width = rect.width || 160;
    const height = rect.height || 44;

    return {
      left: Math.min(
        Math.max(margin, left),
        Math.max(margin, window.innerWidth - width - margin)
      ),
      top: Math.min(
        Math.max(margin, top),
        Math.max(margin, window.innerHeight - height - margin)
      )
    };
  }

  function setAccountsNumberNotePosition(element, left, top) {
    if (!element) return;

    element.style.left = `${Math.round(left)}px`;
    element.style.top = `${Math.round(top)}px`;
    element.style.right = "auto";
    element.style.bottom = "auto";
  }

  function saveAccountsNumberNotePosition(left, top) {
    localStorage.setItem(
      positionStorageKey,
      JSON.stringify({
        left: Math.round(left),
        top: Math.round(top)
      })
    );
  }

  function readAccountsNumberNotePosition() {
    try {
      const parsed = JSON.parse(localStorage.getItem(positionStorageKey) || "null");

      if (
        !parsed ||
        !Number.isFinite(Number(parsed.left)) ||
        !Number.isFinite(Number(parsed.top))
      ) {
        return null;
      }

      return {
        left: Number(parsed.left),
        top: Number(parsed.top)
      };
    } catch (err) {
      return null;
    }
  }

  function applySavedAccountsNumberNotePosition() {
    if (isAccountsNumberNoteMobile()) {
      clearAccountsNumberNoteInlinePosition(widget);
      clearAccountsNumberNoteInlinePosition(openBtn);
      return;
    }

    const savedPosition = readAccountsNumberNotePosition();

    if (!savedPosition) {
      return;
    }

    const activeElement =
      widget && !widget.classList.contains("d-none")
        ? widget
        : (openBtn || widget);

    const clamped = clampAccountsNumberNotePosition(
      savedPosition.left,
      savedPosition.top,
      activeElement
    );

    setAccountsNumberNotePosition(widget, clamped.left, clamped.top);
    setAccountsNumberNotePosition(openBtn, clamped.left, clamped.top);
    saveAccountsNumberNotePosition(clamped.left, clamped.top);
  }

  function startAccountsNumberNoteDrag(event, dragElement) {
    if (!dragElement || isAccountsNumberNoteMobile()) {
      return;
    }

    if (event.button !== undefined && event.button !== 0) {
      return;
    }

    if (
      dragElement === widget &&
      event.target.closest(".accounts-number-note-hide-btn")
    ) {
      return;
    }

    const startRect = dragElement.getBoundingClientRect();
    const startClientX = event.clientX;
    const startClientY = event.clientY;
    let latestLeft = startRect.left;
    let latestTop = startRect.top;
    let didMove = false;

    dragElement.classList.add("is-dragging");
    event.preventDefault();

    function handlePointerMove(moveEvent) {
      const deltaX = moveEvent.clientX - startClientX;
      const deltaY = moveEvent.clientY - startClientY;

      if (Math.abs(deltaX) > 2 || Math.abs(deltaY) > 2) {
        didMove = true;
      }

      const activeElement =
        widget && !widget.classList.contains("d-none")
          ? widget
          : dragElement;

      const nextPosition = clampAccountsNumberNotePosition(
        startRect.left + deltaX,
        startRect.top + deltaY,
        activeElement
      );

      latestLeft = nextPosition.left;
      latestTop = nextPosition.top;

      setAccountsNumberNotePosition(widget, latestLeft, latestTop);
      setAccountsNumberNotePosition(openBtn, latestLeft, latestTop);
    }

    function handlePointerUp() {
      document.removeEventListener("pointermove", handlePointerMove);
      dragElement.classList.remove("is-dragging");

      if (didMove) {
        saveAccountsNumberNotePosition(latestLeft, latestTop);

        if (dragElement === openBtn) {
          openBtnDragMoved = true;

          setTimeout(function () {
            openBtnDragMoved = false;
          }, 0);
        }
      }
    }

    document.addEventListener("pointermove", handlePointerMove);
    document.addEventListener("pointerup", handlePointerUp, { once: true });
  }

  function initAccountsNumberNoteDrag() {
    const noteHead = widget.querySelector(".accounts-number-note-head");

    if (noteHead) {
      noteHead.addEventListener("pointerdown", function (event) {
        startAccountsNumberNoteDrag(event, widget);
      });
    }

    if (openBtn) {
      openBtn.addEventListener("pointerdown", function (event) {
        startAccountsNumberNoteDrag(event, openBtn);
      });
    }

    applySavedAccountsNumberNotePosition();

    window.addEventListener("resize", applySavedAccountsNumberNotePosition);
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

   function normalizeLatestNumbers(data = {}) {
    const latest =
      (
        data &&
        (
          data.latestNumbers ||
          data.notepadLatest
        )
      ) ||
      null;

    const familyNumber =
      String(
        latest?.familyNumber || ""
      ).trim();

    const verificationNumber =
      String(
        latest?.verificationNumber || ""
      ).trim();

    const registrationNumber =
      String(
        latest?.registrationNumber || ""
      ).trim();

    const hasFamilyNumber =
      !!familyNumber;

    const hasVerificationNumber =
      !!verificationNumber;

    const hasRegistrationNumber =
      !!registrationNumber;

    const hasRecord =
      hasFamilyNumber ||
      hasVerificationNumber ||
      hasRegistrationNumber;

    const fallbackCopyText = [
      hasFamilyNumber
        ? `FAM: ${familyNumber}`
        : "",

      hasVerificationNumber
        ? `VERIF: ${verificationNumber}`
        : "",

      hasRegistrationNumber
        ? `REG: ${registrationNumber}`
        : ""
    ]
      .filter(Boolean)
      .join(" | ");

    const copyText =
      String(
        latest?.copyText ||
        fallbackCopyText
      ).trim();

    return {
      hasRecord,
      familyNumber,
      verificationNumber,
      registrationNumber,
      hasFamilyNumber,
      hasVerificationNumber,
      hasRegistrationNumber,
      copyText
    };
  }

  function makeAccountsNumberChip(label, value) {
    return `
      <span
        class="accounts-number-note-chip"
        title="${escapeHtml(value)}">

        <span class="accounts-number-note-chip-label">
          ${escapeHtml(label)}
        </span>

        <span class="accounts-number-note-chip-value">
          ${escapeHtml(value)}
        </span>
      </span>
    `;
  }

  function renderAccountsNumberNote(data = {}) {
    const note =
      normalizeLatestNumbers(data);

    currentNote = note;

    if (!note.hasRecord) {
      listEl.innerHTML = "";

      if (emptyEl) {
        emptyEl.classList.remove("d-none");
      }

      return;
    }

    if (emptyEl) {
      emptyEl.classList.add("d-none");
    }

    const numberChips = [
      note.hasFamilyNumber
        ? makeAccountsNumberChip(
            "FAM",
            note.familyNumber
          )
        : "",

      note.hasVerificationNumber
        ? makeAccountsNumberChip(
            "VERIF",
            note.verificationNumber
          )
        : "",

      note.hasRegistrationNumber
        ? makeAccountsNumberChip(
            "REG",
            note.registrationNumber
          )
        : ""
    ]
      .filter(Boolean)
      .join("");

    listEl.innerHTML = `
      <div class="accounts-number-note-row">
        <div class="accounts-number-note-numbers">
          ${numberChips}
        </div>

        <button
          type="button"
          class="accounts-number-note-copy"
          data-copy-note="1">

          <i class="bi bi-copy me-1"></i>
          Copy
        </button>
      </div>
    `;
  }


  function setNoteHidden(hidden) {
    const shouldHide = !!hidden;

    widget.classList.toggle("d-none", shouldHide);

    if (openBtn) {
      openBtn.classList.toggle("d-none", !shouldHide);
    }

    localStorage.setItem(storageKey, shouldHide ? "1" : "0");

    requestAnimationFrame(applySavedAccountsNumberNotePosition);
  }

  async function refreshAccountsNumberNote() {
    try {
      const response = await fetch("/api/accounts-number-note", {
        headers: {
          Accept: "application/json"
        }
      });

      const data = await response.json();

      const noteData =
        data.accountsNumberNote ||
        data.note ||
        {
          enabled: false,
          highestNumbers: null,
          sidebarHighest: null,
          latestNumbers: null,
          notepadLatest: null,
          latestHighest: null,
          records: [],
          total: 0
        };

      if (
        !response.ok ||
        data.success === false
      ) {
        return;
      }

      window.ACCOUNTS_NUMBER_NOTE = noteData;
      renderAccountsNumberNote(noteData);
    } catch (err) {
      console.warn("accounts number note refresh failed", err);
    }
  }

  if (hideBtn) {
    hideBtn.addEventListener("click", function () {
      setNoteHidden(true);
    });
  }

  if (openBtn) {
    openBtn.addEventListener("click", function () {
      if (openBtnDragMoved) {
        openBtnDragMoved = false;
        return;
      }

      setNoteHidden(false);
    });
  }

  widget.addEventListener("click", async function (event) {
    const copyBtn =
      event.target.closest("[data-copy-note]");

    if (
      !copyBtn ||
      !currentNote ||
      !currentNote.hasRecord
    ) {
      return;
    }

    try {
      await navigator.clipboard.writeText(
        currentNote.copyText || ""
      );

      const oldHtml = copyBtn.innerHTML;
      copyBtn.innerHTML =
        '<i class="bi bi-check2 me-1"></i> Copied';

      if (typeof window.showUploadFlash === "function") {
        window.showUploadFlash(
          "success",
          "Copied",
          "Latest family, verification and registration numbers copied."
        );
      }

      setTimeout(function () {
        copyBtn.innerHTML = oldHtml;
      }, 1200);
    } catch (err) {
      alert("Copy failed. Please copy manually.");
    }
  });

  initAccountsNumberNoteDrag();

  renderAccountsNumberNote(window.ACCOUNTS_NUMBER_NOTE || {});

  const hidden = localStorage.getItem(storageKey) === "1";
  setNoteHidden(hidden);

  setInterval(
    refreshAccountsNumberNote,
    60000
  );

  if (typeof io === "function") {
    try {
      const socket = io();

      socket.on("admission:changed", function () {
        refreshAccountsNumberNote();
      });
    } catch (err) {
      console.warn("accounts number note socket failed", err);
    }
  }
})();
</script>

<script>
(function () {
  const backLinks = Array.from(
    document.querySelectorAll(
      '.js-details-page-back-link'
    )
  );

  const pageNavigationLinks = Array.from(
    document.querySelectorAll(
      'a.btn-premium-edit[href], ' +
      'a.btn-fee-collection[href]'
    )
  );

  if (
    !backLinks.length &&
    !pageNavigationLinks.length
  ) {
    return;
  }

  const DETAILS_NAVIGATION_HOLD_MS = 650;
  let detailsNavigationStarted = false;

  function isDashboardPath(pathname) {
    const cleanPath =
      String(pathname || '').trim();

    if (cleanPath === '/dashboard') {
      return true;
    }

    if (!cleanPath.startsWith('/dashboard/')) {
      return false;
    }

    const isNestedDashboardPage =
      cleanPath.includes('/admission/') ||
      cleanPath.includes('/fee-collection') ||
      cleanPath.includes('/files');

    return !isNestedDashboardPage;
  }

  function isPlainNavigationClick(event) {
    return !!(
      event &&
      !event.defaultPrevented &&
      event.button === 0 &&
      !event.metaKey &&
      !event.ctrlKey &&
      !event.shiftKey &&
      !event.altKey
    );
  }

  function getSafeInternalUrl(rawUrl) {
    const cleanUrl =
      String(rawUrl || '').trim();

    if (!cleanUrl) {
      return '';
    }

    try {
      const targetUrl =
        new URL(
          cleanUrl,
          window.location.origin
        );

      if (
        targetUrl.origin !==
        window.location.origin
      ) {
        return '';
      }

      return targetUrl.href;
    } catch (error) {
      return '';
    }
  }

  function getSafeReturnUrl() {
    const params =
      new URLSearchParams(
        window.location.search
      );

    const rawReturnTo =
      String(
        params.get('returnTo') || ''
      ).trim();

    if (!rawReturnTo) {
      return '';
    }

    try {
      const targetUrl =
        new URL(
          rawReturnTo,
          window.location.origin
        );

      const isSafe =
        targetUrl.origin ===
          window.location.origin &&
        isDashboardPath(
          targetUrl.pathname
        );

      if (!isSafe) {
        return '';
      }

      return (
        targetUrl.pathname +
        targetUrl.search +
        targetUrl.hash
      );
    } catch (error) {
      return '';
    }
  }

  function addReturnToToInternalUrl(
    rawUrl,
    returnUrl
  ) {
    const safeTarget =
      getSafeInternalUrl(rawUrl);

    if (!safeTarget || !returnUrl) {
      return '';
    }

    try {
      const targetUrl =
        new URL(safeTarget);

      targetUrl.searchParams.set(
        'returnTo',
        returnUrl
      );

      return (
        targetUrl.pathname +
        targetUrl.search +
        targetUrl.hash
      );
    } catch (error) {
      return '';
    }
  }

  function commitNavigation(callback) {
    if (
      detailsNavigationStarted ||
      typeof callback !== 'function'
    ) {
      return false;
    }

    detailsNavigationStarted = true;

    if (
      window.IVSLoader &&
      typeof window.IVSLoader.show ===
        'function'
    ) {
      window.IVSLoader.show({
        persist: true
      });

      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          setTimeout(
            callback,
            DETAILS_NAVIGATION_HOLD_MS
          );
        });
      });

      return true;
    }

    callback();
    return true;
  }

  function navigateWithLoader(targetUrl) {
    const safeTarget =
      getSafeInternalUrl(targetUrl);

    if (!safeTarget) {
      return false;
    }

    return commitNavigation(function () {
      window.location.assign(
        safeTarget
      );
    });
  }

  function goBackWithLoader() {
    return commitNavigation(function () {
      window.history.back();
    });
  }

  const safeReturnUrl =
    getSafeReturnUrl();

  /*
   * Dashboard returnTo available ho to:
   * 1. Back button ka safe fallback URL banao.
   * 2. Edit aur Fee Collection links ke saath
   *    original dashboard returnTo forward karo.
   */
  if (safeReturnUrl) {
    backLinks.forEach(function (link) {
      link.setAttribute(
        'href',
        safeReturnUrl
      );
    });

    pageNavigationLinks.forEach(function (link) {
      const nestedPageUrl =
        addReturnToToInternalUrl(
          link.getAttribute('href') || '',
          safeReturnUrl
        );

      if (nestedPageUrl) {
        link.setAttribute(
          'href',
          nestedPageUrl
        );
      }
    });
  }

  /*
   * Edit aur Fee Collection full-page routes hain.
   * Loader ko pehle paint time milega, phir route
   * open hoga. Print/download buttons unchanged hain.
   */
  pageNavigationLinks.forEach(function (link) {
    link.addEventListener(
      'click',
      function (event) {
        if (
          !isPlainNavigationClick(event) ||
          link.hasAttribute('download')
        ) {
          return;
        }

        const targetName =
          String(
            link.getAttribute('target') || ''
          )
            .trim()
            .toLowerCase();

        if (
          targetName &&
          targetName !== '_self'
        ) {
          return;
        }

        const targetUrl =
          String(
            link.getAttribute('href') || ''
          ).trim();

        if (!getSafeInternalUrl(targetUrl)) {
          return;
        }

        event.preventDefault();

        navigateWithLoader(
          targetUrl
        );
      }
    );
  });

  backLinks.forEach(function (link) {
    link.addEventListener(
      'click',
      function (event) {
        if (!isPlainNavigationClick(event)) {
          return;
        }

        const fallbackUrl =
          String(
            link.getAttribute('href') || ''
          ).trim();

        /*
         * User dashboard se directly Details page
         * par aya ho to browser Back exact previous
         * dashboard state, filter aur scroll restore
         * karega. Loader pehle paint hoga.
         */
        if (
          window.history.length > 1 &&
          document.referrer
        ) {
          try {
            const previousUrl =
              new URL(
                document.referrer
              );

            const cameFromDashboard =
              previousUrl.origin ===
                window.location.origin &&
              isDashboardPath(
                previousUrl.pathname
              );

            if (cameFromDashboard) {
              event.preventDefault();
              goBackWithLoader();
              return;
            }
          } catch (error) {
            /*
             * Referrer invalid ho to safe href
             * fallback central loader use karega.
             */
          }
        }

        event.preventDefault();

        navigateWithLoader(
          fallbackUrl
        );
      }
    );
  });
})();
</script>

