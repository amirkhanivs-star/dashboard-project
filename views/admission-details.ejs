                  <div class="drow">
                    <span class="k">Status:</span>
                    <span class="v">
                      <span class="chip chip-ok"><%= (curStatus || '-') %></span>
                    </span>
                  </div>

                  <div class="drow"><span class="k">Admission Date:</span> <span class="v"><%= (admissionInfo.month || '-') %></span></div>
                  <div class="drow"><span class="k">Role:</span> <span class="v">Student</span></div>

                  <div class="drow"><span class="k">Contact:</span> <span class="v"><%= (X.phone || X.contactNumber || '-') %></span></div>

                  <div class="drow mt-2">
                    <span class="k">Fee Status:</span>
                    <span class="v">
                      <span class="chip"><%= (feeStatus || '-') %></span>
                    </span>
                  </div>

                  <div class="drow">
                    <span class="k">Current Fee:</span>
                    <span class="v">
                      <b><%= money(currentMonthlyFee) %></b>
                      <span class="text-muted small ms-1">(<%= (curCode && curCode !== '-' ? curCode : '-') %>)</span>
                    </span>
                  </div>

                  <div class="drow">
                    <span class="k">Reg #:</span>
                    <span class="v"><%= (regNoAccount || '-') %></span>
                  </div>

                  <div class="drow">
                    <span class="k">Family #:</span>
                    <span class="v"><%= (accounts.familyNumber || getFamilyNo(X) || '-') %></span>
                  </div>

                  <div class="drow">
                    <span class="k">Total Received:</span>
                    <span class="v">
                      <b><%= (billTotals.hasRecv ? money(billTotals.recvTotal) : '-') %></b>
                      <% if (curCode && curCode !== '-' && billTotals.hasRecv) { %>
                        <span class="text-muted small ms-1">( <%= curCode %> )</span>
                      <% } %>
                    </span>
                  </div>

                  <div class="drow">
                    <span class="k">Pending Due:</span>
                    <span class="v">
                      <b><%= (Number.isFinite(pendingTotal) ? money(pendingTotal) : '-') %></b>
                      <% if (curCode && curCode !== '-' && Number.isFinite(pendingTotal)) { %>
                        <span class="text-muted small ms-1">( <%= curCode %> )</span>
                      <% } %>
                    </span>
                  </div>
                </div>

              </div>
            </div>
