      </div>
    </div>

    <button
      type="button"
      class="accounts-number-note-open d-none"
      id="accountsNumberNoteOpenBtn"
      title="Show latest numbers">
      <i class="bi bi-stickies"></i>
      Latest Numbers
    </button>
  <% } %>

  <div class="d-flex justify-content-between align-items-center mb-2 top-head">
    <div>
      <h4 class="mb-0 page-title">Admission Details</h4>
      <div class="text-muted small">
        Admission ID: <b><%= A.id %></b>
        <span class="mx-2">|</span>
        Billing Year: <b><%= CURRENT_YEAR %></b>
        <% if (
          P.col.family &&
          (familyNumber || isAutoFamilyMatch)
        ) { %>
          <span class="mx-2">|</span>
          Family #:
          <b><%= familyNumber || 'Auto Matched' %></b>
          <span class="mx-2">|</span>
          Students:
          <b><%= familyList.length %></b>
        <% } %>
      </div>
    </div>

    <div class="d-flex align-items-center gap-2">
  <a
    href="<%= backUrl %>"
    class="btn rounded-pill btn-premium-back btn-sm js-details-page-back-link">
    <i class="bi bi-arrow-left"></i> Back
  </a>
</div>
  </div>

  <% if (canShowFamilySummary) { %>
    <div class="card border-0 inner-card mb-3">
      <div class="card-body p-3">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
          <div class="sec-title">Family Billing Summary</div>

          <% if (P.col.currency) { %>
            <div class="text-muted small">
              Currency:
              <b><%= (famCurrency && famCurrency !== '-' ? famCurrency : '-') %></b>
            </div>
          <% } %>
        </div>

        <div class="dues-summary mt-2">
          <% if (P.col.totalFees) { %>
            <div class="sum-item">
              <div class="label">Total Fee (All Billing)</div>
              <div class="val">
                <%= (famHasFee ? money(famFeeTotal) : '-') %>

                <% if (
                  P.col.currency &&
                  famCurrency &&
                  famCurrency !== '-' &&
                  famHasFee
                ) { %>
                  <span class="text-muted small ms-1">
                    ( <%= famCurrency %> )
                  </span>
                <% } %>
              </div>
            </div>
          <% } %>

          <% if (P.col.receivedPayment) { %>
            <div class="sum-item">
              <div class="label">Total Received (All Billing)</div>
              <div class="val">
                <%= (famHasRecv ? money(famRecvTotal) : '-') %>

                <% if (
                  P.col.currency &&
                  famCurrency &&
                  famCurrency !== '-' &&
                  famHasRecv
                ) { %>
                  <span class="text-muted small ms-1">
                    ( <%= famCurrency %> )
                  </span>
                <% } %>
              </div>
            </div>
          <% } %>

          <% if (P.col.pendingDues) { %>
            <div class="sum-item">
              <div class="label">Total Pending</div>
              <div class="val">
                <%= (famHasPending ? money(famPendingTotal) : '-') %>

                <% if (
                  P.col.currency &&
                  famCurrency &&
                  famCurrency !== '-' &&
                  famHasPending
                ) { %>
                  <span class="text-muted small ms-1">
                    ( <%= famCurrency %> )
                  </span>
                <% } %>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  <% } %>

  <% if (!familyList || familyList.length === 0) { %>
    <div class="text-muted small">No admission data found.</div>
  <% } else { %>

    <% familyList.forEach((X, idx) => {
         const isCurrent = String(X?.id) === String(A?.id);
         const accounts = X.accounts || {};
         const admissionInfo = X.admission || {};

         const curStatus = getCurStatus(X);
         const feeStatus = getFeeStatus(X);

         const studentName = getStudentName(X);
         const initials = initialsFromName(studentName);
         const dept = String(X.dept || '-').trim();
         const grade = String(X.grade || '-').trim();

         const displayStudentName =
           P.col.student
             ? studentName
             : `Admission #${X.id || '-'}`;

         const displayInitials =
           P.col.student
             ? initials
             : '#';

         const profileMetaParts = [
           P.col.grade && grade && grade !== '-'
             ? grade
             : '',

           P.col.dept && dept && dept !== '-'
             ? (
                 dept.charAt(0).toUpperCase() +
                 dept.slice(1)
               )
             : ''
         ].filter(Boolean);

         const curCode =
           P.col.currency
             ? String(getCurrency(X) || '').trim()
             : '-';

         const admissionBank = getAdmissionBank(X);

         const mm = buildMonthMatrix(X, admissionInfo);
         const monthMatrix = mm.matrix;

         const duesRows = buildPendingDues(monthMatrix, admissionInfo);
         const regInfo = buildRegistrationFeeInfo(X, admissionInfo, monthMatrix);

         const monthlyDuesTotal = duesRows.reduce((sum, r) => Number.isFinite(r.due) ? sum + r.due : sum, 0);
const registrationPendingTotal = regInfo.enabled ? Number(regInfo.pending || 0) : 0;

const totalDues = monthlyDuesTotal + registrationPendingTotal;
const hasNumericTotal = duesRows.some(r => Number.isFinite(r.due)) || registrationPendingTotal > 0;

         const historyRows = (monthMatrix || []).filter(m => {
           const st = String(m.status || '').trim();
           const amt = parseFirstNumber(m.amount);
           const fee = parseFirstNumber(m.fee);
           if (st && st.toLowerCase() === 'not admitted') return true;
           return !!st || amt > 0 || fee > 0;
         });

         const billTotals = sumFromMonthMatrix(monthMatrix);

if (regInfo.enabled) {
  billTotals.feeTotal += Number(regInfo.total || 0);
  billTotals.recvTotal += Number(regInfo.received || 0);
  billTotals.hasFee = true;
  if (Number(regInfo.received || 0) > 0) billTotals.hasRecv = true;
}

         const latestHistoryFee =
           (mm?.history && mm.history.length)
             ? parseFirstNumber(mm.history[mm.history.length - 1].fee)
             : 0;

             const registrationFee =
  parseFirstNumber(
    admissionInfo?.registrationFee ||
    admissionInfo?.registration_fee ||
    X?.registrationFee ||
    X?.registration_fee ||
    X?.admission_registration_fee ||
    0
  ) || '-';

         const currentMonthlyFee =
           parseFirstNumber(
             admissionInfo?.monthly_fee_current ||
             admissionInfo?.monthlyFeeCurrent ||
             X?.monthly_fee_current ||
             X?.monthlyFeeCurrent ||
             admissionInfo?.fees ||
             admissionInfo?.fee ||
             latestHistoryFee ||
             0
           ) || '-';

         const regNoAccount = getRegistrationNumber(X);

         const admissionComment = String(
           admissionInfo?.comment ||
           admissionInfo?.admission_comment ||
           X?.comment ||
           X?.admission_comment ||
           ''
         ).trim();

         const pendingTotal = hasNumericTotal ? totalDues : NaN;

         const showFeeTypeColumn =
           P.col.registrationFee ||
           P.col.fees;

         const showMonthColumns =
           P.col.month;

         const showFeeAmountColumn =
           P.col.registrationFee ||
           P.col.fees;

         const duesVisibleColumnCount = [
           showFeeTypeColumn,
           showMonthColumns,
           showMonthColumns,
           P.col.verif,
           P.col.bank,
           showFeeAmountColumn,
           P.col.receivedPayment,
           P.col.pendingDues
         ].filter(Boolean).length || 1;

         const showRegistrationDuesRow =
           regInfo.enabled &&
           regInfo.pending > 0 &&
           (
             P.col.registrationFee ||
             P.col.month ||
             P.col.verif ||
             P.col.bank ||
             P.col.receivedPayment ||
             P.col.pendingDues
           );

         const showMonthlyDuesRows =
           Array.isArray(duesRows) &&
           duesRows.length > 0 &&
           (
             P.col.fees ||
             P.col.month ||
             P.col.verif ||
             P.col.bank ||
             P.col.receivedPayment ||
             P.col.pendingDues
           );

         const showRegistrationHistory =
           regInfo.enabled &&
           (
             P.col.registrationFee ||
             P.col.paymentStatus ||
             P.col.month ||
             P.col.verif ||
             P.col.bank ||
             P.col.receivedPayment ||
             P.col.pendingDues
           );

         const showMonthlyHistory =
           Array.isArray(historyRows) &&
           historyRows.length > 0 &&
           (
             P.col.paymentStatus ||
             P.col.month ||
             P.col.verif ||
             P.col.bank ||
             P.col.fees ||
             P.col.receivedPayment ||
             P.col.pendingDues ||
             canPrintChallans
           );
    %>

