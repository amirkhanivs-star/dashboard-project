<%- include('partials/bootstrap-header', { user, pageTitle: 'Admission Details' }) %>
<%- include('partials/flash') %>

<%
  const A = admission || {};

  function statusClass(v){
    v = String(v||'').toLowerCase().trim();
    if (v === 'running') return 'status-running';
    if (v === 'leave')   return 'status-leave';
    if (v === 'stop')    return 'status-stop';
    if (v === 'left')    return 'status-left';
    if (v === 'freez')   return 'status-freez';
    return '';
  }

  function feeClass(v){
    v = String(v||'').toLowerCase().trim();
    if (v === 'present + dues') return 'fee-dues';
    if (v === 'present + no dues') return 'fee-nodues';
    return '';
  }

  function billingStatusClass(v){
    v = String(v||'').toLowerCase().trim();
    if (v === 'not admitted')   return 'bill-notadmitted';
    if (v === 'full payment')   return 'bill-full';
    if (v === 'partial payment')return 'bill-partial';
    if (v === 'no payment')     return 'bill-none';
    return '';
  }

  const getCurStatus = (x) => String(x?.status || x?.currentStatus || x?.current_status || '').trim();
  const getFeeStatus = (x) => String(x?.feeStatus || x?.fee_status || '').trim();

  const getCurrency = (x) =>
    (x?.currency_code || x?.currencyCode || x?.admission?.currencyCode || x?.admission?.currency_code || '-');

  const getAdmissionBank = (x) =>
    String(
      x?.bank_name ||
      x?.bankName ||
      x?.admission?.bankName ||
      x?.admission?.bank_name ||
      x?.admission?.bank ||
      ''
    ).trim();

  const getFamilyNo = (x) =>
    String(
      x?.accounts?.familyNumber ||
      x?.admission?.familyNumber ||
      x?.familyNumber ||
      x?.family_number ||
      x?.accounts_family_number ||
      ''
    ).trim();

  const getStudentName = (x) => String(x?.student || x?.studentName || '').trim() || '-';

  const initialsFromName = (name) => {
    name = String(name || '').trim();
    if (!name || name === '-') return 'S';
    const parts = name.split(' ').filter(Boolean);
    const a = parts[0] ? parts[0][0] : 'S';
    const b = parts[1] ? parts[1][0] : '';
    return (a + b).toUpperCase();
  };

  const safeStr = (v) => (v === null || v === undefined) ? '' : String(v);

  const tryParseJSON = (s) => {
    try { return JSON.parse(s); } catch(e){ return null; }
  };

  const toNumber = (v) => {
    if (v === null || v === undefined) return NaN;
    const s = String(v).replace(/[, ]/g,'').trim();
    const n = Number(s);
    return Number.isFinite(n) ? n : NaN;
  };

  const money = (v) => {
    const n = toNumber(v);
    if (!Number.isFinite(n)) return String(v ?? '-');
    return String(n);
  };

  const MONTHS = ['january','february','march','april','may','june','july','august','september','october','november','december'];
  const MONTHS_ABBR = ['jan','feb','mar','apr','may','jun','jul','aug','sep','sept','oct','nov','dec'];

  const normMonth = (m) => safeStr(m).toLowerCase().trim();

  const extractMonthName = (raw) => {
    const s = normMonth(raw);
    if (!s) return '';
    for (const mm of MONTHS){
      if (s.includes(mm)) return mm;
    }
    for (let i=0;i<MONTHS_ABBR.length;i++){
      const ab = MONTHS_ABBR[i];
      if (s.includes(ab)) return MONTHS[i];
    }
    return '';
  };

  const monthIndex = (raw) => {
    const mm = extractMonthName(raw) || normMonth(raw);
    const i = MONTHS.indexOf(mm);
    return i >= 0 ? i : 999;
  };

  const sameMonth = (a, b) => {
    const aa = extractMonthName(a) || normMonth(a);
    const bb = extractMonthName(b) || normMonth(b);
    return aa && bb && aa === bb;
  };

  const sortBillingRowsByMonth = (bill) => {
    return (Array.isArray(bill) ? bill.slice() : []).sort((x,y) => {
      const a = monthIndex(x?.month);
      const b = monthIndex(y?.month);
      if (a !== b) return a - b;
      return safeStr(x?.month).localeCompare(safeStr(y?.month));
    });
  };

  const getFeeFromBillingRow = (b) => {
    return (b?.fee || b?.currentFee || b?.fees || b?.monthFee || b?.monthlyFee || b?.month_fee || b?.monthly_fee);
  };

  const getAmountFromBillingRow = (b) => {
    return (b?.amount || b?.amountReceived || b?.received || b?.receivedAmount || b?.amount_received || b?.received_amount);
  };

  const getVerificationFromBillingRow = (b) => {
    return (
      b?.verificationNumber ||
      b?.verification_no ||
      b?.verificationNo ||
      b?.verif ||
      b?.verifNo ||
      b?.verif_no ||
      b?.trx ||
      b?.trxId ||
      b?.transactionId ||
      b?.bankRef ||
      b?.bank_reference ||
      b?.ref ||
      b?.refNo ||
      b?.ref_no
    );
  };

  const getMonthNumberFromBillingRow = (b) => {
    return (
      b?.monthNumber ||
      b?.month_number ||
      b?.billNumber ||
      b?.bill_number ||
      b?.slipNumber ||
      b?.slip_number ||
      b?.receiptNumber ||
      b?.receipt_number ||
      b?.voucherNumber ||
      b?.voucher_number ||
      b?.number ||
      b?.num ||
      b?.monthlyNumber ||
      b?.monthly_number ||
      b?.monthSlipNo ||
      b?.month_slip_no
    );
  };

  const getBankFromBillingRow = (b) => {
  return (
    b?.bank ||
    b?.bankName ||
    b?.bank_name ||
    b?.selectedBank ||
    b?.paymentBank ||
    b?.payment_bank
  );
};

  const getRegistrationNumber = (x) => {
    return (
      x?.accounts?.registrationNumber ||
      x?.accounts?.registration_no ||
      x?.admission?.registrationNumber ||
      x?.admission?.registration_no ||
      x?.registrationNumber ||
      x?.registration_no ||
      ''
    );
  };

  const BILLING_STATUS_LIST = [
    "Not admitted",
    "No payment",
    "Partial payment",
    "Full payment",
  ];

  const parseFirstNumber = (val) => {
    const s = String(val ?? "");
    const m = s.match(/(-?\d+(\.\d+)?)/);
    if (!m) return 0;
    const n = parseFloat(m[1]);
    return Number.isFinite(n) ? n : 0;
  };

  const splitBillingValue = (val) => {
    const v = String(val || "").trim();
    if (!v) return { status: "", rest: "", amount: 0 };

    for (const st of BILLING_STATUS_LIST) {
      if (v === st) return { status: st, rest: "", amount: 0 };
      if (v.startsWith(st + " | ")) {
        const rest = v.slice((st + " | ").length).trim();
        return { status: st, rest, amount: parseFirstNumber(rest) };
      }
      if (v.startsWith(st + " - ")) {
        const rest = v.slice((st + " - ").length).trim();
        return { status: st, rest, amount: parseFirstNumber(rest) };
      }
    }
    return { status: "", rest: v, amount: parseFirstNumber(v) };
  };

 const normalizeBillingEntry = (entry) => {
  if (entry && typeof entry === "object" && !Array.isArray(entry)) {
    return {
      status: safeStr(entry.status).trim(),
      amount: safeStr(entry.amount).trim(),
      feeOverride: safeStr(entry.feeOverride).trim(),
      verificationNumber: safeStr(entry.verification || entry.verificationNumber || entry.verificationNo || entry.verification_no || entry.verif || entry.trx || entry.ref || '').trim(),
      monthNumber: safeStr(entry.monthNumber || entry.month_number || entry.number || entry.num || entry.slipNumber || entry.receiptNumber || '').trim(),
      receivedOn: safeStr(entry.receivedOn || entry.received_on || entry.paidOn || entry.paid_on || entry.date || '').trim(),
      bank: safeStr(entry.bank || entry.bankName || entry.bank_name).trim(),

registrationFeeTotal: safeStr(entry.registrationFeeTotal || '').trim(),
registrationFeeReceived: safeStr(entry.registrationFeeReceived || '').trim(),
registrationFeeStatus: safeStr(entry.registrationFeeStatus || '').trim(),
registrationFeeVerification: safeStr(entry.registrationFeeVerification || '').trim(),
registrationFeeBank: safeStr(entry.registrationFeeBank || '').trim(),
registrationFeePaymentDate: safeStr(entry.registrationFeePaymentDate || '').trim(),
    };
  }

  const raw = safeStr(entry).trim();
  if (!raw) {
    return {
      status: "",
      amount: "",
      feeOverride: "",
      verificationNumber: "",
      monthNumber: "",
      receivedOn: "",
      bank: "",
      registrationFeeTotal: "",
registrationFeeReceived: "",
registrationFeeStatus: "",
registrationFeeVerification: "",
registrationFeeBank: "",
registrationFeePaymentDate: "",
    };
  }

  const { status, amount } = splitBillingValue(raw);
  return {
    status: status || "",
    amount: String(amount || ""),
    feeOverride: "",
    verificationNumber: "",
    monthNumber: "",
    receivedOn: "",
    bank: "",
    registrationFeeTotal: "",
    registrationFeeReceived: "",
    registrationFeeStatus: "",
    registrationFeeVerification: "",
    registrationFeeBank: "",
    registrationFeePaymentDate: "",
  };
};

  const normalizeFeeHistory = (feeHistory, baseFee, startMonthRaw) => {
    let h = feeHistory;
    if (typeof h === 'string') h = tryParseJSON(h);
    if (!Array.isArray(h)) h = [];

    const cleaned = h
      .map((x) => {
        const rawMonth =
          x?.effectiveMonthKey ||
          x?.effective_month_key ||
          x?.effectiveMonth ||
          x?.effective_month ||
          x?.month ||
          x?.startMonth ||
          x?.start_month ||
          '';

        const mk = extractMonthName(rawMonth) || String(rawMonth || "january").toLowerCase().trim();

        return {
          fee: parseFirstNumber(x?.fee),
          effectiveMonthKey: mk,
          changedAt: x?.changedAt || x?.changed_at || "",
          changedBy: x?.changedBy || x?.changed_by || "",
        };
      })
      .filter((x) => x.fee > 0 && MONTHS.includes(x.effectiveMonthKey));

    if (cleaned.length === 0) {
      const bf = parseFirstNumber(baseFee);
      const startKey = extractMonthName(startMonthRaw) || "january";
      if (bf > 0) {
        cleaned.push({
          fee: bf,
          effectiveMonthKey: startKey,
          changedAt: new Date().toISOString(),
          changedBy: "system",
        });
      }
    }

    cleaned.sort((a, b) => {
      const ai = MONTHS.indexOf(a.effectiveMonthKey);
      const bi = MONTHS.indexOf(b.effectiveMonthKey);
      if (ai !== bi) return ai - bi;
      return String(a.changedAt).localeCompare(String(b.changedAt));
    });

    return cleaned;
  };

  const feeForMonthKey = (history, monthKey, fallbackFee) => {
    const idx = MONTHS.indexOf(monthKey);
    if (idx < 0) return parseFirstNumber(fallbackFee) || 0;

    let chosen = null;
    for (const h of history) {
      const hi = MONTHS.indexOf(h.effectiveMonthKey);
      if (hi < 0) continue;
      if (hi <= idx) chosen = h;
    }
    return chosen ? parseFirstNumber(chosen.fee) : (parseFirstNumber(fallbackFee) || 0);
  };

  const readBillingJson = (x, admissionInfo) => {
    const raw =
      admissionInfo?.billingJson ||
      admissionInfo?.billing_json ||
      x?.billingJson ||
      x?.billing_json ||
      x?.billingJSON ||
      admissionInfo?.billingJSON ||
      null;

    if (!raw) return {};
    if (typeof raw === 'object') return raw;
    if (typeof raw === 'string') {
      const j = tryParseJSON(raw);
      return (j && typeof j === 'object') ? j : {};
    }
    return {};
  };

  const buildMonthMatrix = (x, admissionInfo) => {
    const currentFee = admissionInfo?.fees || admissionInfo?.fee || x?.fees || x?.fee || 0;

    const feeHistoryRaw =
      admissionInfo?.feeHistory || admissionInfo?.fee_history || x?.feeHistory || x?.fee_history || [];

    const billingJson = readBillingJson(x, admissionInfo);

    const monthFees =
      admissionInfo?.monthFees ||
      admissionInfo?.month_fees ||
      x?.monthFees ||
      x?.month_fees ||
      {};

    const billRows = Array.isArray(x?.billing) ? sortBillingRowsByMonth(x.billing) : [];

    const billFeeCandidates = (billRows || [])
      .map(r => parseFirstNumber(getFeeFromBillingRow(r)))
      .filter(n => Number.isFinite(n) && n > 0);

    const baseFeeFromBills = billFeeCandidates.length
      ? billFeeCandidates.reduce((a,b)=> Math.min(a,b), billFeeCandidates[0])
      : 0;

    const history = normalizeFeeHistory(feeHistoryRaw, currentFee, admissionInfo?.month);

    const baseFee =
      (history && history.length ? parseFirstNumber(history[0].fee) : 0) ||
      baseFeeFromBills ||
      parseFirstNumber(currentFee) ||
      0;

    const rowByKey = new Map();
    billRows.forEach(r => {
      const mk = extractMonthName(r?.month) || normMonth(r?.month);
      if (mk) rowByKey.set(mk, r);
    });

    const matrix = MONTHS.map((mk) => {
      const entry = normalizeBillingEntry(billingJson?.[mk]);
      const row = rowByKey.get(mk) || null;

      const status = safeStr(row?.status).trim() || safeStr(entry.status).trim() || '';
      const amountStr = safeStr(getAmountFromBillingRow(row)).trim() || safeStr(entry.amount).trim() || '';
      const amount = parseFirstNumber(amountStr);

      const feeOverride = parseFirstNumber(entry.feeOverride);
      const rowFee = parseFirstNumber(getFeeFromBillingRow(row));
      const computedMonthFee = parseFirstNumber(monthFees?.[mk]);
      const feeFromRule = feeForMonthKey(history, mk, baseFee);

      const fee =
        feeOverride > 0
          ? feeOverride
          : rowFee > 0
            ? rowFee
            : computedMonthFee > 0
              ? computedMonthFee
              : feeFromRule;

      const verification =
        safeStr(getVerificationFromBillingRow(row)).trim() ||
        safeStr(entry.verification || entry.verificationNumber).trim() ||
        '';

      const monthNoField =
        safeStr(getMonthNumberFromBillingRow(row)).trim() ||
        safeStr(entry.monthNumber).trim() ||
        '';

      const receivedOn =
        safeStr(row?.receivedOn || row?.received_on || row?.paidOn || row?.paid_on || row?.date || '').trim() ||
        safeStr(entry.receivedOn).trim() ||
        '';

        const bank =
  safeStr(getBankFromBillingRow(row)).trim() ||
  safeStr(entry.bank).trim() ||
  '';

      const hasAny =
        !!status ||
        amount > 0 ||
        feeOverride > 0 ||
        !!verification ||
        !!monthNoField ||
        !!row;

      return {
        key: mk,
        label: mk.charAt(0).toUpperCase() + mk.slice(1),
        monthNo: MONTHS.indexOf(mk) + 1,
        status: status || '',
        statusCls: billingStatusClass(status || ''),
        amount: amountStr ? amountStr : (amount > 0 ? String(amount) : ''),
        amountNum: amount,
        fee: fee > 0 ? fee : 0,
        feeShown: fee > 0 ? String(fee) : '-',
        verification: verification || '-',
        monthNumber: monthNoField || '-',
        bank: bank || '-',
        receivedOn: receivedOn || '',
        feeOverride: feeOverride > 0 ? feeOverride : 0,

registrationFeeTotal: entry.registrationFeeTotal || '',
registrationFeeReceived: entry.registrationFeeReceived || '',
registrationFeeStatus: entry.registrationFeeStatus || '',
registrationFeeVerification: entry.registrationFeeVerification || '',
registrationFeeBank: entry.registrationFeeBank || '',
registrationFeePaymentDate: entry.registrationFeePaymentDate || '',

hasAny
      };
    });

    return { matrix, baseFee, history };
  };

  const buildRegistrationFeeInfo = (x, admissionInfo, matrix) => {
  const total = parseFirstNumber(
    admissionInfo?.registrationFee ||
    admissionInfo?.registration_fee ||
    x?.registrationFee ||
    x?.registration_fee ||
    x?.admission_registration_fee ||
    0
  );

  if (!total || total <= 0) {
    return {
      enabled: false,
      total: 0,
      received: 0,
      pending: 0,
      status: '',
      monthKey: '',
      monthLabel: '',
      verification: '',
      bank: '',
      paymentDate: '',
    };
  }

  const admissionMonthRaw =
    admissionInfo?.month ||
    admissionInfo?.admissionMonth ||
    admissionInfo?.admission_month ||
    x?.admission_month ||
    x?.admissionMonth ||
    '';

  const monthKey = extractMonthName(admissionMonthRaw);
  const monthRow = (Array.isArray(matrix) ? matrix : []).find((m) => sameMonth(m.key, monthKey));

  const received = parseFirstNumber(monthRow?.registrationFeeReceived || 0);
  const pending = Math.max(0, total - received);

  return {
    enabled: true,
    total,
    received,
    pending,
    status:
      pending <= 0
        ? 'Full payment'
        : received > 0
          ? 'Partial payment'
          : 'No payment',
    monthKey: monthKey || '',
    monthLabel: monthKey ? (monthKey.charAt(0).toUpperCase() + monthKey.slice(1)) : '-',
    verification: monthRow?.registrationFeeVerification || '-',
    bank: monthRow?.registrationFeeBank || '-',
    paymentDate: monthRow?.registrationFeePaymentDate || '',
  };
};

  const buildPendingDues = (matrix, admissionInfo) => {
    const mm = Array.isArray(matrix) ? matrix : [];

    const rows = mm
      .filter(m => {
        const st = String(m?.status || '').toLowerCase().trim();
        return (st === 'no payment' || st === 'partial payment');
      })
      .map(m => {
        const feeN = parseFirstNumber(m?.fee);
        const recvN = parseFirstNumber(m?.amount);
        const dueN = Math.max(0, (feeN || 0) - (recvN || 0));

        return {
          month: m.label,
          monthKey: m.key,
          monthNo: m.monthNo,
          verifNo: m.verification || '-',
          bank: m.bank || '-',
          due: Number.isFinite(dueN) ? dueN : NaN,
          feeVal: m.feeShown || '-',
          amountVal: (m.amount ? m.amount : '-'),
          status: m.status || '-',
          statusCls: m.statusCls || '',
          receivedOn: m.receivedOn || ''
        };
      })
      .filter(x => x.month && Number.isFinite(x.due) && x.due > 0)
      .sort((a,b) => monthIndex(a.month) - monthIndex(b.month));

    return rows;
  };

  const sumFromMonthMatrix = (matrix) => {
    let feeTotal = 0;
    let recvTotal = 0;
    let hasFee = false;
    let hasRecv = false;

    (matrix || []).forEach(m => {
      const st = String(m?.status || '').trim();
      const amt = parseFirstNumber(m?.amount);
      const fee = parseFirstNumber(m?.fee);

      const isBlank = !st && amt <= 0 && parseFirstNumber(m?.feeOverride) <= 0 && (fee <= 0);
      if (isBlank) return;

      if (st && st.toLowerCase() === 'not admitted') return;

      if (fee > 0) { feeTotal += fee; hasFee = true; }
      if (amt > 0) { recvTotal += amt; hasRecv = true; }
    });

    return { feeTotal, recvTotal, hasFee, hasRecv };
  };

  const role = String(user?.role || '').toLowerCase();
  const agentType = String(user?.agentType || '').toLowerCase();

  let detailsPerms =
    (typeof perms !== 'undefined' && perms)
      ? perms
      : (
          user?.permissions ||
          user?.perms ||
          user?.permission ||
          user?.permissionMap ||
          {}
        );

  try {
    if (typeof detailsPerms === 'string') {
      detailsPerms = JSON.parse(detailsPerms);
    }
  } catch (e) {
    detailsPerms = {};
  }

  function getNestedPerm(obj, path) {
    try {
      const parts = String(path || '')
        .split('.')
        .filter(Boolean);

      let current = obj;

      for (const part of parts) {
        if (
          !current ||
          typeof current !== 'object' ||
          !(part in current)
        ) {
          return undefined;
        }

        current = current[part];
      }

      return current;
    } catch (e) {
      return undefined;
    }
  }

  function permissionEnabled(value) {
    if (value === true || value === 1) {
      return true;
    }

    if (
      value === false ||
      value === 0 ||
      value === null ||
      typeof value === 'undefined'
    ) {
      return false;
    }

    return [
      '1',
      'true',
      'on',
      'yes'
    ].includes(
      String(value)
        .trim()
        .toLowerCase()
    );
  }

  function hasOwnPermission(key) {
    return !!(
      detailsPerms &&
      typeof detailsPerms === 'object' &&
      !Array.isArray(detailsPerms) &&
      Object.prototype.hasOwnProperty.call(
        detailsPerms,
        key
      )
    );
  }

  function hasKey(key) {
    const cleanKey = String(key || '').trim();

    if (!cleanKey || !detailsPerms) {
      return false;
    }

    if (detailsPerms === true) {
      return true;
    }

    if (Array.isArray(detailsPerms)) {
      return (
        detailsPerms.includes(cleanKey) ||
        detailsPerms.includes('*') ||
        detailsPerms.includes('all')
      );
    }

    if (typeof detailsPerms === 'object') {
      if (hasOwnPermission(cleanKey)) {
        return permissionEnabled(
          detailsPerms[cleanKey]
        );
      }

      const nested =
        getNestedPerm(detailsPerms, cleanKey);

      if (typeof nested !== 'undefined') {
        return permissionEnabled(nested);
      }

      const alt =
        cleanKey.replace(/\./g, '_');

      if (hasOwnPermission(alt)) {
        return permissionEnabled(
          detailsPerms[alt]
        );
      }
    }

    return false;
  }

  function canAny(keys) {
    return (keys || [])
      .filter(Boolean)
      .some(key => hasKey(key));
  }

  const COLUMN_VIEW_KEY_MAP = Object.freeze({
    status: 'colStatus',
    feeStatus: 'colFeeStatus',
    dept: 'colDept',
    student: 'colStudentName',
    father: 'colFatherName',
    fatherEmail: 'colFatherEmail',
    grade: 'colGrade',
    tuitionGrade: 'colTuitionGrade',
    phone: 'colPhone',
    processedBy: 'colProcessedBy',
    paymentStatus: 'colPaymentStatus',
    paidUpto: 'colPaidUpto',
    verificationNumber: 'colVerificationNumber',
    registrationNumber: 'colRegistrationNumber',
    familyNumber: 'colFamilyNumber',
    registrationFee: 'colRegistrationFee',
    fees: 'colFees',
    currency: 'colCurrency',
    bank: 'colBank',
    month: 'colMonth',
    totalFees: 'colTotalFees',
    pendingDues: 'colPendingDues',
    receivedPayment: 'colReceivedPayment',
    comment: 'colComment',
    invoiceStatus: 'colInvoiceStatus',
    invoiceStatusTimestamp: 'colInvoiceStatusTimestamp',
    paidInvoiceStatus: 'colPaidInvoiceStatus',
    paidInvoiceStatusTimestamp: 'colPaidInvoiceStatusTimestamp',
    actionButtons: 'colActionButtons'
  });

  const COLUMN_VIEW_LEGACY_KEY_MAP = Object.freeze({
    phone: ['showPhone'],
    paymentStatus: ['showPaymentStatus'],
    paidUpto: ['showPaidUpto'],
    verificationNumber: ['showVerificationNumber'],
    registrationNumber: ['showRegistrationNumber']
  });

  function canCol(name) {
    const key = String(name || '').trim();
    const permissionKey = COLUMN_VIEW_KEY_MAP[key];

    if (!permissionKey) {
      return false;
    }

    const legacyKeys =
      COLUMN_VIEW_LEGACY_KEY_MAP[key] || [];

    const pascalKey =
      key.charAt(0).toUpperCase() +
      key.slice(1);

    return canAny([
      permissionKey,
      ...legacyKeys,

      `col.${key}`,
      `show_${key}`,
      `show${pascalKey}`,

      `super.col.${key}`,
      `super.column.${key}`,

      `admin.col.${key}`,
      `admin.column.${key}`,

      `agent.col.${key}`,
      `agent.column.${key}`,

      `subagent.col.${key}`,
      `subagent.column.${key}`,

      `sub_agent.col.${key}`,
      `sub_agent.column.${key}`,

      `dashboard_super.col.${key}`,
      `dashboard-super.col.${key}`,

      `dashboard_admin.col.${key}`,
      `dashboard-admin.col.${key}`,

      `dashboard_agent.col.${key}`,
      `dashboard-agent.col.${key}`,

      `dashboard_sub_agent.col.${key}`,
      `dashboard-sub-agent.col.${key}`,

      `perm.super.col.${key}`,
      `perm.admin.col.${key}`,
      `perm.agent.col.${key}`,
      `perm.sub_agent.col.${key}`,

      key
    ]);
  }

  const BUTTON_PERMISSION_KEY_MAP = Object.freeze({
    edit: 'btnEditRow',
    billing: 'btnBilling',
    pdf: 'btnPdf',
    details: 'btnDetails'
  });

  function canBtn(name) {
    const key = String(name || '').trim();
    const permissionKey =
      BUTTON_PERMISSION_KEY_MAP[key];

    if (!permissionKey) {
      return false;
    }

    const pascalKey =
      key.charAt(0).toUpperCase() +
      key.slice(1);

    return canAny([
      permissionKey,

      `super.btn.${key}`,
      `super.button.${key}`,

      `admin.btn.${key}`,
      `admin.button.${key}`,

      `agent.btn.${key}`,
      `agent.button.${key}`,

      `subagent.btn.${key}`,
      `subagent.button.${key}`,

      `sub_agent.btn.${key}`,
      `sub_agent.button.${key}`,

      `dashboard_super.btn.${key}`,
      `dashboard-super.btn.${key}`,

      `dashboard_admin.btn.${key}`,
      `dashboard-admin.btn.${key}`,

      `dashboard_agent.btn.${key}`,
      `dashboard-agent.btn.${key}`,

      `dashboard_sub_agent.btn.${key}`,
      `dashboard-sub-agent.btn.${key}`,

      `perm.super.btn.${key}`,
      `perm.admin.btn.${key}`,
      `perm.agent.btn.${key}`,
      `perm.sub_agent.btn.${key}`,

      `btn_${key}`,
      `btn${pascalKey}`,
      key
    ]);
  }

  const P = {
    col: {
      status: canCol('status'),
      feeStatus: canCol('feeStatus'),
      dept: canCol('dept'),
      student: canCol('student'),
      father: canCol('father'),
      fatherEmail: canCol('fatherEmail'),
      grade: canCol('grade'),
      tuitionGrade: canCol('tuitionGrade'),
      phone: canCol('phone'),
      processedBy: canCol('processedBy'),
      paymentStatus: canCol('paymentStatus'),
      paidUpto: canCol('paidUpto'),
      verif: canCol('verificationNumber'),
      reg: canCol('registrationNumber'),
      family: canCol('familyNumber'),
      registrationFee: canCol('registrationFee'),
      fees: canCol('fees'),
      currency: canCol('currency'),
      bank: canCol('bank'),
      month: canCol('month'),
      totalFees: canCol('totalFees'),
      pendingDues: canCol('pendingDues'),
      receivedPayment: canCol('receivedPayment'),
      comment: canCol('comment'),
      invoiceStatus: canCol('invoiceStatus'),
      invoiceStatusTimestamp: canCol('invoiceStatusTimestamp'),
      paidInvoiceStatus: canCol('paidInvoiceStatus'),
      paidInvoiceStatusTimestamp: canCol('paidInvoiceStatusTimestamp'),
      actionButtons: canCol('actionButtons')
    },

    btn: {
      edit: canBtn('edit'),
      billing: canBtn('billing'),
      pdf: canBtn('pdf'),
      details: canBtn('details')
    }
  };

  const canEditAdmission =
    P.col.actionButtons &&
    P.btn.edit;

  const canOpenFeeCollection =
    P.col.actionButtons &&
    P.btn.billing;

  const canPrintChallans =
    P.col.actionButtons &&
    P.btn.pdf &&
    P.col.month;

  const canShowFamilySummary =
    P.col.currency ||
    P.col.totalFees ||
    P.col.receivedPayment ||
    P.col.pendingDues;

  const canShowBillingDetails =
    P.col.registrationFee ||
    P.col.fees ||
    P.col.month ||
    P.col.paymentStatus ||
    P.col.verif ||
    P.col.bank ||
    P.col.receivedPayment ||
    P.col.pendingDues ||
    canPrintChallans;

 let backUrl = '/dashboard';

if (role === 'super_admin' || role === 'superadmin') backUrl = '/dashboard';
else if (role === 'admin') backUrl = '/dashboard';
else if (role === 'agent') backUrl = '/dashboard';
else if (role === 'sub_agent' || role === 'subagent' || role === 'sub-agent') backUrl = '/dashboard';

if (!user?.role && agentType) {
  if (agentType === 'super_admin' || agentType === 'superadmin') backUrl = '/dashboard';
  else if (agentType === 'admin') backUrl = '/dashboard';
  else if (agentType === 'agent') backUrl = '/dashboard';
  else if (agentType === 'sub_agent' || agentType === 'subagent' || agentType === 'sub-agent') backUrl = '/dashboard';
}

  const incomingList =
    ((typeof admissions !== 'undefined') && Array.isArray(admissions) ? admissions : null) ||
    ((typeof parentAdmissions !== 'undefined') && Array.isArray(parentAdmissions) ? parentAdmissions : null) ||
    ((typeof familyAdmissions !== 'undefined') && Array.isArray(familyAdmissions) ? familyAdmissions : null) ||
    ((typeof sameFamilyAdmissions !== 'undefined') && Array.isArray(sameFamilyAdmissions) ? sameFamilyAdmissions : null) ||
    [];

  const seen = new Set();
  let familyList = (Array.isArray(incomingList) ? incomingList : []).filter(x => {
    const id = String(x?.id || '');
    if (!id) return false;
    if (seen.has(id)) return false;
    seen.add(id);
    return true;
  });

  const hasCurrent = familyList.some(x => String(x?.id) === String(A?.id));
  if (!hasCurrent && A?.id) familyList.unshift(A);

  familyList.sort((p, q) => {
    if (String(p?.id) === String(A?.id)) return -1;
    if (String(q?.id) === String(A?.id)) return 1;
    return Number(q?.id || 0) - Number(p?.id || 0);
  });

  const familyNumber = getFamilyNo(A) || (familyList[0] ? getFamilyNo(familyList[0]) : '');

  let famFeeTotal = 0;
  let famRecvTotal = 0;
  let famPendingTotal = 0;
  let famHasFee = false;
  let famHasRecv = false;
  let famHasPending = false;

  (familyList || []).forEach(X => {
    const admissionInfo = X.admission || {};
    const mm = buildMonthMatrix(X, admissionInfo);
    const billTotals = sumFromMonthMatrix(mm.matrix);

    if (billTotals.hasFee) { famFeeTotal += billTotals.feeTotal; famHasFee = true; }
    if (billTotals.hasRecv){ famRecvTotal += billTotals.recvTotal; famHasRecv = true; }

   const regInfo = buildRegistrationFeeInfo(X, admissionInfo, mm.matrix);

if (regInfo.enabled) {
  famFeeTotal += regInfo.total;
  famRecvTotal += regInfo.received;
  famHasFee = true;

  if (regInfo.received > 0) famHasRecv = true;

  if (regInfo.pending > 0) {
    famPendingTotal += regInfo.pending;
    famHasPending = true;
  }
}

const duesRows = buildPendingDues(mm.matrix, admissionInfo);
const p = duesRows.reduce((s,r)=> Number.isFinite(r?.due) ? (s + r.due) : s, 0);
if (duesRows && duesRows.length && Number.isFinite(p)) { famPendingTotal += p; famHasPending = true; }
  });

  const famCurrency = String(getCurrency(A) || '').trim() || '-';

  const billingYearFromAdmission =
    Number(
      A?.billingYear ||
      A?.billing_year ||
      (
        Array.isArray(A?.billing)
          ? A.billing.find((row) => Number(row?.year))?.year
          : 0
      ) ||
      0
    );

  const CURRENT_YEAR =
    Number.isInteger(billingYearFromAdmission) &&
    billingYearFromAdmission >= 2020 &&
    billingYearFromAdmission <= 2100
      ? billingYearFromAdmission
      : new Date().getFullYear();

  const feeCollectionBaseUrl =
    (role === 'admin')
      ? '/admin/fee-collection'
      : '/dashboard/super/fee-collection';

  const isAutoFamilyMatch =
    !familyNumber &&
    Array.isArray(familyList) &&
    familyList.length > 1;

  const familyRouteNumber =
    familyNumber ||
    (isAutoFamilyMatch ? 'auto' : '');

  const clientFamilyRouteNumber =
    P.col.family
      ? familyRouteNumber
      : '';

  const clientFamilyCount =
    P.col.family
      ? familyList.length
      : 1;

  const familyRouteAdmissionId =
    A?.id ||
    (familyList[0]?.id || '');

  const sharedDetailsUrl =
    `/dashboard/admission/${encodeURIComponent(A?.id || '')}` +
    `?year=${encodeURIComponent(CURRENT_YEAR)}`;

  const accountsNumberNoteData =
    (typeof accountsNumberNote !== 'undefined' && accountsNumberNote)
      ? accountsNumberNote
      : {
          enabled: false,
          highestNumbers: null,
          sidebarHighest: null,
          latestNumbers: null,
          notepadLatest: null,
          latestHighest: null,
          records: [],
          total: 0
        };

  const detailsUserDeptKey =
    String(
      (
        user &&
        (
          user.dept ||
          user.department ||
          user.userDept ||
          user.user_department
        )
      ) ||
      ''
    ).trim().toLowerCase();

  const isSuperDetailsUser =
    !!(
      role === 'super_admin' ||
      role === 'superadmin' ||
      agentType === 'super_admin' ||
      agentType === 'superadmin' ||
      user?.isSuperAdmin === true ||
      user?.is_super_admin === true
    );

  const isAccountsDetailsPageUser =
    detailsUserDeptKey === 'accounts' ||
    detailsUserDeptKey === 'school accounts' ||
    detailsUserDeptKey === 'school_accounts';

  /*
   * Latest Numbers global Accounts summary hai.
   * Is mein student/admission details nahi hotin,
   * is liye column View permissions required nahi.
   */
  const shouldRenderAccountsNumberNote =
    !!(
      (isSuperDetailsUser || isAccountsDetailsPageUser) &&
      accountsNumberNoteData &&
      accountsNumberNoteData.enabled
    );
%>

<div class="container-fluid py-2 admission-details-page"
     data-family-number="<%= clientFamilyRouteNumber %>"
     data-primary-admission-id="<%= A?.id || '' %>"
     data-user-role="<%= String(user?.role || user?.agentType || '').toLowerCase() %>"
     data-billing-year="<%= CURRENT_YEAR %>"
     data-details-url="<%= sharedDetailsUrl %>">

  <% if (shouldRenderAccountsNumberNote) { %>
    <div
      class="accounts-number-note"
      id="accountsNumberNoteWidget"
      data-hidden-storage-key="ivs_accounts_number_note_hidden_details">

      <div class="accounts-number-note-head">
        <div>
          <div class="accounts-number-note-title">
            Latest Fam + Verif + Reg Numbers
          </div>
          <div class="accounts-number-note-subtitle">
            Latest update from each field
          </div>
        </div>

        <button
          type="button"
          class="accounts-number-note-hide-btn"
          id="accountsNumberNoteHideBtn"
          title="Hide note">
          <i class="bi bi-eye-slash"></i>
        </button>
      </div>

      <div
        class="accounts-number-note-list"
        id="accountsNumberNoteList">
      </div>

      <div
        class="accounts-number-note-empty d-none"
        id="accountsNumberNoteEmpty">
