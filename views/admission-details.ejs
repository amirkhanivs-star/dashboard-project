                      </span>
                    </div>
                  <% } %>

                  <% if (P.col.fees) { %>
                    <div class="drow">
                      <span class="k">Current Fee:</span>
                      <span class="v">
                        <b><%= money(currentMonthlyFee) %></b>

                        <% if (
                          P.col.currency &&
                          curCode &&
                          curCode !== '-'
                        ) { %>
                          <span class="text-muted small ms-1">
                            ( <%= curCode %> )
                          </span>
                        <% } %>
                      </span>
                    </div>
                  <% } %>

                  <% if (P.col.bank) { %>
                    <div class="drow">
                      <span class="k">Bank:</span>
                      <span class="v">
                        <%= admissionBank || '-' %>
                      </span>
                    </div>
                  <% } %>

                  <% if (P.col.verif) { %>
                    <div class="drow">
                      <span class="k">Verification #:</span>
                      <span class="v">
                        <%= (
                          accounts.verificationNumber ||
                          X?.accounts_verification_number ||
                          '-'
                        ) %>
                      </span>
                    </div>
                  <% } %>

                  <% if (P.col.reg) { %>
                    <div class="drow">
                      <span class="k">Reg #:</span>
                      <span class="v">
                        <%= (regNoAccount || '-') %>
                      </span>
                    </div>
                  <% } %>

                  <% if (P.col.family) { %>
                    <div class="drow">
                      <span class="k">Family #:</span>
                      <span class="v">
                        <%= (
                          accounts.familyNumber ||
                          getFamilyNo(X) ||
                          (
                            isAutoFamilyMatch
                              ? 'Auto Matched'
                              : '-'
                          )
                        ) %>
                      </span>
                    </div>
                  <% } %>

                  <% if (P.col.receivedPayment) { %>
                    <div class="drow">
                      <span class="k">Total Received:</span>
                      <span class="v">
                        <b>
                          <%= (
                            billTotals.hasRecv
                              ? money(billTotals.recvTotal)
                              : '-'
                          ) %>
                        </b>

                        <% if (
                          P.col.currency &&
                          curCode &&
                          curCode !== '-' &&
                          billTotals.hasRecv
                        ) { %>
                          <span class="text-muted small ms-1">
                            ( <%= curCode %> )
                          </span>
                        <% } %>
                      </span>
                    </div>
                  <% } %>

                  <% if (P.col.pendingDues) { %>
                    <div class="drow">
                      <span class="k">Pending Due:</span>
                      <span class="v">
                        <b>
                          <%= (
                            Number.isFinite(pendingTotal)
                              ? money(pendingTotal)
                              : '-'
                          ) %>
                        </b>

                        <% if (
                          P.col.currency &&
                          curCode &&
                          curCode !== '-' &&
                          Number.isFinite(pendingTotal)
                        ) { %>
                          <span class="text-muted small ms-1">
                            ( <%= curCode %> )
                          </span>
                        <% } %>
                      </span>
                    </div>
                  <% } %>

                  <% if (
                    P.col.comment &&
                    admissionComment
                  ) { %>
                    <div class="admission-comment-box">
                      <div class="admission-comment-label">
                        <i class="bi bi-chat-left-text me-1"></i>
                        Comment
                      </div>

                      <div class="admission-comment-text">
                        <%= admissionComment %>
                      </div>
                    </div>
                  <% } %>

                  <% if (canEditAdmission) { %>
                    <div class="profile-edit-center">
                      <a
                        href="/dashboard/admission/<%= encodeURIComponent(X.id) %>/edit?year=<%= encodeURIComponent(CURRENT_YEAR) %>"
                        class="btn btn-sm btn-premium-edit px-4 rounded-3">
                        <i class="bi bi-pencil-square me-1"></i>
                        Edit
                      </a>
                    </div>
                  <% } %>
                </div>

              </div>
            </div>
          </div>

          <div class="col-lg-8">
            <div class="card border-0 right-panel h-100">
              <div class="card-body p-3">

                <% if (
                  canOpenFeeCollection ||
                  canPrintChallans
                ) { %>
                  <div class="d-flex align-items-center justify-content-end flex-wrap gap-2 mb-2">
                    <% if (canOpenFeeCollection) { %>
                      <a
                        href="<%= feeCollectionBaseUrl %>?admissionId=<%= encodeURIComponent(X.id) %>&familyNumber=<%= encodeURIComponent(clientFamilyRouteNumber || '') %>&year=<%= encodeURIComponent(CURRENT_YEAR) %>"
                        class="btn btn-fee-collection btn-sm rounded-3"
                        title="Open Fee Collection">
                        <i class="bi bi-cash-coin me-1"></i>
                        Fee Collection
                      </a>
                    <% } %>

                    <% if (canPrintChallans) { %>
                      <button
                        type="button"
                        class="btn btn-outline-secondary btn-sm rounded-3 js-open-pending-challan"
                        data-admission-id="<%= X.id %>"
                        data-family-number="<%= clientFamilyRouteNumber %>"
                        data-family-count="<%= clientFamilyCount %>"
                        title="Pending months list + challan">
                        <i class="bi bi-printer me-1"></i>
                        Print Challan
                      </button>
                    <% } %>
                  </div>
                <% } %>

                <% if (canShowBillingDetails) { %>
                  <div class="card border-0 inner-card mb-3">
                    <div class="card-body p-3">
                      <div class="table-responsive">
                        <table class="table table-sm align-middle dues-table mb-2">
                          <thead>
                            <tr>
                              <% if (showFeeTypeColumn) { %>
                                <th style="width:18%">Fee Type</th>
                              <% } %>

                              <% if (showMonthColumns) { %>
                                <th style="width:14%">Month</th>
                                <th style="width:6%">M#</th>
                              <% } %>

                              <% if (P.col.verif) { %>
                                <th style="width:18%">Verification #</th>
                              <% } %>

                              <% if (P.col.bank) { %>
                                <th style="width:14%">Bank</th>
                              <% } %>

                              <% if (showFeeAmountColumn) { %>
                                <th style="width:12%">Month Fee</th>
                              <% } %>

                              <% if (P.col.receivedPayment) { %>
                                <th style="width:9%">Received</th>
                              <% } %>

                              <% if (P.col.pendingDues) { %>
                                <th style="width:9%">Balance</th>
                              <% } %>
                            </tr>
                          </thead>

                          <tbody>
                            <% if (
                              !showRegistrationDuesRow &&
                              !showMonthlyDuesRows
                            ) { %>
                              <tr>
                                <td
                                  colspan="<%= duesVisibleColumnCount %>"
                                  class="text-muted small">
                                  No dues found.
                                </td>
                              </tr>
                            <% } else { %>
                              <% if (showRegistrationDuesRow) { %>
                                <tr class="registration-fee-row">
                                  <% if (showFeeTypeColumn) { %>
                                    <td>
                                      <div class="d-flex align-items-center gap-2">
                                        <span class="tiny-dot reg-dot"></span>
                                        <span>Registration Fee</span>
                                      </div>
                                    </td>
                                  <% } %>

                                  <% if (showMonthColumns) { %>
                                    <td>
                                      <span class="pill-light text-capitalize">
                                        <%= regInfo.monthLabel || '-' %>
                                      </span>
                                    </td>

                                    <td>
                                      <span class="pill-mini">-</span>
                                    </td>
                                  <% } %>

                                  <% if (P.col.verif) { %>
                                    <td>
                                      <span class="pill-mini mono">
                                        <%= regInfo.verification || '-' %>
                                      </span>
                                    </td>
                                  <% } %>

                                  <% if (P.col.bank) { %>
                                    <td>
                                      <span class="pill-mini">
                                        <%= regInfo.bank || '-' %>
                                      </span>
                                    </td>
                                  <% } %>

                                  <% if (showFeeAmountColumn) { %>
                                    <td>
                                      <% if (P.col.registrationFee) { %>
                                        <span class="pill-fee">
                                          <%= money(regInfo.total) %>
                                        </span>

                                        <% if (
                                          P.col.currency &&
                                          curCode &&
                                          curCode !== '-'
                                        ) { %>
                                          <span class="text-muted small ms-1">
                                            ( <%= curCode %> )
                                          </span>
                                        <% } %>
                                      <% } else { %>
                                        <span class="text-muted">-</span>
                                      <% } %>
                                    </td>
                                  <% } %>

                                  <% if (P.col.receivedPayment) { %>
                                    <td>
                                      <span class="pill-recv">
                                        <%= money(regInfo.received) %>
                                      </span>

                                      <% if (
                                        P.col.currency &&
                                        curCode &&
                                        curCode !== '-'
                                      ) { %>
                                        <span class="text-muted small ms-1">
                                          ( <%= curCode %> )
                                        </span>
                                      <% } %>
                                    </td>
                                  <% } %>

                                  <% if (P.col.pendingDues) { %>
                                    <td>
                                      <span class="pill-balance">
                                        <%= money(regInfo.pending) %>
                                      </span>

                                      <% if (
                                        P.col.currency &&
                                        curCode &&
                                        curCode !== '-'
                                      ) { %>
                                        <span class="text-muted small ms-1">
                                          ( <%= curCode %> )
                                        </span>
                                      <% } %>
                                    </td>
                                  <% } %>
                                </tr>
                              <% } %>

                              <% if (showMonthlyDuesRows) { %>
                                <% duesRows.forEach(r => { %>
                                  <tr>
                                    <% if (showFeeTypeColumn) { %>
                                      <td>
                                        <div class="d-flex align-items-center gap-2">
                                          <span class="tiny-dot"></span>
                                          <span>Monthly Fee</span>
                                        </div>
                                      </td>
                                    <% } %>

                                    <% if (showMonthColumns) { %>
                                      <td>
                                        <span class="pill-light text-capitalize">
                                          <%= r.month %>
                                        </span>
                                      </td>

                                      <td>
                                        <span class="pill-mini">
                                          <%= r.monthNo %>
                                        </span>
                                      </td>
                                    <% } %>

                                    <% if (P.col.verif) { %>
                                      <td>
                                        <span class="pill-mini mono">
                                          <%= (r.verifNo || '-') %>
                                        </span>
                                      </td>
                                    <% } %>

                                    <% if (P.col.bank) { %>
                                      <td>
                                        <span class="pill-mini">
                                          <%= (r.bank || '-') %>
                                        </span>
                                      </td>
                                    <% } %>

                                    <% if (showFeeAmountColumn) { %>
                                      <td>
                                        <% if (P.col.fees) { %>
                                          <span class="pill-fee">
                                            <%= (
                                              r.feeVal !== '-'
                                                ? money(r.feeVal)
                                                : '-'
                                            ) %>
                                          </span>

                                          <% if (
                                            P.col.currency &&
                                            curCode &&
                                            curCode !== '-' &&
                                            r.feeVal !== '-'
                                          ) { %>
                                            <span class="text-muted small ms-1">
                                              ( <%= curCode %> )
                                            </span>
                                          <% } %>
                                        <% } else { %>
                                          <span class="text-muted">-</span>
                                        <% } %>
                                      </td>
                                    <% } %>

                                    <% if (P.col.receivedPayment) { %>
                                      <td>
                                        <span class="pill-recv">
                                          <%= money(r.amountVal) %>
                                        </span>

                                        <% if (
                                          P.col.currency &&
                                          curCode &&
                                          curCode !== '-' &&
                                          r.amountVal !== '-'
                                        ) { %>
                                          <span class="text-muted small ms-1">
                                            ( <%= curCode %> )
                                          </span>
                                        <% } %>
                                      </td>
                                    <% } %>

                                    <% if (P.col.pendingDues) { %>
                                      <td>
                                        <span class="pill-balance">
                                          <%= money(r.due) %>
                                        </span>

                                        <% if (
                                          P.col.currency &&
                                          curCode &&
                                          curCode !== '-'
                                        ) { %>
                                          <span class="text-muted small ms-1">
                                            ( <%= curCode %> )
                                          </span>
                                        <% } %>
                                      </td>
                                    <% } %>
                                  </tr>
                                <% }) %>
                              <% } %>
                            <% } %>
                          </tbody>
                        </table>
                      </div>

                      <% if (P.col.pendingDues) { %>
                        <div class="d-flex justify-content-between align-items-center pt-1">
                          <div class="text-muted small">
                            Total Dues:
                          </div>

                          <div class="fw-bold">
                            <%= (
                              hasNumericTotal
                                ? money(totalDues)
                                : '-'
                            ) %>

                            <% if (
                              P.col.currency &&
                              curCode &&
                              curCode !== '-' &&
                              hasNumericTotal
                            ) { %>
                              <span class="text-muted small ms-1">
                                ( <%= curCode %> )
                              </span>
                            <% } %>
                          </div>
                        </div>
                      <% } %>
                    </div>
                  </div>
                <% } %>

                <% if (canShowBillingDetails) { %>
                  <div class="sec-title mb-2">
                    Fees History (Jan–Dec, Popup Style)
                  </div>

                  <div class="card border-0 inner-card">
                    <div class="card-body p-3">
                      <% if (
                        !showRegistrationHistory &&
                        !showMonthlyHistory
                      ) { %>
                        <div class="text-muted small">
                          No fee history found.
                        </div>
                      <% } else { %>
                        <% if (
                          P.col.totalFees ||
                          P.col.receivedPayment ||
                          P.col.pendingDues
                        ) { %>
                          <div class="dues-summary mb-2">
                            <% if (P.col.totalFees) { %>
                              <div class="sum-item">
                                <div class="label">
                                  Total Fee (Billing)
                                </div>

                                <div class="val">
                                  <%= (
                                    billTotals.hasFee
                                      ? money(billTotals.feeTotal)
                                      : '-'
                                  ) %>

                                  <% if (
                                    P.col.currency &&
                                    curCode &&
                                    curCode !== '-' &&
                                    billTotals.hasFee
                                  ) { %>
                                    <span class="text-muted small ms-1">
                                      ( <%= curCode %> )
                                    </span>
                                  <% } %>
                                </div>
                              </div>
                            <% } %>

                            <% if (P.col.receivedPayment) { %>
                              <div class="sum-item">
                                <div class="label">
                                  Total Received (Billing)
                                </div>

                                <div class="val">
                                  <%= (
                                    billTotals.hasRecv
                                      ? money(billTotals.recvTotal)
                                      : '-'
                                  ) %>

                                  <% if (
                                    P.col.currency &&
                                    curCode &&
                                    curCode !== '-' &&
                                    billTotals.hasRecv
                                  ) { %>
                                    <span class="text-muted small ms-1">
                                      ( <%= curCode %> )
                                    </span>
                                  <% } %>
                                </div>
                              </div>
                            <% } %>

                            <% if (P.col.pendingDues) { %>
                              <div class="sum-item">
                                <div class="label">
                                  Total Pending
                                </div>

                                <div class="val">
                                  <%= (
                                    hasNumericTotal
                                      ? money(totalDues)
                                      : '-'
                                  ) %>

                                  <% if (
                                    P.col.currency &&
                                    curCode &&
                                    curCode !== '-' &&
                                    hasNumericTotal
                                  ) { %>
                                    <span class="text-muted small ms-1">
                                      ( <%= curCode %> )
                                    </span>
                                  <% } %>
                                </div>
                              </div>
                            <% } %>
                          </div>
                        <% } %>

                        <div class="timeline">
                          <% if (showRegistrationHistory) { %>
                            <div class="t-item registration-fee-row">
                              <div class="t-dot reg-dot"></div>
                              <div class="t-line"></div>

                              <div class="t-content">
                                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                                  <div class="fw-semibold">
                                    <% if (P.col.registrationFee) { %>
                                      <span class="me-2">
                                        Registration Fee
                                      </span>
                                    <% } %>

                                    <span class="text-muted">
                                      #<%= String(X.id || '-') %>
                                    </span>
                                  </div>

                                  <% if (P.col.paymentStatus) { %>
                                    <div class="text-muted small">
                                      <span class="badge rounded-pill px-3 py-2 bill-pill <%= billingStatusClass(regInfo.status) %>">
                                        <%= regInfo.status || '-' %>
                                      </span>
                                    </div>
                                  <% } %>
                                </div>

                                <% if (
                                  P.col.bank ||
                                  P.col.month ||
                                  P.col.verif
                                ) { %>
                                  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mt-2">
                                    <div class="text-muted">
                                      <% if (P.col.bank) { %>
                                        Bank Name:
                                        <span class="pill-light">
                                          <%= regInfo.bank || '-' %>
                                        </span>
                                      <% } %>

                                      <% if (P.col.month) { %>
                                        <span class="ms-2 pill-mini">
                                          <%= regInfo.monthLabel || '-' %>
                                        </span>
                                      <% } %>
                                    </div>

                                    <% if (P.col.verif) { %>
                                      <div class="text-muted">
                                        Verification #:
                                        <span class="pill-mini mono">
                                          <%= regInfo.verification || '-' %>
                                        </span>
                                      </div>
                                    <% } %>
                                  </div>
                                <% } %>

                                <% if (
                                  P.col.registrationFee ||
                                  P.col.receivedPayment ||
                                  P.col.pendingDues
                                ) { %>
                                  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mt-2">
                                    <% if (P.col.registrationFee) { %>
                                      <div class="text-muted">
                                        Fee:
                                        <b><%= money(regInfo.total) %></b>

                                        <% if (
                                          P.col.currency &&
                                          curCode &&
                                          curCode !== '-'
                                        ) { %>
                                          <span class="text-muted small ms-1">
                                            ( <%= curCode %> )
                                          </span>
                                        <% } %>
                                      </div>
                                    <% } %>

                                    <% if (P.col.receivedPayment) { %>
                                      <div class="text-muted">
                                        Received:
                                        <b><%= money(regInfo.received) %></b>

                                        <% if (
                                          P.col.currency &&
                                          curCode &&
                                          curCode !== '-'
                                        ) { %>
                                          <span class="text-muted small ms-1">
                                            ( <%= curCode %> )
                                          </span>
                                        <% } %>
                                      </div>
                                    <% } %>

                                    <% if (P.col.pendingDues) { %>
                                      <div class="text-muted">
                                        Pending:
                                        <b><%= money(regInfo.pending) %></b>

                                        <% if (
                                          P.col.currency &&
                                          curCode &&
                                          curCode !== '-'
                                        ) { %>
                                          <span class="text-muted small ms-1">
                                            ( <%= curCode %> )
                                          </span>
                                        <% } %>
                                      </div>
                                    <% } %>
                                  </div>
                                <% } %>
                              </div>
                            </div>
                          <% } %>

                          <% if (showMonthlyHistory) { %>
                            <% historyRows.slice().reverse().forEach((m, i, arr) => {
                                 const st = String(m?.status || '-');
                                 const stCls = billingStatusClass(st);

                                 const pendingRow =
                                   (duesRows || []).find(
                                     r => sameMonth(r.monthKey, m.key)
                                   );

                                 const stLower =
                                   String(m?.status || '')
                                     .toLowerCase()
                                     .trim();

                                 let pendingVal = '-';

                                 if (
                                   pendingRow &&
                                   Number.isFinite(pendingRow.due)
                                 ) {
                                   pendingVal = pendingRow.due;
                                 } else if (
                                   stLower === 'partial payment'
                                 ) {
                                   const feeN =
                                     parseFirstNumber(m?.fee);

                                   const recvN =
                                     parseFirstNumber(m?.amount);

                                   const diff = Math.max(
                                     0,
                                     (feeN || 0) - (recvN || 0)
                                   );

                                   pendingVal =
                                     diff > 0
                                       ? diff
                                       : '-';
                                 }

                                 const amountNum =
                                   parseFirstNumber(m?.amount);

                                 const stLower2 =
                                   String(m?.status || '')
                                     .toLowerCase()
                                     .trim();

                                 const isNotAdmittedMonth =
                                   stLower2 === 'not admitted';

                                 const canPrintFeeChallan =
                                   canPrintChallans &&
                                   stLower2 !== 'not admitted';

                                 const canPrintPaid =
                                   canPrintChallans &&
                                   stLower2 !== 'not admitted' &&
                                   amountNum > 0 &&
                                   (
                                     stLower2 === 'full payment' ||
                                     stLower2 === 'partial payment'
                                   );
                            %>
                              <div class="t-item">
                                <div class="t-dot"></div>

                                <div class="t-line <%= (i === arr.length - 1 ? 'end' : '') %>"></div>

                                <div class="t-content">
                                  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                                    <div class="fw-semibold">
                                      <span class="me-2">Slip</span>

                                      <span class="text-muted">
                                        #<%= String(X.id || '-') %>

                                        <% if (P.col.month) { %>
                                          -<%= String(m.key).replace(/\s+/g, '') %>
                                        <% } %>
                                      </span>
                                    </div>

                                    <div class="d-flex align-items-center gap-2">
                                      <% if (canPrintFeeChallan) { %>
                                        <button
                                          type="button"
                                          class="btn btn-outline-secondary btn-sm rounded-3 js-print-month-challan"
                                          data-admission-id="<%= X.id %>"
                                          data-month-key="<%= m.key %>"
                                          data-year="<%= CURRENT_YEAR %>"
                                          title="Is month ka fee challan">
                                          <i class="bi bi-download me-1"></i>
                                          Fee Challan
                                        </button>
                                      <% } %>

                                      <% if (canPrintPaid) { %>
                                        <button
                                          type="button"
                                          class="btn btn-outline-secondary btn-sm rounded-3 js-print-month-paid"
                                          data-admission-id="<%= X.id %>"
                                          data-month-key="<%= m.key %>"
                                          data-year="<%= CURRENT_YEAR %>"
                                          title="Is month ka paid challan (receipt)">
                                          <i class="bi bi-receipt me-1"></i>
                                          Paid Challan
                                        </button>
                                      <% } %>

                                      <% if (P.col.paymentStatus) { %>
                                        <div class="text-muted small">
                                          <span class="badge rounded-pill px-3 py-2 bill-pill <%= stCls %>">
                                            <%= (st || '-') %>
                                          </span>
                                        </div>
                                      <% } %>
                                    </div>
                                  </div>

                                  <% if (
                                    P.col.bank ||
                                    P.col.month ||
                                    P.col.verif
                                  ) { %>
                                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mt-2">
                                      <div class="text-muted">
                                        <% if (P.col.bank) { %>
                                          Bank Name:
                                          <span class="pill-light">
                                            <%= m.bank || '-' %>
                                          </span>
                                        <% } %>

                                        <% if (P.col.month) { %>
                                          <span class="ms-2 pill-mini">
                                            <%= CURRENT_YEAR %>
                                          </span>
                                        <% } %>
                                      </div>

                                      <% if (P.col.verif) { %>
                                        <div class="text-muted">
                                          Verification #:
                                          <span class="pill-mini mono">
                                            <%= (m.verification || '-') %>
                                          </span>
                                        </div>
                                      <% } %>
                                    </div>
                                  <% } %>

                                  <% if (
                                    P.col.fees ||
                                    P.col.receivedPayment ||
                                    P.col.pendingDues
                                  ) { %>
                                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mt-2">
                                      <% if (P.col.fees) { %>
                                        <div class="text-muted">
                                          Fee:
                                          <b>
                                            <%= (
                                              !isNotAdmittedMonth &&
                                              m.feeShown !== '-'
                                                ? money(m.feeShown)
                                                : '-'
                                            ) %>
                                          </b>

                                          <% if (
                                            P.col.currency &&
                                            !isNotAdmittedMonth &&
                                            curCode &&
                                            curCode !== '-' &&
                                            m.feeShown !== '-'
                                          ) { %>
                                            <span class="text-muted small ms-1">
                                              ( <%= curCode %> )
                                            </span>
                                          <% } %>
                                        </div>
                                      <% } %>

                                      <% if (P.col.receivedPayment) { %>
                                        <div class="text-muted">
                                          Received:
                                          <b><%= money(m.amount || '-') %></b>

                                          <% if (
                                            P.col.currency &&
                                            curCode &&
                                            curCode !== '-' &&
                                            m.amount
                                          ) { %>
                                            <span class="text-muted small ms-1">
                                              ( <%= curCode %> )
                                            </span>
                                          <% } %>
                                        </div>
                                      <% } %>

                                      <% if (P.col.pendingDues) { %>
                                        <div class="text-muted">
                                          Pending:
                                          <b><%= money(pendingVal) %></b>

                                          <% if (
                                            P.col.currency &&
                                            curCode &&
                                            curCode !== '-' &&
                                            pendingVal !== '-'
                                          ) { %>
                                            <span class="text-muted small ms-1">
                                              ( <%= curCode %> )
                                            </span>
                                          <% } %>
                                        </div>
                                      <% } %>
                                    </div>
                                  <% } %>
                                </div>
                              </div>
                            <% }) %>
                          <% } %>
                        </div>
                      <% } %>
                    </div>
                  </div>
                <% } %>

              </div>
            </div>
          </div>
        </div>

      </div>

    <% }) %>

  <% } %>

  <!-- (rest of your file unchanged) -->

