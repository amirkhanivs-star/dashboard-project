          <div class="col-lg-8">
            <div class="card border-0 right-panel h-100">
              <div class="card-body p-3">

                <div class="d-flex align-items-center justify-content-end flex-wrap gap-2 mb-2">
  <a
    href="<%= feeCollectionBaseUrl %>?admissionId=<%= X.id %>&familyNumber=<%= encodeURIComponent(familyNumber || '') %>"
    class="btn btn-fee-collection btn-sm rounded-3"
    title="Open Fee Collection"
  >
    <i class="bi bi-cash-coin me-1"></i> Fee Collection
  </a>

  <button
    type="button"
    class="btn btn-outline-secondary btn-sm rounded-3 js-open-pending-challan"
    data-admission-id="<%= X.id %>"
    data-family-number="<%= familyNumber %>"
    data-family-count="<%= familyList.length %>"
    title="Pending months list + challan"
  >
    <i class="bi bi-printer me-1"></i> Print Challan
  </button>
</div>

                <div class="card border-0 inner-card mb-3">
                  <div class="card-body p-3">
                    <div class="table-responsive">
                      <table class="table table-sm align-middle dues-table mb-2">
                        <thead>
                          <tr>
                            <th style="width:18%">Fee Type</th>
                            <th style="width:14%">Month</th>
                            <th style="width:6%">M#</th>
                            <th style="width:18%">Verification #</th>
                            <th style="width:14%">Month Number</th>
                            <th style="width:12%">Month Fee</th>
                            <th style="width:9%">Received</th>
                            <th style="width:9%">Balance</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% if (!duesRows || duesRows.length === 0) { %>
                            <tr>
                              <td colspan="8" class="text-muted small">No dues found.</td>
                            </tr>
                          <% } else { %>
                            <% duesRows.forEach(r => { %>
                              <tr>
                                <td>
                                  <div class="d-flex align-items-center gap-2">
                                    <span class="tiny-dot"></span>
                                    <span>Monthly Fee</span>
                                  </div>
                                </td>
                                <td>
                                  <span class="pill-light text-capitalize"><%= r.month %></span>
                                </td>
                                <td>
                                  <span class="pill-mini"><%= r.monthNo %></span>
                                </td>
                                <td>
                                  <span class="pill-mini mono"><%= (r.verifNo || '-') %></span>
                                </td>
                                <td>
                                  <span class="pill-mini mono"><%= (r.monthSlipNo || '-') %></span>
                                </td>
                                <td>
                                  <span class="pill-fee"><%= (r.feeVal !== '-' ? money(r.feeVal) : '-') %></span>
                                  <% if (curCode && curCode !== '-' && r.feeVal !== '-') { %>
                                    <span class="text-muted small ms-1">( <%= curCode %> )</span>
                                  <% } %>
                                </td>
                                <td>
                                  <span class="pill-recv"><%= money(r.amountVal) %></span>
                                  <% if (curCode && curCode !== '-' && r.amountVal !== '-') { %>
                                    <span class="text-muted small ms-1">( <%= curCode %> )</span>
                                  <% } %>
                                </td>
                                <td>
                                  <span class="pill-balance"><%= money(r.due) %></span>
                                  <% if (curCode && curCode !== '-') { %>
                                    <span class="text-muted small ms-1">( <%= curCode %> )</span>
                                  <% } %>
                                </td>
                              </tr>
                            <% }) %>
                          <% } %>
                        </tbody>
                      </table>
                    </div>

                    <div class="d-flex justify-content-between align-items-center pt-1">
                      <div class="text-muted small">Total Dues:</div>
                      <div class="fw-bold">
                        <%= (hasNumericTotal ? money(totalDues) : '-') %>
                        <% if (curCode && curCode !== '-' && hasNumericTotal) { %>
                          <span class="text-muted small ms-1">( <%= curCode %> )</span>
                        <% } %>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="sec-title mb-2">Fees History (Jan–Dec, Popup Style)</div>

                <div class="card border-0 inner-card">
                  <div class="card-body p-3">
                    <% if (!historyRows || historyRows.length === 0) { %>
                      <div class="text-muted small">No fee history found.</div>
                    <% } else { %>

                      <div class="dues-summary mb-2">
                        <div class="sum-item">
                          <div class="label">Total Fee (Billing)</div>
                          <div class="val">
                            <%= (billTotals.hasFee ? money(billTotals.feeTotal) : '-') %>
                            <% if (curCode && curCode !== '-' && billTotals.hasFee) { %>
                              <span class="text-muted small ms-1">( <%= curCode %> )</span>
                            <% } %>
                          </div>
                        </div>
                        <div class="sum-item">
                          <div class="label">Total Received (Billing)</div>
                          <div class="val">
                            <%= (billTotals.hasRecv ? money(billTotals.recvTotal) : '-') %>
                            <% if (curCode && curCode !== '-' && billTotals.hasRecv) { %>
                              <span class="text-muted small ms-1">( <%= curCode %> )</span>
                            <% } %>
                          </div>
                        </div>
                        <div class="sum-item">
                          <div class="label">Total Pending</div>
                          <div class="val">
                            <%= (hasNumericTotal ? money(totalDues) : '-') %>
                            <% if (curCode && curCode !== '-' && hasNumericTotal) { %>
                              <span class="text-muted small ms-1">( <%= curCode %> )</span>
                            <% } %>
                          </div>
                        </div>
                      </div>

                      <div class="timeline">
                        <% historyRows.slice().reverse().forEach((m, i, arr) => {
                             const st = String(m?.status || '-');
                             const stCls = billingStatusClass(st);

                             const pendingRow = (duesRows || []).find(r => sameMonth(r.monthKey, m.key));
                             const stLower = String(m?.status || '').toLowerCase().trim();

                             let pendingVal = '-';
                             if (pendingRow && Number.isFinite(pendingRow.due)) {
                               pendingVal = pendingRow.due;
                             } else if (stLower === 'partial payment') {
                               const feeN = parseFirstNumber(m?.fee);
                               const recvN = parseFirstNumber(m?.amount);
                               const diff = Math.max(0, (feeN || 0) - (recvN || 0));
                               pendingVal = diff > 0 ? diff : '-';
                             }
const amountNum = parseFirstNumber(m?.amount);
const stLower2 = String(m?.status || '').toLowerCase().trim();
const isNotAdmittedMonth = stLower2 === 'not admitted';

// ✅ Fee challan sirf tab show ho jab month Not admitted na ho
const canPrintFeeChallan = stLower2 !== 'not admitted';

// ✅ Paid challan sirf paid statuses me ho aur Not admitted me na ho
const canPrintPaid =
  stLower2 !== 'not admitted' &&
  amountNum > 0 &&
  (stLower2 === 'full payment' || stLower2 === 'partial payment');
                        %>
                          <div class="t-item">
                            <div class="t-dot"></div>
                            <div class="t-line <%= (i === arr.length - 1 ? 'end' : '') %>"></div>

                            <div class="t-content">
                              <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                                <div class="fw-semibold">
                                  <span class="me-2">Slip</span>
                                  <span class="text-muted">#<%= (String(X.id || '-') + '-' + String(m.key).replace(/\s+/g,'') ) %></span>
                                </div>

                                <div class="d-flex align-items-center gap-2">
                                  <% if (canPrintFeeChallan) { %>
                                    <button
                                      type="button"
                                      class="btn btn-outline-secondary btn-sm rounded-3 js-print-month-challan"
                                      data-admission-id="<%= X.id %>"
                                      data-month-key="<%= m.key %>"
                                      data-year="<%= CURRENT_YEAR %>"
                                      title="Is month ka fee challan"
                                    >
                                      <i class="bi bi-download me-1"></i> Fee Challan
                                    </button>
                                  <% } %>

                                  <% if (canPrintPaid) { %>
                                    <button
                                      type="button"
                                      class="btn btn-outline-secondary btn-sm rounded-3 js-print-month-paid"
                                      data-admission-id="<%= X.id %>"
                                      data-month-key="<%= m.key %>"
                                      data-year="<%= CURRENT_YEAR %>"
                                      title="Is month ka paid challan (receipt)"
                                    >
                                      <i class="bi bi-receipt me-1"></i> Paid Challan
                                    </button>
                                  <% } %>

                                  <div class="text-muted small">
                                    <span class="badge rounded-pill px-3 py-2 bill-pill <%= stCls %>"><%= (st || '-') %></span>
                                  </div>
                                </div>
                              </div>

                              <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mt-2">
                              <div class="text-muted">
                                  Bank Name: <span class="pill-light"><%= m.bank || '-' %></span>
                              <span class="ms-2 pill-mini"><%= CURRENT_YEAR %></span>
                             </div>
                                <div class="text-muted">
                                  Verification #: <span class="pill-mini mono"><%= (m.verification || '-') %></span>
                                </div>
                              </div>

                              <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mt-2">
                                

                                <div class="text-muted">
                                 Fee: <b><%= (!isNotAdmittedMonth && m.feeShown !== '-' ? money(m.feeShown) : '-') %></b>
                                  <% if (!isNotAdmittedMonth && curCode && curCode !== '-' && m.feeShown !== '-') { %>
                                    <span class="text-muted small ms-1">( <%= curCode %> )</span>
                                  <% } %>
                                </div>

                                <div class="text-muted">
                                  Received: <b><%= money(m.amount || '-') %></b>
                                  <% if (curCode && curCode !== '-' && m.amount) { %>
                                    <span class="text-muted small ms-1">( <%= curCode %> )</span>
                                  <% } %>
                                </div>

                                <div class="text-muted">
                                  Pending: <b><%= money(pendingVal) %></b>
                                  <% if (curCode && curCode !== '-' && pendingVal !== '-' ) { %>
                                    <span class="text-muted small ms-1">( <%= curCode %> )</span>
                                  <% } %>
                                </div>
                              </div>

                            </div>
                          </div>
                        <% }) %>
                      </div>
                    <% } %>
                  </div>
                </div>

              </div>
            </div>
          </div>
        </div>

      </div>

    <% }) %>

  <% } %>

  <!-- (rest of your file unchanged) -->

</div>

