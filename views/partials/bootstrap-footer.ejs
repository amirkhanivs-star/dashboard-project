          </div> <!-- /container-fluid -->
        </div> <!-- /page content wrapper -->

        <!-- FOOTER -->
       <footer class="border-top py-2 text-center small text-muted mt-auto ivs-footer">
  © <%= new Date().getFullYear() %>  MAK
</footer>

      </main>
    </div> <!-- /d-flex -->
<script>
  (function () {
    document.addEventListener("click", function (e) {
      const link = e.target.closest("a[href]");
      if (!link) return;

      const href = link.getAttribute("href") || "";

      if (
        href.startsWith("#") ||
        href.startsWith("javascript:") ||
        link.target === "_blank" ||
        link.hasAttribute("download")
      ) {
        return;
      }

      e.preventDefault();

      document.documentElement.classList.add("ivs-page-leaving");
      document.documentElement.classList.add("ivs-loading");

      setTimeout(function () {
        window.location.href = href;
      }, 1000);
    });

    window.addEventListener("pageshow", function (event) {
  document.documentElement.classList.remove("ivs-page-leaving");

  // Browser back/forward cache case only
  if (event.persisted) {
    document.documentElement.classList.remove("ivs-preload");
    document.documentElement.classList.remove("ivs-loading");
  }
});
  })();
</script>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/sidebar-toggle.js"></script>
  </body>
</html>
