    <script>
  (function () {
    "use strict";

    /*
     * Shared partial accidentally ek page par do dafa load ho
     * to duplicate click listeners aur loader controller create na hon.
     */
    if (window.__IVS_GLOBAL_LOADER_INITIALIZED__) {
      return;
    }

    window.__IVS_GLOBAL_LOADER_INITIALIZED__ = true;

   const STORAGE_KEY =
  "ivs:navigation-loader-started-at";

const MIN_VISIBLE_MS = 850;

const STALE_AFTER_MS = 15000;

    const html = document.documentElement;

    let navigationCommitted = false;
    let revealCompleted = false;
    let revealRequestedAt = 0;
    let revealTimer = null;
    let readyCleanupTimer = null;

    function getLoader() {
      return document.getElementById("ivsGlobalLoader");
    }

    function readStoredStartedAt() {
      try {
        const value = Number(
          sessionStorage.getItem(STORAGE_KEY) || 0
        );

        if (
          Number.isFinite(value) &&
          value > 0 &&
          Date.now() - value < STALE_AFTER_MS
        ) {
          return value;
        }

        sessionStorage.removeItem(STORAGE_KEY);
      } catch (e) {}

      return 0;
    }

    function rememberStartedAt() {
      const existing = readStoredStartedAt();

      if (existing) {
        return existing;
      }

      const startedAt = Date.now();

      try {
        sessionStorage.setItem(
          STORAGE_KEY,
          String(startedAt)
        );
      } catch (e) {}

      return startedAt;
    }

    function clearStoredStartedAt() {
      try {
        sessionStorage.removeItem(STORAGE_KEY);
      } catch (e) {}
    }

    function setLoaderHidden(hidden) {
      const loader = getLoader();

      if (loader) {
        loader.setAttribute(
          "aria-hidden",
          hidden ? "true" : "false"
        );
      }
    }

    function showLoader(options = {}) {
      const persist = options.persist === true;

      clearTimeout(revealTimer);
      clearTimeout(readyCleanupTimer);

      revealCompleted = false;
      revealRequestedAt = 0;

      if (persist) {
        rememberStartedAt();
      }

      html.classList.remove("ivs-ready");

      html.classList.add(
        "ivs-loading",
        "ivs-page-leaving"
      );

      setLoaderHidden(false);

      return true;
    }

    function hideLoader(options = {}) {
      const immediate = options.immediate === true;

      if (
        revealCompleted &&
        !html.classList.contains("ivs-preload") &&
        !html.classList.contains("ivs-loading") &&
        !html.classList.contains("ivs-page-leaving")
      ) {
        return;
      }

      clearTimeout(revealTimer);
      clearTimeout(readyCleanupTimer);

      /*
       * Minimum visible duration us waqt se count hogi
       * jab ready page ko reveal karna request kiya gaya.
       * Page parsing ka time is duration ko consume nahi karega.
       */
      if (!revealRequestedAt) {
        revealRequestedAt = Date.now();
      }

      const elapsed = Math.max(
        0,
        Date.now() - revealRequestedAt
      );

      const remaining = immediate
        ? 0
        : Math.max(
            0,
            MIN_VISIBLE_MS - elapsed
          );

      revealTimer = setTimeout(function () {
        html.classList.remove(
          "ivs-preload",
          "ivs-loading",
          "ivs-page-leaving",
          "ivs-navigation-resume"
        );

        html.classList.add("ivs-ready");

        setLoaderHidden(true);
        clearStoredStartedAt();

        navigationCommitted = false;
        revealCompleted = true;
        revealRequestedAt = 0;

        readyCleanupTimer = setTimeout(function () {
          html.classList.remove("ivs-ready");
        }, 320);
      }, remaining);
    }

    function navigate(targetUrl, options = {}) {
      const target = String(
        targetUrl || ""
      ).trim();

      /*
       * Double-click ya duplicate handler se same route
       * do dafa open nahi hoga.
       */
      if (!target || navigationCommitted) {
        return false;
      }

      navigationCommitted = true;

      showLoader({
        persist: true
      });

      /*
       * Do animation frames loader ko pehle paint karne deti hain.
       * Iske baad route immediately change hota hai.
       * Koi artificial 1 ya 2 second delay nahi hai.
       */
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          if (options.replace === true) {
            window.location.replace(target);
          } else {
            window.location.assign(target);
          }
        });
      });

      return true;
    }

    /*
     * Baqi dashboard files isi central API ko use karengi:
     *
     * window.IVSLoader.show()
     * window.IVSLoader.hide()
     * window.IVSLoader.navigate(url)
     *
     * Short alias:
     * window.ivsNavigate(url)
     */
    window.IVSLoader = {
      show: showLoader,
      hide: hideLoader,
      navigate: navigate,

      isActive: function () {
        return (
          html.classList.contains("ivs-preload") ||
          html.classList.contains("ivs-loading") ||
          html.classList.contains("ivs-page-leaving")
        );
      }
    };

    window.ivsNavigate = navigate;

    function revealWhenReady() {
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          hideLoader();
        });
      });
    }

    /*
     * Full images aur unrelated CDN resources ke complete hone
     * ka unnecessary wait nahi hoga. DOM ready hote hi dashboard
     * professionally reveal hoga.
     */
    if (document.readyState === "loading") {
      document.addEventListener(
        "DOMContentLoaded",
        revealWhenReady,
        {
          once: true
        }
      );
    } else {
      revealWhenReady();
    }

    /*
     * Browser back/forward cache se page restore ho to
     * old leaving loader permanently visible na rahe.
     */
       window.addEventListener(
      "pageshow",
      function (event) {
        /*
         * BFCache se dashboard restore ho to purana
         * navigation lock foran reset hona chahiye.
         */
        navigationCommitted = false;

        if (event.persisted !== true) {
          return;
        }

        /*
         * Cached page par loader ko immediate hide karne se
         * kabhi fast blink aur kabhi normal timing aati thi.
         * Restore par bhi normal reveal timing use hogi.
         */
        revealRequestedAt = 0;

        showLoader();

        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            hideLoader();
          });
        });
      }
    );

    /*
     * Kisi existing script ne direct window.location use ki ho
     * to new page ko navigation resume state mil jaye.
     */
    window.addEventListener(
      "beforeunload",
      function () {
        showLoader({
          persist: true
        });
      }
    );

    /*
     * Is shared partial ke internal sidebar links ab central
     * navigation function use karenge. External links aur
     * new-tab links bilkul pehle ki tarah work karenge.
     */
    document.addEventListener(
      "click",
      function (event) {
        if (
          event.defaultPrevented ||
          event.button !== 0 ||
          event.metaKey ||
          event.ctrlKey ||
          event.shiftKey ||
          event.altKey
        ) {
          return;
        }

        const link = event.target.closest(
          ".sidebar-nav a[href]"
        );

        if (
          !link ||
          link.hasAttribute("download") ||
          link.hasAttribute("data-ivs-no-loader")
        ) {
          return;
        }

        const targetName = String(
          link.getAttribute("target") || ""
        )
          .trim()
          .toLowerCase();

        /*
         * target="_blank" links ko intercept nahi karna.
         */
        if (
          targetName &&
          targetName !== "_self"
        ) {
          return;
        }

        const rawHref = String(
          link.getAttribute("href") || ""
        ).trim();

        if (
          !rawHref ||
          rawHref.startsWith("#") ||
          rawHref.startsWith("javascript:") ||
          rawHref.startsWith("mailto:") ||
          rawHref.startsWith("tel:")
        ) {
          return;
        }

        let url;

        try {
          url = new URL(
            rawHref,
            window.location.href
          );
        } catch (e) {
          return;
        }

        /*
         * External websites ko normal browser navigation
         * ke through open hone dena.
         */
        if (
          url.origin !== window.location.origin
        ) {
          return;
        }

        /*
         * Same-page hash navigation loader start nahi karegi.
         */
        if (
          url.pathname === window.location.pathname &&
          url.search === window.location.search &&
          url.hash &&
          url.hash !== window.location.hash
        ) {
          return;
        }

        event.preventDefault();

        /*
         * Sidebar navigation par current document ko foran
         * replace karne se loader sirf blink karta tha.
         *
         * Pehle loader ko paint aur entrance animation start
         * karne dein, phir route commit karein.
         *
         * Yeh delay sirf sidebar links ke liye hai.
         * Dashboard ke baqi buttons aur business logic
         * bilkul unchanged rahenge.
         */
        if (navigationCommitted) {
          return;
        }

        navigationCommitted = true;

        showLoader({
          persist: true
        });

        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            setTimeout(function () {
              window.location.assign(
                url.href
              );
            }, 650);
          });
        });
      }
    );

    /*
     * Kisi unexpected JavaScript ya resource error ki wajah se
     * loader page ko permanently cover nahi karega.
     */
    setTimeout(function () {
      hideLoader({
        immediate: true
      });
    }, 8000);
  })();
</script>
