      <div class="sidebar-footer">
        <div class="sidebar-section-label mb-2" style="padding:0; margin:0 0 8px 0;">Sign Out</div>
        <a href="/logout" class="logout-btn d-flex align-items-center justify-content-center gap-2">
          <i class="bi bi-arrow-left"></i>
          <span>Logout</span>
        </a>
      </div>
    </nav>
  </aside>
<script>
  (function () {
    const path = window.location.pathname;
    const links = Array.from(document.querySelectorAll('.sidebar-nav a'));
    const dashboardLink = document.querySelector('.sidebar-nav a[href="/dashboard"]');

    function activate(link) {
      links.forEach(function (item) {
        item.classList.remove('active');
        item.removeAttribute('aria-current');
      });

      if (link) {
        link.classList.add('active');
        link.setAttribute('aria-current', 'page');
      }
    }

    if (path === '/dashboard') {
      activate(dashboardLink);
      return;
    }

    let bestMatch = null;
    let bestLength = 0;

    links.forEach(function (link) {
      const href = link.getAttribute('href') || '';

      if (
        !href ||
        href === '/dashboard' ||
        href === '/logout' ||
        href.startsWith('http')
      ) {
        return;
      }

      if (path === href || path.startsWith(href + '/')) {
        if (href.length > bestLength) {
          bestMatch = link;
          bestLength = href.length;
        }
      }
    });

    if (bestMatch) {
      activate(bestMatch);
      return;
    }

    const isSharedAdmissionPage =
      path.startsWith('/dashboard/admission/') ||
      path.startsWith('/dashboard/super/admission/') ||
      path === '/dashboard/super/fee-collection' ||
      path === '/admin/fee-collection';

    if (isSharedAdmissionPage || path.startsWith('/dashboard')) {
      activate(dashboardLink);
    }
  })();
</script>

<script>
  (function () {
    const canShowSidebarNote =
      window.SHOW_SIDEBAR_ACCOUNTS_NUMBER_NOTE === true;

    const card = document.getElementById('sidebarAccountsNumberNote');

    if (!canShowSidebarNote || !card) {
      return;
    }

      const emptyEl = document.getElementById('sidebarAccountsNumberEmpty');
    const bodyEl = document.getElementById('sidebarAccountsNumberBody');
    const familyEl = document.getElementById('sidebarHighestFamilyNumber');
    const verifEl = document.getElementById('sidebarHighestVerifNumber');
    const regEl = document.getElementById('sidebarHighestRegNumber');
    const familyChip = document.getElementById('sidebarFamilyChip');
    const verifChip = document.getElementById('sidebarVerifChip');
    const regChip = document.getElementById('sidebarRegChip');
    const copyBtn = document.getElementById('sidebarAccountsNumberCopyBtn');

    function normalizeHighestNote(data) {
      const highest =
        (
          data &&
          (
            data.highestNumbers ||
            data.sidebarHighest
          )
        ) ||
        null;

      const familyNumber =
        String(
          highest?.familyNumber || ''
        ).trim();

      const verificationNumber =
        String(
          highest?.verificationNumber || ''
        ).trim();

      const registrationNumber =
        String(
          highest?.registrationNumber || ''
        ).trim();

      const hasFamilyNumber =
        !!familyNumber;

      const hasVerificationNumber =
        !!verificationNumber;

      const hasRegistrationNumber =
        !!registrationNumber;

      const hasRecord =
        hasFamilyNumber ||
        hasVerificationNumber ||
        hasRegistrationNumber;

      const fallbackCopyText = [
        hasFamilyNumber
          ? `FAM: ${familyNumber}`
          : '',

        hasVerificationNumber
          ? `VERIF: ${verificationNumber}`
          : '',

        hasRegistrationNumber
          ? `REG: ${registrationNumber}`
          : ''
      ]
        .filter(Boolean)
        .join(' | ');

      const copyText =
        String(
          highest?.copyText ||
          fallbackCopyText
        ).trim();

      return {
        hasRecord,
        familyNumber,
        verificationNumber,
        registrationNumber,
        hasFamilyNumber,
        hasVerificationNumber,
        hasRegistrationNumber,
        copyText
      };
    }

    function renderSidebarNote(data) {
      const note =
        normalizeHighestNote(data || {});

      card.setAttribute(
        'data-has-record',
        note.hasRecord ? '1' : '0'
      );

      card.setAttribute(
        'data-copy-text',
        note.copyText || ''
      );

      if (emptyEl) {
        emptyEl.classList.toggle(
          'd-none',
          note.hasRecord
        );
      }

      if (bodyEl) {
        bodyEl.classList.toggle(
          'd-none',
          !note.hasRecord
        );
      }

      if (copyBtn) {
        copyBtn.disabled =
          !note.hasRecord;
      }

      if (familyEl) {
        familyEl.textContent =
          note.familyNumber;
      }

      if (verifEl) {
        verifEl.textContent =
          note.verificationNumber;
      }

      if (regEl) {
        regEl.textContent =
          note.registrationNumber;
      }

      if (familyChip) {
        familyChip.classList.toggle(
          'd-none',
          !note.hasFamilyNumber
        );
      }

      if (verifChip) {
        verifChip.classList.toggle(
          'd-none',
          !note.hasVerificationNumber
        );
      }

      if (regChip) {
        regChip.classList.toggle(
          'd-none',
          !note.hasRegistrationNumber
        );
      }
    }

    async function copySidebarText(text) {
      const cleanText = String(text || '').trim();

      if (!cleanText) {
        return false;
      }

      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(cleanText);
          return true;
        }

        const textarea = document.createElement('textarea');
        textarea.value = cleanText;
        textarea.setAttribute('readonly', 'readonly');
        textarea.style.position = 'fixed';
        textarea.style.left = '-9999px';
        textarea.style.top = '-9999px';
        document.body.appendChild(textarea);
        textarea.focus();
        textarea.select();

        const copied = document.execCommand('copy');
        textarea.remove();

        return copied;
      } catch (err) {
        console.error('Sidebar accounts number copy failed:', err);
        return false;
      }
    }

    async function refreshSidebarAccountsNumberNote() {
      try {
        const res = await fetch('/api/accounts-number-note', {
          method: 'GET',
          credentials: 'same-origin',
          headers: {
            Accept: 'application/json'
          }
        });

        const data = await res.json().catch(function () {
          return {};
        });

        if (!res.ok || data.success === false) {
          return;
        }

        const noteData = data.accountsNumberNote || {
          enabled: false,
          highestNumbers: null,
          sidebarHighest: null,
          latestNumbers: null,
          notepadLatest: null,
          latestHighest: null,
          records: [],
          total: 0
        };

        window.SIDEBAR_ACCOUNTS_NUMBER_NOTE = noteData;

        if (noteData.enabled) {
          renderSidebarNote(noteData);
        }
      } catch (err) {
        console.error('Sidebar accounts number refresh failed:', err);
      }
    }

    if (copyBtn) {
      copyBtn.addEventListener('click', async function () {
        const text = card.getAttribute('data-copy-text') || '';
        const oldHtml = copyBtn.innerHTML;

        copyBtn.disabled = true;
        copyBtn.innerHTML = '<i class="bi bi-hourglass-split"></i><span>Copying...</span>';

        const copied = await copySidebarText(text);

        if (copied) {
          copyBtn.innerHTML = '<i class="bi bi-check2-circle"></i><span>Copied</span>';
        } else {
          prompt('Copy highest family, verification + registration numbers:', text);
          copyBtn.innerHTML = oldHtml;
        }

        setTimeout(function () {
          copyBtn.disabled = card.getAttribute('data-has-record') !== '1';
          copyBtn.innerHTML = oldHtml;
        }, 1200);
      });
    }

    renderSidebarNote(window.SIDEBAR_ACCOUNTS_NUMBER_NOTE || {});

    refreshSidebarAccountsNumberNote();

    setInterval(refreshSidebarAccountsNumberNote, 60000);

    if (typeof io !== 'undefined') {
      try {
        const sidebarNoteSocket = io();

        sidebarNoteSocket.on('admission:changed', function () {
          setTimeout(refreshSidebarAccountsNumberNote, 700);
        });
      } catch (err) {
        console.error('Sidebar accounts number socket failed:', err);
      }
    }
  })();
</script>

