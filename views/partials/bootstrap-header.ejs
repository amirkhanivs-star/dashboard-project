          <button
            type="button"
            class="sidebar-number-note-copy"
            id="sidebarAccountsNumberCopyBtn"
            <%= sidebarAccountsNumberNoteHasRecord ? '' : 'disabled' %>>
            <i class="bi bi-copy"></i>
            <span>Copy</span>
          </button>
        </div>
