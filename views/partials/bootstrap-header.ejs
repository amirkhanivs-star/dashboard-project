<%
  const u = user || {};

  const normalizeRole = (value) => {
    const clean = String(value || '')
      .trim()
      .toLowerCase()
      .replace(/[-\s]+/g, '_');

    if (clean === 'superadmin') return 'super_admin';
    if (clean === 'subagent') return 'sub_agent';
    return clean;
  };

  const rawRole = normalizeRole(u.role || '');
  const normalizedAgentRole = normalizeRole(u.agentType || '');
  const role = rawRole || (
    ['super_admin', 'admin', 'agent', 'sub_agent'].includes(normalizedAgentRole)
      ? normalizedAgentRole
      : ''
  );

  const dept = String(u.dept || u.department || '').trim();
  const agentType = String(u.agentType || u.agent_type || '').trim();

  const formatLabel = (value) => String(value || '')
    .trim()
    .replace(/[_-]+/g, ' ')
    .replace(/\s+/g, ' ')
    .replace(/\b\w/g, ch => ch.toUpperCase());

  const deptTitle = formatLabel(dept);
  const agentTitle = formatLabel(agentType);

  const isSuper = !!(
    role === 'super_admin' ||
    u.isSuperAdmin === true ||
    u.is_super_admin === true
  );

  let headerPerms =
    (typeof perms !== 'undefined' && perms !== null)
      ? perms
      : (u.permissions || u.perms || u.permission || u.permissionMap || {});

  try {
    if (typeof headerPerms === 'string') {
      headerPerms = JSON.parse(headerPerms);
    }
  } catch (e) {
    headerPerms = {};
  }

  function getNestedPermission(obj, path) {
    const parts = String(path || '').split('.').filter(Boolean);
    let current = obj;

    for (const part of parts) {
      if (!current || typeof current !== 'object' || !(part in current)) {
        return undefined;
      }
      current = current[part];
    }

    return current;
  }

  function can(key, def = true) {
    if (isSuper) return true;
    if (headerPerms === true) return true;
    if (!headerPerms) return def;

    const cleanKey = String(key || '').trim();
    if (!cleanKey) return def;

    if (Array.isArray(headerPerms)) {
      if (headerPerms.includes('*') || headerPerms.includes('all')) return true;
      return headerPerms.includes(cleanKey) ? true : def;
    }

    if (typeof headerPerms === 'object') {
      if (headerPerms['*'] === true || headerPerms.all === true) return true;
      if (Object.prototype.hasOwnProperty.call(headerPerms, cleanKey)) {
        return !!headerPerms[cleanKey];
      }

      const nested = getNestedPermission(headerPerms, cleanKey);
      if (typeof nested !== 'undefined') return !!nested;

      const altKey = cleanKey.replace(/\./g, '_');
      if (Object.prototype.hasOwnProperty.call(headerPerms, altKey)) {
        return !!headerPerms[altKey];
      }
    }

    return def;
  }

  let themeClass = '';
  if (role === 'admin') themeClass = 'admin';
  else if (role === 'agent') themeClass = 'agent';
  else if (role === 'sub_agent') themeClass = 'sub_agent';

  const headerTitle =
    pageTitle ||
    (isSuper ? 'Super Admin Dashboard' : 'Dashboard');

  let headerRole = '';
  if (isSuper) headerRole = 'Super Admin';
  else if (role === 'admin') headerRole = deptTitle ? `${deptTitle} Admin` : 'Admin';
  else if (role === 'agent') {
    headerRole = (deptTitle || agentTitle)
      ? `${deptTitle || 'Department'} ${agentTitle || 'Agent'} Agent`.trim()
      : 'Agent';
  } else if (role === 'sub_agent') {
    headerRole = (deptTitle || agentTitle)
      ? `${deptTitle || 'Department'} ${agentTitle || 'Sub Agent'} Sub Agent`.trim()
      : 'Sub Agent';
  } else {
    headerRole = formatLabel(role || 'User');
  }

  const deptLower = dept.toLowerCase().replace(/[_-]+/g, ' ').replace(/\s+/g, ' ').trim();
  const isSchoolDept = deptLower === 'school';
  const isSchoolAccountsDept =
    deptLower === 'accounts' ||
    deptLower === 'school accounts' ||
    deptLower.includes('school accounts');

  const canShowSchoolAdmissionForm = isSchoolDept || isSchoolAccountsDept;

  const currentPath =
    (typeof currentUrl !== 'undefined' && currentUrl)
      ? currentUrl
      : (typeof req !== 'undefined' && req.originalUrl)
        ? req.originalUrl
        : '';

  function isActivePath(paths) {
    const cleanPath = String(currentPath || '').split('?')[0];
    return (paths || []).some(path => {
      const cleanTarget = String(path || '').split('?')[0];
      return cleanPath === cleanTarget || cleanPath.startsWith(cleanTarget + '/');
    });
  }

  const usersPageActive =
    role === 'admin'
      ? isActivePath(['/dashboard/admin/users'])
      : isActivePath(['/dashboard/agent/users']);

  const sidebarAdmissionFormLink =
    (typeof currentUserAdmissionLink !== 'undefined' && currentUserAdmissionLink)
      ? currentUserAdmissionLink
      : (u && (u.admissionLink || u.admission_link))
        ? (u.admissionLink || u.admission_link)
        : '';

  const headerAccountsNumberNoteData =
    (typeof accountsNumberNote !== 'undefined' && accountsNumberNote)
      ? accountsNumberNote
      : {
          enabled: false,
          highestNumbers: null,
          sidebarHighest: null,
          latestNumbers: null,
          notepadLatest: null,
          latestHighest: null,
          records: [],
          total: 0
        };

  const shouldRenderSidebarAccountsNumberNote =
    !!(
      !isSuper &&
      isSchoolAccountsDept &&
      headerAccountsNumberNoteData &&
      headerAccountsNumberNoteData.enabled
    );

  /*
   * Left sidebar sirf database-wide independently highest
   * Family, Verification aur Registration numbers use karega.
   *
   * Ye summary kisi admission/student ke saath linked nahi hai.
   */
  const sidebarHighestAccountsNumbers =
    headerAccountsNumberNoteData.highestNumbers ||
    headerAccountsNumberNoteData.sidebarHighest ||
    null;

  const sidebarHighestFamilyNumber =
    String(
      sidebarHighestAccountsNumbers?.familyNumber || ''
    ).trim();

  const sidebarHighestVerificationNumber =
    String(
      sidebarHighestAccountsNumbers?.verificationNumber || ''
    ).trim();

  const sidebarHighestRegistrationNumber =
    String(
      sidebarHighestAccountsNumbers?.registrationNumber || ''
    ).trim();

  const sidebarAccountsNumberNoteHasRecord =
    !!(
      sidebarHighestFamilyNumber ||
      sidebarHighestVerificationNumber ||
      sidebarHighestRegistrationNumber
    );

  const sidebarHighestAccountsCopyText =
    (
      sidebarHighestAccountsNumbers &&
      sidebarHighestAccountsNumbers.copyText
    )
      ? String(
          sidebarHighestAccountsNumbers.copyText
        ).trim()
      : [
          sidebarHighestFamilyNumber
            ? `FAM: ${sidebarHighestFamilyNumber}`
            : '',

          sidebarHighestVerificationNumber
            ? `VERIF: ${sidebarHighestVerificationNumber}`
            : '',

          sidebarHighestRegistrationNumber
            ? `REG: ${sidebarHighestRegistrationNumber}`
            : ''
        ]
          .filter(Boolean)
          .join(' | ');

  const clientUser = {
    id: u.id || null,
    role,
    dept,
    department: dept,
    agentType,
    isSuperAdmin: isSuper,
    is_super_admin: isSuper
  };

  const safeScriptJson = (value) => JSON.stringify(value ?? null)
    .replace(/</g, '\\u003c')
    .replace(/>/g, '\\u003e')
    .replace(/&/g, '\\u0026')
    .replace(/\u2028/g, '\\u2028')
    .replace(/\u2029/g, '\\u2029');
