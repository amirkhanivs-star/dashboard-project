    <div class="ivs-content flex-grow-1">
      <div class="container-fluid pt-2 pb-4">
        <script>
  (function () {
    async function copySidebarAdmissionLink(text) {
      const cleanText = String(text || '').trim();
      if (!cleanText) return false;

      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(cleanText);
          return true;
        }

        const textarea = document.createElement('textarea');
        textarea.value = cleanText;
        textarea.style.position = 'fixed';
        textarea.style.left = '-9999px';
        textarea.style.top = '-9999px';
        document.body.appendChild(textarea);
        textarea.focus();
        textarea.select();

        const copied = document.execCommand('copy');
        document.body.removeChild(textarea);

        return copied;
      } catch (err) {
        console.error('Sidebar admission link copy failed:', err);
        return false;
      }
    }

    document.addEventListener('click', async function (e) {
      const btn = e.target.closest('#sidebarAdmissionFormLinkCopyBtn');
      if (!btn) return;

      e.preventDefault();

      const link = btn.getAttribute('data-link') || '';

      const oldHtml = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<i class="bi bi-hourglass-split"></i>';

      const copied = await copySidebarAdmissionLink(link);

      if (copied) {
        btn.innerHTML = '<i class="bi bi-check2-circle"></i>';
        btn.title = 'Copied';
      } else {
        prompt('Copy this admission form link:', link);
        btn.innerHTML = oldHtml;
      }

      setTimeout(function () {
        btn.disabled = false;
        btn.innerHTML = oldHtml;
        btn.title = 'Copy admission form link';
      }, 1200);
    });
  })();
</script>
