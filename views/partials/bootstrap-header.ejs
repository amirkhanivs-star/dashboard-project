    <script>
  (function () {
    let revealScheduled = false;

    function revealDashboard(delay = 1000) {
      if (revealScheduled) return;
      revealScheduled = true;

      const html = document.documentElement;
      const loader = document.getElementById('ivsGlobalLoader');

      setTimeout(function () {
        html.classList.remove('ivs-preload', 'ivs-loading', 'ivs-page-leaving');
        html.classList.add('ivs-ready');

        if (loader) loader.setAttribute('aria-hidden', 'true');

        setTimeout(function () {
          html.classList.remove('ivs-ready');
        }, 400);
      }, Math.max(0, Number(delay) || 0));
    }

    if (document.readyState === 'complete') {
      revealDashboard();
    } else {
      window.addEventListener('load', function () {
        revealDashboard();
      }, { once: true });
    }

    window.addEventListener('pageshow', function () {
      revealDashboard(0);
    });

    // CDN/resource failure must never leave the page permanently covered.
    setTimeout(function () {
      revealDashboard(0);
    }, 8000);
  })();
</script>
