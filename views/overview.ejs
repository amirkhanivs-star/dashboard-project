<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  const overviewCharts = <%- JSON.stringify(safeOverview.charts || {}) %>;

  function buildColors(items, fallback) {
    return (items || []).map((x, idx) => x.color || fallback[idx % fallback.length]);
  }

  function makeChart(id, type, labels, values, opts = {}) {
    const el = document.getElementById(id);
    if (!el || !labels || !labels.length) return;

    const palette = ["#dc2626", "#111827", "#2563eb", "#16a34a", "#f59e0b", "#8b5cf6", "#06b6d4", "#e11d48", "#334155", "#0ea5e9"];
    const dataset = { label: opts.label || "Overview", data: values, borderWidth: 2, fill: !!opts.fill, tension: .35 };

    if (type === "pie" || type === "doughnut") {
      dataset.backgroundColor = opts.backgroundColor || palette;
      dataset.borderColor = "#ffffff";
    } else if (type === "bar") {
      dataset.backgroundColor = opts.backgroundColor || "rgba(220,38,38,.72)";
      dataset.borderColor = opts.borderColor || "#dc2626";
    } else {
      dataset.backgroundColor = opts.backgroundColor || "rgba(220,38,38,.12)";
      dataset.borderColor = opts.borderColor || "#dc2626";
      dataset.pointBackgroundColor = opts.borderColor || "#dc2626";
    }

    new Chart(el, {
      type,
      data: { labels, datasets: [dataset] },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: opts.legend !== false } },
        scales: opts.scales === false ? {} : { y: { beginAtZero: true, ticks: { precision: 0 } } }
      }
    });
  }

  const analyticsToggleBtn = document.getElementById("analyticsChartsToggle");
  const analyticsChartsBody = document.getElementById("analyticsChartsBody");

  if (analyticsToggleBtn && analyticsChartsBody) {
    analyticsToggleBtn.addEventListener("click", () => {
      const isHidden = analyticsChartsBody.classList.toggle("is-hidden");
      analyticsToggleBtn.classList.toggle("is-collapsed", isHidden);
      analyticsToggleBtn.setAttribute("aria-expanded", String(!isHidden));
    });
  }

  const deptComparison = overviewCharts.departmentComparison || {};
  makeChart(
    "departmentComparisonChart",
    "bar",
    Object.keys(deptComparison).map(x => x.charAt(0).toUpperCase() + x.slice(1)),
    Object.values(deptComparison),
    { label: "Department Comparison", backgroundColor: "rgba(220,38,38,.70)", borderColor: "#dc2626" }
  );

  const statusDist = overviewCharts.statusDistribution || [];
  makeChart(
    "statusDistributionChart",
    "doughnut",
    statusDist.map(x => x.label),
    statusDist.map(x => x.value),
    { label: "Status Distribution", scales: false, backgroundColor: buildColors(statusDist, ["#dc2626", "#111827", "#2563eb", "#16a34a", "#f59e0b", "#8b5cf6"]) }
  );

  const feeDist = overviewCharts.feeDistribution || [];
  makeChart(
    "feeDistributionChart",
    "pie",
    feeDist.map(x => x.label),
    feeDist.map(x => x.value),
    { label: "Fee Distribution", scales: false, backgroundColor: buildColors(feeDist, ["#dc2626", "#111827", "#0ea5e9", "#16a34a", "#f59e0b", "#8b5cf6"]) }
  );



    function wireClientPagination(tableId, paginationId, rowsPerPage = 5) {
    const table = document.getElementById(tableId);
    const pagination = document.getElementById(paginationId);

    if (!table || !pagination) return;

    const allRows = Array.from(table.querySelectorAll("tbody tr"));
    if (!allRows.length) return;

    let currentPage = 1;

    function getVisibleRows() {
      return allRows.filter(row => row.dataset.searchHidden !== "1");
    }

    function render() {
      const visibleRows = getVisibleRows();
      const totalPages = Math.max(1, Math.ceil(visibleRows.length / rowsPerPage));

      if (currentPage > totalPages) currentPage = totalPages;

      allRows.forEach(row => {
        row.style.display = "none";
      });

      visibleRows.forEach((row, index) => {
        const start = (currentPage - 1) * rowsPerPage;
        const end = start + rowsPerPage;
        row.style.display = index >= start && index < end ? "" : "none";
      });

      pagination.innerHTML = "";

      const info = document.createElement("span");
      info.className = "overview-pagination-info me-auto";
      info.textContent = `Showing ${visibleRows.length ? ((currentPage - 1) * rowsPerPage) + 1 : 0}-${Math.min(currentPage * rowsPerPage, visibleRows.length)} of ${visibleRows.length}`;
      pagination.appendChild(info);

      const prevBtn = document.createElement("button");
      prevBtn.type = "button";
      prevBtn.className = "btn btn-sm btn-outline-secondary";
      prevBtn.textContent = "Prev";
      prevBtn.disabled = currentPage === 1;
      prevBtn.addEventListener("click", () => {
        currentPage -= 1;
        render();
      });
      pagination.appendChild(prevBtn);

      for (let p = 1; p <= totalPages; p++) {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = `btn btn-sm ${p === currentPage ? "btn-danger" : "btn-outline-secondary"}`;
        btn.textContent = p;
        btn.addEventListener("click", () => {
          currentPage = p;
          render();
        });
        pagination.appendChild(btn);
      }

      const nextBtn = document.createElement("button");
      nextBtn.type = "button";
      nextBtn.className = "btn btn-sm btn-outline-secondary";
      nextBtn.textContent = "Next";
      nextBtn.disabled = currentPage === totalPages;
      nextBtn.addEventListener("click", () => {
        currentPage += 1;
        render();
      });
      pagination.appendChild(nextBtn);
    }

    table._overviewPaginationRender = function () {
      currentPage = 1;
      render();
    };

    render();
  }

  function wireSearchWithPagination(inputId, tableId) {
    const input = document.getElementById(inputId);
    const table = document.getElementById(tableId);
    if (!input || !table) return;

    input.addEventListener("input", () => {
      const q = String(input.value || "").toLowerCase().trim();

      table.querySelectorAll("tbody tr").forEach((tr) => {
        const text = tr.innerText.toLowerCase();
        tr.dataset.searchHidden = text.includes(q) ? "0" : "1";
      });

      if (typeof table._overviewPaginationRender === "function") {
        table._overviewPaginationRender();
      }
    });
  }

  wireClientPagination("dailyAdmissionsTable", "dailyAdmissionsPagination", 5);
  wireClientPagination("departmentSummaryTable", "departmentSummaryPagination", 5);
  wireClientPagination("searchResultsTable", "searchResultsPagination", 5);
  wireClientPagination("recentAdmissionsTable", "recentAdmissionsPagination", 5);
  wireClientPagination("recentBillingTable", "recentBillingPagination", 5);
  wireClientPagination("pendingDueTable", "pendingDuePagination", 5);
  wireClientPagination("noPaymentTable", "noPaymentPagination", 5);
  wireClientPagination("statusSummaryTable", "statusSummaryPagination", 5);
  wireClientPagination("feeSummaryTable", "feeSummaryPagination", 5);
  wireClientPagination("currencySummaryTable", "currencySummaryPagination", 5);
  wireClientPagination("billingSummaryTable", "billingSummaryPagination", 5);
  wireClientPagination("invoiceStatusTable", "invoiceStatusPagination", 5);
  wireClientPagination("paidInvoiceStatusTable", "paidInvoiceStatusPagination", 5);

  wireSearchWithPagination("recentAdmissionsSearch", "recentAdmissionsTable");
  wireSearchWithPagination("recentBillingSearch", "recentBillingTable");
  wireSearchWithPagination("dailyAdmissionsSearch", "dailyAdmissionsTable");
  wireSearchWithPagination("searchResultsTableSearch", "searchResultsTable");
</script>

