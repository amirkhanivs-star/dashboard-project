  function canViewOverviewColumn(name) {
    const key =
      String(name || '').trim();

    const permissionKey =
      OVERVIEW_VIEW_PERMISSION_KEYS[key];

    if (!permissionKey) {
      return false;
    }

    const legacyKeys =
      OVERVIEW_LEGACY_VIEW_KEYS[key] ||
      [];

    const pascalKey =
      key.charAt(0).toUpperCase() +
      key.slice(1);

    const possibleKeys = [
      permissionKey,
      ...legacyKeys,

      `col.${key}`,
      `show_${key}`,
      `show${pascalKey}`,

      `super.col.${key}`,
      `super.column.${key}`,

      `dashboard_super.col.${key}`,
      `dashboard-super.col.${key}`,

      `perm.super.col.${key}`,

      key
    ];

    return possibleKeys.some(
      hasOverviewPermission
    );
  }

