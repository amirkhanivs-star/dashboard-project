<%
  let overviewPerms =
    (typeof perms !== 'undefined' && perms)
      ? perms
      : (
          user?.permissions ||
          user?.perms ||
          user?.permission ||
          user?.permissionMap ||
          {}
        );

  try {
    if (typeof overviewPerms === 'string') {
      overviewPerms = JSON.parse(
        overviewPerms
      );
    }
  } catch (error) {
    overviewPerms = {};
  }

  function overviewPermissionEnabled(value) {
    if (value === true || value === 1) {
      return true;
    }

    if (
      value === false ||
      value === 0 ||
      value === null ||
      typeof value === 'undefined'
    ) {
      return false;
    }

    return [
      '1',
      'true',
      'on',
      'yes'
    ].includes(
      String(value)
        .trim()
        .toLowerCase()
    );
  }

  function hasOverviewPermission(key) {
    const cleanKey =
      String(key || '').trim();

    if (!cleanKey || !overviewPerms) {
      return false;
    }

    if (overviewPerms === true) {
      return true;
    }

    if (Array.isArray(overviewPerms)) {
      return (
        overviewPerms.includes(cleanKey) ||
        overviewPerms.includes('*') ||
        overviewPerms.includes('all')
      );
    }

    if (typeof overviewPerms === 'object') {
      if (
        Object.prototype.hasOwnProperty.call(
          overviewPerms,
          cleanKey
        )
      ) {
        return overviewPermissionEnabled(
          overviewPerms[cleanKey]
        );
      }

      const alternateKey =
        cleanKey.replace(/\./g, '_');

      if (
        Object.prototype.hasOwnProperty.call(
          overviewPerms,
          alternateKey
        )
      ) {
        return overviewPermissionEnabled(
          overviewPerms[alternateKey]
        );
      }
    }

    return false;
  }

  const OVERVIEW_VIEW_PERMISSION_KEYS =
    Object.freeze({
      status: 'colStatus',
      feeStatus: 'colFeeStatus',
      dept: 'colDept',
      student: 'colStudentName',
      father: 'colFatherName',
      fatherEmail: 'colFatherEmail',
