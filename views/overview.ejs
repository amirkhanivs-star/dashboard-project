<%- include('partials/bootstrap-header', { user, pageTitle: pageTitle || 'Overview' }) %>
<%- include('partials/flash') %>

<style>
  .overview-page {
    padding: 1rem;
    background:
      radial-gradient(circle at top left, rgba(220, 38, 38, .10), transparent 26%),
      radial-gradient(circle at top right, rgba(15, 23, 42, .08), transparent 24%),
      linear-gradient(180deg, #f8fbff 0%, #f6f8fc 100%);
    min-height: calc(100vh - 80px);
  }

  .overview-hero {
    position: relative;
    overflow: hidden;
    border-radius: 24px;
    padding: 1rem;
    background:
      radial-gradient(circle at 78% 22%, rgba(255,255,255,.16), transparent 22%),
      linear-gradient(135deg, #070707 0%, #18181b 54%, #7f0000 135%);
    color: #fff;
    box-shadow: 0 18px 42px rgba(15, 23, 42, 0.16);
  }

  .overview-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 34px 34px;
    opacity: .55;
    pointer-events: none;
  }

  .overview-hero > * { position: relative; z-index: 1; }

  .overview-hero h1 {
    font-size: clamp(1.45rem, 2vw, 2.15rem);
    font-weight: 900;
    margin-bottom: .35rem;
    letter-spacing: -.03em;
  }

  .overview-hero p {
    margin: 0;
    color: rgba(255,255,255,.84);
    font-size: .88rem;
    max-width: 900px;
  }

  .overview-chip-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
    margin-top: .75rem;
  }

  .overview-chip {
    display: inline-flex;
    align-items: center;
    gap: .42rem;
    padding: .48rem .72rem;
    border-radius: 999px;
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.14);
    font-size: .78rem;
    font-weight: 800;
    color: #fff;
  }

  .panel-card {
    border: 1px solid rgba(226, 232, 240, .75);
    border-radius: 20px;
    background: rgba(255,255,255,.92);
    box-shadow: 0 10px 28px rgba(15, 23, 42, 0.07);
    backdrop-filter: blur(10px);
  }

  .panel-card.tight { border-radius: 18px; }

  .section-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .8rem;
    margin-bottom: .75rem;
  }

  .section-title h4,
  .section-title h5,
  .section-title h6 {
    margin: 0;
    font-weight: 900;
    color: #0f172a;
    letter-spacing: -.02em;
  }

  .section-sub {
    color: #64748b;
    font-size: .78rem;
    line-height: 1.35;
  }

  .ceo-filter-card {
    border-radius: 20px;
    border: 1px solid rgba(220,38,38,.16);
    background:
      linear-gradient(180deg, rgba(255,255,255,.96), rgba(255,250,250,.88));
    box-shadow: 0 14px 34px rgba(127, 29, 29, .10);
  }

  .filter-grid {
    display: grid;
    grid-template-columns: 1.45fr repeat(5, minmax(0, 1fr));
    gap: .65rem;
  }

  .filter-grid .form-label {
    font-size: .72rem;
    font-weight: 900;
    color: #475569;
    margin-bottom: .25rem;
    text-transform: uppercase;
    letter-spacing: .03em;
  }

  .filter-grid .form-control,
  .filter-grid .form-select,
  .table-search {
    border-radius: 12px;
    border-color: #e2e8f0;
    min-height: 38px;
    font-size: .82rem;
  }

  .filter-actions {
    display: flex;
    gap: .45rem;
    align-items: end;
    flex-wrap: wrap;
  }

  .btn-ceo {
    border: 0;
    border-radius: 12px;
    background: linear-gradient(135deg, #dc2626, #991b1b);
    color: #fff;
    font-size: .82rem;
    font-weight: 900;
    padding: .55rem .85rem;
    box-shadow: 0 10px 20px rgba(220,38,38,.20);
  }

  .btn-ceo:hover { color: #fff; filter: brightness(.96); }

  .btn-soft {
    border-radius: 12px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    color: #334155;
    font-size: .82rem;
    font-weight: 800;
    padding: .52rem .8rem;
  }

  .summary-grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: .75rem;
  }

  .summary-card {
    position: relative;
    overflow: hidden;
    border: 1px solid #e9eef7;
    border-radius: 18px;
    padding: .85rem;
    background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
    min-height: 105px;
  }

  .summary-card::after {
    content: "";
    position: absolute;
    right: -28px;
    top: -28px;
    width: 76px;
    height: 76px;
    border-radius: 50%;
    background: rgba(220,38,38,.09);
  }

  .summary-card .icon-wrap {
    width: 34px;
    height: 34px;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: .95rem;
    margin-bottom: .55rem;
    color: #b91c1c;
    background: rgba(220,38,38,.10);
  }

  .summary-card .label {
    font-size: .7rem;
    font-weight: 900;
    color: #64748b;
    margin-bottom: .22rem;
    text-transform: uppercase;
    letter-spacing: .03em;
  }

  .summary-card .value {
    font-size: 1.35rem;
    line-height: 1.05;
    font-weight: 950;
    color: #0f172a;
  }

  .summary-card .hint {
    margin-top: .35rem;
    color: #94a3b8;
    font-size: .72rem;
  }

  .mini-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: .55rem;
  }

  .mini-grid.three { grid-template-columns: repeat(3, minmax(0, 1fr)); }

  .mini-stat {
    border-radius: 14px;
    padding: .55rem .65rem;
    background: linear-gradient(180deg, #fff, #f8fafc);
    border: 1px solid #e2e8f0;
  }

  .mini-stat .title {
    font-size: .68rem;
    color: #64748b;
    font-weight: 900;
    margin-bottom: .18rem;
    text-transform: uppercase;
    letter-spacing: .03em;
  }

  .mini-stat .num {
    font-size: 1rem;
    font-weight: 950;
    color: #0f172a;
    line-height: 1.05;
  }

  .table-premium { font-size: .82rem; }

  .table-premium thead th {
    border-bottom: 1px solid #e2e8f0;
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: .03em;
    color: #64748b;
    font-weight: 950;
    background: #fbfdff;
    white-space: nowrap;
  }

  .table-premium tbody td {
    vertical-align: middle;
    border-color: #eef2f7;
    white-space: nowrap;
  }

  .table-compact tbody td,
  .table-compact thead th { padding: .48rem .55rem; }

  .soft-badge {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: .28rem .55rem;
    font-size: .72rem;
    font-weight: 900;
    background: #eff6ff;
    color: #1d4ed8;
  }

  .danger-badge { background: #fef2f2; color: #b91c1c; }
  .dark-badge { background: #f1f5f9; color: #0f172a; }
  .success-badge { background: #ecfdf5; color: #047857; }
  .warning-badge { background: #fffbeb; color: #b45309; }

  .empty-state {
    border-radius: 18px;
    padding: 1.25rem 1rem;
    background: linear-gradient(180deg, #fff, #f8fafc);
    border: 1px dashed #cbd5e1;
    text-align: center;
    color: #64748b;
    font-size: .86rem;
  }

  .chart-box { position: relative; min-height: 290px; }
  .chart-box.chart-box-sm { min-height: 200px; }

  .analytics-toggle-btn {
    display: inline-flex;
    align-items: center;
    gap: .55rem;
    border: 0;
    background: transparent;
    padding: 0;
    font-size: 1.05rem;
    font-weight: 950;
    color: #0f172a;
    cursor: pointer;
  }

  .analytics-toggle-btn i {
    font-size: .9rem;
    transition: transform .25s ease;
  }

  .analytics-toggle-btn.is-collapsed i { transform: rotate(180deg); }
  #analyticsChartsBody.is-hidden { display: none; }

  .table-search { max-width: 230px; }

  .snapshot-mini-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: .5rem;
  }

  .snapshot-mini-grid .mini-stat {
    padding: .45rem .55rem;
    border-radius: 12px;
    min-height: auto;
  }

  .insight-list {
    display: grid;
    gap: .55rem;
  }

  .insight-item {
    display: flex;
    align-items: flex-start;
    gap: .55rem;
    padding: .65rem;
    border-radius: 14px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    font-size: .82rem;
  }

  .insight-item i {
    color: #dc2626;
    margin-top: .1rem;
  }

  .person-card {
    border-radius: 15px;
    border: 1px solid #e2e8f0;
    background: #ffffff;
    padding: .65rem;
  }

  .person-card .name {
    font-size: .88rem;
    font-weight: 950;
    color: #0f172a;
    margin-bottom: .35rem;
  }

  .person-card .person-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: .35rem;
  }

  .person-card .person-stats span {
    background: #f8fafc;
    border-radius: 10px;
    padding: .35rem;
    font-size: .72rem;
    color: #64748b;
    font-weight: 800;
  }

  .person-card .person-stats b {
    display: block;
    color: #0f172a;
    font-size: .95rem;
  }
  .overview-scroll-box {
    max-height: 250px;
    overflow-y: auto;
    overflow-x: auto;
    padding-right: .25rem;
  }

  .overview-scroll-box::-webkit-scrollbar {
    width: 7px;
    height: 7px;
  }

  .overview-scroll-box::-webkit-scrollbar-track {
    background: #f1f5f9;
    border-radius: 999px;
  }

  .overview-scroll-box::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 999px;
  }

  .overview-scroll-box::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }

  .overview-5-lines {
    max-height: 245px;
    overflow-y: auto;
    overflow-x: auto;
  }

  .overview-pagination-info {
    font-size: .74rem;
    font-weight: 800;
    color: #64748b;
  }
  .super-pagination-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: .35rem;
    justify-content: flex-end;
  }

  .super-pagination-wrap .btn { border-radius: 10px; font-weight: 800; }

  @media (max-width: 1599px) {
    .summary-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .filter-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }

  @media (max-width: 1199px) {
    .summary-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .mini-grid, .mini-grid.three { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .filter-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 767px) {
    .overview-page { padding: .75rem; }
    .overview-hero { padding: .9rem; border-radius: 20px; }
    .summary-grid, .mini-grid, .mini-grid.three, .filter-grid { grid-template-columns: 1fr; }
    .chart-box, .chart-box.chart-box-sm { min-height: 250px; }
    .section-title { align-items: flex-start; flex-direction: column; }
    .table-search { max-width: 100%; }
  }
</style>

<%
  const safeOverview = overviewData || {};
  const summaryCards = Array.isArray(safeOverview.summaryCards) ? safeOverview.summaryCards : [];
  const departmentStats = safeOverview.departmentStats || {};
  const statusStats = Array.isArray(safeOverview.statusStats) ? safeOverview.statusStats : [];
  const feeStats = Array.isArray(safeOverview.feeStats) ? safeOverview.feeStats : [];
  const currencyStats = Array.isArray(safeOverview.currencyStats) ? safeOverview.currencyStats : [];
  const recentAdmissions = Array.isArray(safeOverview.recentAdmissions) ? safeOverview.recentAdmissions : [];
  const recentAdmissionsPageData = recentAdmissions;
  const recentBillingChanges = Array.isArray(safeOverview.recentBillingChanges) ? safeOverview.recentBillingChanges : [];
  const recentBillingPageData = recentBillingChanges;
  const billingStats = safeOverview.billingStats || {};
  const billingBreakdown = Array.isArray(billingStats.billingBreakdown) ? billingStats.billingBreakdown : [];
  const pendingDueAdmissions = Array.isArray(billingStats.pendingDueAdmissions) ? billingStats.pendingDueAdmissions : [];
  const pendingDuePageData = pendingDueAdmissions;
  const noPaymentAdmissions = Array.isArray(billingStats.noPaymentAdmissions) ? billingStats.noPaymentAdmissions : [];
  const noPaymentPageData = noPaymentAdmissions;
  const processedByStatsFromServer = Array.isArray(safeOverview.processedByStats) ? safeOverview.processedByStats : [];
  const dailyAdmissionStatsFromServer = Array.isArray(safeOverview.dailyAdmissionStats) ? safeOverview.dailyAdmissionStats : [];
  const searchResultsFromServer = Array.isArray(safeOverview.searchResults) ? safeOverview.searchResults : [];
  const missingInsightsFromServer = Array.isArray(safeOverview.missingInsights) ? safeOverview.missingInsights : [];
  const queryFilters = safeOverview.filters || {};
  const urlFilters = typeof req !== 'undefined' && req.query ? req.query : {};
  const activeSearch = String(queryFilters.q || urlFilters.q || '').trim();
  const activeDept = String(queryFilters.department || urlFilters.department || '').trim();
  const activeStatus = String(queryFilters.status || urlFilters.status || '').trim();
  const activeFeeStatus = String(queryFilters.feeStatus || urlFilters.feeStatus || '').trim();
  const activeProcessedBy = String(queryFilters.processedBy || urlFilters.processedBy || '').trim();
  const activeFromDate = String(queryFilters.fromDate || urlFilters.fromDate || '').trim();
  const activeToDate = String(queryFilters.toDate || urlFilters.toDate || '').trim();

  function cleanText(value) {
    return String(value || '').trim();
  }

  function getAdmissionDate(item) {
    return cleanText(item.createdAt || item.created_at || item.registration_date || item.date || item.admissionDate).slice(0, 10);
  }

  function getProcessedBy(item) {
    return cleanText(item.processedBy || item.processed_by || item.createdBy || item.created_by || item.agentName || item.agent_name || item.userName || item.user_name || 'Not Assigned');
  }

  const todayIso = new Date().toISOString().slice(0, 10);
  const fallbackProcessedMap = {};
  const fallbackDailyMap = {};
  let todayAdmissionsCount = 0;
  recentAdmissions.forEach((item) => {
    const processor = getProcessedBy(item);
    const dept = cleanText(item.dept || item.department || 'Unknown') || 'Unknown';
    const date = getAdmissionDate(item) || 'No Date';
    if (!fallbackProcessedMap[processor]) {
      fallbackProcessedMap[processor] = { name: processor, total: 0, school: 0, tuition: 0, quran: 0, latestDate: '' };
    }
    fallbackProcessedMap[processor].total += 1;
    const deptLower = dept.toLowerCase();
    if (deptLower.includes('school')) fallbackProcessedMap[processor].school += 1;
    if (deptLower.includes('tuition')) fallbackProcessedMap[processor].tuition += 1;
    if (deptLower.includes('quran')) fallbackProcessedMap[processor].quran += 1;
    if (date && date !== 'No Date') fallbackProcessedMap[processor].latestDate = date;

    if (!fallbackDailyMap[date]) fallbackDailyMap[date] = { date, total: 0, school: 0, tuition: 0, quran: 0 };
    fallbackDailyMap[date].total += 1;
    if (deptLower.includes('school')) fallbackDailyMap[date].school += 1;
    if (deptLower.includes('tuition')) fallbackDailyMap[date].tuition += 1;
    if (deptLower.includes('quran')) fallbackDailyMap[date].quran += 1;
    if (date === todayIso) todayAdmissionsCount += 1;
  });

  const processedByStats = processedByStatsFromServer.length ? processedByStatsFromServer : Object.values(fallbackProcessedMap).sort((a, b) => (b.total || 0) - (a.total || 0));
  const dailyAdmissionStats = dailyAdmissionStatsFromServer.length ? dailyAdmissionStatsFromServer : Object.values(fallbackDailyMap).sort((a, b) => String(b.date).localeCompare(String(a.date)));
  const searchResults = searchResultsFromServer.length ? searchResultsFromServer : recentAdmissions;
  const selectedProcessorTotal = activeProcessedBy ? processedByStats.filter(x => cleanText(x.name || x.processedBy || x.processed_by).toLowerCase().includes(activeProcessedBy.toLowerCase())).reduce((sum, x) => sum + Number(x.total || 0), 0) : 0;
  const totalAdmissions = ['school','tuition','quran'].reduce((sum, key) => sum + Number(departmentStats?.[key]?.total || 0), 0);
  const totalRecentAdmissions = recentAdmissions.length;
  const totalProcessedPeople = processedByStats.length;
  const latestDailyAdmissions = dailyAdmissionStats[0]?.total || todayAdmissionsCount || 0;
  const missingInsights = missingInsightsFromServer.length ? missingInsightsFromServer : [
    { title: 'Processed By tracking', description: processedByStatsFromServer.length ? 'Processed By data is connected.' : 'If full processed-by counts are required, pass overviewData.processedByStats from server.js.' },
    { title: 'Daily admissions tracking', description: dailyAdmissionStatsFromServer.length ? 'Daily admissions data is connected.' : 'If full date-wise counts are required, pass overviewData.dailyAdmissionStats from server.js.' },
    { title: 'CEO search results', description: searchResultsFromServer.length ? 'Server search results are connected.' : 'This page can show recent admissions now. For all records, pass overviewData.searchResults from server.js.' }
  ];
%>

<div class="overview-page">
  <div class="overview-hero mb-3">
    <div class="row g-3 align-items-center">
      <div class="col-lg-8">
        <div class="small text-uppercase fw-bold mb-2" style="letter-spacing:.08em;color:rgba(255,255,255,.72);">
          Super Admin Intelligence Panel
        </div>
        <h1>Overview Dashboard</h1>
        <p>CEO-level overview for admissions, processed-by performance, date-wise intake, billing health, status insights and missing operational data.</p>

        <div class="overview-chip-wrap">
          <span class="overview-chip"><i class="bi bi-mortarboard-fill"></i> School</span>
          <span class="overview-chip"><i class="bi bi-journal-bookmark-fill"></i> Tuition</span>
          <span class="overview-chip"><i class="bi bi-book-half"></i> Quran</span>
          <span class="overview-chip"><i class="bi bi-person-check-fill"></i> Processed By</span>
          <span class="overview-chip"><i class="bi bi-calendar2-check-fill"></i> Daily Intake</span>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="panel-card p-3 h-100" style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);box-shadow:none;">
          <div class="section-title mb-2">
            <div>
              <h6 class="text-white mb-1">Department Snapshot</h6>
              <div style="color:rgba(255,255,255,.72);font-size:.74rem;">Quick department totals</div>
            </div>
          </div>

          <div class="mini-grid snapshot-mini-grid">
            <div class="mini-stat">
              <div class="title">School</div>
              <div class="num"><%= departmentStats.school?.total || 0 %></div>
            </div>
            <div class="mini-stat">
              <div class="title">Tuition</div>
              <div class="num"><%= departmentStats.tuition?.total || 0 %></div>
            </div>
            <div class="mini-stat">
              <div class="title">Quran</div>
              <div class="num"><%= departmentStats.quran?.total || 0 %></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="summary-grid mb-3">
    <div class="summary-card">
      <div class="icon-wrap"><i class="bi bi-people-fill"></i></div>
      <div class="label">Total Admissions</div>
      <div class="value"><%= totalAdmissions %></div>
      <div class="hint">School, Tuition and Quran</div>
    </div>
    <div class="summary-card">
      <div class="icon-wrap"><i class="bi bi-calendar-check-fill"></i></div>
      <div class="label">Today Admissions</div>
      <div class="value"><%= todayAdmissionsCount || 0 %></div>
      <div class="hint"><%= todayIso %></div>
    </div>
    <div class="summary-card">
      <div class="icon-wrap"><i class="bi bi-person-lines-fill"></i></div>
      <div class="label">Processed People</div>
      <div class="value"><%= totalProcessedPeople %></div>
      <div class="hint">Based on processed-by data</div>
    </div>
    <div class="summary-card">
      <div class="icon-wrap"><i class="bi bi-search-heart-fill"></i></div>
      <div class="label">Search Results</div>
      <div class="value"><%= searchResults.length %></div>
      <div class="hint">Current visible result set</div>
    </div>
    <div class="summary-card">
      <div class="icon-wrap"><i class="bi bi-wallet2"></i></div>
      <div class="label">Pending Dues</div>
      <div class="value"><%= billingStats.totalPendingDues || 0 %></div>
      <div class="hint">Billing amount pending</div>
    </div>
    <div class="summary-card">
      <div class="icon-wrap"><i class="bi bi-exclamation-triangle-fill"></i></div>
      <div class="label">Missing Checks</div>
      <div class="value"><%= missingInsights.length %></div>
      <div class="hint">Items to verify</div>
    </div>
  </div>

  <div class="ceo-filter-card p-3 mb-3">
    <div class="section-title">
      <div>
        <h5>CEO Search Center</h5>
        <div class="section-sub">Search by student, registration, phone, department, status, fee status, processed by, or admission date.</div>
      </div>
    </div>

    <form method="GET" action="" class="filter-grid">
      <div>
        <label class="form-label">Search</label>
        <input type="text" class="form-control" name="q" value="<%= activeSearch %>" placeholder="Student, reg no, phone, processed by">
      </div>
      <div>
        <label class="form-label">Department</label>
        <select class="form-select" name="department">
          <option value="">All</option>
          <option value="school" <%= activeDept === 'school' ? 'selected' : '' %>>School</option>
          <option value="tuition" <%= activeDept === 'tuition' ? 'selected' : '' %>>Tuition</option>
          <option value="quran" <%= activeDept === 'quran' ? 'selected' : '' %>>Quran</option>
        </select>
      </div>
      <div>
        <label class="form-label">Status</label>
        <input type="text" class="form-control" name="status" value="<%= activeStatus %>" placeholder="Current status">
      </div>
      <div>
        <label class="form-label">Fee Status</label>
        <input type="text" class="form-control" name="feeStatus" value="<%= activeFeeStatus %>" placeholder="Fee status">
      </div>
      <div>
        <label class="form-label">Processed By</label>
        <input type="text" class="form-control" name="processedBy" value="<%= activeProcessedBy %>" placeholder="Agent/Admin name">
      </div>
      <div>
        <label class="form-label">From</label>
        <input type="date" class="form-control" name="fromDate" value="<%= activeFromDate %>">
      </div>
      <div>
        <label class="form-label">To</label>
