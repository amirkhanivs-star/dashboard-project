      canViewSearchTextFilter ||
      P.col.dept ||
      P.col.status ||
      P.col.feeStatus ||
      canViewAdmissionCounts
    );

  const canViewDateAnalytics =
    !!canViewAdmissionCounts;

  const canViewExecutiveQuickNumbers =
    !!(
      canViewAdmissionCounts ||
      P.col.receivedPayment ||
      P.col.paymentStatus
    );

  const canViewDepartmentSummary =
    !!(
      P.col.dept &&
      (
        canViewAdmissionCounts ||
        P.col.status ||
        P.col.feeStatus ||
        P.col.paymentStatus ||
        P.col.currency
      )
    );

  const canViewRecentAdmissions =
    !!(
      P.col.student ||
      P.col.dept ||
      P.col.status ||
      P.col.processedBy ||
      canViewAdmissionCounts
    );

  const canViewRecentBilling =
    !!(
      P.col.student ||
      P.col.month ||
      P.col.paymentStatus ||
      P.col.invoiceStatusTimestamp
    );

  const canViewPendingDueRows =
    !!P.col.pendingDues;

  const canViewNoPaymentRows =
    !!P.col.paymentStatus;

  const activeSearch =
    canViewSearchTextFilter
      ? cleanOverviewFilter(
          queryFilters.q ||
          urlFilters.q
        )
      : '';

  const activeDept =
    P.col.dept
      ? cleanOverviewFilter(
          queryFilters.department ||
          urlFilters.department
        )
      : '';

  const activeStatus =
    P.col.status
      ? cleanOverviewFilter(
          queryFilters.status ||
          urlFilters.status
        )
      : '';

  const activeFeeStatus =
    P.col.feeStatus
      ? cleanOverviewFilter(
          queryFilters.feeStatus ||
          urlFilters.feeStatus
        )
      : '';

  const activeProcessedBy =
    P.col.processedBy
      ? cleanOverviewFilter(
          queryFilters.processedBy ||
          urlFilters.processedBy
        )
      : '';

  const activeFromDate =
    canViewAdmissionCounts
      ? cleanOverviewFilter(
          queryFilters.startDate ||
          queryFilters.fromDate ||
          urlFilters.startDate ||
          urlFilters.fromDate
        )
      : '';

  const activeToDate =
    canViewAdmissionCounts
      ? cleanOverviewFilter(
          queryFilters.endDate ||
          queryFilters.toDate ||
          urlFilters.endDate ||
          urlFilters.toDate
        )
      : '';

  const todayIso =
    new Date().toISOString().slice(0, 10);

  const fallbackProcessedMap = {};
  const fallbackDailyMap = {};
  let todayAdmissionsCount = 0;

  if (
    P.col.processedBy ||
    canViewDateAnalytics
  ) {
    recentAdmissions.forEach((item) => {
      const processor =
        getProcessedBy(item);

      const dept =
        cleanText(
          item.dept ||
          item.department ||
          'Unknown'
        ) || 'Unknown';

      const date =
        getAdmissionDate(item) ||
        'No Date';

      const deptLower =
        dept.toLowerCase();

      if (P.col.processedBy) {
        if (!fallbackProcessedMap[processor]) {
          fallbackProcessedMap[processor] = {
            name: processor,
            total: 0,
            school: 0,
            tuition: 0,
            quran: 0,
            latestDate: ''
          };
        }

        fallbackProcessedMap[processor].total += 1;

        if (deptLower.includes('school')) {
          fallbackProcessedMap[processor].school += 1;
        }

        if (deptLower.includes('tuition')) {
          fallbackProcessedMap[processor].tuition += 1;
        }

        if (deptLower.includes('quran')) {
          fallbackProcessedMap[processor].quran += 1;
        }

        if (
          date &&
          date !== 'No Date'
        ) {
          fallbackProcessedMap[processor].latestDate =
            date;
        }
      }

      if (canViewDateAnalytics) {
        if (!fallbackDailyMap[date]) {
          fallbackDailyMap[date] = {
            date,
            total: 0,
            school: 0,
            tuition: 0,
            quran: 0
          };
        }

        fallbackDailyMap[date].total += 1;

        if (deptLower.includes('school')) {
          fallbackDailyMap[date].school += 1;
        }

        if (deptLower.includes('tuition')) {
          fallbackDailyMap[date].tuition += 1;
        }

        if (deptLower.includes('quran')) {
          fallbackDailyMap[date].quran += 1;
        }

        if (date === todayIso) {
          todayAdmissionsCount += 1;
        }
      }
    });
  }

  const processedByStats =
    P.col.processedBy
      ? (
          processedByStatsFromServer.length
            ? processedByStatsFromServer
            : Object.values(
                fallbackProcessedMap
              ).sort(
                (a, b) =>
                  Number(b.total || 0) -
                  Number(a.total || 0)
              )
        )
      : [];

  const dailyAdmissionStats =
    canViewDateAnalytics
      ? (
          dailyAdmissionStatsFromServer.length
            ? dailyAdmissionStatsFromServer
            : Object.values(
                fallbackDailyMap
              ).sort(
                (a, b) =>
                  String(b.date).localeCompare(
                    String(a.date)
                  )
              )
        )
      : [];

  const searchResults =
    canViewSearchResults
      ? (
          searchResultsFromServer.length
            ? searchResultsFromServer
            : recentAdmissions
        )
      : [];

  const selectedProcessorTotal =
    P.col.processedBy && activeProcessedBy
      ? processedByStats
          .filter((item) =>
            cleanText(
              item.name ||
              item.processedBy ||
              item.processed_by
            )
              .toLowerCase()
              .includes(
                activeProcessedBy.toLowerCase()
              )
          )
          .reduce(
            (sum, item) =>
              sum + Number(item.total || 0),
            0
          )
      : 0;

  const totalAdmissions =
    canViewAdmissionCounts
      ? ['school', 'tuition', 'quran']
          .reduce(
            (sum, key) =>
              sum + Number(
                departmentStats?.[key]?.total ||
                0
              ),
            0
          )
      : 0;

  const totalRecentAdmissions =
    canViewAdmissionCounts
      ? recentAdmissions.length
      : 0;

  const totalProcessedPeople =
    P.col.processedBy
      ? processedByStats.length
      : 0;

  const latestDailyAdmissions =
    canViewDateAnalytics
      ? (
          dailyAdmissionStats[0]?.total ||
          todayAdmissionsCount ||
          0
        )
      : 0;

  const generatedInsights = [];

  if (P.col.processedBy) {
    generatedInsights.push({
      title: 'Processed By tracking',
      description:
        processedByStatsFromServer.length
          ? 'Processed By data is connected.'
          : 'Full processed-by counts require overviewData.processedByStats from server.js.'
    });
  }

  if (canViewDateAnalytics) {
    generatedInsights.push({
      title: 'Daily admissions tracking',
      description:
        dailyAdmissionStatsFromServer.length
          ? 'Daily admissions data is connected.'
          : 'Full date-wise counts require overviewData.dailyAdmissionStats from server.js.'
    });
  }

  if (canViewSearchResults) {
    generatedInsights.push({
      title: 'CEO search results',
      description:
        searchResultsFromServer.length
          ? 'Server search results are connected.'
          : 'For all matched records, pass overviewData.searchResults from server.js.'
    });
  }

  const canViewMissingInsights =
    !!(
      P.col.processedBy ||
      canViewDateAnalytics ||
      canViewSearchResults
    );

  const canViewAllOverviewColumns =
    Object.values(P.col).every(Boolean);

  const missingInsights =
    !canViewMissingInsights
      ? []
      : (
          canViewAllOverviewColumns &&
          missingInsightsFromServer.length
            ? missingInsightsFromServer
            : generatedInsights
        );

  const rawOverviewCharts =
    safeOverview.charts &&
    typeof safeOverview.charts === 'object'
      ? safeOverview.charts
      : {};

  const safeOverviewCharts = {};

  if (
    P.col.dept &&
    canViewAdmissionCounts
  ) {
    safeOverviewCharts.departmentComparison =
      rawOverviewCharts.departmentComparison ||
      {};
  }

  if (P.col.status) {
    safeOverviewCharts.statusDistribution =
      Array.isArray(
        rawOverviewCharts.statusDistribution
      )
        ? rawOverviewCharts.statusDistribution
        : [];
  }

  if (P.col.feeStatus) {
    safeOverviewCharts.feeDistribution =
      Array.isArray(
        rawOverviewCharts.feeDistribution
      )
        ? rawOverviewCharts.feeDistribution
        : [];
  }

  const safeOverviewChartsJson =
    JSON.stringify(safeOverviewCharts)
      .replace(/</g, '\\u003c')
      .replace(/>/g, '\\u003e')
      .replace(/&/g, '\\u0026');

  const canViewCharts =
    Object.keys(safeOverviewCharts).length > 0;

  const dailyAdmissionsVisibleColumnCount =
    Math.max(
      1,
      2 + (P.col.dept ? 3 : 0)
    );

  const departmentSummaryVisibleColumnCount =
    Math.max(
      1,
      1 +
      (canViewAdmissionCounts ? 1 : 0) +
      (P.col.status ? 1 : 0) +
      (P.col.feeStatus ? 1 : 0) +
      (P.col.paymentStatus ? 1 : 0) +
      (P.col.currency ? 1 : 0) +
      (canViewDateAnalytics ? 3 : 0)
    );

  const statusSummaryVisibleColumnCount =
    Math.max(
      1,
      2 + (P.col.dept ? 3 : 0)
    );

  const feeSummaryVisibleColumnCount =
    Math.max(
      1,
      2 + (P.col.dept ? 3 : 0)
    );

  const currencySummaryVisibleColumnCount =
    Math.max(
      1,
      1 +
      (canViewAdmissionCounts ? 1 : 0) +
      (P.col.receivedPayment ? 1 : 0) +
      (P.col.pendingDues ? 1 : 0)
    );

  const searchResultsVisibleColumnCount =
    Math.max(
      1,
      (P.col.student ? 1 : 0) +
      (P.col.registrationNumber ? 1 : 0) +
      (P.col.dept ? 1 : 0) +
      (P.col.status ? 1 : 0) +
      (P.col.feeStatus ? 1 : 0) +
      (P.col.processedBy ? 1 : 0) +
      (canViewAdmissionCounts ? 1 : 0) +
      (P.col.phone ? 1 : 0)
    );

  const recentAdmissionsVisibleColumnCount =
    Math.max(
      1,
      (P.col.student ? 1 : 0) +
      (P.col.dept ? 1 : 0) +
      (P.col.status ? 1 : 0) +
      (P.col.processedBy ? 1 : 0) +
      (canViewAdmissionCounts ? 1 : 0)
    );

  const recentBillingVisibleColumnCount =
    Math.max(
      1,
      (P.col.student ? 1 : 0) +
      (P.col.month ? 1 : 0) +
      (P.col.paymentStatus ? 1 : 0) +
      (P.col.invoiceStatusTimestamp ? 1 : 0)
    );

  const pendingDueVisibleColumnCount =
    Math.max(
      1,
      (P.col.student ? 1 : 0) +
      (P.col.dept ? 1 : 0) +
      1 +
      (P.col.month ? 2 : 0) +
      1
    );

  const noPaymentVisibleColumnCount =
    Math.max(
      1,
      (P.col.student ? 1 : 0) +
      (P.col.dept ? 1 : 0) +
      (P.col.pendingDues || P.col.fees ? 1 : 0) +
      (P.col.month ? 2 : 0) +
      1
    );
%>

<div class="overview-page">
  <div class="overview-hero mb-3">
    <div class="row g-3 align-items-center">
      <div class="<%= P.col.dept && canViewAdmissionCounts ? 'col-lg-8' : 'col-12' %>">
        <div
          class="small text-uppercase fw-bold mb-2"
          style="letter-spacing:.08em;color:rgba(255,255,255,.72);">
          Super Admin Intelligence Panel
        </div>

        <h1>Overview Dashboard</h1>

        <p>
          Permission-controlled overview for admissions, processed-by performance,
          date-wise intake, billing health and operational analytics.
        </p>

        <% if (
          P.col.dept ||
          P.col.processedBy ||
          canViewDateAnalytics
        ) { %>
          <div class="overview-chip-wrap">
            <% if (P.col.dept) { %>
              <span class="overview-chip">
                <i class="bi bi-mortarboard-fill"></i>
                School
              </span>

              <span class="overview-chip">
                <i class="bi bi-journal-bookmark-fill"></i>
                Tuition
              </span>

              <span class="overview-chip">
                <i class="bi bi-book-half"></i>
                Quran
              </span>
            <% } %>

            <% if (P.col.processedBy) { %>
              <span class="overview-chip">
                <i class="bi bi-person-check-fill"></i>
                Processed By
              </span>
            <% } %>

            <% if (canViewDateAnalytics) { %>
              <span class="overview-chip">
                <i class="bi bi-calendar2-check-fill"></i>
                Daily Intake
              </span>
            <% } %>
          </div>
        <% } %>
      </div>

      <% if (P.col.dept && canViewAdmissionCounts) { %>
        <div class="col-lg-4">
          <div
            class="panel-card p-3 h-100"
            style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);box-shadow:none;">
            <div class="section-title mb-2">
              <div>
                <h6 class="text-white mb-1">
                  Department Snapshot
                </h6>

                <div style="color:rgba(255,255,255,.72);font-size:.74rem;">
                  Quick department totals
                </div>
              </div>
            </div>

            <div class="mini-grid snapshot-mini-grid">
              <div class="mini-stat">
                <div class="title">School</div>
                <div class="num">
                  <%= departmentStats.school?.total || 0 %>
                </div>
              </div>

              <div class="mini-stat">
                <div class="title">Tuition</div>
                <div class="num">
                  <%= departmentStats.tuition?.total || 0 %>
                </div>
              </div>

              <div class="mini-stat">
                <div class="title">Quran</div>
                <div class="num">
                  <%= departmentStats.quran?.total || 0 %>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <% if (
    canViewAdmissionCounts ||
    P.col.processedBy ||
    canViewSearchResults ||
    P.col.pendingDues ||
    missingInsights.length
  ) { %>
    <div class="summary-grid mb-3">
      <% if (canViewAdmissionCounts) { %>
        <div class="summary-card">
          <div class="icon-wrap">
            <i class="bi bi-people-fill"></i>
          </div>

          <div class="label">
            Total Admissions
          </div>

          <div class="value">
            <%= totalAdmissions %>
          </div>

          <div class="hint">
            Current permitted result set
          </div>
        </div>

        <div class="summary-card">
          <div class="icon-wrap">
            <i class="bi bi-calendar-check-fill"></i>
          </div>

          <div class="label">
            Today Admissions
          </div>

          <div class="value">
            <%= todayAdmissionsCount || 0 %>
          </div>

          <div class="hint">
            <%= todayIso %>
          </div>
        </div>
      <% } %>

      <% if (P.col.processedBy) { %>
        <div class="summary-card">
          <div class="icon-wrap">
            <i class="bi bi-person-lines-fill"></i>
          </div>

          <div class="label">
            Processed People
          </div>

          <div class="value">
            <%= totalProcessedPeople %>
          </div>

          <div class="hint">
            Based on processed-by data
          </div>
        </div>
      <% } %>

      <% if (canViewSearchResults) { %>
        <div class="summary-card">
          <div class="icon-wrap">
            <i class="bi bi-search-heart-fill"></i>
          </div>

          <div class="label">
            Search Results
          </div>

          <div class="value">
            <%= searchResults.length %>
          </div>

          <div class="hint">
            Current visible result set
          </div>
        </div>
      <% } %>

      <% if (P.col.pendingDues) { %>
        <div class="summary-card">
          <div class="icon-wrap">
            <i class="bi bi-wallet2"></i>
          </div>

          <div class="label">
            Pending Dues
          </div>

          <div class="value">
            <%= billingStats.totalPendingDues || 0 %>
          </div>

          <div class="hint">
            Billing amount pending
          </div>
        </div>
      <% } %>

      <% if (missingInsights.length) { %>
        <div class="summary-card">
          <div class="icon-wrap">
            <i class="bi bi-exclamation-triangle-fill"></i>
          </div>

          <div class="label">
            Missing Checks
          </div>

          <div class="value">
            <%= missingInsights.length %>
          </div>

          <div class="hint">
            Permitted items to verify
          </div>
        </div>
      <% } %>
    </div>
  <% } %>

  <% if (canViewCeoSearch) { %>
    <div class="ceo-filter-card p-3 mb-3">
      <div class="section-title">
        <div>
          <h5>CEO Search Center</h5>

          <div class="section-sub">
            Only filters allowed by the selected user's Can View permissions are shown.
          </div>
        </div>
      </div>

      <form method="GET" action="" class="filter-grid">
        <% if (canViewSearchTextFilter) { %>
          <div>
            <label class="form-label">
              Search
            </label>

            <input
              type="text"
              class="form-control"
              name="q"
              value="<%= activeSearch %>"
              placeholder="Search permitted record fields">
          </div>
        <% } %>

        <% if (P.col.dept) { %>
          <div>
            <label class="form-label">
              Department
            </label>

            <select
              class="form-select"
              name="department">
              <option value="">All</option>

              <option
                value="school"
                <%= activeDept === 'school' ? 'selected' : '' %>>
                School
              </option>

              <option
                value="tuition"
                <%= activeDept === 'tuition' ? 'selected' : '' %>>
                Tuition
              </option>

              <option
                value="quran"
                <%= activeDept === 'quran' ? 'selected' : '' %>>
                Quran
              </option>
            </select>
          </div>
        <% } %>

        <% if (P.col.status) { %>
          <div>
            <label class="form-label">
              Status
            </label>

            <input
              type="text"
              class="form-control"
              name="status"
              value="<%= activeStatus %>"
              placeholder="Current status">
          </div>
        <% } %>

        <% if (P.col.feeStatus) { %>
          <div>
            <label class="form-label">
              Fee Status
            </label>

            <input
              type="text"
              class="form-control"
              name="feeStatus"
              value="<%= activeFeeStatus %>"
              placeholder="Fee status">
          </div>
        <% } %>

        <% if (P.col.processedBy) { %>
          <div>
            <label class="form-label">
              Processed By
            </label>

            <input
              type="text"
              class="form-control"
              name="processedBy"
              value="<%= activeProcessedBy %>"
              placeholder="Agent/Admin name">
          </div>
        <% } %>

        <% if (canViewAdmissionCounts) { %>
          <div>
            <label class="form-label">
              From
            </label>

            <input
              type="date"
              class="form-control"
              name="startDate"
              value="<%= activeFromDate %>">
          </div>

          <div>
            <label class="form-label">
              To
            </label>

            <input
              type="date"
              class="form-control"
              name="endDate"
              value="<%= activeToDate %>">
          </div>
        <% } %>

        <div class="filter-actions">
          <button
            type="submit"
            class="btn-ceo">
            <i class="bi bi-funnel-fill me-1"></i>
            Apply
          </button>

          <a
            href="/dashboard/overview"
            class="btn-soft text-decoration-none">
            <i class="bi bi-arrow-counterclockwise me-1"></i>
            Reset
          </a>
        </div>
      </form>
    </div>
  <% } %>

  <% if (P.col.processedBy || missingInsights.length) { %>
    <div class="row g-3 mb-3">
      <% if (P.col.processedBy) { %>
        <div class="<%= missingInsights.length ? 'col-xl-8' : 'col-12' %>">
          <div class="panel-card p-3 h-100">
            <div class="section-title">
              <div>
                <h5>Processed By Performance</h5>

                <div class="section-sub">
                  How many admissions each person processed.
                </div>
              </div>

              <% if (activeProcessedBy) { %>
                <span class="soft-badge danger-badge">
                  Selected total:
                  <%= selectedProcessorTotal %>
                </span>
              <% } %>
            </div>

            <% if (processedByStats.length) { %>
              <div class="processed-by-scroll">
                <div class="row g-2">
                  <% processedByStats.forEach((item) => {
                    const personName =
                      item.name ||
                      item.processedBy ||
                      item.processed_by ||
                      'Not Assigned';
                  %>
                    <div class="col-md-6 col-xl-4">
                      <div class="person-card">
                        <div class="name">
                          <i class="bi bi-person-badge me-1 text-danger"></i>
                          <%= personName %>
                        </div>

                        <div class="person-stats">
                          <span>
                            <b><%= item.total || 0 %></b>
                            Total
                          </span>

                          <% if (P.col.dept) { %>
                            <span>
                              <b><%= item.school || 0 %></b>
                              School
                            </span>

                            <span>
                              <b><%= item.tuition || 0 %></b>
                              Tuition
                            </span>
                          <% } %>
                        </div>

                        <div class="mt-2 d-flex justify-content-between align-items-center">
                          <% if (P.col.dept) { %>
                            <span class="soft-badge dark-badge">
                              Quran:
                              <%= item.quran || 0 %>
                            </span>
                          <% } %>

                          <% if (canViewDateAnalytics) { %>
                            <small class="text-muted">
                              <%= item.latestDate || item.lastDate || '' %>
                            </small>
                          <% } %>
                        </div>
                      </div>
                    </div>
                  <% }) %>
                </div>
              </div>
            <% } else { %>
              <div class="empty-state">
                No processed-by data found
              </div>
            <% } %>
          </div>
        </div>
      <% } %>

      <% if (missingInsights.length) { %>
        <div class="<%= P.col.processedBy ? 'col-xl-4' : 'col-12' %>">
          <div class="panel-card p-3 h-100">
            <div class="section-title">
              <div>
                <h5>Missing Data Monitor</h5>

                <div class="section-sub">
                  Only permitted operational checks are shown.
                </div>
              </div>
            </div>

            <div class="insight-list">
              <% missingInsights.forEach((item) => { %>
                <div class="insight-item">
                  <i class="bi bi-info-circle-fill"></i>

                  <div>
                    <strong>
                      <%= item.title || 'Insight' %>
                    </strong>

                    <div class="text-muted">
                      <%= item.description || item.message || '-' %>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  <% } %>

  <% if (
    canViewDateAnalytics ||
    canViewExecutiveQuickNumbers
  ) { %>
    <div class="row g-3 mb-3">
      <% if (canViewDateAnalytics) { %>
        <div class="<%= canViewExecutiveQuickNumbers ? 'col-xl-7' : 'col-12' %>">
          <div class="panel-card p-3 h-100">
            <div class="section-title">
              <div>
                <h5>Date-wise Admissions</h5>

                <div class="section-sub">
                  Admissions by day with permitted totals.
                </div>
              </div>

              <input
                type="text"
                class="form-control table-search"
                id="dailyAdmissionsSearch"
                placeholder="Search date">
            </div>

            <% if (dailyAdmissionStats.length) { %>
              <div class="table-responsive overview-scroll-box">
                <table
                  class="table table-premium table-compact align-middle mb-0"
                  id="dailyAdmissionsTable">
                  <thead>
                    <tr>
                      <th>Date</th>
                      <th>Total Admissions</th>

                      <% if (P.col.dept) { %>
                        <th>School</th>
                        <th>Tuition</th>
                        <th>Quran</th>
                      <% } %>
                    </tr>
                  </thead>

                  <tbody>
                    <% dailyAdmissionStats.slice(0, 20).forEach((item) => { %>
