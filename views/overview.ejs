<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  const overviewCharts = <%- JSON.stringify(safeOverview.charts || {}) %>;

  function buildColors(items, fallback) {
    return (items || []).map((x, idx) => x.color || fallback[idx % fallback.length]);
  }

  function makeChart(id, type, labels, values, opts = {}) {
    const el = document.getElementById(id);
    if (!el || !labels || !labels.length) return;

    const palette = [
      "#2563eb", "#16a34a", "#f59e0b", "#ef4444", "#8b5cf6",
      "#06b6d4", "#14b8a6", "#e11d48", "#334155", "#0ea5e9"
    ];

    const dataset = {
      label: opts.label || "Overview",
      data: values,
      borderWidth: 2,
      fill: !!opts.fill,
      tension: .35
    };

    if (type === "pie" || type === "doughnut") {
      dataset.backgroundColor = opts.backgroundColor || palette;
      dataset.borderColor = "#ffffff";
    } else if (type === "bar") {
      dataset.backgroundColor = opts.backgroundColor || "rgba(37,99,235,.75)";
      dataset.borderColor = opts.borderColor || "#2563eb";
    } else {
      dataset.backgroundColor = opts.backgroundColor || "rgba(37,99,235,.12)";
      dataset.borderColor = opts.borderColor || "#2563eb";
      dataset.pointBackgroundColor = opts.borderColor || "#2563eb";
    }

    new Chart(el, {
      type,
      data: {
        labels,
        datasets: [dataset]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            display: opts.legend !== false
          }
        },
        scales: opts.scales === false ? {} : {
          y: {
            beginAtZero: true,
            ticks: {
              precision: 0
            }
          }
        }
      }
    });
  }

 const analyticsToggleBtn = document.getElementById("analyticsChartsToggle");
  const analyticsChartsBody = document.getElementById("analyticsChartsBody");
  const analyticsToggleIcon = document.getElementById("analyticsChartsToggleIcon");

  if (analyticsToggleBtn && analyticsChartsBody) {
    analyticsToggleBtn.addEventListener("click", () => {
      const isHidden = analyticsChartsBody.classList.toggle("is-hidden");
      analyticsToggleBtn.classList.toggle("is-collapsed", isHidden);
      analyticsToggleBtn.setAttribute("aria-expanded", String(!isHidden));
    });
  }

  const deptComparison = overviewCharts.departmentComparison || {};
  makeChart(
    "departmentComparisonChart",
    "bar",
    Object.keys(deptComparison).map(x => x.charAt(0).toUpperCase() + x.slice(1)),
    Object.values(deptComparison),
    {
      label: "Department Comparison",
      backgroundColor: "rgba(22,163,74,.70)",
      borderColor: "#16a34a"
    }
  );

  const statusDist = overviewCharts.statusDistribution || [];
  makeChart(
    "statusDistributionChart",
    "doughnut",
    statusDist.map(x => x.label),
    statusDist.map(x => x.value),
    {
      label: "Status Distribution",
      scales: false,
      backgroundColor: buildColors(statusDist, ["#2563eb","#16a34a","#f59e0b","#ef4444","#8b5cf6","#06b6d4"])
    }
  );

  const feeDist = overviewCharts.feeDistribution || [];
  makeChart(
    "feeDistributionChart",
    "pie",
    feeDist.map(x => x.label),
    feeDist.map(x => x.value),
    {
      label: "Fee Distribution",
      scales: false,
      backgroundColor: buildColors(feeDist, ["#0ea5e9","#16a34a","#f59e0b","#ef4444","#8b5cf6","#14b8a6"])
    }
  );

  function wireTableSearch(inputId, tableId) {
    const input = document.getElementById(inputId);
    const table = document.getElementById(tableId);
    if (!input || !table) return;

    input.addEventListener("input", () => {
      const q = String(input.value || "").toLowerCase().trim();
      table.querySelectorAll("tbody tr").forEach((tr) => {
        const text = tr.innerText.toLowerCase();
        tr.style.display = text.includes(q) ? "" : "none";
      });
    });
  }

  wireTableSearch("recentAdmissionsSearch", "recentAdmissionsTable");
  wireTableSearch("recentBillingSearch", "recentBillingTable");
</script>

