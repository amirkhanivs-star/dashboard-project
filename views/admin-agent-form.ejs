<%- include('partials/bootstrap-header', { user, pageTitle: (user.role === 'agent' ? 'Create Sub Agents' : 'Create Agents / Sub Agents') }) %>

<%
  const isAdmin = user.role === 'admin';
  const isAgent = user.role === 'agent';

  const cap = (txt) => txt ? txt.charAt(0).toUpperCase() + txt.slice(1) : '';
  const deptLabel =
  String(user.dept || '').trim().toLowerCase() === 'accounts'
    ? 'School Accounts'
    : cap(user.dept || 'Department');

  const currentAgentType = user.agentType || 'accounts';
const isSchoolAccountsDept =
  String(user.dept || '').trim().toLowerCase() === 'accounts' ||
  String(user.dept || '').trim().toLowerCase() === 'school accounts' ||
  String(user.dept || '').trim().toLowerCase() === 'school_accounts';

const schoolAgentTypeOptions = [
  { value: 'accounts',  label: 'Accounts'  },
  { value: 'admission', label: 'Admission' },
  { value: 'management',label: 'Management' }
];

const schoolAccountsAgentTypeOptions = [
  { value: 'print_record_update', label: 'Print + Record update' },
  { value: 'verification_registration', label: 'Verification & Registration' },
  { value: 'paid_slip', label: 'Paid slip' }
];

const agentTypeOptions = isSchoolAccountsDept
  ? schoolAccountsAgentTypeOptions
  : schoolAgentTypeOptions;

const currentAgentTypeLabel = (() => {
  const found = [...schoolAgentTypeOptions, ...schoolAccountsAgentTypeOptions]
    .find((x) => x.value === currentAgentType);

  return found ? found.label : cap(currentAgentType);
})();

const createdRoleLabel = isAdmin ? 'Agent / Sub Agent' : 'Sub Agent';

  const usersListPath = isAdmin ? '/dashboard/admin/users' : '/dashboard/agent/users';
    const createUserPostPath = isAdmin ? '/dashboard/admin/agents' : '/dashboard/agent/agents';
   const themeTextClass = isAdmin ? 'text-success' : 'agent-purple-text';
const themeBtnClass = isAdmin ? 'btn-success' : 'agent-purple-btn';
const themeIconClass = isAdmin ? 'text-success' : 'agent-purple-text';
const roleBadgeClass = isAdmin ? 'bg-success-subtle text-success' : 'agent-purple-badge';

 const roleDeptHelpText = isAdmin
  ? 'Department is fixed by Super Admin. You can choose role and pipeline / agent type.'
   : 'Department, role, and pipeline / agent type are fixed. You can assign only your own allowed permissions to Sub Agent.';

  const deptFieldHelpText = isAdmin
  ? 'Users can be created only within the assigned department.'
  : 'You can create users only within your assigned department.';

const roleFieldHelpText = isAdmin
  ? 'Admin can create Agent or Sub Agent.'
  : 'Agent can create only Sub Agent.';

const agentTypeFieldHelpText = isAdmin
  ? 'You can choose pipeline / agent type.'
  : 'Pipeline / agent type is fixed for Agent.';

    const step1Class = isAdmin
  ? 'bg-success text-white'
  : 'agent-step-main';

const step2Class = 'bg-danger-subtle text-danger';

const step3Class = isAdmin
  ? 'admin-step-purple'
  : 'agent-step-green';

const step4Class = isAdmin
  ? 'subagent-step-badge'
  : 'agent-step-blue';
  // ✅ Use normalized perms coming from server (res.locals.perms OR explicit perms)
  const parentPermRaw = (typeof perms !== 'undefined' && perms) ? perms : (user.permissions || {});

  // ✅ who can create users (same as your server route)
  const canCreateUsers = (user.role === "admin" || user.role === "agent");

   // ✅ Admin aur Agent dono apni allowed permissions me se choose kar sakte hain.
  // Agent ko sirf wahi permissions show hongi jo uske apne account me allowed hain.
  const canEditPerms = isAdmin || isAgent;


  // helper: read bool with legacy support (default false)
  const boolPerm = (raw, key, defVal, legacyKey) => {
    if (typeof raw?.[key] !== 'undefined') return !!raw[key];
    if (legacyKey && typeof raw?.[legacyKey] !== 'undefined') return !!raw[legacyKey];
    return !!defVal;
  };

  // ✅ Parent allowed columns (default false)
 const parentColsAllowed = {
  colStatus: boolPerm(parentPermRaw, 'colStatus', false),
  colFeeStatus: boolPerm(parentPermRaw, 'colFeeStatus', false),

  colDept: boolPerm(parentPermRaw, 'colDept', false),
  colStudentName: boolPerm(parentPermRaw, 'colStudentName', false),
  colFatherName: boolPerm(parentPermRaw, 'colFatherName', false),
  colFatherEmail: boolPerm(parentPermRaw, 'colFatherEmail', false),
  colGrade: boolPerm(parentPermRaw, 'colGrade', false),
  colTuitionGrade: boolPerm(parentPermRaw, 'colTuitionGrade', false),

  colPhone: boolPerm(parentPermRaw, 'colPhone', false, 'showPhone'),
  colProcessedBy: boolPerm(parentPermRaw, 'colProcessedBy', false),
  colPaymentStatus: boolPerm(parentPermRaw, 'colPaymentStatus', false, 'showPaymentStatus'),
  colPaidUpto: boolPerm(parentPermRaw, 'colPaidUpto', false, 'showPaidUpto'),
  colVerificationNumber: boolPerm(parentPermRaw, 'colVerificationNumber', false, 'showVerificationNumber'),
  colRegistrationNumber: boolPerm(parentPermRaw, 'colRegistrationNumber', false, 'showRegistrationNumber'),

  colFamilyNumber: boolPerm(parentPermRaw, 'colFamilyNumber', false),
  colRegistrationFee: boolPerm(parentPermRaw, 'colRegistrationFee', false),
  colFees: boolPerm(parentPermRaw, 'colFees', false),
  colCurrency: boolPerm(parentPermRaw, 'colCurrency', false),
  colBank: boolPerm(parentPermRaw, 'colBank', false),
  colMonth: boolPerm(parentPermRaw, 'colMonth', false),
  colTotalFees: boolPerm(parentPermRaw, 'colTotalFees', false),
  colPendingDues: boolPerm(parentPermRaw, 'colPendingDues', false),
colReceivedPayment: boolPerm(parentPermRaw, 'colReceivedPayment', false),
colComment: boolPerm(parentPermRaw, 'colComment', false),
colInvoiceStatus: boolPerm(parentPermRaw, 'colInvoiceStatus', false),
colInvoiceStatusTimestamp: boolPerm(parentPermRaw, 'colInvoiceStatusTimestamp', false),
colPaidInvoiceStatus: boolPerm(parentPermRaw, 'colPaidInvoiceStatus', false),
colPaidInvoiceStatusTimestamp: boolPerm(parentPermRaw, 'colPaidInvoiceStatusTimestamp', false),
colActionButtons: boolPerm(parentPermRaw, 'colActionButtons', false)
};
  // ✅ Parent allowed buttons (default false)
   const parentBtnsAllowed = {
  btnEditRow: boolPerm(parentPermRaw, 'btnEditRow', false),
  btnDetails: boolPerm(parentPermRaw, 'btnDetails', false),
  btnUpdateRow: boolPerm(parentPermRaw, 'btnUpdateRow', false),
  btnPdf: boolPerm(parentPermRaw, 'btnPdf', false),
  btnBilling: boolPerm(parentPermRaw, 'btnBilling', false),
  btnWhatsApp: boolPerm(parentPermRaw, 'btnWhatsApp', false),
  btnUpload: boolPerm(parentPermRaw, 'btnUpload', false),
  btnFiles: boolPerm(parentPermRaw, 'btnFiles', false),
  canDeleteFiles: boolPerm(parentPermRaw, 'canDeleteFiles', false),
  canDeleteAdmissions: boolPerm(parentPermRaw, 'canDeleteAdmissions', false)
};

 const ALL_COLS = [
  { name: 'colStatus',             label: 'Current Status' },
  { name: 'colFeeStatus',          label: 'Fee Status' },
  { name: 'colDept',               label: 'Dept' },
  { name: 'colStudentName',        label: 'Student' },
  { name: 'colFatherName',         label: 'Father' },
  { name: 'colFatherEmail',        label: 'Father Email' },
  { name: 'colGrade',              label: 'Grade' },
  { name: 'colTuitionGrade',       label: 'Grade Section' },
  { name: 'colPhone',              label: 'Phone Number' },
  { name: 'colProcessedBy',        label: 'Processed By' },
  { name: 'colPaymentStatus',      label: 'Payment Status' },
  { name: 'colPaidUpto',           label: 'Paid Upto' },
  { name: 'colVerificationNumber', label: 'Verif #' },
  { name: 'colRegistrationNumber', label: 'Reg #' },
  { name: 'colFamilyNumber',       label: 'Family Num #' },
  { name: 'colRegistrationFee',    label: 'Registration Fee' },
  { name: 'colFees',               label: 'Fees' },
  { name: 'colCurrency',           label: 'Currency' },
  { name: 'colBank',               label: 'Bank' },
  { name: 'colMonth',              label: 'Month' },
  { name: 'colTotalFees',          label: 'Total Fees' },
  { name: 'colPendingDues',        label: 'Pending Dues' },
{ name: 'colReceivedPayment',    label: 'Received Payment' },
{ name: 'colComment',            label: 'Comment' },
{ name: 'colInvoiceStatus',      label: 'Invoice Status' },
{ name: 'colInvoiceStatusTimestamp', label: 'Invoice Status Timestamp' },
{ name: 'colPaidInvoiceStatus',  label: 'Paid Invoice Status' },
{ name: 'colPaidInvoiceStatusTimestamp', label: 'Paid Invoice Status Timestamp' },
{ name: 'colActionButtons',      label: 'Action Buttons' }
];

  const ALL_BTNS = [
  { name: 'btnEditRow',     label: 'Show Edit button' },
  { name: 'btnDetails',     label: 'Show View Details button' },
  { name: 'btnUpdateRow',   label: 'Show Update/Save button' },
  { name: 'btnPdf',         label: 'Show PDF button' },
  { name: 'btnBilling',     label: 'Show Billing button' },
  { name: 'btnWhatsApp',    label: 'Show WhatsApp button' },
  { name: 'btnUpload',      label: 'Show Upload button' },
  { name: 'btnFiles',       label: 'Show Files button' },
  { name: 'canDeleteFiles', label: 'Can Delete Files' },
  { name: 'canDeleteAdmissions', label: 'Can Delete Admissions' }
];
%>

<style>
    /* Agent create user page purple theme only */
  .agent-purple-text{
    color: #7c3aed !important;
  }

  .agent-purple-btn{
    background: linear-gradient(135deg, #7c3aed, #5b21b6) !important;
    border-color: #5b21b6 !important;
    color: #fff !important;
    font-weight: 700;
    box-shadow: 0 8px 18px rgba(124,58,237,.22);
  }

  .agent-purple-btn:hover,
  .agent-purple-btn:focus{
    background: linear-gradient(135deg, #6d28d9, #4c1d95) !important;
    border-color: #4c1d95 !important;
    color: #fff !important;
  }

  .agent-purple-badge{
    background: rgba(124,58,237,.14) !important;
    color: #5b21b6 !important;
    border: 1px solid rgba(124,58,237,.30) !important;
  }
  .admin-step-purple{
  background: rgba(124,58,237,.14) !important;
  color: #5b21b6 !important;
  border: 1px solid rgba(124,58,237,.30) !important;
}
  .agent-step-main{
    background: linear-gradient(135deg, #7c3aed, #5b21b6) !important;
    color: #fff !important;
    border: 1px solid #5b21b6 !important;
  }

  .agent-step-soft{
    background: rgba(124,58,237,.14) !important;
    color: #5b21b6 !important;
    border: 1px solid rgba(124,58,237,.30) !important;
  }
    .agent-step-green{
    background: rgba(34,197,94,.14) !important;
    color: #15803d !important;
    border: 1px solid rgba(34,197,94,.30) !important;
  }

  .agent-step-blue{
    background: rgba(59,130,246,.14) !important;
    color: #1d4ed8 !important;
    border: 1px solid rgba(59,130,246,.30) !important;
  }

   

  .agent-create-purple .form-check-input:checked{
    background-color: #0d6efd !important;
    border-color: #0d6efd !important;
  }

  .agent-create-purple .form-check-input:focus{
    border-color: #86b7fe !important;
    box-shadow: 0 0 0 .2rem rgba(13,110,253,.25) !important;
  }  .subagent-step-badge{
    background: rgba(59, 130, 246, 0.14) !important;
    color: #1d4ed8 !important;
    border: 1px solid rgba(59, 130, 246, 0.30) !important;
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.10);
  }
  .create-user-link-preview{
    margin-top: 8px;
    width: 100%;
  }

  .create-user-link-mini{
    display: flex;
    align-items: flex-start;
    gap: 7px;
    width: 100%;
    padding: 6px 8px;
    border-radius: 10px;
    font-size: .70rem;
    font-weight: 800;
    line-height: 1.25;
    background: #f8fafc;
    border: 1px solid #e5e7eb;
    color: #475569;
  }

  .create-user-link-mini i{
    font-size: .74rem;
    line-height: 1.2;
    margin-top: 1px;
    flex: 0 0 auto;
    color: #64748b;
  }

  .create-user-link-text{
    flex: 1 1 auto;
    min-width: 0;
    white-space: normal;
    overflow: visible;
    text-overflow: unset;
    overflow-wrap: anywhere;
    word-break: break-word;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: .66rem;
    font-weight: 800;
  }

  .create-user-link-copy{
    width: 23px;
    height: 23px;
    border: 0;
    border-radius: 8px;
    padding: 0;
    background: #e5e7eb;
    color: #475569;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 23px;
    transition: all .16s ease;
  }

  .create-user-link-copy i{
    font-size: .72rem;
    line-height: 1;
    color: #475569;
  }

  .create-user-link-copy:hover{
    background: #d1d5db;
    transform: translateY(-1px);
  }

  .create-user-link-copy:disabled{
    opacity: .75;
    cursor: not-allowed;
    transform: none;
  }
</style>

<div class="container-fluid py-4 <%= isAgent ? 'agent-create-purple' : '' %>">

  <a href="<%= usersListPath %>" class="small <%= themeTextClass %> text-decoration-none mb-3 d-inline-flex align-items-center fw-semibold">
     <i class="bi bi-arrow-left me-1"></i> Back to Users
  </a>

  <div class="card border-0 shadow-sm rounded-4 mb-3">
    <div class="card-body py-3 d-flex flex-wrap align-items-center gap-3">
      <span class="badge rounded-pill bg-light text-muted border d-flex align-items-center">
        <i class="bi bi-magic me-2 <%= themeIconClass %>"></i>
        User Creation Wizard
      </span>

      <div class="d-flex flex-wrap gap-3 small">
        <div class="d-flex align-items-center gap-2">
         <span class="d-inline-flex align-items-center justify-content-center rounded-circle <%= step1Class %>"
      style="width:22px;height:22px;font-size:.75rem;">1</span>
          <span>Basic info</span>
        </div>
        <div class="d-flex align-items-center gap-2">
         <span class="d-inline-flex align-items-center justify-content-center rounded-circle <%= step2Class %>"
      style="width:22px;height:22px;font-size:.75rem;">2</span>
          <span>Role, department &amp; assignment</span>
        </div>
        <div class="d-flex align-items-center gap-2">
         <span class="d-inline-flex align-items-center justify-content-center rounded-circle <%= step3Class %>"
      style="width:22px;height:22px;font-size:.75rem;">3</span>
          <span>Columns</span>
        </div>
        <div class="d-flex align-items-center gap-2">
         <span class="d-inline-flex align-items-center justify-content-center rounded-circle <%= step4Class %>"
      style="width:22px;height:22px;font-size:.75rem;">4</span>
          <span>Buttons &amp; Permissions</span>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-lg-3">
      <div class="card shadow-sm h-100 border-0 rounded-4">
        <div class="card-body small">
          <h6 class="mb-3 d-flex align-items-center">
            <i class="bi bi-compass me-2 <%= themeIconClass %>"></i>
            User Creation Wizard
          </h6>

          <p class="text-muted mb-3">
         From here, you can create users for the <%= deptLabel %> department.
            <strong><%= createdRoleLabel %></strong> 
          </p>

          <ol class="ps-3 mb-0">
            <li class="mb-1">Set basic information.</li>
            <li class="mb-1">Admin can choose role & type. Agent can create only Sub Agent.</li>
            <li class="mb-1">Select allowed columns.</li>
            <li class="mb-1">Select allowed buttons/panels.</li>
          </ol>

          <hr>

          <div class="mb-2">
            <div class="text-muted">Logged in as</div>
            <span class="badge rounded-pill <%= roleBadgeClass %> text-capitalize">
              <%= user.role %>
            </span>
          </div>

          <div class="text-muted">
            Rule: You can only assign permissions that you already have.
          </div>

          <% if (!canCreateUsers) { %>
            <hr>
            <div class="alert alert-warning py-2 small mb-0">
              You don’t have permission to create users.
            </div>
          <% } %>

        </div>
      </div>
    </div>

    <div class="col-lg-9">
      <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header border-0 bg-white bg-opacity-75">
          <h5 class="mb-0 d-flex align-items-center">
            <i class="bi bi-person-plus me-2 <%= themeIconClass %>"></i>
           Create <%= createdRoleLabel %> (Dept: <span><%= deptLabel || 'N/A' %></span>)
          </h5>
          <small class="text-muted">
             Keep a strong password. The users & you cannot change it later, Only Super Admin can change it.
          </small>
        </div>

        <div class="card-body">

          <% if (error) { %>
            <div class="alert alert-danger py-2 small"><%= error %></div>
          <% } %>

         <form method="POST" action="<%= createUserPostPath %>">
            <div class="row g-3">
              <div class="col-12">
                <h6 class="mb-1">1. Basic information</h6>
                <p class="text-muted small mb-2">Set name, email, and password.</p>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Name</label>
                <input
                  type="text"
                  name="name"
                  id="createUserNameInput"
                  class="form-control"
                  placeholder=""
                  <%= canCreateUsers ? 'required' : 'disabled' %>>

                <div class="create-user-link-preview">
                  <div class="create-user-link-mini" title="">
                    <i class="bi bi-link-45deg"></i>

                    <span
                      id="createUserAdmissionLinkPreview"
                      class="create-user-link-text">
                      Type name to generate link
                    </span>

                    <button
                      type="button"
                      class="create-user-link-copy"
                      id="copyCreateUserAdmissionLinkBtn"
                      title="Copy admission form link"
                      aria-label="Copy admission form link"
                      <%= canCreateUsers ? '' : 'disabled' %>>
                      <i class="bi bi-clipboard"></i>
                    </button>
                  </div>
                </div>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Email</label>
                <input type="email" name="email" class="form-control"
                       placeholder="name@ivs.com"
                       <%= canCreateUsers ? 'required' : 'disabled' %>>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Password</label>
                <input type="text" name="password" class="form-control"
                       placeholder=""
                       <%= canCreateUsers ? 'required' : 'disabled' %>>
              </div>

              <div class="col-12 mt-3">
                <h6 class="mb-1">2. Role, Department &amp; Assignment</h6>
               <p class="text-muted small mb-2">
                <%= roleDeptHelpText %>
               </p>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Department (Fixed)</label>
                <input type="text" class="form-control bg-light"
                       value="<%= deptLabel %>" disabled>
                <input type="hidden" name="dept" value="<%= user.dept || '' %>">
                 <small class="text-muted d-block"><%= deptFieldHelpText %></small>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Role</label>

                <% if (isAdmin) { %>
                  <select name="newRole" class="form-select" <%= canCreateUsers ? 'required' : 'disabled' %>>
                    <option value="agent">Agent</option>
                    <option value="sub_agent">Sub Agent</option>
                  </select>
                <% } else { %>
                  <input type="text" class="form-control bg-light" value="Sub Agent" disabled>
                  <input type="hidden" name="newRole" value="sub_agent">
                <% } %>

                <small class="text-muted d-block">
                <%= roleFieldHelpText %>
                </small>
              </div>

              <div class="col-md-4">
                <label class="form-label small">Pipeline / Agent Type</label>

                <% if (isAdmin) { %>
                  <select name="agentType" class="form-select" <%= canCreateUsers ? 'required' : 'disabled' %>>
                    <% agentTypeOptions.forEach(function(opt){ %>
                      <option value="<%= opt.value %>"><%= opt.label %></option>
                    <% }) %>
                  </select>
                <% } else { %>
                  <input type="text" class="form-control bg-light"
                         value="<%= currentAgentTypeLabel %>" disabled>
                  <input type="hidden" name="agentType" value="<%= currentAgentType %>">
                <% } %>

                 <small class="text-muted d-block">
                  <%= agentTypeFieldHelpText %>
                 </small>
              </div>
              <div class="col-12 mt-2">
                <div class="rounded-4 border bg-light p-3">
                  <div class="d-flex align-items-start gap-2">
                    <div class="mt-1">
                      <i class="bi bi-diagram-3 <%= themeIconClass %>"></i>
                    </div>
                    <div>
                      <h6 class="mb-1">Assignment & Data Access</h6>

                      <% if (isAdmin) { %>
                        <p class="text-muted small mb-0">
                          This user will be automatically assigned to you. You will see this user's admissions in your department dashboard.
                        </p>
                      <% } else { %>
                        <p class="text-muted small mb-0">
                          This Sub Agent will remain under your assigned Admin team. The Admin will be able to see this Sub Agent's admissions.
                        </p>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>

              <div class="col-12 mt-3">
                <div class="d-flex flex-wrap gap-2 align-items-center">
                  <span class="small text-muted">Quick:</span>

                  <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill px-3" id="btnSelectAll">
                    Select all
                  </button>
                  <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill px-3" id="btnSelectNone">
                    Select none
                  </button>
                  <span class="small text-muted ms-2">
                    (Applies only to visible permissions)
                  </span>
                </div>
              </div>

              <div class="col-12 mt-3">
                <h6 class="mb-1">3. Columns &  Buttons  Permissions</h6>
                <p class="text-muted small mb-2">
                  Only allowed options will be visible here.
                </p>

                <div class="accordion" id="permAccordion">

                  <div class="accordion-item border-0 shadow-sm rounded-4 mb-2">
                    <h2 class="accordion-header" id="headingCols">
                      <button class="accordion-button rounded-4" type="button"
                              data-bs-toggle="collapse" data-bs-target="#collapseCols"
                              aria-expanded="true" aria-controls="collapseCols">
                        <i class="bi bi-table me-2 <%= themeIconClass %>"></i>
                        Admissions pipeline columns
                      </button>
                    </h2>

                    <div id="collapseCols" class="accordion-collapse collapse show"
                         aria-labelledby="headingCols" data-bs-parent="#permAccordion">
                      <div class="accordion-body">



                        <div class="row g-2">
                          <% ALL_COLS.forEach(function(c){
                               const parentAllowed = !!parentColsAllowed[c.name];
                          %>

                            <% if (parentAllowed && canEditPerms) { %>
                              <div class="col-md-4">
                                <input type="hidden" name="<%= c.name %>" value="">
                                <div class="form-check small">
                                  <input class="form-check-input col-toggle" type="checkbox"
                                         id="<%= c.name %>" name="<%= c.name %>" value="on"
                                         checked <%= canCreateUsers ? '' : 'disabled' %>>
                                  <label class="form-check-label" for="<%= c.name %>"><%= c.label %></label>
                                </div>
                              </div>
                            <% } else { %>
                              <!-- ✅ auto inherit -->
                              <input type="hidden" name="<%= c.name %>" value="<%= parentAllowed ? 'on' : '' %>">
                            <% } %>

                          <% }) %>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="accordion-item border-0 shadow-sm rounded-4">
                    <h2 class="accordion-header" id="headingBtns">
                      <button class="accordion-button collapsed rounded-4" type="button"
                              data-bs-toggle="collapse" data-bs-target="#collapseBtns"
                              aria-expanded="false" aria-controls="collapseBtns">
                        <i class="bi bi-hand-index-thumb me-2 <%= themeIconClass %>"></i>
                        Buttons
                      </button>
                    </h2>

                    <div id="collapseBtns" class="accordion-collapse collapse"
                         aria-labelledby="headingBtns" data-bs-parent="#permAccordion">
                      <div class="accordion-body">

                                                <% if (isAgent) { %>
                          <div class="alert alert-light border small mb-2">
                            Only your allowed buttons/panels are visible here. You can assign selected permissions to your Sub Agent.
                          </div>
                        <% } %>

                        <div class="row g-2">
                          <% ALL_BTNS.forEach(function(b){
                               const parentAllowed = !!parentBtnsAllowed[b.name];
                          %>

                            <% if (parentAllowed && canEditPerms) { %>
                              <div class="col-md-4">
                                <input type="hidden" name="<%= b.name %>" value="">
                                <div class="form-check small">
                                  <input class="form-check-input perm-toggle" type="checkbox"
                                         id="<%= b.name %>" name="<%= b.name %>" value="on"
                                         checked <%= canCreateUsers ? '' : 'disabled' %>>
                                  <label class="form-check-label" for="<%= b.name %>"><%= b.label %></label>
                                </div>
                              </div>
                            <% } else { %>
                              <!-- ✅ auto inherit -->
                              <input type="hidden" name="<%= b.name %>" value="<%= parentAllowed ? 'on' : '' %>">
                            <% } %>

                          <% }) %>
                        </div>

                      </div>
                    </div>
                  </div>

                </div>
              </div>
            </div>

            <hr>

            <div class="d-flex justify-content-between">
             <a href="<%= usersListPath %>" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                 Cancel
             </a>

              <% if (canCreateUsers) { %>
                <button type="submit" class="btn <%= themeBtnClass %> rounded-pill px-4">
                  <i class="bi bi-save me-1"></i>
                  Save User
                </button>
              <% } else { %>
                <button type="button" class="btn btn-primary rounded-pill px-4" disabled>
                  <i class="bi bi-save me-1"></i>
                  Save User
                </button>
              <% } %>
            </div>

          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const btnSelectAll = document.getElementById("btnSelectAll");
    const btnSelectNone = document.getElementById("btnSelectNone");

        const createUserNameInput = document.getElementById("createUserNameInput");
    const createUserAdmissionLinkPreview = document.getElementById("createUserAdmissionLinkPreview");
    const copyCreateUserAdmissionLinkBtn = document.getElementById("copyCreateUserAdmissionLinkBtn");

    const admissionFormBaseUrl = "<%= typeof admissionFormBaseUrl !== 'undefined' ? admissionFormBaseUrl : 'https://ivs-admission-form.onrender.com/' %>";
        function buildAdmissionLinkFromName(name) {
      const cleanName = String(name || "").trim();
      const baseUrl = String(admissionFormBaseUrl || "https://ivs-admission-form.onrender.com/")
        .trim()
        .replace(/\?+$/, "")
        .replace(/\/+$/, "/");

      if (!cleanName) return "";

      return baseUrl + "?sentBy=" + encodeURIComponent(cleanName);
    }

        function syncCreateUserAdmissionLinkPreview() {
      if (!createUserNameInput || !createUserAdmissionLinkPreview) return;

      const link = buildAdmissionLinkFromName(createUserNameInput.value);
      createUserAdmissionLinkPreview.textContent = link || "Type name to generate link";

      const linkWrap = createUserAdmissionLinkPreview.closest(".create-user-link-mini");
      if (linkWrap) {
        linkWrap.setAttribute("title", link || "");
      }

      if (copyCreateUserAdmissionLinkBtn) {
        copyCreateUserAdmissionLinkBtn.disabled = !link || createUserNameInput.disabled;
      }
    }

    async function copyCreateUserAdmissionLink(text) {
      const cleanText = String(text || "").trim();
      if (!cleanText) return false;

      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(cleanText);
          return true;
        }

        const textarea = document.createElement("textarea");
        textarea.value = cleanText;
        textarea.style.position = "fixed";
        textarea.style.left = "-9999px";
        textarea.style.top = "-9999px";
        document.body.appendChild(textarea);
        textarea.focus();
        textarea.select();

        const copied = document.execCommand("copy");
        document.body.removeChild(textarea);

        return copied;
      } catch (err) {
        console.error("Admin/Agent create user admission link copy failed:", err);
        return false;
      }
    }
    function toggleAll(on) {
      document.querySelectorAll(".perm-toggle, .col-toggle").forEach((cb) => {
        if (cb.disabled) return;
        cb.checked = !!on;
      });
    }
        if (createUserNameInput) {
      createUserNameInput.addEventListener("input", syncCreateUserAdmissionLinkPreview);
    }

    if (copyCreateUserAdmissionLinkBtn) {
      copyCreateUserAdmissionLinkBtn.addEventListener("click", async function () {
        const link = createUserAdmissionLinkPreview
          ? createUserAdmissionLinkPreview.textContent.trim()
          : "";
        if (!link || link === "Type name to generate link") return;

        const oldHtml = copyCreateUserAdmissionLinkBtn.innerHTML;
        copyCreateUserAdmissionLinkBtn.disabled = true;
        copyCreateUserAdmissionLinkBtn.innerHTML = '<i class="bi bi-hourglass-split"></i>';

        const copied = await copyCreateUserAdmissionLink(link);

        if (copied) {
          copyCreateUserAdmissionLinkBtn.innerHTML = '<i class="bi bi-check2-circle"></i>';
          copyCreateUserAdmissionLinkBtn.title = "Copied";
        } else {
          prompt("Copy this admission form link:", link);
          copyCreateUserAdmissionLinkBtn.innerHTML = oldHtml;
        }

        setTimeout(function () {
          copyCreateUserAdmissionLinkBtn.disabled = false;
          copyCreateUserAdmissionLinkBtn.innerHTML = oldHtml;
          copyCreateUserAdmissionLinkBtn.title = "Copy admission form link";
          syncCreateUserAdmissionLinkPreview();
        }, 1200);
      });
    }
    if (btnSelectAll) btnSelectAll.addEventListener("click", () => toggleAll(true));
    if (btnSelectNone) btnSelectNone.addEventListener("click", () => toggleAll(false));

    syncCreateUserAdmissionLinkPreview();
  })();
</script>

<%- include('partials/bootstrap-footer') %>
