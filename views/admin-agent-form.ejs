  .create-user-link-copy:disabled{
    opacity: .75;
    cursor: not-allowed;
    transform: none;
  }
    /* ================== CAN VIEW / CAN EDIT MATRIX ================== */
  .permission-quickbar {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    padding: 10px 12px;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    background: #f8fafc;
  }

  .permission-quickbar-label {
    margin-right: 2px;
    color: #475569;
    font-size: .70rem;
    font-weight: 800;
  }

  .permission-quickbar .btn {
    padding: 4px 10px;
    font-size: .68rem;
    font-weight: 700;
  }

  .permission-default-note {
    margin-left: auto;
    color: #64748b;
    font-size: .66rem;
    font-weight: 700;
  }

  .permission-groups-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .permission-group-card {
    min-width: 0;
    overflow: hidden;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    background: #ffffff;
  }

  .permission-group-title {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 9px 10px;
    border-bottom: 1px solid #e5e7eb;
    background: #f8fafc;
    color: #1f2937;
    font-size: .74rem;
    font-weight: 800;
  }

  .permission-group-title i {
    font-size: .78rem;
  }

  .permission-matrix-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 43px 43px;
    align-items: stretch;
    min-height: 34px;
    border-top: 1px solid #f1f5f9;
  }

  .permission-matrix-row:first-of-type {
    border-top: 0;
  }

  .permission-matrix-head {
    min-height: 29px;
    background: #f8fafc;
    color: #64748b;
    font-size: .59rem;
    font-weight: 800;
    letter-spacing: .035em;
    text-transform: uppercase;
  }

  .permission-matrix-head > span:first-child {
    display: flex;
    align-items: center;
    padding: 5px 9px;
  }

  .permission-field-label {
    display: flex;
    align-items: center;
    min-width: 0;
    margin: 0;
    padding: 6px 9px;
    color: #334155;
    font-size: .69rem;
    font-weight: 700;
    line-height: 1.15;
    cursor: pointer;
    overflow-wrap: anywhere;
  }

  .permission-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    border-left: 1px solid #eef2f7;
  }

  .permission-cell .form-check-input {
    float: none;
    width: 1rem;
    height: 1rem;
    margin: 0;
    cursor: pointer;
  }

  .permission-cell .form-check-input:disabled {
    opacity: .42;
    cursor: not-allowed;
  }

  .permission-lock {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 7px;
    background: #f1f5f9;
    color: #94a3b8;
    font-size: .65rem;
  }

  .permission-legend {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 7px;
    margin-bottom: 9px;
    color: #64748b;
    font-size: .67rem;
  }

  .permission-legend-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 8px;
    border: 1px solid #e5e7eb;
    border-radius: 999px;
    background: #ffffff;
    font-weight: 700;
  }

  .permission-legend-item i {
    font-size: .68rem;
  }

  @media (max-width: 1199.98px) {
    .permission-groups-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
